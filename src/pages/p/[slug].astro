---
import Layout from '../../layouts/Layout.astro';
import { buildPublicProfilePath } from '../../lib/public-profile-url';
import { PublicBookingApiError, resolvePublicProfileSlugWithOrds } from '../../lib/public-booking';
import '../../styles/global.css';

const legacySlug = String(Astro.params.slug || '').trim();
let loadError = '';

if (legacySlug) {
	try {
		const resolved = await resolvePublicProfileSlugWithOrds(legacySlug);
		const target = buildPublicProfilePath(resolved.organization_slug, resolved.profile_slug);
		if (target) {
			return Astro.redirect(target, 301);
		}
	} catch (error) {
		const bookingError =
			error instanceof PublicBookingApiError
				? error
				: new PublicBookingApiError('No fue posible abrir esta agenda.', 500);
		loadError = bookingError.message;
	}
} else {
	loadError = 'Enlace de agenda inválido.';
}

if (!loadError) {
	loadError =
		'Este enlace ya no es válido. Pedí a tu profesional el enlace completo (nombre del negocio + perfil).';
}
---

<Layout>
	<main class="mx-auto flex min-h-[60vh] max-w-lg items-center px-6 py-16">
		<section class="w-full rounded-3xl border border-rose-200 bg-rose-50 px-8 py-10 text-rose-900 shadow-sm">
			<h1 class="text-2xl font-semibold tracking-tight">No fue posible abrir esta agenda</h1>
			<p class="mt-3 text-base font-medium text-rose-800">{loadError}</p>
			<a
				href="/"
				class="mt-6 inline-flex rounded-full bg-rose-100 px-6 py-2.5 text-sm font-medium text-rose-900 no-underline transition hover:bg-rose-200"
			>
				Volver al inicio
			</a>
		</section>
	</main>
</Layout>
