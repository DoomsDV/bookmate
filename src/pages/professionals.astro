---
import AppAlert from '../components/AppAlert.astro';
import FlashMessage from '../components/FlashMessage.astro';
import ProfessionalsGrid from '../components/ProfessionalsGrid.astro';
import SideNav from '../components/SideNav.astro';
import TopBar from '../components/TopBar.astro';
import { ProfessionalsApiError, listProfessionals, type Professional } from '../lib/professionals';
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import 'tom-select/dist/css/tom-select.css';

const token = Astro.locals.token ?? '';
const PAGE_SIZE = 9;
const rawPage = Number(Astro.url.searchParams.get('page') || '1');
const currentPage = Number.isInteger(rawPage) && rawPage > 0 ? rawPage : 1;
const flashMessage = Astro.url.searchParams.get('flash_message') ?? '';
const flashTypeRaw = Astro.url.searchParams.get('flash_type') ?? 'success';
const validFlashTypes = ['success', 'error', 'info', 'warning'] as const;
type FlashType = (typeof validFlashTypes)[number];
const flashType: FlashType = validFlashTypes.includes(flashTypeRaw as FlashType)
	? (flashTypeRaw as FlashType)
	: 'info';
const rawPublicProfileDomain = String(
	import.meta.env.PUBLIC_BOOKMATE_PUBLIC_DOMAIN ?? Astro.url.origin
).trim();
const publicProfileDomain =
	rawPublicProfileDomain.replace(/^https?:\/\//i, '').replace(/\/+$/, '') || Astro.url.host;

let professionals: Professional[] = [];
let loadError = '';
let pagination = {
	current_page: currentPage,
	per_page: PAGE_SIZE,
	total_records: 0,
	total_pages: 1,
};

if (!token) {
	loadError = 'No hay sesión válida para consultar personal.';
} else {
	try {
		const listResult = await listProfessionals(token, { page: currentPage, limit: PAGE_SIZE });
		professionals = listResult.data;
		pagination = listResult.meta;
	} catch (error) {
		loadError =
			error instanceof ProfessionalsApiError
				? error.message
				: 'No fue posible cargar el listado de personal.';
	}
}

const totalPages = Math.max(1, pagination.total_pages);
const safeCurrentPage = Math.min(Math.max(1, pagination.current_page), totalPages);
const canPrevPage = safeCurrentPage > 1;
const canNextPage = safeCurrentPage < totalPages;

const toPageHref = (page: number) => {
	const nextUrl = new URL(Astro.url);
	nextUrl.searchParams.set('page', String(page));
	nextUrl.searchParams.delete('flash_message');
	nextUrl.searchParams.delete('flash_type');
	return `${nextUrl.pathname}${nextUrl.search}`;
};

const pageWindowStart = Math.max(1, safeCurrentPage - 1);
const pageWindowEnd = Math.min(totalPages, safeCurrentPage + 1);
const visiblePages = Array.from(
	{ length: pageWindowEnd - pageWindowStart + 1 },
	(_, index) => pageWindowStart + index
);
---

<Layout>
	<div class="min-h-screen">
		<div
			class="app-shell grid min-h-screen overflow-hidden border border-[color:var(--shell-border)] bg-[color:var(--shell-surface)] shadow-[0_30px_80px_rgba(15,23,42,0.12)] backdrop-blur-xl"
			data-app-shell
			data-sidebar-state="expanded"
		>
			<SideNav currentPath={Astro.url.pathname} />

			<div class="grid min-h-full grid-rows-[auto_1fr]">
				<TopBar />

				<main class="bg-[color:var(--content-surface)] px-5 py-5 sm:px-7 sm:py-7">
					<section class="grid gap-6">
						{
							flashMessage ? (
								<div class="pointer-events-auto fixed right-4 top-24 z-[70] w-[min(calc(100vw-2rem),30rem)] sm:right-6 sm:top-28">
									<FlashMessage message={flashMessage} type={flashType} autoHideMs={4200} />
								</div>
							) : null
						}

						{
							loadError ? (
								<FlashMessage message={loadError} type="error" expand={true} dismissible={false} />
							) : (
								<div class="grid gap-5">
									<ProfessionalsGrid professionals={professionals} showCreateAction={true} />

									<div class="flex flex-col gap-3 rounded-[1.2rem] border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
										<p class="text-sm text-[color:var(--on-surface-variant)]">
											Página <span class="font-semibold text-[color:var(--on-surface)]">{safeCurrentPage}</span> de
											<span class="font-semibold text-[color:var(--on-surface)]"> {totalPages}</span>
											<span class="mx-2">-</span>
											Total de
											<span class="font-semibold text-[color:var(--on-surface)]">
												{` ${pagination.total_records} `}
											</span>
											profesionales
										</p>

										<nav class="flex items-center gap-2" aria-label="Paginación personal">
											{
												canPrevPage ? (
													<a
														href={toPageHref(safeCurrentPage - 1)}
														class="rounded-lg border border-[color:var(--shell-border)] px-3 py-1.5 text-sm font-semibold text-[color:var(--on-surface)] no-underline transition hover:bg-[color:var(--control-surface)]"
													>
														Anterior
													</a>
												) : (
													<span class="cursor-not-allowed rounded-lg border border-[color:var(--shell-border)] px-3 py-1.5 text-sm font-semibold text-[color:var(--on-surface-variant)]/60">
														Anterior
													</span>
												)
											}

											{
												visiblePages.map((page) =>
													page === safeCurrentPage ? (
														<span class="rounded-lg border border-[color:var(--primary-container)] bg-[color:var(--primary-soft)] px-3 py-1.5 text-sm font-bold text-[color:var(--primary)]">
															{page}
														</span>
													) : (
														<a
															href={toPageHref(page)}
															class="rounded-lg border border-[color:var(--shell-border)] px-3 py-1.5 text-sm font-semibold text-[color:var(--on-surface)] no-underline transition hover:bg-[color:var(--control-surface)]"
														>
															{page}
														</a>
													)
												)
											}

											{
												canNextPage ? (
													<a
														href={toPageHref(safeCurrentPage + 1)}
														class="rounded-lg border border-[color:var(--shell-border)] px-3 py-1.5 text-sm font-semibold text-[color:var(--on-surface)] no-underline transition hover:bg-[color:var(--control-surface)]"
													>
														Siguiente
													</a>
												) : (
													<span class="cursor-not-allowed rounded-lg border border-[color:var(--shell-border)] px-3 py-1.5 text-sm font-semibold text-[color:var(--on-surface-variant)]/60">
														Siguiente
													</span>
												)
											}
										</nav>
									</div>
								</div>
							)
						}
					</section>
				</main>
			</div>
		</div>
	</div>

	<dialog
		class="w-[min(46rem,calc(100vw-2rem))] rounded-[1.25rem] border border-[color:var(--shell-border)] bg-[color:var(--surface-bright)] p-0 text-[color:var(--on-surface)] shadow-[0_26px_80px_rgba(15,23,42,0.28)] backdrop:bg-slate-950/40"
		data-professional-modal
	>
		<div class="border-b border-[color:var(--shell-border)] px-5 py-4">
			<h2 class="text-lg font-bold" data-professional-modal-title>Crear personal</h2>
			<p class="mt-1 text-sm text-[color:var(--on-surface-variant)]" data-professional-modal-description>
				Completa los datos para registrar profesional y cuenta en una sola operación.
			</p>
		</div>

		<form class="relative grid gap-3 px-5 py-5" data-professional-form>
			<div
				class="pointer-events-none absolute inset-0 z-20 hidden items-center justify-center rounded-b-[1.25rem] bg-[color:var(--surface-bright)]/78 backdrop-blur-[1px]"
				data-professional-loading
			>
				<div class="inline-flex items-center gap-2 rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--surface-bright)] px-3 py-2 text-sm font-semibold text-[color:var(--on-surface)] shadow-[0_10px_24px_rgba(15,23,42,0.12)]">
					<span class="material-symbols-rounded animate-spin text-[1rem]">progress_activity</span>
					Procesando...
				</div>
			</div>

			<div class="hidden rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700 dark:border-rose-900/60 dark:bg-rose-950/25 dark:text-rose-300" data-form-error></div>

			<div class="mt-1 border-b border-[color:var(--shell-border)] pb-1">
				<p class="text-xs font-bold uppercase tracking-[0.08em] text-[color:var(--on-surface-variant)]">
					Datos personales y acceso
				</p>
			</div>

			<div class="grid gap-3 sm:grid-cols-2">
				<label class="grid gap-1 text-sm font-semibold">
					<span class="inline-flex items-center gap-1">
						Nombre
						<span class="text-rose-600">*</span>
					</span>
					<input
						type="text"
						name="first_name"
						required
						class="rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-3 py-2.5 text-sm outline-none transition focus:border-[color:var(--primary)]"
						placeholder="Ej: Maria"
					/>
					<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="first_name"></span>
				</label>

				<label class="grid gap-1 text-sm font-semibold">
					<span class="inline-flex items-center gap-1">
						Apellido
						<span class="text-rose-600">*</span>
					</span>
					<input
						type="text"
						name="last_name"
						required
						class="rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-3 py-2.5 text-sm outline-none transition focus:border-[color:var(--primary)]"
						placeholder="Ej: Lopez"
					/>
					<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="last_name"></span>
				</label>
			</div>

			<div class="grid gap-3 sm:grid-cols-2">
				<label class="grid gap-1 text-sm font-semibold">
					Email (opcional)
					<input
						type="email"
						name="email"
						class="rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-3 py-2.5 text-sm outline-none transition focus:border-[color:var(--primary)]"
						placeholder="correo@dominio.com"
					/>
					<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="email"></span>
				</label>

				<label class="grid gap-1 text-sm font-semibold">
					<span class="inline-flex items-center gap-1">
						Telefono
						<span class="text-rose-600">*</span>
					</span>
					<input
						type="text"
						name="phone_number"
						required
						class="rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-3 py-2.5 text-sm outline-none transition focus:border-[color:var(--primary)]"
						placeholder="Ej: +595981000000"
					/>
					<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="phone_number"></span>
				</label>
			</div>

			<div class="grid gap-3 sm:grid-cols-2">
				<label class="grid gap-1 text-sm font-semibold">
					<span class="inline-flex items-center gap-1">
						Usuario
						<span class="text-rose-600">*</span>
					</span>
					<input
						type="text"
						name="apex_user_name"
						required
						class="rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-3 py-2.5 text-sm outline-none transition focus:border-[color:var(--primary)]"
						placeholder="Ej: mlopez"
					/>
					<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="apex_user_name"></span>
				</label>

				<label class="grid gap-1 text-sm font-semibold">
					<span class="inline-flex items-center gap-1">
						Contraseña
						<span data-password-required-indicator class="text-rose-600">*</span>
					</span>
					<input
						type="password"
						name="password"
						class="rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-3 py-2.5 text-sm outline-none transition focus:border-[color:var(--primary)]"
						placeholder="********"
					/>
					<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="password"></span>
				</label>
			</div>

			<div class="grid gap-3 sm:grid-cols-2">
				<label class="grid gap-1 text-sm font-semibold">
					<span class="inline-flex items-center gap-1">
						Rol
						<span class="text-rose-600">*</span>
					</span>
					<select
						name="rol_id_role"
						required
						data-role-select
						class="rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-3 py-2.5 text-sm outline-none transition focus:border-[color:var(--primary)]"
					>
						<option value="">Selecciona un rol</option>
					</select>
					<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="rol_id_role"></span>
				</label>

				<label class="grid gap-1 text-sm font-semibold">
					Estado de usuario
					<select
						name="user_is_active"
						class="rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-3 py-2.5 text-sm outline-none transition focus:border-[color:var(--primary)]"
					>
						<option value="1">Activo</option>
						<option value="0">Inactivo</option>
					</select>
					<span class="text-xs font-normal text-[color:var(--on-surface-variant)]">
						Permite iniciar sesion.
					</span>
					<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="user_is_active"></span>
				</label>
			</div>

			<div class="mt-6 border-b border-[color:var(--shell-border)] pb-1">
				<p class="text-xs font-bold uppercase tracking-[0.08em] text-[color:var(--on-surface-variant)]">
					Perfil público (agenda)
				</p>
			</div>

			<label class="grid gap-1 text-sm font-semibold">
				Especialidad (opcional)
				<select
					name="spe_id_specialty"
					data-specialty-select
					class="rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-3 py-2.5 text-sm outline-none transition focus:border-[color:var(--primary)]"
				>
					<option value="">Sin especialidad</option>
				</select>
				<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="spe_id_specialty"></span>
			</label>

			<label class="mt-2 grid gap-1 text-sm font-semibold">
				URL del perfil público (opcional)
				<div class="flex items-stretch overflow-hidden rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] transition focus-within:border-[color:var(--primary)]">
					<span class="inline-flex items-center border-r border-[color:var(--shell-border)] bg-[color:var(--control-surface)] px-3 text-xs font-semibold text-[color:var(--on-surface-variant)] sm:text-sm">
						{publicProfileDomain}/p/
					</span>
					<input
						type="text"
						name="profile_slug"
						class="min-w-0 flex-1 bg-transparent px-3 py-2.5 text-sm outline-none"
						placeholder="maria-lopez"
					/>
				</div>
				<span class="text-xs font-normal text-[color:var(--on-surface-variant)]">
					Este será el enlace directo para que los clientes agenden con este profesional.
				</span>
				<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="profile_slug"></span>
			</label>

			<label class="mt-2 grid gap-1 text-sm font-semibold">
				Imagen (opcional)
				<input type="file" name="profile_image" accept="image/*" class="sr-only" />
				<div
					data-image-dropzone
					role="button"
					tabindex="0"
					aria-label="Seleccionar imagen de perfil"
					class="flex items-center gap-3 rounded-xl border border-dashed border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-3 py-3 transition"
				>
					<span class="material-symbols-rounded text-[1.15rem] text-[color:var(--primary)]">upload</span>
					<div class="min-w-0">
						<p class="text-sm font-semibold text-[color:var(--on-surface)]">
							Arrastra una imagen o haz click para elegir.
						</p>
						<p
							data-image-file-name
							class="truncate text-xs font-normal text-[color:var(--on-surface-variant)]"
						>
							No se eligio ningun archivo
						</p>
					</div>
				</div>
				<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="image_base64"></span>
			</label>

			<label class="mt-2 grid gap-1 text-sm font-semibold">
				Servicios (opcional)
				<select
					name="services"
					multiple
					data-services-select
					data-placeholder="Busca o selecciona servicios..."
					class="rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-3 py-2.5 text-sm outline-none transition focus:border-[color:var(--primary)]"
				></select>
				<span class="text-xs font-normal text-[color:var(--on-surface-variant)]">
					Selecciona uno o varios servicios activos.
				</span>
				<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="services"></span>
			</label>

			<label class="mt-2 grid max-w-sm gap-1 text-sm font-semibold">
				Estado de profesional
				<select
					name="prof_is_active"
					class="rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-3 py-2.5 text-sm outline-none transition focus:border-[color:var(--primary)]"
				>
					<option value="1">Activo</option>
					<option value="0">Inactivo</option>
				</select>
				<span class="text-xs font-normal text-[color:var(--on-surface-variant)]">
					Recibe reservas de clientes.
				</span>
				<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="prof_is_active"></span>
			</label>

			<div class="mt-6 flex items-center justify-between gap-2">
				<button
					type="button"
					class="hidden rounded-xl border border-rose-500/30 bg-rose-500 px-4 py-2 text-sm font-semibold text-white transition hover:brightness-105 disabled:cursor-not-allowed disabled:opacity-60"
					data-delete-professional
				>
					<span class="material-symbols-rounded mr-1 align-[-0.2em] text-[1rem]">delete</span>
					Eliminar
				</button>

				<div class="ml-auto flex items-center justify-end gap-2">
					<button
						type="button"
						class="rounded-xl border border-[color:var(--shell-border)] px-4 py-2 text-sm font-semibold text-[color:var(--on-surface)] transition hover:bg-[color:var(--control-surface)]"
						data-close-professional-modal
					>
						Cancelar
					</button>
					<button
						type="submit"
						class="btn-primary-soft inline-flex items-center gap-2 rounded-xl px-4 py-2 text-sm font-semibold transition disabled:cursor-not-allowed disabled:opacity-60"
						data-submit-professional
					>
						<span class="material-symbols-rounded text-[1rem]" data-submit-professional-icon>check</span>
						<span data-submit-professional-label>Crear personal</span>
					</button>
				</div>
			</div>
		</form>
	</dialog>

	<AppAlert />
</Layout>

<script>
	import TomSelect from 'tom-select';

	const initializeProfessionalsPage = () => {
	const modal = document.querySelector<HTMLDialogElement>('[data-professional-modal]');
	if (!modal || modal.dataset.bound === 'true') return;
	modal.dataset.bound = 'true';
	const openButton = document.querySelector<HTMLButtonElement>('[data-open-professional-modal]');
	const closeButton = document.querySelector<HTMLButtonElement>('[data-close-professional-modal]');
	const deleteButton = document.querySelector<HTMLButtonElement>('[data-delete-professional]');
	const form = document.querySelector<HTMLFormElement>('[data-professional-form]');
	const submitButton = document.querySelector<HTMLButtonElement>('[data-submit-professional]');
	const submitLabel = document.querySelector<HTMLElement>('[data-submit-professional-label]');
	const submitIcon = document.querySelector<HTMLElement>('[data-submit-professional-icon]');
	const formErrorNode = document.querySelector<HTMLElement>('[data-form-error]');
	const fieldErrorNodes = document.querySelectorAll<HTMLElement>('[data-field-error]');
	const loadingNode = document.querySelector<HTMLElement>('[data-professional-loading]');
	const modalTitle = document.querySelector<HTMLElement>('[data-professional-modal-title]');
	const modalDescription = document.querySelector<HTMLElement>('[data-professional-modal-description]');
	const professionalCards = document.querySelectorAll<HTMLElement>('[data-professional-card]');
	const formFields =
		form?.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(
			'input, select, textarea'
		);
	const specialtySelect = form?.querySelector<HTMLSelectElement>('[data-specialty-select]');
	const roleSelect = form?.querySelector<HTMLSelectElement>('[data-role-select]');
	const servicesSelect = form?.querySelector<HTMLSelectElement>('[data-services-select]');
	const imageInput = form?.querySelector<HTMLInputElement>('[name="profile_image"]');
	const imageDropzone = form?.querySelector<HTMLElement>('[data-image-dropzone]');
	const imageFileNameNode = form?.querySelector<HTMLElement>('[data-image-file-name]');
	const passwordRequiredIndicator = form?.querySelector<HTMLElement>('[data-password-required-indicator]');
	const usernameInput = form?.querySelector<HTMLInputElement>('[name="apex_user_name"]');
	const emailInput = form?.querySelector<HTMLInputElement>('[name="email"]');
	const firstNameInput = form?.querySelector<HTMLInputElement>('[name="first_name"]');
	const lastNameInput = form?.querySelector<HTMLInputElement>('[name="last_name"]');
	const passwordInput = form?.querySelector<HTMLInputElement>('[name="password"]');
	const phoneInput = form?.querySelector<HTMLInputElement>('[name="phone_number"]');
	const profileSlugInput = form?.querySelector<HTMLInputElement>('[name="profile_slug"]');
	const userStatusInput = form?.querySelector<HTMLSelectElement>('[name="user_is_active"]');
	const profStatusInput = form?.querySelector<HTMLSelectElement>('[name="prof_is_active"]');
	let closeTimer: number | null = null;
	let mode = 'create';
	let editingProfessionalId = 0;
	let professionalReadRequestSeq = 0;
	let specialtiesLoadPromise: Promise<void> | null = null;
	let specialtiesLoaded = false;
	let rolesLoadPromise: Promise<void> | null = null;
	let rolesLoaded = false;
	let servicesLoadPromise: Promise<void> | null = null;
	let servicesLoaded = false;
	let servicesTom: TomSelect | null = null;
	let servicesTouched = false;
	let suppressServicesTouched = false;
	let editServicesAvailable = false;
	let slugSuggestTimer: number | null = null;
	let slugRequestSeq = 0;
	let slugManuallyEdited = false;
	let suppressSlugManualTracking = false;

	const currentUrl = new URL(window.location.href);
	if (currentUrl.searchParams.has('flash_message')) {
		currentUrl.searchParams.delete('flash_message');
		currentUrl.searchParams.delete('flash_type');
		window.history.replaceState({}, '', `${currentUrl.pathname}${currentUrl.search}${currentUrl.hash}`);
	}

	const redirectWithFlash = (message: string, type = 'success') => {
		const nextUrl = new URL(window.location.href);
		nextUrl.searchParams.set('flash_message', message);
		nextUrl.searchParams.set('flash_type', type);
		window.location.assign(`${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`);
	};

	const clearErrors = () => {
		if (formErrorNode) {
			formErrorNode.textContent = '';
			formErrorNode.classList.add('hidden');
		}

		for (const node of fieldErrorNodes) {
			node.textContent = '';
			node.classList.add('hidden');
		}
	};

	const showFormError = (message: string) => {
		if (!formErrorNode) return;
		formErrorNode.textContent = message;
		formErrorNode.classList.remove('hidden');
	};

	const setSuggestedSlug = (slug: string) => {
		if (!profileSlugInput) return;
		suppressSlugManualTracking = true;
		profileSlugInput.value = slug;
		suppressSlugManualTracking = false;
	};

	const clearSlugSuggestTimer = () => {
		if (!slugSuggestTimer) return;
		window.clearTimeout(slugSuggestTimer);
		slugSuggestTimer = null;
	};

	const getSlugSourceName = () =>
		`${String(firstNameInput?.value || '').trim()} ${String(lastNameInput?.value || '').trim()}`.trim();

	const queueSlugSuggestion = () => {
		if (!profileSlugInput) return;

		const fullName = getSlugSourceName();
		if (!fullName) return;

		if (slugManuallyEdited && profileSlugInput.value.trim() !== '') return;

		clearSlugSuggestTimer();
		const currentRequest = ++slugRequestSeq;
		slugSuggestTimer = window.setTimeout(async () => {
			try {
				const response = await fetch(
					`/api/professionals/slug/suggest?name=${encodeURIComponent(fullName)}`,
					{
						method: 'GET',
						headers: { Accept: 'application/json' },
					}
				);

				let data = null;
				try {
					data = await response.json();
				} catch {
					return;
				}

				if (currentRequest !== slugRequestSeq) return;
				if (!response.ok || !data || data.status !== 'success' || typeof data.slug !== 'string') return;
				if (slugManuallyEdited && profileSlugInput.value.trim() !== '') return;

				const suggestedSlug = String(data.slug || '').trim();
				if (!suggestedSlug) return;
				setSuggestedSlug(suggestedSlug);
			} catch {
				// Ignoramos errores de red para no bloquear la edición.
			}
		}, 350);
	};

	const setImageFileNameLabel = () => {
		if (!imageFileNameNode) return;
		const selectedFile = imageInput?.files?.[0];
		imageFileNameNode.textContent = selectedFile ? selectedFile.name : 'No se eligio ningun archivo';
	};

	const setImageDropzoneState = (isDisabled: boolean) => {
		if (!imageDropzone) return;
		imageDropzone.classList.toggle('is-disabled', isDisabled);
	};

	const renderFieldErrors = (errors: unknown, fallbackMessage = '') => {
		let rendered = false;
		const items = Array.isArray(errors) ? errors : [];

		for (const error of items) {
			if (!error || typeof error !== 'object') continue;
			const field = 'field' in error ? String(error.field || '') : '';
			const messageText = 'message' in error ? String(error.message || '') : '';
			if (!field || !messageText) continue;

			const fieldNode = document.querySelector(`[data-field-error="${field}"]`);
			if (!fieldNode) continue;
			fieldNode.textContent = messageText;
			fieldNode.classList.remove('hidden');
			rendered = true;
		}

		if (rendered) return true;

		if (typeof fallbackMessage === 'string' && /slug|perfil/i.test(fallbackMessage)) {
			const slugFieldNode = document.querySelector('[data-field-error="profile_slug"]');
			if (slugFieldNode) {
				slugFieldNode.textContent = fallbackMessage;
				slugFieldNode.classList.remove('hidden');
				return true;
			}
		}

		return false;
	};

	const isGenericValidationMessage = (message: string) => {
		const normalized = String(message || '')
			.trim()
			.toLowerCase();
		return (
			normalized === 'errores de validacion.' ||
			normalized === 'errores de validacion' ||
			normalized === 'errores de validación.' ||
			normalized === 'errores de validación'
		);
	};

	const setCreateMode = () => {
		mode = 'create';
		editingProfessionalId = 0;
		if (modalTitle) modalTitle.textContent = 'Crear personal';
		if (modalDescription) {
			modalDescription.textContent =
				'Completa los datos para registrar profesional y cuenta en una sola operacion.';
		}
		if (passwordInput) {
			passwordInput.required = true;
			passwordInput.placeholder = '********';
		}
		passwordRequiredIndicator?.classList.remove('hidden');
		if (submitLabel) submitLabel.textContent = 'Crear personal';
		if (submitIcon) submitIcon.textContent = 'check';
		deleteButton?.classList.add('hidden');
		deleteButton?.setAttribute('disabled', 'true');
		loadingNode?.classList.add('hidden');
		slugManuallyEdited = false;
		clearSlugSuggestTimer();
		slugRequestSeq += 1;
	};

	const setEditMode = (professionalId: number) => {
		mode = 'edit';
		editingProfessionalId = professionalId;
		if (modalTitle) modalTitle.textContent = 'Editar personal';
		if (modalDescription) {
			modalDescription.textContent = 'Actualiza los datos del profesional y su cuenta asociada.';
		}
		if (passwordInput) {
			passwordInput.required = false;
			passwordInput.placeholder = 'Dejar vacia para no cambiar';
		}
		passwordRequiredIndicator?.classList.add('hidden');
		if (submitLabel) submitLabel.textContent = 'Guardar cambios';
		if (submitIcon) submitIcon.textContent = 'save';
		deleteButton?.classList.remove('hidden');
		deleteButton?.removeAttribute('disabled');
		slugManuallyEdited = false;
		clearSlugSuggestTimer();
		slugRequestSeq += 1;
	};

	const setFormLoadingState = (isLoading: boolean) => {
		if (isLoading) {
			loadingNode?.classList.add('flex');
			loadingNode?.classList.remove('hidden');
		} else {
			loadingNode?.classList.add('hidden');
			loadingNode?.classList.remove('flex');
		}

		for (const field of formFields ?? []) {
			field.disabled = isLoading;
		}
		setImageDropzoneState(isLoading);

		if (servicesTom) {
			if (isLoading) {
				servicesTom.disable();
			} else {
				servicesTom.enable();
			}
		}
	};

	const setLoadingMode = (label = 'Procesando...') => {
		if (submitButton) submitButton.disabled = true;
		if (deleteButton && mode === 'edit') deleteButton.disabled = true;
		if (submitLabel) submitLabel.textContent = label;
		if (submitIcon) submitIcon.textContent = 'hourglass_top';
	};

	const restoreButtons = () => {
		if (submitButton) submitButton.disabled = false;
		if (mode === 'create') {
			if (submitLabel) submitLabel.textContent = 'Crear personal';
			if (submitIcon) submitIcon.textContent = 'check';
			return;
		}

		if (submitLabel) submitLabel.textContent = 'Guardar cambios';
		if (submitIcon) submitIcon.textContent = 'save';
		if (deleteButton) deleteButton.disabled = false;
	};

	const openModalShell = () => {
		modal?.classList.remove('is-closing');
		if (closeTimer) {
			window.clearTimeout(closeTimer);
			closeTimer = null;
		}
		if (!modal?.open) modal?.showModal();
	};

	const closeModal = () => {
		if (!modal?.open) return;
		professionalReadRequestSeq += 1;
		clearSlugSuggestTimer();
		slugRequestSeq += 1;
		modal.classList.add('is-closing');

		closeTimer = window.setTimeout(() => {
			modal.close();
			modal.classList.remove('is-closing');
			form?.reset();
			resetFormValues();
			setCreateMode();
			setFormLoadingState(false);
			clearErrors();
			closeTimer = null;
		}, 160);
	};

	const renderSpecialties = (items: unknown[], selectedSpecialtyId = 0) => {
		if (!specialtySelect) return;
		specialtySelect.innerHTML = '';

		const emptyOption = document.createElement('option');
		emptyOption.value = '';
		emptyOption.textContent = 'Sin especialidad';
		specialtySelect.appendChild(emptyOption);

		for (const specialty of items) {
			if (!specialty || typeof specialty !== 'object') continue;
			const id = Number('id_specialty' in specialty ? specialty.id_specialty : 0);
			const name =
				'name' in specialty ? String(specialty.name || '').trim() : '';
			if (!Number.isInteger(id) || id <= 0) continue;

			const option = document.createElement('option');
			option.value = String(id);
			option.textContent = name || `Especialidad #${id}`;
			specialtySelect.appendChild(option);
		}

		const selectedValue = selectedSpecialtyId > 0 ? String(selectedSpecialtyId) : '';
		const hasOption = Array.from(specialtySelect.options).some(
			(option) => option.value === selectedValue
		);
		specialtySelect.value = hasOption ? selectedValue : '';
	};

	const ensureSpecialtiesLoaded = async () => {
		if (specialtiesLoaded) return;
		if (specialtiesLoadPromise) return specialtiesLoadPromise;

		if (specialtySelect) specialtySelect.disabled = true;
		specialtiesLoadPromise = (async () => {
			const response = await fetch('/api/specialties?page=1&limit=100', {
				method: 'GET',
				headers: { Accept: 'application/json' },
			});

			let data = null;
			try {
				data = await response.json();
			} catch {
				throw new Error('No fue posible interpretar la lista de especialidades.');
			}

			if (!response.ok || !data || data.status !== 'success' || !Array.isArray(data.data)) {
				throw new Error(data?.message || 'No fue posible cargar especialidades.');
			}

			renderSpecialties(data.data, 0);
			specialtiesLoaded = true;
		})()
			.catch((error) => {
				if (specialtySelect) {
					specialtySelect.innerHTML = '<option value="">Sin especialidad</option>';
				}
				throw error;
			})
			.finally(() => {
				if (specialtySelect) specialtySelect.disabled = false;
				specialtiesLoadPromise = null;
			});

		return specialtiesLoadPromise;
	};

	const renderRoles = (items: unknown[], selectedRoleId = 0) => {
		if (!roleSelect) return;
		roleSelect.innerHTML = '';

		const emptyOption = document.createElement('option');
		emptyOption.value = '';
		emptyOption.textContent = 'Selecciona un rol';
		roleSelect.appendChild(emptyOption);

		for (const role of items) {
			if (!role || typeof role !== 'object') continue;
			const id = Number('id_role' in role ? role.id_role : 0);
			const name = 'name' in role ? String(role.name || '').trim() : '';
			if (!Number.isInteger(id) || id <= 0) continue;

			const option = document.createElement('option');
			option.value = String(id);
			option.textContent = name || `Rol #${id}`;
			roleSelect.appendChild(option);
		}

		const selectedValue = selectedRoleId > 0 ? String(selectedRoleId) : '';
		const hasOption = Array.from(roleSelect.options).some((option) => option.value === selectedValue);
		roleSelect.value = hasOption ? selectedValue : '';
	};

	const ensureRolesLoaded = async () => {
		if (rolesLoaded) return;
		if (rolesLoadPromise) return rolesLoadPromise;

		if (roleSelect) roleSelect.disabled = true;
		rolesLoadPromise = (async () => {
			const response = await fetch('/api/roles', {
				method: 'GET',
				headers: { Accept: 'application/json' },
			});

			let data = null;
			try {
				data = await response.json();
			} catch {
				throw new Error('No fue posible interpretar la lista de roles.');
			}

			if (!response.ok || !data || data.status !== 'success' || !Array.isArray(data.data)) {
				throw new Error(data?.message || 'No fue posible cargar los roles.');
			}

			renderRoles(data.data, 0);
			rolesLoaded = true;
		})()
			.catch((error) => {
				if (roleSelect) {
					roleSelect.innerHTML = '<option value="">No fue posible cargar roles</option>';
				}
				throw error;
			})
			.finally(() => {
				if (roleSelect) roleSelect.disabled = false;
				rolesLoadPromise = null;
			});

		return rolesLoadPromise;
	};

	const ensureServicesControl = () => {
		if (!servicesSelect || servicesTom) return;

		servicesTom = new TomSelect(servicesSelect, {
			plugins: {
				remove_button: {
					title: 'Quitar',
				},
			},
			placeholder:
				servicesSelect.dataset.placeholder?.trim() || 'Busca o selecciona servicios...',
			create: false,
			persist: false,
			maxOptions: 200,
			closeAfterSelect: false,
			hideSelected: true,
		});

		servicesTom.on('change', () => {
			if (!suppressServicesTouched) {
				servicesTouched = true;
			}
		});
	};

	const renderServices = (items: unknown[]) => {
		if (!servicesSelect) return;

		ensureServicesControl();

		if (!servicesTom) {
			servicesSelect.innerHTML = '';
			for (const item of items) {
				if (!item || typeof item !== 'object') continue;
				const id = Number('id_service' in item ? item.id_service : 0);
				const name = 'name' in item ? String(item.name || '').trim() : '';
				if (!Number.isInteger(id) || id <= 0) continue;

				const option = document.createElement('option');
				option.value = String(id);
				option.textContent = name || `Servicio #${id}`;
				servicesSelect.appendChild(option);
			}
			return;
		}

		servicesTom.clear(true);
		servicesTom.clearOptions();

		for (const item of items) {
			if (!item || typeof item !== 'object') continue;
			const id = Number('id_service' in item ? item.id_service : 0);
			const name = 'name' in item ? String(item.name || '').trim() : '';
			if (!Number.isInteger(id) || id <= 0) continue;

			servicesTom.addOption({
				value: String(id),
				text: name || `Servicio #${id}`,
			});
		}

		servicesTom.refreshOptions(false);
	};

	const setSelectedServices = (serviceIds: number[] = []) => {
		const normalized = serviceIds
			.map((serviceId) => Number(serviceId))
			.filter((serviceId) => Number.isInteger(serviceId) && serviceId > 0);
		const values = normalized.map((serviceId) => String(serviceId));

		if (servicesTom) {
			suppressServicesTouched = true;
			servicesTom.setValue(values, true);
			suppressServicesTouched = false;
			return;
		}

		if (!servicesSelect) return;
		const selectedSet = new Set(values);
		for (const option of Array.from(servicesSelect.options)) {
			option.selected = selectedSet.has(option.value);
		}
	};

	const getSelectedServiceIds = () => {
		if (servicesTom) {
			const selectedValue = servicesTom.getValue();
			const rawValues = Array.isArray(selectedValue)
				? selectedValue
				: String(selectedValue || '')
						.split(',')
						.map((value) => value.trim())
						.filter((value) => value !== '');

			return rawValues
				.map((value) => Number(value))
				.filter((serviceId) => Number.isInteger(serviceId) && serviceId > 0);
		}

		if (!servicesSelect) return [];
		return Array.from(servicesSelect.selectedOptions)
			.map((option) => Number(option.value))
			.filter((serviceId) => Number.isInteger(serviceId) && serviceId > 0);
	};

	const ensureServicesLoaded = async () => {
		ensureServicesControl();

		if (servicesLoaded) return;
		if (servicesLoadPromise) return servicesLoadPromise;

		if (servicesTom) {
			servicesTom.disable();
		} else if (servicesSelect) {
			servicesSelect.disabled = true;
		}

		servicesLoadPromise = (async () => {
			const response = await fetch('/api/services/lov', {
				method: 'GET',
				headers: { Accept: 'application/json' },
			});

			let data = null;
			try {
				data = await response.json();
			} catch {
				throw new Error('No fue posible interpretar la lista de servicios.');
			}

			if (!response.ok || !data || data.status !== 'success' || !Array.isArray(data.data)) {
				throw new Error(data?.message || 'No fue posible cargar servicios activos.');
			}

			renderServices(data.data);
			servicesLoaded = true;
		})()
			.catch((error) => {
				renderServices([]);
				throw error;
			})
			.finally(() => {
				if (servicesTom) {
					servicesTom.enable();
				} else if (servicesSelect) {
					servicesSelect.disabled = false;
				}
				servicesLoadPromise = null;
			});

		return servicesLoadPromise;
	};

	const resetFormValues = () => {
		if (usernameInput) usernameInput.value = '';
		if (emailInput) emailInput.value = '';
		if (firstNameInput) firstNameInput.value = '';
		if (lastNameInput) lastNameInput.value = '';
		if (passwordInput) passwordInput.value = '';
		if (roleSelect) roleSelect.value = '';
		if (phoneInput) phoneInput.value = '';
		if (profileSlugInput) profileSlugInput.value = '';
		if (specialtySelect) specialtySelect.value = '';
		if (userStatusInput) userStatusInput.value = '1';
		if (profStatusInput) profStatusInput.value = '1';
		if (imageInput) imageInput.value = '';
		setImageFileNameLabel();
		setSelectedServices([]);
		servicesTouched = false;
		editServicesAvailable = false;
		slugManuallyEdited = false;
		clearSlugSuggestTimer();
		slugRequestSeq += 1;
	};

	const openCreateModal = async () => {
		setCreateMode();
		resetFormValues();
		setFormLoadingState(false);
		clearErrors();
		openModalShell();
		try {
			await Promise.all([ensureSpecialtiesLoaded(), ensureRolesLoaded(), ensureServicesLoaded()]);
		} catch (error) {
			showFormError(
				error instanceof Error
					? error.message
					: 'No fue posible cargar catalogos para el formulario.'
			);
		}
	};

	const fillFormWithProfessional = (professional: any) => {
		const user = professional?.user && typeof professional.user === 'object' ? professional.user : {};

		if (usernameInput) usernameInput.value = String(user.apex_user_name || '');
		if (emailInput) emailInput.value = String(user.email || '');
		if (firstNameInput) firstNameInput.value = String(user.first_name || '');
		if (lastNameInput) lastNameInput.value = String(user.last_name || '');
		if (passwordInput) passwordInput.value = '';
		if (roleSelect) {
			const roleId = Number(user.rol_id_role || 0);
			roleSelect.value = Number.isInteger(roleId) && roleId > 0 ? String(roleId) : '';
		}
		if (phoneInput) phoneInput.value = String(professional?.phone_number || '');
		if (profileSlugInput) profileSlugInput.value = String(professional?.profile_slug || '');
		slugManuallyEdited = false;
		if (userStatusInput) {
			userStatusInput.value = String(user.is_active === 0 || user.is_active === '0' ? 0 : 1);
		}
		if (profStatusInput) {
			profStatusInput.value = String(
				professional?.is_active === 0 || professional?.is_active === '0' ? 0 : 1
			);
		}
		if (imageInput) imageInput.value = '';
		setImageFileNameLabel();

		const specialtyId =
			professional?.specialty &&
			typeof professional.specialty === 'object' &&
			Number.isInteger(Number(professional.specialty.id_specialty)) &&
			Number(professional.specialty.id_specialty) > 0
				? Number(professional.specialty.id_specialty)
				: 0;

		if (specialtySelect) {
			specialtySelect.value = specialtyId > 0 ? String(specialtyId) : '';
		}

		const assignedServices = Array.isArray(professional?.services)
			? professional.services
					.map((value: unknown) => Number(value))
					.filter((serviceId: number) => Number.isInteger(serviceId) && serviceId > 0)
			: [];

		editServicesAvailable = Array.isArray(professional?.services);
		setSelectedServices(assignedServices);
		servicesTouched = false;
	};

	const openEditModal = async (professionalId: number) => {
		if (!professionalId) return;
		const requestId = ++professionalReadRequestSeq;
		setEditMode(professionalId);
		resetFormValues();
		clearErrors();
		openModalShell();
		setFormLoadingState(true);
		setLoadingMode('Cargando...');

		try {
			const response = await fetch(`/api/professionals/${professionalId}`, {
				method: 'GET',
				headers: { Accept: 'application/json' },
			});

			let data = null;
			try {
				data = await response.json();
			} catch {
				throw new Error('No fue posible interpretar la respuesta del servidor.');
			}

			if (!response.ok || !data || data.status !== 'success' || !data.data) {
				throw new Error(data?.message || 'No fue posible obtener el personal seleccionado.');
			}

			if (requestId !== professionalReadRequestSeq) return;
			await Promise.all([ensureSpecialtiesLoaded(), ensureRolesLoaded(), ensureServicesLoaded()]);
			if (requestId !== professionalReadRequestSeq) return;
			fillFormWithProfessional(data.data);
		} catch (error) {
			if (requestId !== professionalReadRequestSeq) return;
			setCreateMode();
			showFormError(error instanceof Error ? error.message : 'No fue posible obtener el personal.');
		} finally {
			if (requestId !== professionalReadRequestSeq) return;
			setFormLoadingState(false);
			restoreButtons();
		}
	};

	const fileToBase64 = (file: File): Promise<string> =>
		new Promise((resolve, reject) => {
			const reader = new FileReader();
			reader.onload = () => {
				const result = String(reader.result || '');
				const base64 = result.includes(',') ? result.split(',')[1] : result;
				resolve(base64);
			};
			reader.onerror = () => reject(new Error('No fue posible leer la imagen seleccionada.'));
			reader.readAsDataURL(file);
		});

	const onImageDropzoneClick = () => {
		if (!imageInput || imageInput.disabled) return;
		imageInput.click();
	};

	imageDropzone?.addEventListener('click', onImageDropzoneClick);
	imageDropzone?.addEventListener('keydown', (event) => {
		if (event.key !== 'Enter' && event.key !== ' ') return;
		event.preventDefault();
		onImageDropzoneClick();
	});

	const stopDropDefaults = (event: Event) => {
		event.preventDefault();
		event.stopPropagation();
	};

	for (const eventName of ['dragenter', 'dragover', 'dragleave', 'drop']) {
		imageDropzone?.addEventListener(eventName, stopDropDefaults);
	}

	imageDropzone?.addEventListener('dragenter', () => {
		if (!imageInput?.disabled) imageDropzone.classList.add('is-dragover');
	});
	imageDropzone?.addEventListener('dragover', () => {
		if (!imageInput?.disabled) imageDropzone.classList.add('is-dragover');
	});
	imageDropzone?.addEventListener('dragleave', () => {
		imageDropzone.classList.remove('is-dragover');
	});
	imageDropzone?.addEventListener('drop', (event) => {
		imageDropzone.classList.remove('is-dragover');
		if (!imageInput || imageInput.disabled) return;

		const files = event instanceof DragEvent ? event.dataTransfer?.files : null;
		if (!files || files.length === 0) return;

		const droppedFile = Array.from(files).find((file) => file.type.startsWith('image/')) || files[0];
		const transfer = new DataTransfer();
		transfer.items.add(droppedFile);
		imageInput.files = transfer.files;
		setImageFileNameLabel();
	});

	imageInput?.addEventListener('change', setImageFileNameLabel);
	setImageFileNameLabel();

	openButton?.addEventListener('click', openCreateModal);
	closeButton?.addEventListener('click', closeModal);

	profileSlugInput?.addEventListener('input', () => {
		if (suppressSlugManualTracking) return;
		const currentValue = String(profileSlugInput.value || '').trim();
		slugManuallyEdited = currentValue !== '';
		if (!slugManuallyEdited) {
			queueSlugSuggestion();
		}
	});

	firstNameInput?.addEventListener('input', () => {
		queueSlugSuggestion();
	});

	lastNameInput?.addEventListener('input', () => {
		queueSlugSuggestion();
	});

	modal?.addEventListener('click', (event) => {
		const target = event.target;
		if (target instanceof HTMLDialogElement) closeModal();
	});

	for (const card of professionalCards) {
		const openFromCard = () => {
			const professionalId = Number(card.getAttribute('data-professional-id') || '0');
			if (professionalId > 0) openEditModal(professionalId);
		};

		card.addEventListener('click', openFromCard);
		card.addEventListener('keydown', (event) => {
			if (event.key !== 'Enter' && event.key !== ' ') return;
			event.preventDefault();
			openFromCard();
		});
	}

	form?.addEventListener('submit', async (event) => {
		event.preventDefault();
		clearErrors();

		if (!form) return;
		const formData = new FormData(form);

		const username = String(formData.get('apex_user_name') || '').trim();
		const firstName = String(formData.get('first_name') || '').trim();
		const lastName = String(formData.get('last_name') || '').trim();
		const password = String(formData.get('password') || '');
		const roleRaw = String(formData.get('rol_id_role') || '').trim();
		const phone = String(formData.get('phone_number') || '').trim();
		const email = String(formData.get('email') || '').trim();
		const specialtyRaw = String(formData.get('spe_id_specialty') || '').trim();
		const profileSlug = String(formData.get('profile_slug') || '').trim();
		const userActiveRaw = String(formData.get('user_is_active') || '1').trim();
		const profActiveRaw = String(formData.get('prof_is_active') || '1').trim();
		const roleId = Number(roleRaw);

		if (
			!username ||
			!firstName ||
			!lastName ||
			!phone ||
			!Number.isInteger(roleId) ||
			roleId <= 0 ||
			(mode === 'create' && password.trim() === '')
		) {
			showFormError('Completa los campos requeridos antes de continuar.');
			return;
		}

		type ProfessionalSubmitPayload = {
			rol_id_role: number;
			apex_user_name: string;
			first_name: string;
			last_name: string;
			email: string;
			phone_number: string;
			user_is_active: 0 | 1;
			prof_is_active: 0 | 1;
			password?: string;
			profile_slug?: string;
			spe_id_specialty?: number;
			image_base64?: string;
			image_name?: string;
			image_mime?: string;
			services?: number[];
		};

		const payload: ProfessionalSubmitPayload = {
			rol_id_role: roleId,
			apex_user_name: username,
			first_name: firstName,
			last_name: lastName,
			email,
			phone_number: phone,
			user_is_active: (userActiveRaw === '0' ? 0 : 1) as 0 | 1,
			prof_is_active: (profActiveRaw === '0' ? 0 : 1) as 0 | 1,
		};

		if (mode === 'create' || password.trim() !== '') payload.password = password;
		if (profileSlug) payload.profile_slug = profileSlug;

		const specialtyId = Number(specialtyRaw);
		if (specialtyRaw && Number.isInteger(specialtyId) && specialtyId > 0) {
			payload.spe_id_specialty = specialtyId;
		}

		const selectedServices = getSelectedServiceIds();
		if (mode === 'create' || editServicesAvailable || servicesTouched) {
			payload.services = selectedServices;
		}

		const imageFile = imageInput?.files?.[0];
		if (imageFile) {
			try {
				const base64 = await fileToBase64(imageFile);
				payload.image_base64 = base64;
				payload.image_name = imageFile.name;
				payload.image_mime = imageFile.type || 'application/octet-stream';
			} catch (error) {
				showFormError(
					error instanceof Error ? error.message : 'No fue posible procesar la imagen.'
				);
				return;
			}
		}

		const endpoint =
			mode === 'edit' && editingProfessionalId
				? `/api/professionals/${editingProfessionalId}`
				: '/api/professionals';
		const httpMethod = mode === 'edit' && editingProfessionalId ? 'PUT' : 'POST';
		setLoadingMode(mode === 'edit' ? 'Guardando...' : 'Creando...');
		setFormLoadingState(true);

		try {
			const response = await fetch(endpoint, {
				method: httpMethod,
				headers: {
					'Content-Type': 'application/json',
					Accept: 'application/json',
				},
				body: JSON.stringify(payload),
			});

			let data = null;
			try {
				data = await response.json();
			} catch {
				throw new Error('No fue posible interpretar la respuesta del servidor.');
			}

			if (!response.ok || !data || data.status !== 'success') {
				const message = data?.message || 'No fue posible crear el personal.';
				const hasFieldErrors = renderFieldErrors(data?.errors, message);

				if (hasFieldErrors && isGenericValidationMessage(message)) {
					if (formErrorNode) {
						formErrorNode.textContent = '';
						formErrorNode.classList.add('hidden');
					}
				} else {
					showFormError(message);
				}

				if (hasFieldErrors && /slug|perfil/i.test(message)) {
					profileSlugInput?.focus();
				}
				return;
			}

			const successMessage =
				typeof data?.message === 'string' && data.message.trim()
					? data.message
					: mode === 'edit'
						? 'Personal actualizado correctamente.'
						: 'Personal creado correctamente.';

			closeModal();
			redirectWithFlash(successMessage, 'success');
		} catch (error) {
			const message =
				error instanceof Error
					? error.message
					: mode === 'edit'
						? 'No fue posible actualizar el personal.'
						: 'No fue posible crear el personal.';
			showFormError(message);
		} finally {
			setFormLoadingState(false);
			restoreButtons();
		}
	});

	deleteButton?.addEventListener('click', async () => {
		if (!editingProfessionalId || mode !== 'edit') return;

		const confirmed = await window.BookmateAlert?.confirm({
			type: 'error',
			title: 'Eliminar personal',
			message:
				'Esta accion eliminara al profesional y su cuenta de forma permanente. Deseas continuar?',
			confirmText: 'Eliminar',
			cancelText: 'Cancelar',
		});
		if (!confirmed) return;

		clearErrors();
		setLoadingMode('Eliminando...');
		setFormLoadingState(true);

		try {
			const response = await fetch(`/api/professionals/${editingProfessionalId}`, {
				method: 'DELETE',
				headers: { Accept: 'application/json' },
			});

			let data = null;
			try {
				data = await response.json();
			} catch {
				throw new Error('No fue posible interpretar la respuesta del servidor.');
			}

			if (!response.ok || !data || data.status !== 'success') {
				throw new Error(data?.message || 'No fue posible eliminar el personal.');
			}

			const successMessage =
				typeof data?.message === 'string' && data.message.trim()
					? data.message
					: 'Personal eliminado correctamente.';

			closeModal();
			redirectWithFlash(successMessage, 'success');
		} catch (error) {
			showFormError(error instanceof Error ? error.message : 'No fue posible eliminar el personal.');
			setFormLoadingState(false);
			restoreButtons();
		}
	});
	};

	initializeProfessionalsPage();
	document.addEventListener('astro:page-load', initializeProfessionalsPage);
</script>

