---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const features = [
	{
		title: 'Agenda inteligente',
		description: 'Centraliza citas, bloqueos y disponibilidad en tiempo real para cada profesional.',
		icon: 'calendar_month',
	},
	{
		title: 'Equipo sincronizado',
		description: 'Roles, permisos y operaciones clave en una interfaz pensada para trabajo colaborativo.',
		icon: 'groups',
	},
	{
		title: 'Métricas accionables',
		description: 'Visualiza volumen de citas, pendientes y rendimiento diario sin cambiar de pantalla.',
		icon: 'monitoring',
	},
];

const steps = [
	{
		step: '01',
		title: 'Configura tu espacio',
		text: 'Registra servicios, sucursales y equipo en minutos con formularios guiados.',
		icon: 'settings_suggest',
	},
	{
		step: '02',
		title: 'Publica tu agenda',
		text: 'Comparte perfiles públicos y habilita reservas con reglas claras por horario.',
		icon: 'public',
	},
	{
		step: '03',
		title: 'Mide y optimiza',
		text: 'Toma decisiones con paneles diarios y estados de cita siempre actualizados.',
		icon: 'insights',
	},
];
---

<Layout>
	<main class="landing-root">
		<!-- Blurred orbs for an expressive modern look -->
		<div class="landing-orb landing-orb-a"></div>
		<div class="landing-orb landing-orb-b"></div>
		<div class="landing-orb landing-orb-c"></div>

		<div class="landing-shell">
			<header class="m3-navbar">
				<a href="/" class="brand no-underline">
					<img src="/icon-512x512.png" alt="Logo Hasel" class="brand-logo" loading="eager" decoding="async" />
					<span class="brand-text">Hasel</span>
				</a>

				<div class="nav-actions">
					<a href="/auth/login" class="m3-btn m3-btn-primary m3-btn-nav no-underline">Iniciar sesión</a>
				</div>
			</header>

			<section class="m3-hero">
				<div class="m3-hero-content">
					<div class="m3-chip m3-chip-primary">
						<span class="material-symbols-rounded">auto_awesome</span>
						<span>Plataforma Todo-en-uno</span>
					</div>
					<h1 class="m3-display">Orquestación de citas para equipos en crecimiento</h1>
					<p class="m3-body-large">
						Hasel unifica operación, agenda y visibilidad de tu negocio en una plataforma
						clara, moderna y pensada para crecer sin límites de TI.
					</p>

					<div class="hero-actions">
						<a href="/auth/login" class="m3-btn m3-btn-primary m3-btn-large no-underline">
							Crear mi espacio
							<span class="material-symbols-rounded">arrow_forward</span>
						</a>
						<a href="#beneficios" class="m3-btn m3-btn-tonal m3-btn-large no-underline">Ver más</a>
						</div>
					</div>

				<div class="m3-hero-visuals">
					<div class="visual-story-shell">
						<div class="visual-card visual-card-main">
							<div class="visual-header">
								<div class="visual-avatar">
								<span class="material-symbols-rounded">person</span>
								</div>
								<div class="visual-info">
								<strong>Nuevo cliente</strong>
								<span>Hoy, 10:00 AM</span>
								</div>
								<div class="visual-badge visual-badge-success">Confirmada</div>
							</div>
						</div>

						<div class="visual-metrics-grid">
							<div class="visual-card visual-card-2">
								<div class="visual-icon-box">
							<span class="material-symbols-rounded">insert_chart</span>
						</div>
						<div class="visual-info">
							<strong>Crecimiento</strong>
							<span>+24% este mes</span>
						</div>
					</div>

					<div class="visual-card visual-card-3">
						<div class="visual-icon-box visual-icon-ai">
							<span class="material-symbols-rounded">auto_awesome</span>
						</div>
						<div class="visual-info">
							<strong>Asistente IA</strong>
							<span>Resumen del día generado</span>
						</div>
					</div>
					</div>
				</div>
				</div>
			</section>

			<section id="beneficios" class="m3-section">
				<div class="section-header center">
					<h2 class="m3-headline">Beneficios clave</h2>
					<p class="m3-body">Diseñado para simplificar tu día a día operativo.</p>
				</div>
				<div class="m3-feature-grid">
					{
						features.map((feature) => (
							<article class="m3-card m3-feature-card">
								<div class="m3-icon-container">
									<span class="material-symbols-rounded">{feature.icon}</span>
								</div>
								<h3 class="m3-title">{feature.title}</h3>
								<p class="m3-body">{feature.description}</p>
							</article>
						))
					}
				</div>
			</section>

			<section id="flujo" class="m3-section m3-section-tonal">
				<div class="m3-workflow-layout">
					<div class="workflow-content">
						<div class="m3-chip m3-chip-secondary">
							<span class="material-symbols-rounded">bolt</span>
							<span>Rápida implementación</span>
						</div>
						<h2 class="m3-headline">Un flujo claro para arrancar en minutos</h2>
						<p class="m3-body-large">
							Construye y lanza tus flujos de reserva sin cuellos de botella. 
							Tu equipo estará operando el mismo día.
						</p>
					</div>

					<div class="m3-workflow-steps">
						{
							steps.map((item) => (
								<article class="m3-step-card">
									<div class="step-icon-wrap">
										<span class="material-symbols-rounded">{item.icon}</span>
									</div>
									<div class="step-content">
										<span class="step-label">Paso {item.step}</span>
										<h3 class="m3-title">{item.title}</h3>
										<p class="m3-body">{item.text}</p>
									</div>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section id="contacto" class="m3-cta-card">
				<div class="cta-content">
					<h2 class="m3-headline">Lleva Hasel a tu equipo hoy</h2>
					<p class="m3-body-large">Empieza con tu flujo actual y escala operaciones sin fricción.</p>
				</div>
			</section>

			<section id="acerca-de" class="m3-section">
				<div class="section-header center">
					<h2 class="m3-headline">Acerca de</h2>
					<p class="m3-body">
						Este sitio web es operado y administrado por Daniel Ramon Villasanti Vergara.
					</p>
				</div>
			</section>
			
			<footer class="m3-footer">
				<p>© {new Date().getFullYear()} Hasel. Plataforma de agenda inteligente.</p>
				<a href="/politicas-y-privacidad" class="m3-footer-link no-underline">
					Políticas y privacidad
				</a>
			</footer>
		</div>
</main>
</Layout>

<script is:inline>
	(() => {
		if (typeof window === 'undefined') return;

		const nav = document.querySelector('.m3-navbar');
		const getOffset = () => {
			const navHeight = nav instanceof HTMLElement ? nav.getBoundingClientRect().height : 0;
			return navHeight + 24;
		};

		const scrollToHash = (hash, behavior = 'smooth') => {
			if (!hash || !hash.startsWith('#')) return;
			const id = decodeURIComponent(hash.slice(1));
			if (!id) return;
			const target = document.getElementById(id);
			if (!target) return;

			const top = target.getBoundingClientRect().top + window.scrollY - getOffset();
			window.scrollTo({ top: Math.max(0, top), behavior });
		};

		document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
			anchor.addEventListener('click', (event) => {
				const href = anchor.getAttribute('href');
				if (!href) return;
				event.preventDefault();
				history.pushState(null, '', href);
				scrollToHash(href, 'smooth');
			});
		});

		if (window.location.hash) {
			requestAnimationFrame(() => scrollToHash(window.location.hash, 'auto'));
		}
	})();
</script>

<style>
	/* PREMIUM DARK — single palette, no light/dark duality */
	:root {
		--m3-sys-light-primary: #3a6fd7;
		--m3-sys-light-on-primary: #ffffff;
		--m3-sys-light-primary-container: rgba(58, 111, 215, 0.2);
		--m3-sys-light-on-primary-container: #bfd6ff;

		--m3-sys-light-secondary: #6b8ecf;
		--m3-sys-light-secondary-container: rgba(148, 163, 184, 0.12);
		--m3-sys-light-on-secondary-container: #dbe7ff;

		--m3-sys-light-surface: #09090b;
		--m3-sys-light-surface-container: rgba(255, 255, 255, 0.04);
		--m3-sys-light-on-surface: #ffffff;
		--m3-sys-light-on-surface-variant: #a1a1aa;

		--m3-sys-light-outline: #3f3f46;
		--m3-sys-light-outline-variant: rgba(255, 255, 255, 0.1);
	}

	.landing-root {
		position: relative;
		overflow: hidden;
		min-height: 100vh;
		background-color: var(--m3-sys-light-surface);
		color: var(--m3-sys-light-on-surface);
		font-family: 'Inter', system-ui, sans-serif;
	}

	html { scroll-padding-top: 7.5rem; }

	.landing-root [id] {
		scroll-margin-top: 7.5rem;
	}

	/* Expressive gradient orbs — electric neon light sources */
	.landing-orb {
		position: absolute;
		border-radius: 9999px;
		filter: blur(100px);
		pointer-events: none;
		z-index: 0;
	}

	.landing-orb-a {
		top: -15%;
		left: -10%;
		width: 55vw;
		height: 55vw;
		background: radial-gradient(circle, rgba(59, 130, 246, 0.28), transparent 65%);
	}

	.landing-orb-b {
		bottom: -15%;
		right: -10%;
		width: 65vw;
		height: 65vw;
		background: radial-gradient(circle, rgba(14, 165, 233, 0.22), transparent 65%);
	}

	.landing-orb-c {
		top: 38%;
		left: 18%;
		width: 35vw;
		height: 35vw;
		background: radial-gradient(circle, rgba(99, 102, 241, 0.18), transparent 65%);
	}

	.landing-shell {
		position: relative;
		z-index: 1;
		width: min(1200px, 100%);
		margin: 0 auto;
		padding: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	/* Navbar — floating pill with dark glassmorphism */
	.m3-navbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.62rem 0.9rem 0.62rem 1.05rem;
		border-radius: 999px;
		background: linear-gradient(115deg, rgba(2, 6, 23, 0.72), rgba(15, 23, 42, 0.48));
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
		border: 1px solid rgba(148, 163, 184, 0.24);
		box-shadow: 0 12px 28px rgba(2, 6, 23, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.06);
		position: sticky;
		top: 1.25rem;
		z-index: 50;
		margin: 1.5rem 0 0;
		width: 100%;
		overflow: hidden;
		isolation: isolate;
	}

	.m3-navbar::after {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		background: linear-gradient(
			90deg,
			rgba(148, 163, 184, 0.08) 0%,
			transparent 30%,
			transparent 68%,
			rgba(148, 163, 184, 0.06) 100%
		);
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--m3-sys-light-on-surface);
	}

	.brand-logo {
		height: 2rem;
		width: 2rem;
		flex-shrink: 0;
		object-fit: contain;
		border-radius: 999px;
	}

	.brand-mark {
		display: grid;
		place-items: center;
		color: var(--m3-sys-light-on-primary);
		background-color: var(--m3-sys-light-primary);
		border-radius: 50%;
		width: 2.25rem;
		height: 2.25rem;
	}

	.brand-mark .material-symbols-rounded {
		font-size: 1.25rem;
	}

	.brand-text {
		font-weight: 700;
		font-size: 1.25rem;
		letter-spacing: -0.02em;
	}

	.nav-links {
		display: none;
		align-items: center;
		gap: 1.5rem;
	}

	.nav-link {
		color: var(--m3-sys-light-on-surface-variant);
		text-decoration: none;
		font-weight: 500;
		font-size: 0.95rem;
		transition: color 0.2s;
	}

	.nav-link:hover {
		color: var(--m3-sys-light-on-surface);
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	@media (min-width: 768px) {
		.landing-shell { padding: 1.5rem; gap: 1.5rem; }
		.m3-navbar { margin: 1.5rem 0 0; width: 100%; }
		.nav-links, .nav-actions { display: flex; }
	}

	/* Buttons */
	.m3-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		border-radius: 999px;
		font-weight: 500;
		font-size: 0.95rem;
		padding: 0.625rem 1.5rem;
		transition: all 0.2s cubic-bezier(0.2, 0, 0, 1);
		cursor: pointer;
		border: 1px solid transparent;
		text-decoration: none;
	}

	.m3-btn:hover {
		transform: translateY(-1px);
		box-shadow: 0 4px 10px rgba(2, 6, 23, 0.22);
	}

	.m3-btn:active {
		transform: translateY(0);
	}

	.m3-btn-large {
		padding: 0.875rem 2rem;
		font-size: 1.05rem;
	}

	.m3-btn-primary {
		background: #3c6fc8;
		color: var(--m3-sys-light-on-primary);
		border-color: rgba(147, 197, 253, 0.24);
		box-shadow: none;
	}

	.m3-btn-primary:hover {
		background: #335fa9;
	}

	.m3-btn-tonal {
		background-color: rgba(30, 41, 59, 0.42);
		color: var(--m3-sys-light-on-secondary-container);
		border-color: rgba(148, 163, 184, 0.32);
	}

	.m3-btn-tonal:hover {
		background-color: rgba(51, 65, 85, 0.56);
		border-color: rgba(203, 213, 225, 0.36);
	}

	.m3-btn-nav {
		padding: 0.62rem 1.85rem;
		font-weight: 600;
		letter-spacing: 0.01em;
		box-shadow: none;
	}

	.m3-btn-nav:hover {
		box-shadow: none;
	}

	.m3-btn-subtle {
		background-color: transparent;
		color: var(--m3-sys-light-primary);
	}
	
	.m3-btn-subtle:hover {
		background-color: var(--m3-sys-light-surface-container);
		box-shadow: none;
	}

	/* Chips */
	.m3-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		border-radius: 999px;
		font-size: 0.875rem;
		font-weight: 600;
		background: var(--m3-sys-light-surface-container);
		color: var(--m3-sys-light-on-surface);
		border: 1px solid var(--m3-sys-light-outline-variant);
	}

	.m3-chip-primary {
		background: var(--m3-sys-light-primary-container);
		color: var(--m3-sys-light-on-primary-container);
		border-color: transparent;
	}

	.m3-chip-secondary {
		background: var(--m3-sys-light-secondary-container);
		color: var(--m3-sys-light-on-secondary-container);
		border-color: transparent;
	}

	.m3-chip .material-symbols-rounded {
		font-size: 1.125rem;
	}

	/* Hero */
	.m3-hero {
		display: grid;
		gap: 3rem;
		padding: 1rem 1rem 2rem;
		align-items: center;
	}

	.m3-hero-content {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1.5rem;
	}

	.m3-display {
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		font-weight: 700;
		line-height: 1.05;
		letter-spacing: -0.03em;
		color: var(--m3-sys-light-on-surface);
		margin: 0;
	}

	.m3-body-large {
		font-size: clamp(1rem, 2vw, 1.25rem);
		line-height: 1.6;
		color: var(--m3-sys-light-on-surface-variant);
		max-width: 54ch;
		margin: 0;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin-top: 1rem;
	}

	/* Hero Visuals */
	.m3-hero-visuals {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		width: 100%;
	}

	.visual-story-shell {
		display: contents;
	}

	.visual-story-head {
		display: none;
	}

	.visual-story-kicker {
		display: none;
	}

	.visual-story-head strong {
		display: none;
	}

	.visual-card {
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 1.25rem;
		padding: 0.875rem 1rem;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.08);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		display: flex;
		align-items: center;
		gap: 0.875rem;
		width: 100%;
		animation: float 7s ease-in-out infinite;
	}

	.visual-card-main {
		animation-delay: 0s;
	}

	.visual-flow-note {
		display: none;
	}

	.visual-metrics-grid {
		display: contents;
	}

	.visual-card-2 {
		animation-delay: -2.4s;
	}

	.visual-card-3 {
		animation-delay: -4.2s;
	}

	@media (min-width: 1024px) {
		.m3-hero-visuals {
			position: relative;
			height: 360px;
			display: block;
			width: auto;
			justify-content: flex-end;
		}

		.visual-card {
			position: absolute;
			width: auto;
			padding: 1.25rem;
			border-radius: 1.5rem;
		}

		.visual-card-main { top: 5%; left: 0; z-index: 2; }
		.visual-card-2 { bottom: 5%; left: 0; z-index: 1; }
		.visual-card-3 { top: 38%; right: 0; z-index: 3; }
	}

	@keyframes float {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-9px); }
	}

	.visual-icon-ai {
		background: rgba(148, 163, 184, 0.22);
		color: #dbeafe;
	}

	.visual-header {
		display: flex;
		align-items: center;
		gap: 1rem;
		justify-content: space-between;
	}

	.visual-avatar, .visual-icon-box {
		width: 3rem;
		height: 3rem;
		border-radius: 50%;
		display: grid;
		place-items: center;
	}

	.visual-avatar {
		background: rgba(226, 232, 240, 0.9);
		color: #1e293b;
	}

	.visual-icon-box {
		background: rgba(191, 219, 254, 0.9);
		color: #1e3a8a;
	}

	.visual-info {
		display: flex;
		flex-direction: column;
	}

	.visual-info strong {
		font-size: 0.95rem;
		color: var(--m3-sys-light-on-surface);
	}

	.visual-info span {
		font-size: 0.85rem;
		color: var(--m3-sys-light-on-surface-variant);
	}

	.visual-badge {
		padding: 0.25rem 0.65rem;
		border-radius: 999px;
		font-size: 0.74rem;
		font-weight: 700;
	}

	.visual-badge-success {
		background: rgba(34, 197, 94, 0.24);
		border: 1px solid rgba(74, 222, 128, 0.3);
		color: #bbf7d0;
	}

	html[data-theme='dark'] .visual-badge-success {
		background: #14532d;
		color: #86efac;
	}

	@media (min-width: 1024px) {
		.m3-hero {
			grid-template-columns: 1fr 1fr;
			padding: 2rem 2rem 3rem;
		}
	}

	/* Section Commons */
	.m3-section {
		padding: 2rem 1rem;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	@media (min-width: 768px) {
		.m3-section { padding: 4rem 1.5rem; gap: 3rem; }
	}

	.m3-section-tonal {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 2rem;
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
	}

	.section-header.center {
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.m3-headline {
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin: 0 0 1rem 0;
		color: var(--m3-sys-light-on-surface);
	}

	.m3-body {
		font-size: 1rem;
		line-height: 1.5;
		color: var(--m3-sys-light-on-surface-variant);
		margin: 0;
	}

	/* Features Grid */
	.m3-feature-grid {
		display: grid;
		gap: 1.5rem;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
	}

	.m3-card {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 1.5rem;
		padding: 1.25rem;
