---
import SideNav from '../components/SideNav.astro';
import TopBar from '../components/TopBar.astro';
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout>
	<div class="min-h-screen pb-10">
		<TopBar />
		<SideNav />

		<main class="px-4 pt-8 sm:px-6 lg:px-8">
			<section class="grid w-full gap-6 xl:grid-cols-[minmax(0,1.5fr)_minmax(22rem,1fr)]">
				<div
					class="overflow-hidden rounded-[2rem] border border-white/70 bg-[color:var(--surface)]/75 p-6 shadow-[0_24px_80px_rgba(15,23,42,0.12)] backdrop-blur xl:p-8"
				>
					<div class="max-w-3xl">
						<p
							class="mb-3 inline-flex rounded-full bg-[color:var(--secondary-container)] px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--secondary)]"
						>
							Workspace shell
						</p>
						<h1 class="text-4xl font-extrabold tracking-[-0.04em] text-[color:var(--on-surface)] sm:text-5xl">
							Bookmate ahora usa una navegacion lateral invocada desde el top bar.
						</h1>
						<p class="mt-4 max-w-2xl text-base leading-7 text-[color:var(--on-surface-variant)] sm:text-lg">
							El contenido principal mantiene siempre todo el ancho de la pantalla,
							mientras el side navigation aparece como drawer flotante al pulsar el menu
							hamburguesa.
						</p>
					</div>

					<div class="mt-8 grid gap-4 lg:grid-cols-3">
						<div class="rounded-[1.5rem] bg-white/70 p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
							<p class="text-sm font-semibold text-[color:var(--on-surface)]">Actividad</p>
							<p class="mt-2 text-sm leading-6 text-[color:var(--on-surface-variant)]">
								Aqui puedes conectar el contenido principal del dashboard.
							</p>
						</div>
						<div class="rounded-[1.5rem] bg-white/70 p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
							<p class="text-sm font-semibold text-[color:var(--on-surface)]">Equipo</p>
							<p class="mt-2 text-sm leading-6 text-[color:var(--on-surface-variant)]">
								El submenu de Equipo sigue listo para crecer con vistas reales.
							</p>
						</div>
						<div class="rounded-[1.5rem] bg-white/70 p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
							<p class="text-sm font-semibold text-[color:var(--on-surface)]">Servicios</p>
							<p class="mt-2 text-sm leading-6 text-[color:var(--on-surface-variant)]">
								La shell principal ya no pierde espacio por una columna fija lateral.
							</p>
						</div>
					</div>
				</div>

				<div class="grid gap-6">
					<div class="rounded-[2rem] border border-white/70 bg-white/75 p-6 shadow-[0_16px_42px_rgba(15,23,42,0.08)] backdrop-blur">
						<p class="text-sm font-semibold uppercase tracking-[0.18em] text-[color:var(--secondary)]">
							Resumen rapido
						</p>
						<p class="mt-4 text-sm leading-7 text-[color:var(--on-surface-variant)]">
							El top bar y el contenido ahora se extienden de borde a borde util, con el
							mismo padding exterior para mantener consistencia visual.
						</p>
					</div>

					<div class="rounded-[2rem] border border-white/70 bg-white/75 p-6 shadow-[0_16px_42px_rgba(15,23,42,0.08)] backdrop-blur">
						<p class="text-sm font-semibold uppercase tracking-[0.18em] text-[color:var(--secondary)]">
							Interaccion
						</p>
						<p class="mt-4 text-sm leading-7 text-[color:var(--on-surface-variant)]">
							El drawer lateral se cierra con su boton, al tocar el backdrop o con la
							tecla Escape.
						</p>
					</div>
				</div>
			</section>
		</main>
	</div>
</Layout>
