---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
const siteOrigin = String(Astro.site ?? Astro.url.origin).replace(/\/+$/, '');
const pageTitle = 'Hasel — Software de citas, agenda y reservas online para tu negocio';
const metaDescription =
	'Gestiona calendario, sucursales, clientes, horarios y tu equipo sin límite de personas. Ofrece reservas por enlace público personalizado en minutos.';
const features = [
	{
		title: 'Calendario centralizado',
		description:
			'Visualiza y administra todas las citas del equipo en un solo calendario, con estados claros y actualización en tiempo real.',
		icon: 'calendar_month',
	},
	{
		title: 'Sucursales y ubicaciones',
		description:
			'Organiza múltiples locales, direcciones y disponibilidad por sede desde un mismo panel.',
		icon: 'storefront',
	},
	{
		title: 'Base de clientes',
		description:
			'Registra, consulta y reutiliza datos de clientes en cada nueva cita sin perder historial.',
		icon: 'contacts',
	},
	{
		title: 'Equipo sin límites',
		description:
			'Agrega todos los profesionales que necesites, con perfiles, servicios y permisos por rol.',
		icon: 'groups',
	},
	{
		title: 'Horarios flexibles',
		description:
			'Define disponibilidad por profesional, sucursal y servicio para que solo se reserven slots válidos.',
		icon: 'schedule',
	},
];

const steps = [
	{
		step: '01',
		title: 'Configura tu negocio',
		text: 'Carga sucursales, servicios, horarios y profesionales. Tu espacio queda listo en pocos minutos.',
		icon: 'settings_suggest',
	},
	{
		step: '02',
		title: 'Publica tu enlace de reserva',
		text: 'Comparte tu agenda pública personalizada. Tus clientes eligen día, hora y confirman solos.',
		icon: 'public',
	},
	{
		step: '03',
		title: 'Gestiona desde el calendario',
		text: 'Recibe reservas, revisa clientes, ajusta citas y mantén el día bajo control desde un solo lugar.',
		icon: 'event_available',
	},
];

const jsonLd = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: 'Hasel',
		url: siteOrigin,
		description: metaDescription,
		inLanguage: 'es',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'SoftwareApplication',
		name: 'Hasel',
		applicationCategory: 'BusinessApplication',
		operatingSystem: 'Web',
		url: siteOrigin,
		description: metaDescription,
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
			description: 'Registro y configuración inicial',
		},
		featureList: features.map((feature) => feature.title).join(', '),
	},
];
---

<Layout
	pageTitle={pageTitle}
	metaDescription={metaDescription}
	canonicalPath="/"
	ogImage="/icon-512x512.png"
	jsonLd={jsonLd}
>
	<main class="landing-root">
		<div class="landing-orb landing-orb-a" aria-hidden="true"></div>
		<div class="landing-orb landing-orb-b" aria-hidden="true"></div>
		<div class="landing-orb landing-orb-c" aria-hidden="true"></div>

		<div class="landing-shell">
			<header class="m3-navbar">
				<a href="/" class="brand no-underline" aria-label="Hasel — Inicio">
					<img src="/icon-512x512.png" alt="" class="brand-logo" width="32" height="32" loading="eager" decoding="async" />
					<span class="brand-text">Hasel</span>
				</a>

				<div class="nav-actions">
					<a href="/auth/login" class="m3-btn m3-btn-primary m3-btn-nav no-underline">Iniciar sesión</a>
				</div>
			</header>

			<section class="m3-hero" aria-labelledby="hero-heading">
				<div class="m3-hero-content">
					<p class="m3-chip m3-chip-primary">
						<span class="material-symbols-rounded" aria-hidden="true">auto_awesome</span>
						<span>Agenda y reservas online</span>
					</p>
					<h1 id="hero-heading" class="m3-display">
						Tu calendario, equipo y reservas públicas en una sola plataforma
					</h1>
					<p class="m3-body-large">
						Hasel ayuda a barberías, salones, consultorios y negocios de servicios a organizar citas,
						gestionar sucursales y clientes, y recibir reservas 24/7 con un enlace personalizado.
					</p>

					<div class="hero-actions">
						<a href="/auth/login" class="m3-btn m3-btn-primary m3-btn-large no-underline">
							Crear mi espacio gratis
							<span class="material-symbols-rounded" aria-hidden="true">arrow_forward</span>
						</a>
						<a href="#funciones" class="m3-btn m3-btn-tonal m3-btn-large no-underline">Ver funciones</a>
					</div>
				</div>

				<div class="m3-hero-visuals" aria-hidden="true">
					<div class="visual-story-shell">
						<div class="visual-card visual-card-main">
							<div class="visual-header">
								<div class="visual-avatar">
									<span class="material-symbols-rounded">event</span>
								</div>
								<div class="visual-info">
									<strong>Reserva confirmada</strong>
									<span>Cliente desde tu enlace público</span>
								</div>
								<div class="visual-badge visual-badge-success">Nueva cita</div>
							</div>
						</div>

						<div class="visual-metrics-grid">
							<div class="visual-card visual-card-3">
								<div class="visual-icon-box visual-icon-ai">
									<span class="material-symbols-rounded">groups</span>
								</div>
								<div class="visual-info">
									<strong>Equipo completo</strong>
									<span>Sin límite de profesionales</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section id="funciones" class="m3-section" aria-labelledby="funciones-heading">
				<div class="section-header center">
					<h2 id="funciones-heading" class="m3-headline">Todo lo que necesitas para operar tu agenda</h2>
					<p class="m3-body section-lead">
						Desde el calendario diario hasta la reserva pública: herramientas pensadas para equipos
						que atienden clientes todos los días.
					</p>
				</div>

				<div class="m3-feature-grid">
					{
						features.map((feature) => (
							<article class="m3-card m3-feature-card">
								<div class="m3-icon-container">
									<span class="material-symbols-rounded" aria-hidden="true">{feature.icon}</span>
								</div>
								<h3 class="m3-title">{feature.title}</h3>
								<p class="m3-body">{feature.description}</p>
							</article>
						))
					}
				</div>
			</section>

			<section id="como-funciona" class="m3-section m3-section-tonal" aria-labelledby="como-funciona-heading">
				<div class="m3-workflow-layout">
					<div class="workflow-content">
						<p class="m3-chip m3-chip-secondary">
							<span class="material-symbols-rounded" aria-hidden="true">bolt</span>
							<span>En minutos, no en semanas</span>
						</p>
						<h2 id="como-funciona-heading" class="m3-headline">Cómo funciona Hasel</h2>
						<p class="m3-body-large">
							Configura tu negocio, comparte tu enlace de reserva y empieza a recibir citas el mismo
							día. Sin instalaciones complejas: funciona en navegador y como app en el móvil.
						</p>
					</div>

					<ol class="m3-workflow-steps">
						{
							steps.map((item) => (
								<li>
									<article class="m3-step-card">
										<div class="step-icon-wrap">
											<span class="material-symbols-rounded" aria-hidden="true">{item.icon}</span>
										</div>
										<div class="step-content">
											<span class="step-label">Paso {item.step}</span>
											<h3 class="m3-title">{item.title}</h3>
											<p class="m3-body">{item.text}</p>
										</div>
									</article>
								</li>
							))
						}
					</ol>
				</div>
			</section>

			<section class="m3-cta-card" aria-labelledby="cta-heading">
				<div class="cta-content">
					<h2 id="cta-heading" class="m3-headline">Empieza a recibir reservas con tu enlace hoy</h2>
					<p class="m3-body-large">
						Crea tu espacio, configura horarios y comparte tu página pública. Tus clientes reservan;
						tú controlas todo desde el calendario.
					</p>
					<a href="/auth/login" class="m3-btn m3-btn-primary m3-btn-large no-underline cta-btn">
						Crear mi espacio
						<span class="material-symbols-rounded" aria-hidden="true">arrow_forward</span>
					</a>
				</div>
			</section>

			<footer class="m3-footer">
				<p>© {new Date().getFullYear()} Hasel — Software de citas y reservas online.</p>
				<nav class="m3-footer-nav" aria-label="Enlaces legales">
					<a href="/politicas-y-privacidad" class="m3-footer-link no-underline">
						Políticas y privacidad
					</a>
				</nav>
			</footer>
		</div>
	</main>
</Layout>

<script is:inline>
	(() => {
		if (typeof window === 'undefined') return;

		const nav = document.querySelector('.m3-navbar');
		const getOffset = () => {
			const navHeight = nav instanceof HTMLElement ? nav.getBoundingClientRect().height : 0;
			return navHeight + 24;
		};

		const scrollToHash = (hash, behavior = 'smooth') => {
			if (!hash || !hash.startsWith('#')) return;
			const id = decodeURIComponent(hash.slice(1));
			if (!id) return;
			const target = document.getElementById(id);
			if (!target) return;

			const top = target.getBoundingClientRect().top + window.scrollY - getOffset();
			window.scrollTo({ top: Math.max(0, top), behavior });
		};

		document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
			anchor.addEventListener('click', (event) => {
				const href = anchor.getAttribute('href');
				if (!href) return;
				event.preventDefault();
				history.pushState(null, '', href);
				scrollToHash(href, 'smooth');
			});
		});

		if (window.location.hash) {
			requestAnimationFrame(() => scrollToHash(window.location.hash, 'auto'));
		}
	})();
</script>

<style>
	/* PREMIUM DARK — single palette, no light/dark duality */
	:root {
		--m3-sys-light-primary: #3a6fd7;
		--m3-sys-light-on-primary: #ffffff;
		--m3-sys-light-primary-container: rgba(58, 111, 215, 0.2);
		--m3-sys-light-on-primary-container: #bfd6ff;

		--m3-sys-light-secondary: #6b8ecf;
		--m3-sys-light-secondary-container: rgba(148, 163, 184, 0.12);
		--m3-sys-light-on-secondary-container: #dbe7ff;

		--m3-sys-light-surface: #09090b;
		--m3-sys-light-surface-container: rgba(255, 255, 255, 0.04);
		--m3-sys-light-on-surface: #ffffff;
		--m3-sys-light-on-surface-variant: #a1a1aa;

		--m3-sys-light-outline: #3f3f46;
		--m3-sys-light-outline-variant: rgba(255, 255, 255, 0.1);
	}

	.landing-root {
		position: relative;
		overflow: hidden;
		min-height: 100vh;
		background-color: var(--m3-sys-light-surface);
		color: var(--m3-sys-light-on-surface);
		font-family: 'Inter', system-ui, sans-serif;
	}

	html {
		scroll-padding-top: 7.5rem;
	}

	.landing-root [id] {
		scroll-margin-top: 7.5rem;
	}

	.landing-orb {
		position: absolute;
		border-radius: 9999px;
		filter: blur(92px);
		pointer-events: none;
		z-index: 0;
		animation: landing-orb-drift 16s ease-in-out infinite;
		will-change: transform, opacity;
	}

	.landing-orb-a {
		top: -15%;
		left: -10%;
		width: 55vw;
		height: 55vw;
		background: radial-gradient(circle, rgba(59, 130, 246, 0.28), transparent 65%);
		animation-duration: 18s;
	}

	.landing-orb-b {
		bottom: -15%;
		right: -10%;
		width: 65vw;
		height: 65vw;
		background: radial-gradient(circle, rgba(14, 165, 233, 0.22), transparent 65%);
		animation-duration: 22s;
		animation-direction: reverse;
	}

	.landing-orb-c {
		top: 38%;
		left: 18%;
		width: 35vw;
		height: 35vw;
		background: radial-gradient(circle, rgba(99, 102, 241, 0.18), transparent 65%);
		animation-duration: 19s;
		animation-delay: -4s;
	}

	.landing-shell {
		position: relative;
		z-index: 1;
		width: min(1200px, 100%);
		margin: 0 auto;
		padding: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.m3-navbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.62rem 0.9rem 0.62rem 1.05rem;
		border-radius: 999px;
		background: linear-gradient(115deg, rgba(2, 6, 23, 0.72), rgba(15, 23, 42, 0.48));
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
		border: 1px solid rgba(148, 163, 184, 0.24);
		box-shadow: 0 12px 28px rgba(2, 6, 23, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.06);
		position: sticky;
		top: 1.25rem;
		z-index: 50;
		margin: 1.5rem 0 0;
		width: 100%;
		overflow: hidden;
		isolation: isolate;
	}

	.m3-navbar::after {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		background: linear-gradient(
			90deg,
			rgba(148, 163, 184, 0.08) 0%,
			transparent 30%,
			transparent 68%,
			rgba(148, 163, 184, 0.06) 100%
		);
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--m3-sys-light-on-surface);
	}

	.brand-logo {
		height: 2rem;
		width: 2rem;
		flex-shrink: 0;
		object-fit: contain;
		border-radius: 999px;
	}

	.brand-text {
		font-weight: 700;
		font-size: 1.25rem;
		letter-spacing: -0.02em;
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-shrink: 0;
	}

	@media (min-width: 768px) {
		.landing-shell {
			padding: 1.5rem;
			gap: 1.5rem;
		}

		.m3-navbar {
			margin: 1.5rem 0 0;
			width: 100%;
		}

	}

	.m3-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		border-radius: 999px;
		font-weight: 500;
		font-size: 0.95rem;
		padding: 0.625rem 1.5rem;
		transition: all 0.2s cubic-bezier(0.2, 0, 0, 1);
		cursor: pointer;
		border: 1px solid transparent;
		text-decoration: none;
	}

	.m3-btn:hover {
		transform: translateY(-1px);
		box-shadow: 0 4px 10px rgba(2, 6, 23, 0.22);
	}

	.m3-btn:active {
		transform: translateY(0);
	}

	.m3-btn-large {
		padding: 0.875rem 2rem;
		font-size: 1.05rem;
	}

	.m3-btn-primary {
		background: #3c6fc8;
		color: var(--m3-sys-light-on-primary);
		border-color: rgba(147, 197, 253, 0.24);
		box-shadow: none;
	}

	.m3-btn-primary:hover {
		background: #335fa9;
	}

	.m3-btn-tonal {
		background-color: rgba(30, 41, 59, 0.42);
		color: var(--m3-sys-light-on-secondary-container);
		border-color: rgba(148, 163, 184, 0.32);
	}

	.m3-btn-tonal:hover {
		background-color: rgba(51, 65, 85, 0.56);
		border-color: rgba(203, 213, 225, 0.36);
	}

	.m3-btn-nav {
		padding: 0.62rem 1.85rem;
		font-weight: 600;
		letter-spacing: 0.01em;
		box-shadow: none;
	}

	.m3-btn-nav:hover {
		box-shadow: none;
	}

	.m3-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		border-radius: 999px;
		font-size: 0.875rem;
		font-weight: 600;
		background: var(--m3-sys-light-surface-container);
		color: var(--m3-sys-light-on-surface);
		border: 1px solid var(--m3-sys-light-outline-variant);
		margin: 0;
	}

	.m3-chip-primary {
		background: var(--m3-sys-light-primary-container);
		color: var(--m3-sys-light-on-primary-container);
		border-color: transparent;
	}

	.m3-chip-secondary {
		background: var(--m3-sys-light-secondary-container);
		color: var(--m3-sys-light-on-secondary-container);
		border-color: transparent;
	}

	.m3-chip .material-symbols-rounded {
		font-size: 1.125rem;
	}

	.m3-hero {
		display: grid;
		gap: 3rem;
		padding: 1rem 1rem 2rem;
		align-items: center;
	}

	.m3-hero-content {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1.5rem;
	}

	.m3-display {
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		font-weight: 700;
		line-height: 1.05;
		letter-spacing: -0.03em;
		color: var(--m3-sys-light-on-surface);
		margin: 0;
	}

	.m3-body-large {
		font-size: clamp(1rem, 2vw, 1.25rem);
		line-height: 1.6;
		color: var(--m3-sys-light-on-surface-variant);
		max-width: 54ch;
		margin: 0;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin-top: 0.25rem;
	}

	.m3-hero-visuals {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		width: 100%;
	}

	.visual-story-shell {
		display: contents;
	}

	.visual-card {
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 1.25rem;
		padding: 0.875rem 1rem;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.08);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		display: flex;
		align-items: center;
		gap: 0.875rem;
		width: 100%;
		animation: float 7s ease-in-out infinite;
	}

	.visual-card-main {
		animation-delay: 0s;
	}

	.visual-metrics-grid {
		display: contents;
	}

	.visual-card-2 {
		animation-delay: -2.4s;
	}

	.visual-card-3 {
		animation-delay: -4.2s;
	}

	@media (min-width: 1024px) {
		.m3-hero-visuals {
			position: relative;
			height: 360px;
			display: block;
			width: auto;
		}

		.visual-card {
			position: absolute;
			width: auto;
			padding: 1.25rem;
			border-radius: 1.5rem;
		}

		.visual-card-main {
			top: 5%;
			left: 0;
			z-index: 2;
		}

		.visual-card-2 {
			bottom: 5%;
			left: 0;
			z-index: 1;
		}

		.visual-card-3 {
			top: 38%;
			right: 0;
			z-index: 3;
		}

		.m3-hero {
			grid-template-columns: 1fr 1fr;
			padding: 2rem 2rem 3rem;
		}
	}

	@keyframes float {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-9px);
		}
	}

	@keyframes landing-orb-drift {
		0%,
		100% {
			transform: translate3d(0, 0, 0) scale(1);
			opacity: 0.82;
		}
		25% {
			transform: translate3d(10%, -2%, 0) scale(1.05);
			opacity: 0.96;
		}
		50% {
			transform: translate3d(22%, 1%, 0) scale(1.1);
			opacity: 1;
		}
		75% {
			transform: translate3d(10%, -2%, 0) scale(1.05);
			opacity: 0.94;
		}
	}

	.visual-icon-ai {
		background: rgba(148, 163, 184, 0.22);
		color: #dbeafe;
	}

	.visual-header {
		display: flex;
		align-items: center;
		gap: 1rem;
		justify-content: space-between;
		width: 100%;
	}

	.visual-avatar,
	.visual-icon-box {
		width: 3rem;
		height: 3rem;
		border-radius: 50%;
		display: grid;
		place-items: center;
		flex-shrink: 0;
	}

	.visual-avatar {
		background: rgba(226, 232, 240, 0.9);
		color: #1e293b;
	}

	.visual-icon-box {
		background: rgba(191, 219, 254, 0.9);
		color: #1e3a8a;
	}

	.visual-info {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}

	.visual-info strong {
		font-size: 0.95rem;
		color: var(--m3-sys-light-on-surface);
	}

	.visual-info span {
		font-size: 0.85rem;
		color: var(--m3-sys-light-on-surface-variant);
	}

	.visual-badge {
		padding: 0.25rem 0.65rem;
		border-radius: 999px;
		font-size: 0.74rem;
		font-weight: 700;
		flex-shrink: 0;
	}

	.visual-badge-success {
		background: rgba(34, 197, 94, 0.24);
