---
import SideNav from '../components/SideNav.astro';
import TopBar from '../components/TopBar.astro';
import { DashboardApiError, getMainDashboardWithOrds, type DashboardMainData } from '../lib/dashboard';
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const token = Astro.locals.token ?? '';
const organizationName = String(Astro.locals.organizationName || 'Workspace').trim() || 'Workspace';

let dashboard: DashboardMainData = {
	kpis: {
		today_appointments: 0,
		pending_appointments: 0,
		my_customers: 0,
		total_customers: null,
	},
	upcoming_appointments: [],
};
let loadError = '';

if (!token) {
	loadError = 'No hay sesion valida para consultar el dashboard.';
} else {
	try {
		dashboard = await getMainDashboardWithOrds(token);
	} catch (error) {
		loadError =
			error instanceof DashboardApiError
				? error.message
				: 'No fue posible cargar los datos del dashboard.';
	}
}

const dashboardDate = new Intl.DateTimeFormat('es-PY', {
	weekday: 'long',
	year: 'numeric',
	month: 'long',
	day: 'numeric',
}).format(new Date());

const metrics = [
	{
		label: 'Citas de hoy',
		value: dashboard.kpis.today_appointments,
		description: 'Turnos no cancelados para la jornada actual.',
		icon: 'today',
	},
	{
		label: 'Citas pendientes',
		value: dashboard.kpis.pending_appointments,
		description: 'Turnos por atender desde este momento en adelante.',
		icon: 'schedule',
	},
	{
		label: 'Mis clientes',
		value: dashboard.kpis.my_customers,
		description: 'Clientes únicos que has atendido personalmente.',
		icon: 'group',
	},
	...(dashboard.kpis.total_customers !== null
		? [
				{
					label: 'Total de clientes',
					value: dashboard.kpis.total_customers,
					description: 'Base total de clientes registrados.',
					icon: 'hub',
				},
			]
		: []),
];

const getStatusLabel = (status: string) => {
	switch (status) {
		case 'CONFIRMADO':
			return 'Confirmado';
		case 'PENDIENTE':
			return 'Pendiente';
		case 'COMPLETADO':
			return 'Completado';
		case 'CANCELADO':
			return 'Cancelado';
		default:
			return status || 'Estado';
	}
};

const getStatusTone = (status: string) => {
	switch (status) {
		case 'CONFIRMADO':
			return 'border-emerald-200 bg-emerald-50 text-emerald-700';
		case 'PENDIENTE':
				return 'border-[color:var(--status-pending-border)] bg-[color:var(--status-pending-bg)] text-[color:var(--status-pending-text)]';
		case 'COMPLETADO':
			return 'border-sky-200 bg-sky-50 text-sky-700';
		case 'CANCELADO':
			return 'border-rose-200 bg-rose-50 text-rose-700';
		default:
			return 'border-[color:var(--shell-border)] bg-[color:var(--control-surface)] text-[color:var(--on-surface-variant)]';
	}
};
---

<Layout>
	<div class="min-h-screen w-full max-w-full overflow-x-hidden">
		<div
			class="app-shell grid min-h-screen overflow-hidden border border-(--shell-border) bg-(--shell-surface) shadow-[0_30px_80px_rgba(15,23,42,0.12)] backdrop-blur-xl"
			data-app-shell
			data-sidebar-state="expanded"
		>
			<SideNav currentPath={Astro.url.pathname} />

			<div class="grid min-h-full grid-rows-[auto_1fr]">
				<TopBar />

				<main class="w-full max-w-full overflow-x-hidden bg-(--content-surface) px-4 py-4 sm:px-6 sm:py-6">
					<section class="grid w-full max-w-full min-w-0 gap-4 sm:gap-5">
						<section class="material-region rounded-3xl bg-(--surface-container) p-5 sm:p-6">
							<div class="flex flex-col justify-between gap-3 sm:flex-row sm:items-center sm:gap-4">
								<div class="grid gap-1">
									<p class="text-xs font-bold uppercase tracking-[0.2em] text-(--on-surface-variant)">
										Dashboard
									</p>
									<h1 class="text-2xl font-extrabold text-(--on-surface) sm:text-3xl">
										Resumen diario
									</h1>
									<p class="text-sm leading-relaxed text-(--on-surface-variant)">
										{organizationName} - {dashboardDate}
									</p>
								</div>

								<a
									href="/calendar"
									class="btn-primary-soft inline-flex w-full items-center justify-center gap-2 rounded-xl px-4 py-2.5 text-sm font-semibold no-underline transition sm:w-auto"
								>
									<span class="material-symbols-rounded text-[1rem]">calendar_month</span>
									Ir al calendario
								</a>
							</div>

							<div class="mt-4 border-t border-(--shell-border)/70 pt-4 sm:mt-5 sm:pt-5">
								<div
									class="ai-card rounded-2xl border border-(--shell-border)/60 bg-(--secondary-container) p-4"
									data-ai-summary-card
								>
									<div class="mb-2.5 inline-flex items-center gap-2">
										<span class="material-symbols-rounded text-(--primary)">auto_awesome</span>
										<p class="text-xs font-bold uppercase tracking-widest text-(--on-surface-variant)">
											Resumen Inteligente del dia
										</p>
									</div>
									<p
										class="inline-flex items-center gap-2 text-sm leading-relaxed text-(--on-surface-variant)"
										data-ai-summary-state
									>
										<span class="material-symbols-rounded animate-spin text-base text-(--primary)">
											autorenew
										</span>
										Cargando resumen inteligente...
									</p>
									<p
										class="hidden whitespace-pre-line text-[1.05rem] leading-relaxed text-(--on-surface)"
										data-ai-summary-text
									></p>
								</div>
							</div>
						</section>

						{
							loadError ? (
								<div class="rounded-[1.2rem] border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-700">
									{loadError}
								</div>
							) : (
								<>
									<div class="material-cards-grid md:grid-cols-4">
										{
											metrics.map((metric) => (
												<article class="material-data-card rounded-3xl border border-(--shell-border) bg-(--card-surface) shadow-sm">
													<div class="flex items-start justify-between gap-3">
														<div>
															<p class="text-xs font-bold uppercase tracking-[0.16em] text-(--on-surface-variant)">
																{metric.label}
															</p>
															<p class="mt-2 text-3xl font-extrabold leading-none text-(--on-surface)">
																{metric.value}
															</p>
														</div>
														<span class="material-symbols-rounded rounded-full bg-(--primary-soft) p-2 text-[1.25rem] text-(--primary)">
															{metric.icon}
														</span>
													</div>
													<p class="mt-auto text-sm text-(--on-surface-variant)">
														{metric.description}
													</p>
												</article>
											))
										}
									</div>

									<div class="material-region bg-(--card-surface)">
										<div class="mb-4 flex items-center justify-between gap-3">
											<h2 class="text-lg font-bold text-(--on-surface)">Proximas citas del dia</h2>
											<span class="rounded-full border border-(--shell-border) bg-(--control-surface) px-3 py-1 text-xs font-semibold text-(--on-surface-variant)">
												{dashboard.upcoming_appointments.length} registro(s)
											</span>
										</div>

										{
											dashboard.upcoming_appointments.length === 0 ? (
												<div class="rounded-xl border border-dashed border-(--shell-border) bg-(--control-surface) px-4 py-6 text-sm text-(--on-surface-variant)">
													No hay citas proximas para mostrar en este momento.
												</div>
											) : (
												<div class="w-full max-w-full overflow-x-auto overscroll-x-contain">
													<table class="w-full min-w-full border-collapse text-sm">
														<thead>
															<tr class="border-b border-(--shell-border) text-left text-xs uppercase tracking-[0.12em] text-(--on-surface-variant)">
																<th class="px-3 py-2 font-semibold">Cliente</th>
																<th class="px-3 py-2 font-semibold">Hora</th>
																<th class="px-3 py-2 font-semibold">Servicio</th>
																<th class="px-3 py-2 font-semibold">Estado</th>
															</tr>
														</thead>
														<tbody>
															{
																dashboard.upcoming_appointments.map((appointment) => (
																	<tr class="border-b border-(--shell-border)/70 last:border-none">
																		<td class="px-3 py-3 font-semibold text-(--on-surface)">
																			{appointment.customer_name}
																		</td>
																		<td class="px-3 py-3 text-(--on-surface-variant)">
																			{appointment.time_start} - {appointment.time_end}
																		</td>
																		<td class="px-3 py-3 text-(--on-surface)">
																			{appointment.service_name}
																		</td>
																		<td class="px-3 py-3">
																			<span
																				class:list={[
																					'inline-flex rounded-full border px-2.5 py-1 text-xs font-semibold',
																					getStatusTone(appointment.status),
																				]}
																			>
																				{getStatusLabel(appointment.status)}
																			</span>
																		</td>
																	</tr>
																))
															}
														</tbody>
													</table>
												</div>
											)
										}
									</div>
								</>
							)
						}
					</section>
				</main>
			</div>
		</div>
	</div>
</Layout>

<script>
	const sanitizeAiSummary = (value: unknown): string =>
		String(value ?? '')
			.replace(/\*+/g, '')
			.replace(/\\r\\n|\\n|\\r/g, '\n')
			.replace(/\r\n|\r/g, '\n')
			.replace(/\t/g, ' ')
			.replace(/\u0000/g, '')
			.replace(/[ ]{2,}/g, ' ')
			.replace(/\n{3,}/g, '\n\n')
			.replace(/^\s*["'`]/, '')
			.replace(/["'`]\s*$/, '')
			.trim();

	const splitSummaryIntoTokens = (text: string): string[] =>
		String(text || '')
			.split(/(\s+)/)
			.filter((token) => token.length > 0);

	const wait = (ms: number): Promise<void> => new Promise((resolve) => window.setTimeout(resolve, ms));

	const getTokenDelayMs = () => 28 + Math.floor(Math.random() * 53);

	const streamSummaryTokens = async (node: HTMLElement, text: string): Promise<void> => {
		node.replaceChildren();

		const tokens = splitSummaryIntoTokens(text);
		for (const token of tokens) {
			if (/^\s+$/.test(token)) {
				node.appendChild(document.createTextNode(token));
				continue;
			}

			const tokenNode = document.createElement('span');
			tokenNode.className = 'ai-summary-token';
			tokenNode.textContent = token;
			node.appendChild(tokenNode);

			await wait(getTokenDelayMs());
		}
	};

	const loadAiSummary = async () => {
		const card = document.querySelector<HTMLElement>('[data-ai-summary-card]');
		if (!card) return;

		if (card.getAttribute('data-ai-summary-loaded') === '1') return;
		card.setAttribute('data-ai-summary-loaded', '1');

		const stateNode = card.querySelector<HTMLElement>('[data-ai-summary-state]');
		const textNode = card.querySelector<HTMLElement>('[data-ai-summary-text]');

		if (!stateNode || !textNode) return;

		const revealSummary = async (summaryText: string) => {
			stateNode.classList.add('hidden');
			stateNode.setAttribute('aria-hidden', 'true');
			stateNode.style.display = 'none';
			textNode.classList.remove('hidden');
			textNode.style.display = 'block';
			await streamSummaryTokens(textNode, summaryText);
		};

		try {
			const response = await fetch('/api/dashboard/ai-summary', {
				headers: { Accept: 'application/json' },
			});
			const payload = await response.json();

			if (!response.ok || payload?.status !== 'success') {
				throw new Error(payload?.message || 'No fue posible recuperar el resumen IA.');
			}

			const summary = sanitizeAiSummary(payload?.data?.ai_summary);
			if (!summary) {
				throw new Error('El resumen IA no está disponible en este momento.');
			}

			await revealSummary(summary);
		} catch (error) {
			stateNode.textContent =
				error instanceof Error
					? error.message
					: 'No fue posible recuperar el resumen IA.';
		}
	};

	loadAiSummary();
	document.addEventListener('astro:page-load', loadAiSummary);
</script>

<style>
	@keyframes ai-token-reveal {
		from {
			opacity: 0;
			transform: translateY(3px);
			filter: blur(2px);
		}

		to {
			opacity: 1;
			transform: translateY(0);
			filter: blur(0);
		}
	}

	.ai-summary-token {
		display: inline-block;
		animation: ai-token-reveal 280ms cubic-bezier(0.16, 1, 0.3, 1) both;
	}

	@media (prefers-reduced-motion: reduce) {
		.ai-summary-token {
			animation: none;
		}
	}
</style>
