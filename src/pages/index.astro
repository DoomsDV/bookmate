---
import SideNav from '../components/SideNav.astro';
import TopBar from '../components/TopBar.astro';
import { DashboardApiError, getMainDashboardWithOrds, type DashboardMainData } from '../lib/dashboard';
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const token = Astro.locals.token ?? '';
const organizationName = String(Astro.locals.organizationName || 'Workspace').trim() || 'Workspace';

let dashboard: DashboardMainData = {
	kpis: {
		today_appointments: 0,
		pending_appointments: 0,
		total_customers: 0,
	},
	upcoming_appointments: [],
};
let loadError = '';

if (!token) {
	loadError = 'No hay sesion valida para consultar el dashboard.';
} else {
	try {
		dashboard = await getMainDashboardWithOrds(token);
	} catch (error) {
		loadError =
			error instanceof DashboardApiError
				? error.message
				: 'No fue posible cargar los datos del dashboard.';
	}
}

const dashboardDate = new Intl.DateTimeFormat('es-PY', {
	weekday: 'long',
	year: 'numeric',
	month: 'long',
	day: 'numeric',
}).format(new Date());

const metrics = [
	{
		label: 'Citas de hoy',
		value: dashboard.kpis.today_appointments,
		description: 'Turnos no cancelados para la jornada actual.',
		icon: 'today',
	},
	{
		label: 'Citas pendientes',
		value: dashboard.kpis.pending_appointments,
		description: 'Turnos por atender desde este momento en adelante.',
		icon: 'schedule',
	},
	{
		label: 'Clientes unicos',
		value: dashboard.kpis.total_customers,
		description: 'Cantidad acumulada de clientes con historial.',
		icon: 'groups',
	},
];

const getStatusLabel = (status: string) => {
	switch (status) {
		case 'CONFIRMADO':
			return 'Confirmado';
		case 'PENDIENTE':
			return 'Pendiente';
		case 'COMPLETADO':
			return 'Completado';
		case 'CANCELADO':
			return 'Cancelado';
		default:
			return status || 'Estado';
	}
};

const getStatusTone = (status: string) => {
	switch (status) {
		case 'CONFIRMADO':
			return 'border-emerald-200 bg-emerald-50 text-emerald-700';
		case 'PENDIENTE':
			return 'border-amber-200 bg-amber-50 text-amber-700';
		case 'COMPLETADO':
			return 'border-sky-200 bg-sky-50 text-sky-700';
		case 'CANCELADO':
			return 'border-rose-200 bg-rose-50 text-rose-700';
		default:
			return 'border-[color:var(--shell-border)] bg-[color:var(--control-surface)] text-[color:var(--on-surface-variant)]';
	}
};
---

<Layout>
	<div class="min-h-screen">
		<div
			class="app-shell grid min-h-screen overflow-hidden border border-[color:var(--shell-border)] bg-[color:var(--shell-surface)] shadow-[0_30px_80px_rgba(15,23,42,0.12)] backdrop-blur-xl"
			data-app-shell
			data-sidebar-state="expanded"
		>
			<SideNav currentPath={Astro.url.pathname} />

			<div class="grid min-h-full grid-rows-[auto_1fr]">
				<TopBar />

				<main class="bg-[color:var(--content-surface)] px-5 py-5 sm:px-7 sm:py-7">
					<section class="grid gap-5">
						<div class="rounded-[1.25rem] border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.55)] sm:p-6">
							<div class="flex flex-wrap items-start justify-between gap-4">
								<div class="grid gap-1">
									<p class="text-xs font-bold uppercase tracking-[0.2em] text-[color:var(--on-surface-variant)]">
										Dashboard
									</p>
									<h1 class="text-2xl font-extrabold text-[color:var(--on-surface)] sm:text-3xl">
										Resumen diario
									</h1>
									<p class="text-sm text-[color:var(--on-surface-variant)]">
										{organizationName} - {dashboardDate}
									</p>
								</div>

								<a
									href="/calendar"
									class="btn-primary-soft inline-flex items-center gap-2 rounded-xl px-4 py-2 text-sm font-semibold no-underline transition"
								>
									<span class="material-symbols-rounded text-[1rem]">calendar_month</span>
									Ir al calendario
								</a>
							</div>
						</div>

						{
							loadError ? (
								<div class="rounded-[1.2rem] border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-700">
									{loadError}
								</div>
							) : (
								<>
									<div class="grid gap-4 md:grid-cols-3">
										{
											metrics.map((metric) => (
												<article class="rounded-[1.2rem] border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.55)]">
													<div class="flex items-start justify-between gap-3">
														<div>
															<p class="text-xs font-bold uppercase tracking-[0.16em] text-[color:var(--on-surface-variant)]">
																{metric.label}
															</p>
															<p class="mt-2 text-3xl font-extrabold leading-none text-[color:var(--on-surface)]">
																{metric.value}
															</p>
														</div>
														<span class="material-symbols-rounded rounded-xl bg-[color:var(--primary-soft)] p-2 text-[1.25rem] text-[color:var(--primary)]">
															{metric.icon}
														</span>
													</div>
													<p class="mt-3 text-sm text-[color:var(--on-surface-variant)]">
														{metric.description}
													</p>
												</article>
											))
										}
									</div>

									<div class="rounded-[1.2rem] border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.55)] sm:p-5">
										<div class="mb-4 flex items-center justify-between gap-3">
											<h2 class="text-lg font-bold text-[color:var(--on-surface)]">Proximas citas del dia</h2>
											<span class="rounded-full border border-[color:var(--shell-border)] bg-[color:var(--control-surface)] px-3 py-1 text-xs font-semibold text-[color:var(--on-surface-variant)]">
												{dashboard.upcoming_appointments.length} registro(s)
											</span>
										</div>

										{
											dashboard.upcoming_appointments.length === 0 ? (
												<div class="rounded-xl border border-dashed border-[color:var(--shell-border)] bg-[color:var(--control-surface)] px-4 py-6 text-sm text-[color:var(--on-surface-variant)]">
													No hay citas proximas para mostrar en este momento.
												</div>
											) : (
												<div class="overflow-x-auto">
													<table class="min-w-full border-collapse text-sm">
														<thead>
															<tr class="border-b border-[color:var(--shell-border)] text-left text-xs uppercase tracking-[0.12em] text-[color:var(--on-surface-variant)]">
																<th class="px-3 py-2 font-semibold">Cliente</th>
																<th class="px-3 py-2 font-semibold">Hora</th>
																<th class="px-3 py-2 font-semibold">Servicio</th>
																<th class="px-3 py-2 font-semibold">Estado</th>
															</tr>
														</thead>
														<tbody>
															{
																dashboard.upcoming_appointments.map((appointment) => (
																	<tr class="border-b border-[color:var(--shell-border)]/70 last:border-none">
																		<td class="px-3 py-3 font-semibold text-[color:var(--on-surface)]">
																			{appointment.customer_name}
																		</td>
																		<td class="px-3 py-3 text-[color:var(--on-surface-variant)]">
																			{appointment.time_start} - {appointment.time_end}
																		</td>
																		<td class="px-3 py-3 text-[color:var(--on-surface)]">
																			{appointment.service_name}
																		</td>
																		<td class="px-3 py-3">
																			<span
																				class:list={[
																					'inline-flex rounded-full border px-2.5 py-1 text-xs font-semibold',
																					getStatusTone(appointment.status),
																				]}
																			>
																				{getStatusLabel(appointment.status)}
																			</span>
																		</td>
																	</tr>
																))
															}
														</tbody>
													</table>
												</div>
											)
										}
									</div>
								</>
							)
						}
					</section>
				</main>
			</div>
		</div>
	</div>
</Layout>
