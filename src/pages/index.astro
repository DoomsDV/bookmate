---
import SideNav from '../components/SideNav.astro';
import TopBar from '../components/TopBar.astro';
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout>
	<div class="min-h-screen">
		<div
			class="app-shell grid min-h-screen overflow-hidden border border-[color:var(--shell-border)] bg-[color:var(--shell-surface)] shadow-[0_30px_80px_rgba(15,23,42,0.12)] backdrop-blur-xl"
			data-app-shell
			data-sidebar-state="expanded"
		>
			<SideNav />

			<div class="grid min-h-full grid-rows-[auto_1fr]">
				<TopBar />

				<main class="bg-[color:var(--content-surface)] px-5 py-5 sm:px-7 sm:py-7">
					<section class="grid gap-6 xl:grid-cols-[minmax(0,1.45fr)_21rem]">
						<div class="grid gap-6">
							<div
								class="relative overflow-hidden rounded-[1.85rem] bg-[image:var(--hero-gradient)] p-6 text-white shadow-[0_24px_44px_var(--hero-shadow)]"
							>
								<div class="absolute inset-y-0 right-0 w-1/2 bg-[image:var(--hero-glow)]"></div>
								<div class="relative max-w-xl">
									<p class="text-xs font-bold uppercase tracking-[0.24em] text-white/75">
										Workspace
									</p>
									<h1 class="mt-4 max-w-lg text-3xl font-extrabold leading-tight tracking-[-0.04em] sm:text-4xl">
										Una interfaz limpia donde sidebar y top bar hablan el mismo idioma.
									</h1>
									<p class="mt-4 max-w-lg text-sm leading-7 text-white/82 sm:text-base">
										El sistema ahora vive dentro de una sola shell visual: panel lateral
										integrado, cabecera interna y contenido respirando sobre la misma base.
									</p>
								</div>
							</div>

							<div class="grid gap-4 md:grid-cols-3">
								<div class="rounded-[1.5rem] border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.55)]">
									<p class="text-xs font-bold uppercase tracking-[0.2em] text-[color:var(--on-surface-variant)]/75">
										Dashboard
									</p>
									<p class="mt-3 text-lg font-semibold text-[color:var(--on-surface)]">Vista principal</p>
									<p class="mt-2 text-sm leading-6 text-[color:var(--on-surface-variant)]">
										Bloques ligeros, bordes suaves y acentos medidos.
									</p>
								</div>
								<div class="rounded-[1.5rem] border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.55)]">
									<p class="text-xs font-bold uppercase tracking-[0.2em] text-[color:var(--on-surface-variant)]/75">
										Equipo
									</p>
									<p class="mt-3 text-lg font-semibold text-[color:var(--on-surface)]">Segundo nivel</p>
									<p class="mt-2 text-sm leading-6 text-[color:var(--on-surface-variant)]">
										El submenu mantiene continuidad con el resto del sistema.
									</p>
								</div>
								<div class="rounded-[1.5rem] border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.55)]">
									<p class="text-xs font-bold uppercase tracking-[0.2em] text-[color:var(--on-surface-variant)]/75">
										Servicios
									</p>
									<p class="mt-3 text-lg font-semibold text-[color:var(--on-surface)]">Layout unificado</p>
									<p class="mt-2 text-sm leading-6 text-[color:var(--on-surface-variant)]">
										Ya no hay sensacion de piezas separadas ni barras flotantes.
									</p>
								</div>
							</div>

							<div class="rounded-[1.7rem] border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.55)]">
								<p class="text-sm font-semibold text-[color:var(--on-surface)]">Contenido central</p>
								<p class="mt-3 max-w-3xl text-sm leading-7 text-[color:var(--on-surface-variant)]">
									Esta zona queda lista para insertar tus vistas reales. El objetivo del
									cambio fue construir una shell consistente, elegante y cohesionada, sin
									repetir la maqueta de referencia de forma literal.
								</p>
							</div>
						</div>

						<aside class="grid gap-6">
							<div class="rounded-[1.7rem] border border-[color:var(--shell-border)] bg-[color:var(--card-surface-strong)] p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.55)]">
								<p class="text-xs font-bold uppercase tracking-[0.22em] text-[color:var(--on-surface-variant)]/75">
									Sincronia visual
								</p>
								<p class="mt-4 text-lg font-semibold text-[color:var(--on-surface)]">
									Top bar y side nav comparten la misma familia visual.
								</p>
								<p class="mt-3 text-sm leading-7 text-[color:var(--on-surface-variant)]">
									Mismo borde, mismos radios, mismo tipo de relieve y una jerarquia de color
									controlada.
								</p>
							</div>

							<div class="rounded-[1.7rem] border border-[color:var(--shell-border)] bg-[color:var(--card-surface-strong)] p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.55)]">
								<p class="text-xs font-bold uppercase tracking-[0.22em] text-[color:var(--on-surface-variant)]/75">
									Interaccion
								</p>
								<p class="mt-4 text-sm leading-7 text-[color:var(--on-surface-variant)]">
									En movil el sidebar aparece como drawer. En desktop queda integrado como
									columna fija dentro de la shell principal.
								</p>
							</div>
						</aside>
					</section>
				</main>
			</div>
		</div>
	</div>
</Layout>
