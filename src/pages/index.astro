---
import SideNav from '../components/SideNav.astro';
import TopBar from '../components/TopBar.astro';
import { DashboardApiError, getMainDashboardWithOrds, type DashboardMainData } from '../lib/dashboard';
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const token = Astro.locals.token ?? '';
const organizationName = String(Astro.locals.organizationName || 'Workspace').trim() || 'Workspace';

let dashboard: DashboardMainData = {
	kpis: {
		today_appointments: 0,
		pending_appointments: 0,
		total_customers: 0,
	},
	upcoming_appointments: [],
};
let loadError = '';

if (!token) {
	loadError = 'No hay sesion valida para consultar el dashboard.';
} else {
	try {
		dashboard = await getMainDashboardWithOrds(token);
	} catch (error) {
		loadError =
			error instanceof DashboardApiError
				? error.message
				: 'No fue posible cargar los datos del dashboard.';
	}
}

const dashboardDate = new Intl.DateTimeFormat('es-PY', {
	weekday: 'long',
	year: 'numeric',
	month: 'long',
	day: 'numeric',
}).format(new Date());

const metrics = [
	{
		label: 'Citas de hoy',
		value: dashboard.kpis.today_appointments,
		description: 'Turnos no cancelados para la jornada actual.',
		icon: 'today',
	},
	{
		label: 'Citas pendientes',
		value: dashboard.kpis.pending_appointments,
		description: 'Turnos por atender desde este momento en adelante.',
		icon: 'schedule',
	},
	{
		label: 'Clientes unicos',
		value: dashboard.kpis.total_customers,
		description: 'Cantidad acumulada de clientes con historial.',
		icon: 'groups',
	},
];

const getStatusLabel = (status: string) => {
	switch (status) {
		case 'CONFIRMADO':
			return 'Confirmado';
		case 'PENDIENTE':
			return 'Pendiente';
		case 'COMPLETADO':
			return 'Completado';
		case 'CANCELADO':
			return 'Cancelado';
		default:
			return status || 'Estado';
	}
};

const getStatusTone = (status: string) => {
	switch (status) {
		case 'CONFIRMADO':
			return 'border-emerald-200 bg-emerald-50 text-emerald-700';
		case 'PENDIENTE':
				return 'border-[color:var(--status-pending-border)] bg-[color:var(--status-pending-bg)] text-[color:var(--status-pending-text)]';
		case 'COMPLETADO':
			return 'border-sky-200 bg-sky-50 text-sky-700';
		case 'CANCELADO':
			return 'border-rose-200 bg-rose-50 text-rose-700';
		default:
			return 'border-[color:var(--shell-border)] bg-[color:var(--control-surface)] text-[color:var(--on-surface-variant)]';
	}
};
---

<Layout>
	<div class="min-h-screen w-full max-w-full overflow-x-hidden">
		<div
			class="app-shell grid min-h-screen overflow-hidden border border-(--shell-border) bg-(--shell-surface) shadow-[0_30px_80px_rgba(15,23,42,0.12)] backdrop-blur-xl"
			data-app-shell
			data-sidebar-state="expanded"
		>
			<SideNav currentPath={Astro.url.pathname} />

			<div class="grid min-h-full grid-rows-[auto_1fr]">
				<TopBar />

				<main class="w-full max-w-full overflow-x-hidden bg-(--content-surface) px-4 py-4 sm:px-6 sm:py-6">
					<section class="grid w-full max-w-full min-w-0 gap-4 sm:gap-5">
						<div class="material-region bg-(--card-surface)">
							<div class="flex flex-col justify-between gap-3 sm:flex-row sm:items-center sm:gap-4">
								<div class="grid gap-1">
									<p class="text-xs font-bold uppercase tracking-[0.2em] text-(--on-surface-variant)">
										Dashboard
									</p>
									<h1 class="text-2xl font-extrabold text-(--on-surface) sm:text-3xl">
										Resumen diario
									</h1>
									<p class="text-[0.95rem] leading-relaxed text-(--on-surface-variant)">
										{organizationName} - {dashboardDate}
									</p>
								</div>

								<a
									href="/calendar"
									class="btn-primary-soft inline-flex w-full items-center justify-center gap-2 rounded-xl px-4 py-2.5 text-sm font-semibold no-underline transition sm:w-auto"
								>
									<span class="material-symbols-rounded text-[1rem]">calendar_month</span>
									Ir al calendario
								</a>
							</div>
						</div>

						{
							loadError ? (
								<div class="rounded-[1.2rem] border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-700">
									{loadError}
								</div>
							) : (
								<>
									<div class="material-cards-grid md:grid-cols-3">
										{
											metrics.map((metric) => (
												<article class="material-data-card bg-(--card-surface)">
													<div class="flex items-start justify-between gap-3">
														<div>
															<p class="text-xs font-bold uppercase tracking-[0.16em] text-(--on-surface-variant)">
																{metric.label}
															</p>
															<p class="mt-2 text-3xl font-extrabold leading-none text-(--on-surface)">
																{metric.value}
															</p>
														</div>
														<span class="material-symbols-rounded rounded-xl bg-(--primary-soft) p-2 text-[1.25rem] text-(--primary)">
															{metric.icon}
														</span>
													</div>
													<p class="mt-auto text-sm text-(--on-surface-variant)">
														{metric.description}
													</p>
												</article>
											))
										}
									</div>

									<div class="material-region bg-(--card-surface)">
										<div class="mb-4 flex items-center justify-between gap-3">
											<h2 class="text-lg font-bold text-(--on-surface)">Proximas citas del dia</h2>
											<span class="rounded-full border border-(--shell-border) bg-(--control-surface) px-3 py-1 text-xs font-semibold text-(--on-surface-variant)">
												{dashboard.upcoming_appointments.length} registro(s)
											</span>
										</div>

										{
											dashboard.upcoming_appointments.length === 0 ? (
												<div class="rounded-xl border border-dashed border-(--shell-border) bg-(--control-surface) px-4 py-6 text-sm text-(--on-surface-variant)">
													No hay citas proximas para mostrar en este momento.
												</div>
											) : (
												<div class="w-full max-w-full overflow-x-auto overscroll-x-contain">
													<table class="w-full min-w-full border-collapse text-sm">
														<thead>
															<tr class="border-b border-(--shell-border) text-left text-xs uppercase tracking-[0.12em] text-(--on-surface-variant)">
																<th class="px-3 py-2 font-semibold">Cliente</th>
																<th class="px-3 py-2 font-semibold">Hora</th>
																<th class="px-3 py-2 font-semibold">Servicio</th>
																<th class="px-3 py-2 font-semibold">Estado</th>
															</tr>
														</thead>
														<tbody>
															{
																dashboard.upcoming_appointments.map((appointment) => (
																	<tr class="border-b border-(--shell-border)/70 last:border-none">
																		<td class="px-3 py-3 font-semibold text-(--on-surface)">
																			{appointment.customer_name}
																		</td>
																		<td class="px-3 py-3 text-(--on-surface-variant)">
																			{appointment.time_start} - {appointment.time_end}
																		</td>
																		<td class="px-3 py-3 text-(--on-surface)">
																			{appointment.service_name}
																		</td>
																		<td class="px-3 py-3">
																			<span
																				class:list={[
																					'inline-flex rounded-full border px-2.5 py-1 text-xs font-semibold',
																					getStatusTone(appointment.status),
																				]}
																			>
																				{getStatusLabel(appointment.status)}
																			</span>
																		</td>
																	</tr>
																))
															}
														</tbody>
													</table>
												</div>
											)
										}
									</div>
								</>
							)
						}
					</section>
				</main>
			</div>
		</div>
	</div>
</Layout>
