---
import AppAlert from '../../components/AppAlert.astro';
import FlashMessage from '../../components/FlashMessage.astro';
import SideNav from '../../components/SideNav.astro';
import SpecialtiesGrid from '../../components/SpecialtiesGrid.astro';
import TopBar from '../../components/TopBar.astro';
import { SpecialtiesApiError, SpecialtiesClient, type Specialty } from '../../lib/specialties';
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';

const token = Astro.locals.token ?? '';
const PAGE_SIZE = 9;
const rawPage = Number(Astro.url.searchParams.get('page') || '1');
const currentPage = Number.isInteger(rawPage) && rawPage > 0 ? rawPage : 1;

let specialties: Specialty[] = [];
let loadError = '';
let pagination = {
	current_page: currentPage,
	per_page: PAGE_SIZE,
	total_records: 0,
	total_pages: 1,
};

if (!token) {
	loadError = 'No hay sesion valida para consultar especialidades.';
} else {
	try {
		const apiClient = new SpecialtiesClient(token);
		const listResult = await apiClient.list(currentPage, PAGE_SIZE);
		specialties = listResult.data;
		pagination = listResult.meta;
	} catch (error) {
		loadError =
			error instanceof SpecialtiesApiError
				? error.message
				: 'No fue posible cargar el listado de especialidades.';
	}
}

const totalPages = Math.max(1, pagination.total_pages);
const safeCurrentPage = Math.min(Math.max(1, pagination.current_page), totalPages);
const canPrevPage = safeCurrentPage > 1;
const canNextPage = safeCurrentPage < totalPages;

const toPageHref = (page: number) => {
	const nextUrl = new URL(Astro.url);
	nextUrl.searchParams.set('page', String(page));
	nextUrl.searchParams.delete('flash_message');
	nextUrl.searchParams.delete('flash_type');
	return `${nextUrl.pathname}${nextUrl.search}`;
};

const pageWindowStart = Math.max(1, safeCurrentPage - 1);
const pageWindowEnd = Math.min(totalPages, safeCurrentPage + 1);
const visiblePages = Array.from(
	{ length: pageWindowEnd - pageWindowStart + 1 },
	(_, index) => pageWindowStart + index
);
---

<Layout>
	<specialty-manager>
		<div class="min-h-screen">
			<div
				class="app-shell grid min-h-screen overflow-hidden border border-(--shell-border) bg-(--shell-surface) shadow-[0_30px_80px_rgba(15,23,42,0.12)] backdrop-blur-xl"
				data-app-shell
				data-sidebar-state="expanded"
			>
				<SideNav currentPath={Astro.url.pathname} />

				<div class="grid min-h-full grid-rows-[auto_1fr]">
					<TopBar />

					<main class="bg-(--content-surface) px-4 py-4 sm:px-6 sm:py-6">
						<section class="grid gap-4 sm:gap-5">
							{
								loadError ? (
									<FlashMessage message={loadError} type="error" expand={true} dismissible={false} />
								) : (
									<div class="grid gap-4">
										<SpecialtiesGrid specialties={specialties} showCreateAction={true} />

										<div class="material-inline-panel flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
											<p class="text-sm text-(--on-surface-variant)">
												Pagina <span class="font-semibold text-(--on-surface)">{safeCurrentPage}</span> de
												<span class="font-semibold text-(--on-surface)"> {totalPages}</span>
												<span class="mx-2">-</span>
												Total de
												<span class="font-semibold text-(--on-surface)">
													{` ${pagination.total_records} `}
												</span>
												especialidades
											</p>

											<nav class="flex items-center gap-2" aria-label="Paginacion especialidades">
												{
													canPrevPage ? (
														<a
															href={toPageHref(safeCurrentPage - 1)}
															class="rounded-lg border border-(--shell-border) px-3 py-1.5 text-sm font-semibold text-(--on-surface) no-underline transition hover:bg-(--control-surface)"
														>
															Anterior
														</a>
													) : (
														<span class="cursor-not-allowed rounded-lg border border-(--shell-border) px-3 py-1.5 text-sm font-semibold text-(--on-surface-variant)/60">
															Anterior
														</span>
													)
												}

												{
													visiblePages.map((page) =>
														page === safeCurrentPage ? (
															<span class="rounded-lg border border-(--primary-container) bg-(--primary-soft) px-3 py-1.5 text-sm font-bold text-(--primary)">
																{page}
															</span>
														) : (
															<a
																href={toPageHref(page)}
																class="rounded-lg border border-(--shell-border) px-3 py-1.5 text-sm font-semibold text-(--on-surface) no-underline transition hover:bg-(--control-surface)"
															>
																{page}
															</a>
														)
													)
												}

												{
													canNextPage ? (
														<a
															href={toPageHref(safeCurrentPage + 1)}
															class="rounded-lg border border-(--shell-border) px-3 py-1.5 text-sm font-semibold text-(--on-surface) no-underline transition hover:bg-(--control-surface)"
														>
															Siguiente
														</a>
													) : (
														<span class="cursor-not-allowed rounded-lg border border-(--shell-border) px-3 py-1.5 text-sm font-semibold text-(--on-surface-variant)/60">
															Siguiente
														</span>
													)
												}
											</nav>
										</div>
									</div>
								)
							}
						</section>
					</main>
				</div>
			</div>
		</div>

		<dialog
			class="m-0 mt-auto mb-0 w-screen max-w-none sm:m-auto sm:w-[min(48rem,calc(100vw-2rem))] sm:max-w-[min(48rem,calc(100vw-2rem))] open:flex open:flex-col max-h-[80vh] sm:max-h-[90vh] overflow-hidden rounded-t-[1.8rem] rounded-b-none sm:rounded-[1.8rem] border border-(--shell-border) bg-(--surface-bright) p-0 text-(--on-surface) shadow-[0_24px_80px_rgba(0,0,0,0.2)]"
			data-specialty-modal
		>
			<div
				class="shrink-0 z-10 shadow-sm border-b border-(--shell-border) bg-(--surface-bright) px-4 py-3 sm:px-7 sm:py-6"
			>
				<div class="flex items-start justify-between gap-4">
					<div class="flex items-center gap-4">
						<div
							class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-(--primary-soft) text-(--primary)"
						>
							<span class="material-symbols-rounded text-[1.4rem]"
								>workspace_premium</span
							>
						</div>
						<div>
							<h2
								class="text-[1.2rem] font-extrabold tracking-tight text-(--on-surface)"
								data-specialty-modal-title
							>
								Crear especialidad
							</h2>
							<p
								class="text-[0.9rem] font-medium text-(--on-surface-variant) mt-0.5 hidden sm:block"
								data-specialty-modal-description
							>
								Completa los campos para registrar una nueva especialidad.
							</p>
						</div>
					</div>
					<button
						type="button"
						class="flex size-9 shrink-0 items-center justify-center rounded-full text-(--on-surface-variant) transition-colors hover:bg-(--surface-variant) hover:text-(--on-surface) focus:outline-none focus:ring-2 focus:ring-(--primary)"
						data-close-specialty-modal
						aria-label="Cerrar modal"
					>
						<span class="material-symbols-rounded text-[1.3rem]">close</span>
					</button>
				</div>
			</div>

			<form
				class="relative flex flex-col bg-(--surface)/30 overflow-y-auto overscroll-contain min-h-0 shadow-[inset_0_4px_10px_rgba(0,0,0,0.015)]"
				data-specialty-form
			>
				<div
					class="pointer-events-none absolute inset-0 z-10 hidden items-center justify-center bg-(--surface-bright)/80 backdrop-blur-[2px] transition-all"
					data-specialty-loading
				>
					<div class="inline-flex items-center gap-3 rounded-2xl border border-(--shell-border) bg-(--surface-bright) px-5 py-3.5 text-[0.95rem] font-extrabold text-(--on-surface) shadow-[0_12px_32px_rgba(0,0,0,0.12)]">
						<span class="material-symbols-rounded animate-spin text-[1.2rem] text-(--primary)">progress_activity</span>
						Procesando...
					</div>
				</div>

				<div class="flex-1 px-7 py-7 grid gap-5">
					<div class="hidden rounded-2xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-[0.9rem] font-bold text-rose-500 shadow-sm" data-form-error></div>

					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span class="inline-flex items-center gap-1">
							Nombre
							<span class="text-rose-500">*</span>
						</span>
						<input
							type="text"
							name="name"
							maxlength="100"
							required
							class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
							placeholder="Ej: Colorimetría"
						/>
						<span class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400" data-field-error="name"></span>
					</label>

					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span class="inline-flex items-center gap-1">
							Descripción <span class="text-(--on-surface-variant) font-medium">(Opcional)</span>
						</span>
						<textarea
							name="description"
							maxlength="255"
							rows="3"
							class="resize-y rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
							placeholder="Describe brevemente la especialidad"
						></textarea>
						<span class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400" data-field-error="description"></span>
					</label>

					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)" data-specialty-status-wrap hidden>
						Estado
						<div class="relative">
							<select
								name="is_active"
								class="w-full appearance-none rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 font-bold text-(--on-surface) cursor-pointer"
							>
								<option value="1">Activa (Visible para todos)</option>
								<option value="0">Inactiva (Oculta temporalmente)</option>
							</select>
							<span class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-(--on-surface-variant) flex items-center">
								<span class="material-symbols-rounded text-[1.2rem]">expand_more</span>
							</span>
						</div>
						<span class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400" data-field-error="is_active"></span>
					</label>
				</div>

				<div class="sticky bottom-0 z-20 mt-auto flex flex-col-reverse sm:flex-row shrink-0 sm:items-center gap-3 border-t border-(--shell-border) bg-(--surface-bright) px-7 py-5">
					<button type="button" class="hidden items-center justify-center w-full sm:w-auto sm:mr-auto rounded-2xl border border-rose-500/20 bg-rose-500/10 px-5 py-3 text-[0.95rem] font-extrabold text-rose-500 transition hover:bg-rose-500/20 hover:border-rose-500/30 disabled:opacity-50 disabled:pointer-events-none" data-delete-specialty>
						<span class="material-symbols-rounded mr-1.5 align-[-0.22em] text-[1.15rem]">delete</span>
						Eliminar
					</button>
					<button type="button" class="w-full sm:w-auto rounded-2xl border border-transparent px-5 py-3 text-[0.95rem] font-extrabold text-(--on-surface-variant) transition hover:bg-(--surface-variant) hover:text-(--on-surface) focus:outline-none focus:ring-2 focus:ring-(--shell-border) hidden sm:block" data-close-specialty-modal>
						Cancelar
					</button>
					<button type="submit" class="btn-primary-soft w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-2xl px-6 py-3 text-[0.95rem] font-extrabold transition shadow-sm hover:shadow-md focus:outline-none focus:ring-2 focus:ring-(--primary) focus:ring-offset-2 focus:ring-offset-(--surface-bright) disabled:opacity-60 disabled:pointer-events-none" data-submit-specialty>
						<span class="material-symbols-rounded text-[1.2rem] hidden sm:inline" data-submit-specialty-icon>check</span>
						<span data-submit-specialty-label>Crear especialidad</span>
					</button>
				</div>
			</form>
		</dialog>
	</specialty-manager>

	<AppAlert />
</Layout>

<script>
	import { navigate } from 'astro:transitions/client';

	type SpecialtyMode = 'create' | 'edit';
	type SpecialtySubmitPayload = {
		name: string;
		description?: string;
		is_active: 0 | 1;
	};

	type SpecialtyFormValues = {
		name?: string | null;
		description?: string | null;
		is_active?: number | null;
	};

	class SpecialtyManager extends HTMLElement {
		private els = {
			modal: null as HTMLDialogElement | null,
			form: null as HTMLFormElement | null,
			submitBtn: null as HTMLButtonElement | null,
			submitLabel: null as HTMLElement | null,
			submitIcon: null as HTMLElement | null,
			deleteBtn: null as HTMLButtonElement | null,
			errorBox: null as HTMLElement | null,
			loading: null as HTMLElement | null,
			modalTitle: null as HTMLElement | null,
			modalDesc: null as HTMLElement | null,
			statusWrap: null as HTMLElement | null,
		};

		private formEls = {
			name: null as HTMLInputElement | null,
			description: null as HTMLTextAreaElement | null,
			status: null as HTMLSelectElement | null,
			fields: [] as (HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement)[],
			fieldErrors: [] as HTMLElement[],
		};

		private bound = false;
		private closeTimer: number | null = null;
		private mode: SpecialtyMode = 'create';
		private editingSpecialtyId = 0;
		private requestSeq = 0;

		constructor() {
			super();
			this.els = {
				modal: this.querySelector<HTMLDialogElement>('[data-specialty-modal]'),
				form: this.querySelector<HTMLFormElement>('[data-specialty-form]'),
				submitBtn: this.querySelector<HTMLButtonElement>('[data-submit-specialty]'),
				submitLabel: this.querySelector<HTMLElement>('[data-submit-specialty-label]'),
				submitIcon: this.querySelector<HTMLElement>('[data-submit-specialty-icon]'),
				deleteBtn: this.querySelector<HTMLButtonElement>('[data-delete-specialty]'),
				errorBox: this.querySelector<HTMLElement>('[data-form-error]'),
				loading: this.querySelector<HTMLElement>('[data-specialty-loading]'),
				modalTitle: this.querySelector<HTMLElement>('[data-specialty-modal-title]'),
				modalDesc: this.querySelector<HTMLElement>('[data-specialty-modal-description]'),
				statusWrap: this.querySelector<HTMLElement>('[data-specialty-status-wrap]'),
			};

			const formNode = this.els.form;
			this.formEls = {
				name: formNode?.querySelector<HTMLInputElement>('[name="name"]') || null,
				description: formNode?.querySelector<HTMLTextAreaElement>('[name="description"]') || null,
				status: formNode?.querySelector<HTMLSelectElement>('[name="is_active"]') || null,
				fields: formNode
					? Array.from(formNode.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>('input, select, textarea'))
					: [],
				fieldErrors: Array.from(this.querySelectorAll<HTMLElement>('[data-field-error]')),
			};
		}

		connectedCallback() {
			if (this.bound) return;
			this.bound = true;
			this.cleanFlashUrl();
			this.addEventListener('click', this.handleRootClick);
			this.addEventListener('keydown', this.handleRootKeydown);
			this.els.form?.addEventListener('submit', this.handleSubmit);
		}

		disconnectedCallback() {
			this.bound = false;
			this.removeEventListener('click', this.handleRootClick);
			this.removeEventListener('keydown', this.handleRootKeydown);
			this.els.form?.removeEventListener('submit', this.handleSubmit);
			if (this.closeTimer) {
				window.clearTimeout(this.closeTimer);
				this.closeTimer = null;
			}
		}

		private cleanFlashUrl() {
			const currentUrl = new URL(window.location.href);
			if (!currentUrl.searchParams.has('flash_message')) return;
			currentUrl.searchParams.delete('flash_message');
			currentUrl.searchParams.delete('flash_type');
			window.history.replaceState({}, '', `${currentUrl.pathname}${currentUrl.search}${currentUrl.hash}`);
		}

		private navigateWithFlash(message: string, type = 'success') {
			const nextUrl = new URL(window.location.href);
			nextUrl.searchParams.set('flash_message', message);
			nextUrl.searchParams.set('flash_type', type);
			void navigate(`${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`);
		}

		private clearErrors() {
			if (this.els.errorBox) {
				this.els.errorBox.textContent = '';
				this.els.errorBox.classList.add('hidden');
			}
			for (const node of this.formEls.fieldErrors) {
				node.textContent = '';
				node.classList.add('hidden');
			}
		}

		private showFormError(message: string) {
			if (!this.els.errorBox) return;
			this.els.errorBox.textContent = message;
			this.els.errorBox.classList.remove('hidden');
		}

		private updateUIMode(mode: SpecialtyMode) {
			this.mode = mode;
			const isEdit = mode === 'edit';

			if (this.els.modalTitle) {
				this.els.modalTitle.textContent = isEdit ? 'Editar especialidad' : 'Crear especialidad';
			}
			if (this.els.modalDesc) {
				this.els.modalDesc.textContent = isEdit
					? 'Actualiza la información de la especialidad.'
					: 'Completa los campos para registrar una nueva especialidad.';
			}

			if (this.els.submitLabel) {
				this.els.submitLabel.textContent = isEdit ? 'Guardar cambios' : 'Crear especialidad';
			}
			if (this.els.submitIcon) {
				this.els.submitIcon.textContent = isEdit ? 'save' : 'check';
			}

			if (this.els.deleteBtn) {
				if (isEdit) {
					this.els.deleteBtn.classList.remove('hidden');
					this.els.deleteBtn.classList.add('inline-flex');
					this.els.deleteBtn.removeAttribute('disabled');
				} else {
					this.els.deleteBtn.classList.remove('inline-flex');
					this.els.deleteBtn.classList.add('hidden');
					this.els.deleteBtn.setAttribute('disabled', 'true');
				}
			}

			if (this.els.statusWrap) {
				if (isEdit) {
					this.els.statusWrap.removeAttribute('hidden');
				} else {
					this.els.statusWrap.setAttribute('hidden', '');
				}
			}

			if (this.formEls.status) {
				if (isEdit) {
					this.formEls.status.disabled = false;
				} else {
					this.formEls.status.value = '1';
					this.formEls.status.disabled = true;
				}
			}

			if (!isEdit) {
				this.editingSpecialtyId = 0;
				this.els.loading?.classList.add('hidden');
			}
		}

		private toggleFormLoading(isLoading: boolean) {
			if (this.els.loading) {
				isLoading
					? this.els.loading.classList.replace('hidden', 'flex')
					: this.els.loading.classList.replace('flex', 'hidden');
			}

			for (const field of this.formEls.fields) {
				field.disabled = isLoading;
			}

			if (!isLoading && this.mode === 'create' && this.formEls.status) {
				this.formEls.status.value = '1';
				this.formEls.status.disabled = true;
			}
		}

		private setLoadingMode(label = 'Procesando...') {
			if (this.els.submitBtn) this.els.submitBtn.disabled = true;
			if (this.els.deleteBtn && this.mode === 'edit') this.els.deleteBtn.disabled = true;
			if (this.els.submitLabel) this.els.submitLabel.textContent = label;
			if (this.els.submitIcon) this.els.submitIcon.textContent = 'hourglass_top';
		}

		private restoreButtons() {
			if (this.els.submitBtn) this.els.submitBtn.disabled = false;
			const isEdit = this.mode === 'edit';
			if (this.els.submitLabel) {
				this.els.submitLabel.textContent = isEdit ? 'Guardar cambios' : 'Crear especialidad';
			}
			if (this.els.submitIcon) {
				this.els.submitIcon.textContent = isEdit ? 'save' : 'check';
			}
			if (this.els.deleteBtn && isEdit) {
				this.els.deleteBtn.disabled = false;
			}
		}

		private openModalShell() {
			this.els.modal?.classList.remove('is-closing');
			this.els.modal?.removeAttribute('data-bottom-sheet-swipe-dismiss');
			if (this.closeTimer) {
				window.clearTimeout(this.closeTimer);
				this.closeTimer = null;
			}
			if (!this.els.modal?.open) this.els.modal?.showModal();
		}

		private closeModal() {
			if (!this.els.modal?.open) return;
			this.requestSeq++;
			const swipeDismiss =
				this.els.modal.hasAttribute('data-bottom-sheet-swipe-dismiss');
			this.els.modal.classList.add('is-closing');

			if (swipeDismiss) {
				this.els.modal.close();
				this.els.modal.classList.remove('is-closing');
				this.els.modal.removeAttribute('data-bottom-sheet-swipe-dismiss');
				this.closeTimer = window.setTimeout(() => {
					this.els.form?.reset();
					this.updateUIMode('create');
					this.toggleFormLoading(false);
					this.clearErrors();
					this.closeTimer = null;
				}, 0);
				return;
			}

			this.closeTimer = window.setTimeout(() => {
				this.els.modal?.close();
				this.els.modal?.classList.remove('is-closing');
				this.els.modal?.removeAttribute('data-bottom-sheet-swipe-dismiss');
				this.els.form?.reset();
				this.updateUIMode('create');
				this.toggleFormLoading(false);
				this.clearErrors();
				this.closeTimer = null;
			}, 160);
		}

		private openCreateModal() {
			this.updateUIMode('create');
			this.resetFormValues();
			this.toggleFormLoading(false);
			this.clearErrors();
			this.openModalShell();
		}

		private fillFormWithSpecialty(specialty: SpecialtyFormValues) {
			if (this.formEls.name) this.formEls.name.value = String(specialty?.name || '');
			if (this.formEls.description) this.formEls.description.value = String(specialty?.description || '');
			if (this.formEls.status) {
				this.formEls.status.value = String(specialty?.is_active === 0 ? 0 : 1);
			}
		}

		private resetFormValues() {
			if (this.formEls.name) this.formEls.name.value = '';
			if (this.formEls.description) this.formEls.description.value = '';
			if (this.formEls.status) this.formEls.status.value = '1';
		}

		private async parseJson(response: Response) {
			try {
				return await response.json();
			} catch {
				throw new Error('No fue posible interpretar la respuesta del servidor.');
			}
		}

		private async openEditModal(specialtyId: number) {
			if (!specialtyId) return;
			const reqId = ++this.requestSeq;
			this.updateUIMode('edit');
			this.editingSpecialtyId = specialtyId;
			this.resetFormValues();
			this.clearErrors();
			this.openModalShell();
			this.toggleFormLoading(true);
			this.setLoadingMode('Cargando...');

			try {
				const response = await fetch(`/api/specialties/${specialtyId}`, {
					method: 'GET',
					headers: { Accept: 'application/json' },
				});

				const data = await this.parseJson(response);
				if (!response.ok || !data || data.status !== 'success' || !data.data) {
					throw new Error(data?.message || 'No fue posible obtener la especialidad seleccionada.');
				}

				if (reqId !== this.requestSeq) return;
				this.fillFormWithSpecialty(data.data);
			} catch (error) {
				if (reqId !== this.requestSeq) return;
				this.updateUIMode('create');
				this.showFormError(error instanceof Error ? error.message : 'No fue posible obtener la especialidad.');
			} finally {
				if (reqId !== this.requestSeq) return;
				this.toggleFormLoading(false);
				this.restoreButtons();
			}
		}

		private handleRootClick = (event: MouseEvent) => {
			const target = event.target;
			if (!(target instanceof Element)) return;

			if (this.els.modal && target === this.els.modal) {
				this.closeModal();
				return;
			}

			const closeTrigger = target.closest('[data-close-specialty-modal]');
			if (closeTrigger && this.contains(closeTrigger)) {
				this.closeModal();
				return;
			}

			const deleteTrigger = target.closest('[data-delete-specialty]');
			if (deleteTrigger && this.contains(deleteTrigger)) {
				void this.handleDelete();
				return;
			}

			const openTrigger = target.closest('[data-open-specialty-modal], [data-specialty-card]');
			if (!openTrigger || !this.contains(openTrigger)) return;

			const card = openTrigger.closest('[data-specialty-card]');
			if (card) {
				const specialtyId = Number(card.getAttribute('data-specialty-id') || '0');
				if (specialtyId > 0) {
					void this.openEditModal(specialtyId);
				}
				return;
			}

			this.openCreateModal();
		};

		private handleRootKeydown = (event: KeyboardEvent) => {
			if (event.key !== 'Enter' && event.key !== ' ') return;
			const target = event.target;
			if (!(target instanceof Element)) return;
			const card = target.closest('[data-specialty-card]');
			if (!card || !this.contains(card)) return;
			event.preventDefault();
			const specialtyId = Number(card.getAttribute('data-specialty-id') || '0');
			if (specialtyId > 0) {
				void this.openEditModal(specialtyId);
			}
		};

		private handleSubmit = async (event: SubmitEvent) => {
			event.preventDefault();
			this.clearErrors();

			if (!this.els.form) return;
			const formData = new FormData(this.els.form);

			const name = String(formData.get('name') || '').trim();
			const description = String(formData.get('description') || '').trim();
			const isActiveRaw = String(formData.get('is_active') || '1').trim();

			if (!name) {
				this.showFormError('Completa los campos requeridos antes de continuar.');
				return;
			}

			const payload: SpecialtySubmitPayload = {
				name,
				is_active: isActiveRaw === '0' ? 0 : 1,
			};
			if (description) payload.description = description;

			const endpoint =
				this.mode === 'edit' && this.editingSpecialtyId
					? `/api/specialties/${this.editingSpecialtyId}`
					: '/api/specialties';
			const httpMethod = this.mode === 'edit' && this.editingSpecialtyId ? 'PUT' : 'POST';
			this.setLoadingMode(this.mode === 'edit' ? 'Guardando...' : 'Creando...');

			try {
				const response = await fetch(endpoint, {
					method: httpMethod,
					headers: {
						'Content-Type': 'application/json',
						Accept: 'application/json',
					},
					body: JSON.stringify(payload),
				});

				const data = await this.parseJson(response);
				if (!response.ok || !data || data.status !== 'success') {
					const message =
						typeof data?.message === 'string'
							? data.message
							: 'No fue posible guardar la especialidad.';
					this.showFormError(message);

					const fieldErrors = Array.isArray(data?.errors) ? data.errors : [];
					for (const error of fieldErrors) {
						if (!error || typeof error !== 'object') continue;
						const field = 'field' in error ? String(error.field || '') : '';
						const messageText = 'message' in error ? String(error.message || '') : '';
						if (!field || !messageText) continue;

						const fieldNode = this.querySelector<HTMLElement>(`[data-field-error="${field}"]`);
						if (fieldNode) {
							fieldNode.textContent = messageText;
							fieldNode.classList.remove('hidden');
						}
					}

					return;
				}

				const successMessage =
					typeof data?.message === 'string' && data.message.trim()
						? data.message
						: this.mode === 'edit'
							? 'Especialidad actualizada correctamente.'
							: 'Especialidad creada correctamente.';

				this.closeModal();
				this.navigateWithFlash(successMessage, 'success');
			} catch (error) {
				const message = error instanceof Error ? error.message : 'No fue posible guardar la especialidad.';
				this.showFormError(message);
			} finally {
				this.restoreButtons();
			}
		};

		private async handleDelete() {
			if (!this.editingSpecialtyId || this.mode !== 'edit') return;

			const confirmed = await (window as any).BookmateAlert?.confirm?.({
				type: 'error',
				title: 'Eliminar especialidad',
				message: 'Esta acción eliminará la especialidad de forma permanente. ¿Deseas continuar?',
				confirmText: 'Eliminar',
				cancelText: 'Cancelar',
			});
			if (!confirmed) return;

			this.clearErrors();
			this.setLoadingMode('Eliminando...');

			try {
				const response = await fetch(`/api/specialties/${this.editingSpecialtyId}`, {
					method: 'DELETE',
					headers: { Accept: 'application/json' },
				});

				const data = await this.parseJson(response);
				if (!response.ok || !data || data.status !== 'success') {
					throw new Error(data?.message || 'No fue posible eliminar la especialidad.');
				}

				const successMessage =
					typeof data?.message === 'string' && data.message.trim()
						? data.message
						: 'Especialidad eliminada correctamente.';

				this.closeModal();
				this.navigateWithFlash(successMessage, 'success');
			} catch (error) {
				this.showFormError(
					error instanceof Error ? error.message : 'No fue posible eliminar la especialidad.'
				);
				this.restoreButtons();
			}
		}
	}

	if (!customElements.get('specialty-manager')) {
		customElements.define('specialty-manager', SpecialtyManager);
	}
</script>

<style is:global>
	specialty-manager {
		display: block;
	}

	dialog[data-specialty-modal] {
		position: fixed;
		inset: 0;
		animation: specialty-modal-in 180ms ease-out;
	}

	dialog[data-specialty-modal]::backdrop {
		animation: specialty-backdrop-in 180ms ease-out;
	}

	dialog[data-specialty-modal].is-closing {
		animation: specialty-modal-out 160ms ease-in forwards;
	}

	dialog[data-specialty-modal].is-closing::backdrop {
		animation: specialty-backdrop-out 160ms ease-in forwards;
	}

	@keyframes specialty-modal-in {
		from {
			opacity: 0;
			transform: translateY(100%);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes specialty-modal-out {
		from {
			opacity: 1;
			transform: translateY(0);
		}

		to {
			opacity: 0;
			transform: translateY(100%);
		}
	}

	@media (min-width: 640px) {
		@keyframes specialty-modal-in {
			from {
				opacity: 0;
				transform: translateY(10px) scale(0.98);
			}

			to {
				opacity: 1;
				transform: translateY(0) scale(1);
			}
		}

		@keyframes specialty-modal-out {
			from {
				opacity: 1;
				transform: translateY(0) scale(1);
			}

			to {
				opacity: 0;
				transform: translateY(8px) scale(0.98);
			}
		}
	}

	@keyframes specialty-backdrop-in {
		from {
			opacity: 0;
		}

		to {
			opacity: 1;
		}
	}

	@keyframes specialty-backdrop-out {
		from {
			opacity: 1;
		}

		to {
			opacity: 0;
		}
	}
</style>


