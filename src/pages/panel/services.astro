---
import AppAlert from "../../components/AppAlert.astro";
import FlashMessage from "../../components/FlashMessage.astro";
import ServicesGrid from "../../components/ServicesGrid.astro";
import SideNav from "../../components/SideNav.astro";
import TopBar from "../../components/TopBar.astro";
import {
	ServicesApiError,
	ServicesClient,
	type Service,
} from "../../lib/services";
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";

const token = Astro.locals.token ?? "";
const PAGE_SIZE = 9;
const rawPage = Number(Astro.url.searchParams.get("page") || "1");
const currentPage = Number.isInteger(rawPage) && rawPage > 0 ? rawPage : 1;

let services: Service[] = [];
let loadError = "";
let pagination = {
	current_page: currentPage,
	per_page: PAGE_SIZE,
	total_records: 0,
	total_pages: 1,
};

if (!token) {
	loadError = "No hay sesion valida para consultar servicios.";
} else {
	try {
		const apiClient = new ServicesClient(token);
		const listResult = await apiClient.list(currentPage, PAGE_SIZE);
		services = listResult.data;
		pagination = listResult.meta;
	} catch (error) {
		loadError =
			error instanceof ServicesApiError
				? error.message
				: "No fue posible cargar el listado de servicios.";
	}
}

const totalPages = Math.max(1, pagination.total_pages);
const safeCurrentPage = Math.min(
	Math.max(1, pagination.current_page),
	totalPages,
);
const canPrevPage = safeCurrentPage > 1;
const canNextPage = safeCurrentPage < totalPages;

const toPageHref = (page: number) => {
	const nextUrl = new URL(Astro.url);
	nextUrl.searchParams.set("page", String(page));
	nextUrl.searchParams.delete("flash_message");
	nextUrl.searchParams.delete("flash_type");
	return `${nextUrl.pathname}${nextUrl.search}`;
};

const pageWindowStart = Math.max(1, safeCurrentPage - 1);
const pageWindowEnd = Math.min(totalPages, safeCurrentPage + 1);
const visiblePages = Array.from(
	{ length: pageWindowEnd - pageWindowStart + 1 },
	(_, index) => pageWindowStart + index,
);
---

<Layout>
	<service-manager>
		<div class="min-h-screen bg-[#EEF1F5] dark:bg-(--page-background) transition-colors duration-300">
			<div
				class="app-shell grid min-h-screen overflow-hidden bg-transparent"
				data-app-shell
				data-sidebar-state="expanded"
			>
				<SideNav currentPath={Astro.url.pathname} />

				<div class="grid min-h-full grid-rows-[auto_1fr]">
					<TopBar />

					<main class="px-4 py-4 sm:px-6 sm:py-6">
						<section class="grid gap-4 sm:gap-5">
							{
								loadError ? (
									<FlashMessage
										message={loadError}
										type="error"
										expand={true}
										dismissible={false}
									/>
								) : (
									<div class="grid gap-4">
										<ServicesGrid
											services={services}
											showCreateAction={true}
										/>

										<div class="flex flex-col gap-3 rounded-[1.35rem] bg-white/88 dark:bg-(--surface-container-low) px-4 py-3 shadow-[0_10px_28px_rgba(15,23,42,0.08)] dark:shadow-none backdrop-blur sm:flex-row sm:items-center sm:justify-between transition-colors duration-300">
											<p class="text-sm text-(--on-surface-variant)">
												Pagina{" "}
												<span class="font-semibold text-(--on-surface)">
													{safeCurrentPage}
												</span>{" "}
												de
												<span class="font-semibold text-(--on-surface)">
													{" "}
													{totalPages}
												</span>
												<span class="mx-2">-</span>
												Total de
												<span class="font-semibold text-(--on-surface)">
													{` ${pagination.total_records} `}
												</span>
												servicios
											</p>

											<nav
												class="flex items-center gap-2"
												aria-label="Paginacion servicios"
											>
												{canPrevPage ? (
													<a
														href={toPageHref(
															safeCurrentPage - 1,
														)}
														class="rounded-full bg-[#E8EAED] dark:bg-(--surface-container) px-3.5 py-1.5 text-sm font-semibold text-(--on-surface) no-underline transition hover:bg-[#DCE1E7] dark:hover:bg-(--surface-container-high)"
													>
														Anterior
													</a>
												) : (
													<span class="cursor-not-allowed rounded-full bg-[#EEF1F5] dark:bg-(--surface-container) px-3.5 py-1.5 text-sm font-semibold text-(--on-surface-variant)/65">
														Anterior
													</span>
												)}

												{visiblePages.map((page) =>
													page === safeCurrentPage ? (
														<span class="rounded-full bg-[#1967D2] dark:bg-[#8AB4F8]/25 px-3.5 py-1.5 text-sm font-bold text-white dark:text-[#A8C7FA] shadow-[0_6px_14px_rgba(25,103,210,0.24)] dark:shadow-none">
															{page}
														</span>
													) : (
														<a
															href={toPageHref(
																page,
															)}
															class="rounded-full bg-[#E8EAED] dark:bg-(--surface-container) px-3.5 py-1.5 text-sm font-semibold text-(--on-surface) no-underline transition hover:bg-[#DCE1E7] dark:hover:bg-(--surface-container-high)"
														>
															{page}
														</a>
													),
												)}

												{canNextPage ? (
													<a
														href={toPageHref(
															safeCurrentPage + 1,
														)}
														class="rounded-full bg-[#E8EAED] dark:bg-(--surface-container) px-3.5 py-1.5 text-sm font-semibold text-(--on-surface) no-underline transition hover:bg-[#DCE1E7] dark:hover:bg-(--surface-container-high)"
													>
														Siguiente
													</a>
												) : (
													<span class="cursor-not-allowed rounded-full bg-[#EEF1F5] dark:bg-(--surface-container) px-3.5 py-1.5 text-sm font-semibold text-(--on-surface-variant)/65">
														Siguiente
													</span>
												)}
											</nav>
										</div>
									</div>
								)
							}
						</section>
					</main>
				</div>
			</div>
		</div>

		<dialog
			class="m-0 mt-auto mb-0 w-screen max-w-none sm:m-auto sm:w-[min(48rem,calc(100vw-2rem))] sm:max-w-[min(48rem,calc(100vw-2rem))] open:flex open:flex-col max-h-[80vh] sm:max-h-[90vh] overflow-hidden rounded-t-[1.8rem] rounded-b-none sm:rounded-[1.8rem] border border-(--shell-border) bg-(--surface-bright) p-0 text-(--on-surface) shadow-[0_24px_80px_rgba(0,0,0,0.2)]"
			data-service-modal
		>

			<div
				class="shrink-0 z-10 shadow-sm border-b border-(--shell-border) bg-(--surface-bright) px-4 py-3 sm:px-7 sm:py-6"
			>
				<div class="flex items-start justify-between gap-4">
					<div class="flex items-center gap-4">
						<div
							class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-(--primary-soft) text-(--primary)"
						>
							<span class="material-symbols-rounded text-[1.4rem]"
								>design_services</span
							>
						</div>
						<div>
							<h2
								class="text-[1.2rem] font-extrabold tracking-tight text-(--on-surface)"
								data-service-modal-title
							>
								Crear servicio
							</h2>
							<p
								class="text-[0.9rem] font-medium text-(--on-surface-variant) mt-0.5 hidden sm:block"
								data-service-modal-description
							>
								Completa los campos para registrar un nuevo
								servicio.
							</p>
						</div>
					</div>
					<button
						type="button"
						class="flex size-9 shrink-0 items-center justify-center rounded-full text-(--on-surface-variant) transition-colors hover:bg-(--surface-variant) hover:text-(--on-surface) focus:outline-none focus:ring-2 focus:ring-(--primary)"
						data-close-service-modal
						aria-label="Cerrar modal"
					>
						<span class="material-symbols-rounded text-[1.3rem]">close</span>
					</button>
				</div>
			</div>

			<form
				class="relative flex flex-col bg-(--surface)/30 overflow-y-auto overscroll-contain min-h-0 shadow-[inset_0_4px_10px_rgba(0,0,0,0.015)]"
				data-service-create-form
			>
				<div
					class="pointer-events-none absolute inset-0 z-10 hidden items-center justify-center bg-(--surface-bright)/80 backdrop-blur-[2px] transition-all"
					data-service-loading
				>
					<div
						class="inline-flex items-center gap-3 rounded-2xl border border-(--shell-border) bg-(--surface-bright) px-5 py-3.5 text-[0.95rem] font-extrabold text-(--on-surface) shadow-[0_12px_32px_rgba(0,0,0,0.12)]"
					>
						<span
							class="material-symbols-rounded animate-spin text-[1.2rem] text-(--primary)"
							>progress_activity</span
						>
						Procesando...
					</div>
				</div>

				<fieldset data-form-fieldset class="flex flex-col min-h-0">
				<div class="px-7 py-7 grid gap-5">
				<div
					class="hidden rounded-2xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-[0.9rem] font-bold text-rose-500 shadow-sm"
					data-form-error
				>
				</div>

				<label
					class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)"
				>
					<span class="inline-flex items-center gap-1">
						Nombre
						<span class="text-rose-500">*</span>
					</span>
					<input
						type="text"
						name="name"
						maxlength="100"
						required
						class="w-full min-w-0 rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
						placeholder="Ej: Corte premium"
					/>
					<span
						class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400"
						data-field-error="name"></span>
				</label>

				<div class="grid grid-cols-2 gap-5">
					<label
						class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)"
					>
						<span class="inline-flex items-center gap-1">
							Duración <span
								class="text-(--on-surface-variant) font-medium"
								>(min)</span
							>
							<span class="text-rose-500">*</span>
						</span>
						<input
							type="number"
							name="duration_minutes"
							min="1"
							step="1"
							required
							class="w-full min-w-0 rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
							placeholder="Ej: 45"
						/>
						<span
							class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400"
							data-field-error="duration_minutes"></span>
					</label>

					<label
						class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)"
					>
						<span class="inline-flex items-center gap-1">
							Precio <span
								class="text-(--on-surface-variant) font-medium"
								>(Opcional)</span
							>
						</span>
						<input
							type="text"
							name="price"
							inputmode="numeric"
							class="w-full min-w-0 rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
							placeholder="Ej: 45.000"
							data-price-mask
						/>
						<span
							class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400"
							data-field-error="price"></span>
					</label>
				</div>

				<label
					class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)"
					data-service-status-wrap
					hidden
				>
					Estado
					<div class="relative">
						<select
							name="is_active"
							class="w-full appearance-none rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 font-bold text-(--on-surface) cursor-pointer"
						>
							<option value="1"
								>Activo (Visible para clientes)</option
							>
							<option value="0"
								>Inactivo (Oculto temporalmente)</option
							>
						</select>
						<span
							class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-(--on-surface-variant)"
						>
							<span class="material-symbols-rounded"
								>expand_more</span
							>
						</span>
					</div>
					<span
						class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400"
						data-field-error="is_active"></span>
				</label>

				</div>
				<div
					class="sticky bottom-0 z-20 mt-auto flex flex-col-reverse sm:flex-row shrink-0 sm:items-center gap-3 border-t border-(--shell-border) bg-(--surface-bright) px-7 py-5"
				>
					<button
						type="button"
						class="hidden w-full sm:w-auto sm:mr-auto rounded-2xl border border-rose-500/20 bg-rose-500/10 px-5 py-3 text-[0.95rem] font-extrabold text-rose-500 transition hover:bg-rose-500/20 hover:border-rose-500/30 disabled:opacity-50 disabled:pointer-events-none"
						data-delete-service
					>
						<span
							class="material-symbols-rounded mr-1.5 align-[-0.22em] text-[1.15rem]"
							>delete</span
						>
						Eliminar
					</button>

					<div class="w-full sm:w-auto flex flex-col sm:flex-row items-center gap-3">
						<button
							type="button"
							class="w-full sm:w-auto rounded-2xl border border-transparent px-5 py-3 text-[0.95rem] font-extrabold text-(--on-surface-variant) transition hover:bg-(--surface-variant) hover:text-(--on-surface) focus:outline-none focus:ring-2 focus:ring-(--shell-border) hidden sm:block"
							data-close-service-modal
						>
							Cancelar
						</button>
						<button
							type="submit"
							class="btn-primary-soft w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-2xl px-6 py-3 text-[0.95rem] font-extrabold transition shadow-sm hover:shadow-md focus:outline-none focus:ring-2 focus:ring-(--primary) focus:ring-offset-2 focus:ring-offset-(--surface-bright) disabled:opacity-60 disabled:pointer-events-none"
							data-submit-service
						>
							<span
								class="material-symbols-rounded text-[1.2rem] hidden sm:inline"
								data-submit-service-icon>check</span
							>
							<span data-submit-service-label>Crear servicio</span
							>
						</button>
					</div>
				</div>
				</fieldset>
			</form>
		</dialog>
	</service-manager>

	<AppAlert />
</Layout>

<script>
	import { navigate } from "astro:transitions/client";

	type ServiceMode = "create" | "edit";
	type ServiceSubmitPayload = {
		name: string;
		duration_minutes: number;
		is_active: 0 | 1;
		price?: number;
	};

	type ServiceDetail = {
		name?: string | null;
		duration_minutes?: number | null;
		price?: number | null;
		is_active?: 0 | 1 | boolean | null;
	};

	class ServiceManager extends HTMLElement {
		private abortController: AbortController | null = null;
		private closeTimer: number | null = null;
		private mode: ServiceMode = "create";
		private editingServiceId = 0;
		private requestSeq = 0;

		// Grouped DOM References
		private els!: {
			modal: HTMLDialogElement | null;
			form: HTMLFormElement | null;
			submitBtn: HTMLButtonElement | null;
			submitLabel: HTMLElement | null;
			submitIcon: HTMLElement | null;
			deleteBtn: HTMLButtonElement | null;
			errorBox: HTMLElement | null;
			loading: HTMLElement | null;
			modalTitle: HTMLElement | null;
			modalDesc: HTMLElement | null;
			statusWrap: HTMLElement | null;
			priceInput: HTMLInputElement | null;
		};

		private formEls!: {
			fieldset: HTMLFieldSetElement | null;
			name: HTMLInputElement | null;
			duration: HTMLInputElement | null;
			status: HTMLSelectElement | null;
			fieldErrors: HTMLElement[];
		};

		connectedCallback() {
			this.els = {
				modal: this.querySelector<HTMLDialogElement>(
					"[data-service-modal]",
				),
				form: this.querySelector<HTMLFormElement>(
					"[data-service-create-form]",
				),
				submitBtn: this.querySelector<HTMLButtonElement>(
					"[data-submit-service]",
				),
				submitLabel: this.querySelector<HTMLElement>(
					"[data-submit-service-label]",
				),
				submitIcon: this.querySelector<HTMLElement>(
					"[data-submit-service-icon]",
				),
				deleteBtn: this.querySelector<HTMLButtonElement>(
					"[data-delete-service]",
				),
				errorBox: this.querySelector<HTMLElement>("[data-form-error]"),
				loading: this.querySelector<HTMLElement>("[data-service-loading]"),
				modalTitle: this.querySelector<HTMLElement>(
					"[data-service-modal-title]",
				),
				modalDesc: this.querySelector<HTMLElement>(
					"[data-service-modal-description]",
				),
				statusWrap: this.querySelector<HTMLElement>(
					"[data-service-status-wrap]",
				),
				priceInput:
					this.querySelector<HTMLInputElement>("[data-price-mask]"),
			};

			this.formEls = {
				fieldset: this.els.form?.querySelector<HTMLFieldSetElement>(
					"[data-form-fieldset]"
				) || null,
				name: this.els.form?.querySelector<HTMLInputElement>(
					'[name="name"]',
				) || null,
				duration: this.els.form?.querySelector<HTMLInputElement>(
					'[name="duration_minutes"]',
				) || null,
				status: this.els.form?.querySelector<HTMLSelectElement>(
					'[name="is_active"]',
				) || null,
				fieldErrors: Array.from(
					this.querySelectorAll<HTMLElement>("[data-field-error]"),
				),
			};

			if (this.abortController) return;
			this.abortController = new AbortController();
			const { signal } = this.abortController;

			this.cleanUrlParams();
			this.addEventListener("click", this.handleRootClick, { signal });
			this.addEventListener("keydown", this.handleRootKeydown, {
				signal,
			});
			this.els.form?.addEventListener("submit", this.handleSubmit, {
				signal,
			});
			this.els.priceInput?.addEventListener(
				"input",
				this.handlePriceInput,
				{ signal },
			);
		}

		disconnectedCallback() {
			this.abortController?.abort();
			this.abortController = null;
			if (this.closeTimer) window.clearTimeout(this.closeTimer);
		}

		private cleanUrlParams() {
			const url = new URL(window.location.href);
			if (!url.searchParams.has("flash_message")) return;
			url.searchParams.delete("flash_message");
			url.searchParams.delete("flash_type");
			window.history.replaceState(
				{},
				"",
				`${url.pathname}${url.search}${url.hash}`,
			);
		}

		private navigateWithFlash(message: string, type = "success") {
			const url = new URL(window.location.href);
			url.searchParams.set("flash_message", message);
			url.searchParams.set("flash_type", type);
			void navigate(`${url.pathname}${url.search}${url.hash}`);
		}

		private clearErrors() {
			if (this.els.errorBox) {
				this.els.errorBox.textContent = "";
				this.els.errorBox.classList.add("hidden");
			}
			this.formEls.fieldErrors.forEach((node) => {
				node.textContent = "";
				node.classList.add("hidden");
			});
		}

		private showFormError(message: string) {
			if (!this.els.errorBox) return;
			this.els.errorBox.textContent = message;
			this.els.errorBox.classList.remove("hidden");
		}

		private updateUIMode(mode: ServiceMode) {
			this.mode = mode;
			const isEdit = mode === "edit";

			if (this.els.modalTitle)
				this.els.modalTitle.textContent = isEdit
					? "Editar servicio"
					: "Crear servicio";
			if (this.els.modalDesc) {
				this.els.modalDesc.textContent = isEdit
					? "Actualiza la información del servicio."
					: "Completa los campos para registrar un nuevo servicio.";
			}

			if (this.els.submitLabel)
				this.els.submitLabel.textContent = isEdit
					? "Guardar cambios"
					: "Crear servicio";
			if (this.els.submitIcon)
				this.els.submitIcon.textContent = isEdit ? "save" : "check";

			if (this.els.deleteBtn) {
				isEdit
					? this.els.deleteBtn.classList.remove("hidden")
					: this.els.deleteBtn.classList.add("hidden");
				this.els.deleteBtn.disabled = !isEdit;
			}

			if (this.els.statusWrap) {
				if (isEdit) {
					this.els.statusWrap.removeAttribute("hidden");
				} else {
					this.els.statusWrap.setAttribute("hidden", "");
				}
			}

			if (this.formEls.status) {
				if (isEdit) {
					this.formEls.status.disabled = false;
				} else {
					this.formEls.status.value = "1";
					this.formEls.status.disabled = true;
				}
			}

			if (!isEdit) {
				this.editingServiceId = 0;
				this.els.loading?.classList.add("hidden");
			}
		}

		private toggleFormLoading(isLoading: boolean) {
			if (this.els.loading) {
				isLoading
					? this.els.loading.classList.replace("hidden", "flex")
					: this.els.loading.classList.replace("flex", "hidden");
			}
			if (this.formEls.fieldset) {
				this.formEls.fieldset.disabled = isLoading;
			}
		}

		private setButtonsProcessing(label = "Procesando...") {
			if (this.els.submitBtn) this.els.submitBtn.disabled = true;
			if (this.els.deleteBtn && this.mode === "edit")
				this.els.deleteBtn.disabled = true;
			if (this.els.submitLabel) this.els.submitLabel.textContent = label;
			if (this.els.submitIcon)
				this.els.submitIcon.textContent = "hourglass_top";
		}

		private restoreButtons() {
			if (this.els.submitBtn) this.els.submitBtn.disabled = false;
			const isEdit = this.mode === "edit";
			if (this.els.submitLabel)
				this.els.submitLabel.textContent = isEdit
					? "Guardar cambios"
					: "Crear servicio";
			if (this.els.submitIcon)
				this.els.submitIcon.textContent = isEdit ? "save" : "check";
			if (this.els.deleteBtn && isEdit)
				this.els.deleteBtn.disabled = false;
		}

		private openModalShell() {
			this.els.modal?.classList.remove("is-closing");
			if (this.closeTimer) {
				window.clearTimeout(this.closeTimer);
				this.closeTimer = null;
			}
			if (!this.els.modal?.open) this.els.modal?.showModal();
		}

		private closeModal() {
			if (!this.els.modal?.open) return;
			this.requestSeq++;
			this.els.modal.classList.add("is-closing");

			this.closeTimer = window.setTimeout(() => {
				this.els.modal?.close();
				this.els.modal?.classList.remove("is-closing");
				this.els.form?.reset();
				this.updateUIMode("create");
				this.toggleFormLoading(false);
				this.clearErrors();
				this.closeTimer = null;
			}, 140);
		}
		private openCreateModal() {
			this.updateUIMode("create");
			this.resetFormValues();
			this.toggleFormLoading(false);
			this.clearErrors();
			this.openModalShell();
		}

		private formatPrice(val: string | number | null | undefined) {
			const digits = String(val || "").replace(/\D/g, "");
			return digits ? Number(digits).toLocaleString("es-PY") : "";
		}

		private fillForm(service: ServiceDetail) {
			if (this.formEls.name)
				this.formEls.name.value = String(service?.name || "");
			if (this.formEls.duration)
				this.formEls.duration.value =
					typeof service?.duration_minutes === "number"
						? String(service.duration_minutes)
						: "";
			if (this.els.priceInput)
				this.els.priceInput.value = this.formatPrice(
					service?.price ?? "",
				);
			if (this.formEls.status)
				this.formEls.status.value = String(
					service?.is_active === 0 ? 0 : 1,
				);
		}

		private resetFormValues() {
			[
				this.formEls.name,
				this.formEls.duration,
				this.els.priceInput,
			].forEach((el) => el && (el.value = ""));
			if (this.formEls.status) this.formEls.status.value = "1";
		}

		private async requestApi<T = any>(url: string, options?: RequestInit): Promise<any> {
			const response = await fetch(url, options);
			let data = null;
			try { data = await response.json(); } catch { throw new Error("No fue posible interpretar la respuesta del servidor."); }
			if (!response.ok || !data || data.status !== "success") {
				const error = new Error(data?.message || "Error en la petición.");
				(error as any).apiData = data;
				throw error;
			}
			return data;
		}

		private async openEditModal(serviceId: number) {
			if (!serviceId) return;
			const currentReq = ++this.requestSeq;

			this.editingServiceId = serviceId;
			this.updateUIMode("edit");
			this.resetFormValues();
			this.clearErrors();
			this.openModalShell();

			this.toggleFormLoading(true);
			this.setButtonsProcessing("Cargando...");

			try {
				const data = await this.requestApi(`/api/services/${serviceId}`, {
					headers: { Accept: "application/json" },
				});
				if (currentReq === this.requestSeq) this.fillForm(data.data);
			} catch (err) {
				if (currentReq !== this.requestSeq) return;
				this.updateUIMode("create");
				this.showFormError(
					err instanceof Error ? err.message : "Error desconocido.",
				);
			} finally {
				if (currentReq === this.requestSeq) {
					this.toggleFormLoading(false);
					this.restoreButtons();
				}
			}
		}

		private handlePriceInput = () => {
			if (this.els.priceInput)
				this.els.priceInput.value = this.formatPrice(
					this.els.priceInput.value,
				);
		};

		private handleRootClick = (e: MouseEvent) => {
			const target = e.target as Element;
			if (!target) return;

			if (this.els.modal && target === this.els.modal)
				return this.closeModal();

			if (target.closest("[data-close-service-modal]"))
				return this.closeModal();

			const deleteTrigger = target.closest("[data-delete-service]");
			if (deleteTrigger && this.contains(deleteTrigger)) {
				void this.handleDelete();
				return;
			}

			const card = target.closest("[data-service-card]");
			if (card && this.contains(card)) {
				const id = Number(card.getAttribute("data-service-id") || "0");
				if (id > 0) void this.openEditModal(id);
				return;
			}

			if (
				target.closest("[data-open-service-modal]") &&
				this.contains(target.closest("[data-open-service-modal]"))
			) {
				this.openCreateModal();
			}
		};

		private handleRootKeydown = (e: KeyboardEvent) => {
			if (e.key !== "Enter" && e.key !== " ") return;
			const target = e.target as Element;
			const card = target?.closest("[data-service-card]");
			if (!card || !this.contains(card)) return;

			e.preventDefault();
			const id = Number(card.getAttribute("data-service-id") || "0");
			if (id > 0) void this.openEditModal(id);
		};

		private handleSubmit = async (e: SubmitEvent) => {
			e.preventDefault();
			this.clearErrors();
			if (!this.els.form) return;

			const formData = new FormData(this.els.form);
			const name = String(formData.get("name") || "").trim();
			const duration = Number(formData.get("duration_minutes"));
			const isActive = String(formData.get("is_active")) === "0" ? 0 : 1;
			const priceRaw = String(formData.get("price") || "").replace(
				/\D/g,
				"",
			);

			if (!name || !duration || !Number.isFinite(duration)) {
				return this.showFormError(
					"Completa los campos requeridos antes de continuar.",
				);
			}

			const payload: ServiceSubmitPayload = {
				name,
				duration_minutes: duration,
				is_active: isActive,
			};
			if (priceRaw) payload.price = Number(priceRaw);

			const isEdit = this.mode === "edit" && this.editingServiceId > 0;
			this.setButtonsProcessing(isEdit ? "Guardando..." : "Creando...");

			try {
				const data = await this.requestApi(
					isEdit
						? `/api/services/${this.editingServiceId}`
						: "/api/services",
					{
						method: isEdit ? "PUT" : "POST",
						headers: {
							"Content-Type": "application/json",
							Accept: "application/json",
						},
						body: JSON.stringify(payload),
					},
				);

				this.closeModal();
				this.navigateWithFlash(
					data?.message ||
						`Servicio ${isEdit ? "actualizado" : "creado"} correctamente.`,
					"success",
				);
			} catch (err: any) {
				this.showFormError(
					err instanceof Error
						? err.message
						: "Error inesperado del servidor.",
				);
				if (err.apiData && Array.isArray(err.apiData.errors)) {
					err.apiData.errors.forEach((errorItem: any) => {
						if (!errorItem?.field || !errorItem?.message) return;
						const node = this.querySelector<HTMLElement>(
							`[data-field-error="${errorItem.field}"]`,
						);
						if (node) {
							node.textContent = errorItem.message;
							node.classList.remove("hidden");
						}
					});
				}
			} finally {
				this.restoreButtons();
			}
		};

		private async handleDelete() {
			if (!this.editingServiceId || this.mode !== "edit") return;

			const confirmed = await (window as any).BookmateAlert?.confirm?.({
				type: "error",
				title: "Eliminar servicio",
				message:
					"Esta acción eliminará el servicio de forma permanente. ¿Deseas continuar?",
				confirmText: "Eliminar",
				cancelText: "Cancelar",
			});
			if (!confirmed) return;

			this.clearErrors();
			this.setButtonsProcessing("Eliminando...");

			try {
				const data = await this.requestApi(
					`/api/services/${this.editingServiceId}`,
					{
						method: "DELETE",
						headers: { Accept: "application/json" },
					},
				);

				this.closeModal();
				this.navigateWithFlash(
					data?.message || "Servicio eliminado correctamente.",
					"success",
				);
			} catch (err) {
				this.restoreButtons();
				this.showFormError(
					err instanceof Error
						? err.message
						: "Error al eliminar el servicio.",
				);
			}
		}
	}

	if (!customElements.get("service-manager")) {
		customElements.define("service-manager", ServiceManager);
	}
</script>

<style is:global>
	service-manager {
		display: block;
	}

	dialog[data-service-modal] {
		position: fixed;
		inset: 0;
		animation: service-modal-in var(--modal-open-duration) var(--modal-easing);
	}

	dialog[data-service-modal]::backdrop {
		animation: service-backdrop-in var(--modal-open-duration) var(--modal-easing);
	}

	dialog[data-service-modal].is-closing {
		animation: service-modal-out var(--modal-close-duration) var(--modal-easing) forwards;
	}

	dialog[data-service-modal].is-closing::backdrop {
		animation: service-backdrop-out var(--modal-close-duration) var(--modal-easing) forwards;
	}

	@keyframes service-modal-in {
		from {
			opacity: 0;
			transform: translateY(100%);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes service-modal-out {
		from {
			opacity: 1;
			transform: translateY(0);
		}

		to {
			opacity: 0;
			transform: translateY(100%);
		}
	}

	@media (min-width: 640px) {
		@keyframes service-modal-in {
			from {
				opacity: 0;
				transform: translateY(10px) scale(0.98);
			}

			to {
				opacity: 1;
				transform: translateY(0) scale(1);
			}
		}

		@keyframes service-modal-out {
			from {
				opacity: 1;
				transform: translateY(0) scale(1);
			}

			to {
				opacity: 0;
				transform: translateY(8px) scale(0.98);
			}
		}
	}

	@keyframes service-backdrop-in {
		from {
			opacity: 0;
		}

		to {
			opacity: 1;
		}
	}

	@keyframes service-backdrop-out {
		from {
			opacity: 1;
		}

		to {
			opacity: 0;
		}
	}

</style>


