﻿---
import AppAlert from '../../components/AppAlert.astro';
import FlashMessage from '../../components/FlashMessage.astro';
import SideNav from '../../components/SideNav.astro';
import TopBar from '../../components/TopBar.astro';
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';

const GOOGLE_PROVIDER = 'google_calendar';
const token = Astro.locals.token ?? '';
const initialLoadError = token ? '' : 'No hay sesión válida para consultar el calendario.';
const googleSuccessFlag = String(Astro.url.searchParams.get('success') || '').trim();
const googleErrorFlag = String(Astro.url.searchParams.get('error') || '').trim();
const googleDebugParam = String(Astro.url.searchParams.get('debug') || '').trim();
const showGoogleDebug = import.meta.env.DEV && Boolean(googleDebugParam);

let isGoogleConnected = false;
let googleStatusMessage = '';

const getIntegrationUrl = () => {
	const baseUrl = String(import.meta.env.ORDS_INTEGRATIONS_URL || '').trim();
	if (!baseUrl) return '';
	return `${baseUrl.replace(/\/+$/, '')}/${GOOGLE_PROVIDER}`;
};

const parseMessageFromResponse = async (response: Response) => {
	try {
		const payload = await response.json();
		if (payload && typeof payload === 'object' && 'message' in payload) {
			const message = String(payload.message || '').trim();
			if (message) return message;
		}
	} catch {
		// Ignore parse errors and fallback below.
	}
	return `Request failed with status ${response.status}.`;
};

if (!initialLoadError) {
	const integrationUrl = getIntegrationUrl();
	if (!integrationUrl) {
		googleStatusMessage = 'Falta configurar ORDS_INTEGRATIONS_URL para integrar Google Calendar.';
	} else {
		try {
			const response = await fetch(integrationUrl, {
				method: 'GET',
				headers: {
					Authorization: `Bearer ${token}`,
					Accept: 'application/json',
				},
			});

			if (response.status === 200) {
				isGoogleConnected = true;
			} else if (response.status === 404) {
				isGoogleConnected = false;
			} else {
				googleStatusMessage = await parseMessageFromResponse(response);
			}
		} catch (error) {
			console.error('[panel-calendar] google integration status error', error);
			googleStatusMessage = 'No fue posible consultar el estado de Google Calendar.';
		}
	}
}

const hasGoogleSuccess = googleSuccessFlag === 'google_connected' || googleSuccessFlag === 'google_disconnected';
const googleSuccessMessage =
	googleSuccessFlag === 'google_connected'
		? 'Google Calendar se conectó correctamente.'
		: googleSuccessFlag === 'google_disconnected'
			? 'Google Calendar se desconectó correctamente.'
			: '';

const hasGoogleError = Boolean(googleErrorFlag);
const googleErrorMessageMap: Record<string, string> = {
	google_connect_failed: 'No fue posible iniciar la conexión con Google.',
	google_oauth_error: 'Google devolvió un error durante la autorización OAuth.',
	google_missing_code: 'Google no envió el código de autorización.',
	google_token_exchange_failed: 'Google no devolvió tokens válidos al canjear el código.',
	google_ords_payload_invalid: 'No se pudo construir el body JSON para guardar la integración.',
	google_ords_save_failed: 'Google respondió, pero no se pudieron guardar los tokens en ORDS.',
	google_callback_failed: 'No fue posible completar la conexión con Google Calendar.',
	google_disconnect_failed: 'No fue posible desconectar Google Calendar.',
};
const googleErrorMessage = hasGoogleError
	? (googleErrorMessageMap[googleErrorFlag] || 'Ocurrió un error con la integración de Google Calendar.')
	: '';
---

<Layout>
	<calendar-manager data-google-connected={isGoogleConnected ? 'true' : 'false'}>
		<div class="min-h-screen bg-[#EEF1F5] dark:bg-(--page-background) transition-colors duration-300">
			<div
				class="app-shell grid min-h-screen overflow-hidden bg-transparent"
				data-app-shell
				data-sidebar-state="expanded"
			>
				<SideNav currentPath={Astro.url.pathname} />

				<div class="grid min-h-full grid-rows-[auto_1fr]">
					<TopBar />

				<main class="px-4 py-4 sm:px-6 sm:py-6">
					<section class="material-region dark:shadow-none" data-calendar-root>
						{
							initialLoadError ? (
								<FlashMessage message={initialLoadError} type="error" expand={true} dismissible={false} />
							) : (
								<div class="grid gap-4 sm:gap-5">
									<header class="flex flex-col justify-between gap-3 sm:flex-row sm:items-center sm:gap-4">
										<div class="grid gap-1">
											<h1 class="text-[1.3rem] font-extrabold text-(--on-surface)">
												Calendario de citas
											</h1>
											<div class="mt-1 inline-flex w-fit items-center gap-2 rounded-full px-3 py-1 text-[0.73rem] font-bold uppercase tracking-[0.08em] bg-(--surface-container-high) text-(--on-surface-variant)">
												<span class:list={[
													'inline-block size-2 rounded-full',
													isGoogleConnected ? 'bg-emerald-500' : 'bg-zinc-400'
												]}></span>
												{isGoogleConnected ? 'Google sincronizado' : 'Google no conectado'}
											</div>
										</div>

										<div class="flex w-full flex-col gap-2 sm:w-auto sm:items-end">
											<div class="flex w-full flex-col gap-2 sm:w-auto sm:flex-row sm:items-center">
												{
													isGoogleConnected ? (
														<form method="post" action="/api/google/disconnect" class="w-full sm:w-auto">
															<button
																type="submit"
																class="inline-flex w-full items-center justify-center rounded-full border border-rose-500/30 bg-rose-500/12 px-5 py-3 text-sm font-extrabold text-rose-600 transition hover:bg-rose-500/18 sm:w-auto"
															>
																Desconectar Google
															</button>
														</form>
													) : (
														<a
															href="/api/google/connect"
															class="inline-flex w-full items-center justify-center rounded-full border border-(--shell-border) bg-(--surface-bright) px-5 py-3 text-sm font-extrabold text-(--on-surface) no-underline transition hover:bg-(--surface-container-high) sm:w-auto"
														>
															Conectar Google
														</a>
													)
												}

												<button
													type="button"
													class="calendar-refresh-btn w-full sm:w-auto inline-flex items-center justify-center gap-2"
													data-refresh-calendar
												>
													<span class="material-symbols-rounded text-[1.12rem]">refresh</span>
													<span>Refrescar</span>
												</button>

												<button
													type="button"
													class="calendar-create-btn w-full sm:w-auto inline-flex items-center justify-center gap-2"
													data-open-appointment-modal
												>
													<svg
														class="calendar-create-btn-icon w-[18px] h-[18px]"
														viewBox="0 0 24 24"
														fill="none"
														aria-hidden="true"
													>
														<path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" />
													</svg>
													<span>Nueva cita</span>
												</button>
											</div>
										</div>
									</header>

									{
										hasGoogleSuccess && (
											<div class="rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-4 py-3 text-[0.9rem] font-semibold text-emerald-700 dark:text-emerald-300">
												{googleSuccessMessage}
											</div>
										)
									}

									{
										hasGoogleError && (
											<div class="rounded-2xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-[0.9rem] font-semibold text-rose-700 dark:text-rose-300">
												{googleErrorMessage}
												{
													showGoogleDebug && (
														<p class="mt-2 rounded-lg border border-rose-500/25 bg-black/20 px-2.5 py-2 font-mono text-[0.74rem] leading-snug text-rose-100/90">
															[{googleErrorFlag || 'google_error'}] {googleDebugParam}
														</p>
													)
												}
											</div>
										)
									}

									{
										googleStatusMessage && (
											<div class="rounded-2xl border border-amber-500/20 bg-amber-500/10 px-4 py-3 text-[0.9rem] font-semibold text-amber-700 dark:text-amber-300">
												{googleStatusMessage}
											</div>
										)
									}

									<div class="grid gap-3 sm:gap-4 sm:grid-cols-2">
										<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)" data-professional-filter-wrap>
											Profesional
											<select
												data-professional-filter
												class="cursor-pointer appearance-none w-full rounded-2xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] font-semibold outline-none transition hover:border-(--on-surface-variant) focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 shadow-sm bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M7%2010l5%205%205-5%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-position-[calc(100%-12px)_center] bg-no-repeat pr-10"
											>
												<option value="">Todos los profesionales</option>
											</select>
										</label>

										<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
											Sucursal
											<select
												data-location-filter
												class="cursor-pointer appearance-none w-full rounded-2xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] font-semibold outline-none transition hover:border-(--on-surface-variant) focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 shadow-sm bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M7%2010l5%205%205-5%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-position-[calc(100%-12px)_center] bg-no-repeat pr-10"
											>
												<option value="">Todas las sucursales</option>
											</select>
										</label>
									</div>

									<div
										class="hidden rounded-2xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-[0.9rem] font-bold text-rose-500 shadow-sm"
										data-calendar-error
									></div>

									<div class="mt-1.5 rounded-[1.3rem] bg-(--calendar-surface) p-2.5 sm:rounded-[1.45rem] sm:border sm:border-(--calendar-outline) sm:p-4">
										<div
											class="mb-3 hidden rounded-xl bg-(--calendar-toolbar-surface) px-3 py-2.5 text-[0.86rem] font-semibold text-(--on-surface-variant) sm:border sm:border-(--calendar-outline-strong)"
											data-calendar-loading
										>
											Cargando calendario...
										</div>
										<div data-calendar-el class="calendar-host min-h-136 md:min-h-152"></div>
									</div>
								</div>
							)
						}
					</section>
					</main>
				</div>
			</div>
		</div>

		<appointment-modal>
		<dialog
			class="m-0 mt-auto mb-0 w-screen max-w-none sm:m-auto sm:w-[min(42rem,calc(100vw-2rem))] sm:max-w-[min(42rem,calc(100vw-2rem))] open:flex open:flex-col max-h-[80vh] sm:max-h-[90vh] overflow-hidden rounded-t-[1.8rem] rounded-b-none sm:rounded-[1.8rem] border border-(--shell-border) bg-(--surface-bright) p-0 text-(--on-surface) shadow-[0_24px_80px_rgba(0,0,0,0.2)]"
			data-appointment-modal
		>
			<div class="shrink-0 z-10 shadow-sm border-b border-(--shell-border) bg-(--surface-bright) px-4 py-3 sm:px-7 sm:py-6 ">
				<div class="flex items-start justify-between gap-4">
					<div class="flex items-center gap-4">
						<div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-(--primary-soft) text-(--primary)">
							<span class="material-symbols-rounded text-[1.4rem]">calendar_add_on</span>
						</div>
						<div>
							<h2 class="text-[1.2rem] font-extrabold tracking-tight text-(--on-surface)" data-appointment-modal-title>Crear cita</h2>
							<p class="text-[0.9rem] font-medium text-(--on-surface-variant) mt-0.5 hidden sm:block" data-appointment-modal-description>
								Completa los datos para registrar una nueva reserva.
							</p>
						</div>
					</div>
					<button type="button" class="flex size-9 shrink-0 items-center justify-center rounded-full text-(--on-surface-variant) transition-colors hover:bg-(--surface-variant) hover:text-(--on-surface) focus:outline-none focus:ring-2 focus:ring-(--primary)" data-close-appointment-modal aria-label="Cerrar modal">
						<span class="material-symbols-rounded text-[1.3rem]">close</span>
					</button>
				</div>
			</div>

			<form class="relative flex flex-col bg-(--surface)/30 overflow-y-auto overscroll-contain min-h-0 shadow-[inset_0_4px_10px_rgba(0,0,0,0.015)]" data-appointment-form>
				<div
					class="pointer-events-none absolute inset-0 z-20 hidden items-center justify-center bg-(--surface-bright)/80 backdrop-blur-[2px] transition-all"
					data-appointment-loading
				>
					<div class="inline-flex items-center gap-3 rounded-2xl border border-(--shell-border) bg-(--surface-bright) px-5 py-3.5 text-[0.95rem] font-extrabold text-(--on-surface) shadow-[0_12px_32px_rgba(0,0,0,0.12)]">
						<span class="material-symbols-rounded animate-spin text-[1.2rem] text-(--primary)">progress_activity</span>
						Procesando...
					</div>
				</div>

				<div class="flex-1 px-7 py-7 grid gap-5">
					<div class="hidden rounded-2xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-[0.9rem] font-bold text-rose-500 shadow-sm" data-form-error></div>

					<div class="grid gap-5 sm:grid-cols-2">
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
							<span class="inline-flex items-center gap-1">
								Cliente
								<span class="text-rose-500">*</span>
							</span>
							<input
								type="text"
								name="customer_name"
								required
								maxlength="100"
								class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
								placeholder="Ej: Carlos Gomez"
							/>
							<span class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400" data-field-error="customer_name"></span>
						</label>

						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
							<span class="inline-flex items-center gap-1">
								Teléfono
								<span class="text-rose-500">*</span>
							</span>
							<div class="flex rounded-2xl shadow-sm transition-shadow focus-within:ring-4 focus-within:ring-(--primary)/10">
								<span class="inline-flex items-center rounded-l-2xl border border-r-0 border-(--shell-border) bg-(--control-surface) px-4 text-[0.95rem] font-semibold text-(--on-surface-variant)">
									+595
								</span>
								<input
									type="tel"
									name="customer_phone"
									maxlength="11"
									inputmode="numeric"
									autocomplete="tel-national"
									class="min-w-0 flex-1 rounded-none rounded-r-2xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary)"
									placeholder="981 123 456"
								/>
							</div>
							<span class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400" data-field-error="customer_phone"></span>
						</label>
					</div>

					<div class="grid gap-5 sm:grid-cols-2">
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)" data-modal-professional-wrap>
							<span class="inline-flex items-center gap-1">
								Profesional
								<span class="text-rose-500">*</span>
							</span>
							<select
								name="pro_id_professional"
								data-modal-professional
								required
								class="cursor-pointer appearance-none rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] font-semibold outline-none transition hover:border-(--on-surface-variant) focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M7%2010l5%205%205-5%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-position-[calc(100%-12px)_center] bg-no-repeat pr-10"
							>
								<option value="">Selecciona un profesional</option>
							</select>
							<span class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400" data-field-error="pro_id_professional"></span>
						</label>

						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
							<span class="inline-flex items-center gap-1">
								Sucursal
								<span class="text-rose-500">*</span>
							</span>
							<select
								name="loc_id_location"
								data-modal-location
								required
								class="cursor-pointer appearance-none rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] font-semibold outline-none transition hover:border-(--on-surface-variant) focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M7%2010l5%205%205-5%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-position-[calc(100%-12px)_center] bg-no-repeat pr-10"
							>
								<option value="">Selecciona una sucursal</option>
							</select>
							<span class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400" data-field-error="loc_id_location"></span>
						</label>
					</div>

					<div class="grid gap-5 sm:grid-cols-2">
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
							<span class="inline-flex items-center gap-1">
								Servicio
								<span class="text-rose-500">*</span>
							</span>
							<select
								name="ser_id_service"
								data-modal-service
								required
								class="cursor-pointer appearance-none rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] font-semibold outline-none transition hover:border-(--on-surface-variant) focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M7%2010l5%205%205-5%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-position-[calc(100%-12px)_center] bg-no-repeat pr-10"
							>
								<option value="">Selecciona un servicio</option>
							</select>
							<span class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400" data-field-error="ser_id_service"></span>
						</label>

						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)" data-modal-status-wrap hidden>
							Estado
							<select
								name="status"
								data-modal-status
								class="cursor-pointer appearance-none rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] font-semibold outline-none transition hover:border-(--on-surface-variant) focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M7%2010l5%205%205-5%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-position-[calc(100%-12px)_center] bg-no-repeat pr-10"
							>
								<option value="PENDIENTE">Pendiente</option>
								<option value="CONFIRMADO">Confirmado</option>
								<option value="COMPLETADO">Completado</option>
								<option value="CANCELADO">Cancelado</option>
							</select>
							<span class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400" data-field-error="status"></span>
						</label>
					</div>

					<div class="relative">
						<div class="grid w-full gap-5 sm:grid-cols-2">
							<label class="grid w-full gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
							<span class="inline-flex items-center gap-1">
								Inicio
								<span class="text-rose-500">*</span>
							</span>
							<div class="relative">
								<input
									type="text"
									data-start-display
									readonly
									placeholder="Selecciona fecha y hora"
