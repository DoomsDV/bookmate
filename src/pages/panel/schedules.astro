---
import AppAlert from '../../components/AppAlert.astro';
import FlashMessage from '../../components/FlashMessage.astro';
import SideNav from '../../components/SideNav.astro';
import TopBar from '../../components/TopBar.astro';
import { ROLES } from '../../config/roles';
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';

const token = Astro.locals.token ?? '';
const roleId = Number(Astro.locals.roleId ?? 0);
const isProfessional = roleId === ROLES.PROFESIONAL;
const canManageSchedules = !isProfessional;
const initialLoadError = token ? '' : 'No hay sesión válida para configurar horarios.';
---

<Layout>
	<schedule-manager
		data-can-edit={canManageSchedules ? 'true' : 'false'}
		data-role-id={String(roleId)}
	>
		<div class="min-h-screen bg-(--page-background) transition-colors duration-300">
			<div
				class="app-shell grid min-h-screen overflow-hidden bg-transparent"
				data-app-shell
				data-sidebar-state="expanded"
			>
				<SideNav currentPath={Astro.url.pathname} />

				<div class="grid min-h-full grid-rows-[auto_1fr]">
					<TopBar />

					<main class="schedule-page-main relative px-4 pb-4 pt-0 sm:px-6 sm:pb-6 sm:pt-0">
						<section class="grid gap-4 sm:gap-5">
							{
								initialLoadError ? (
									<FlashMessage message={initialLoadError} type="error" expand={true} dismissible={false} />
								) : (
									<div class="grid gap-4 sm:gap-6" data-schedule-page-header>
										<div class="schedule-page-header__hero" data-schedule-header-hero>
											<div class="schedule-page-header__intro grid gap-1">
												<h1 class="text-[1.3rem] font-extrabold text-(--on-surface)">
													Horarios y disponibilidad
												</h1>
												<p class="text-[0.95rem] text-(--on-surface-variant) leading-relaxed">
													{
														isProfessional
															? 'Consulta la plantilla semanal y las excepciones del calendario.'
															: 'Plantilla semanal recurrente y excepciones puntuales por fecha.'
													}
												</p>
											</div>
										</div>

										<div
											class="schedule-page-header__sticky-bar"
											data-schedule-header-sticky
										>
										{
											isProfessional ? (
												<select
													data-professional-select
													hidden
													class="hidden"
													aria-hidden="true"
													tabindex="-1"
												></select>
											) : (
												<div
													class="schedule-page-header__toolbar"
													data-schedule-header-toolbar
												>
													<div
														class="schedule-page-header__professional relative grid min-w-0 flex-1 gap-3 sm:gap-4"
														data-schedule-professional-field
													>
														<label class="schedule-professional-select-field grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
															<span class="inline-flex items-center gap-1">
																Profesional
																<span class="text-rose-500">*</span>
															</span>
															<select
																data-professional-select
																class="cursor-pointer appearance-none w-full rounded-2xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] font-semibold outline-none transition hover:border-(--on-surface-variant) focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 shadow-sm bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M7%2010l5%205%205-5%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-position-[calc(100%-12px)_center] bg-no-repeat pr-10"
															>
																<option value="">Selecciona un profesional</option>
															</select>
														</label>
													</div>
													{
														canManageSchedules && (
															<button
																type="button"
																class="schedule-save-btn schedule-page-header__save inline-flex shrink-0 items-center justify-center gap-2 self-end rounded-2xl px-5 py-3 text-[0.95rem] font-extrabold transition focus:outline-none focus:ring-2 focus:ring-(--primary) focus:ring-offset-2 focus:ring-offset-(--surface-bright) disabled:opacity-60 disabled:pointer-events-none"
																data-save-schedule
															>
																<span class="material-symbols-rounded text-[1.2rem]">save</span>
																<span data-save-schedule-label>Guardar horarios</span>
															</button>
														)
													}
												</div>
											)
										}

										<div class="schedule-error-anchor" data-schedule-error-anchor>
											<div
												data-schedule-error
												class="schedule-error-banner hidden"
												role="alert"
												aria-live="assertive"
												hidden
											></div>
										</div>
										</div>

										<div class="flex flex-wrap items-center gap-2 sm:gap-3">
											<div data-schedule-tabs role="tablist" class="min-w-0 flex-1">
												<button
													type="button"
													class="schedule-tab schedule-tab--active"
													data-schedule-tab="template"
													role="tab"
													aria-selected="true"
												>
													Plantilla semanal
												</button>
												<button
													type="button"
													class="schedule-tab"
													data-schedule-tab="exceptions"
													role="tab"
													aria-selected="false"
												>
													Excepciones del calendario
												</button>
											</div>
											<button
												type="button"
												class="schedule-exceptions-help inline-flex shrink-0 items-center gap-1.5 rounded-full border border-(--shell-border) bg-(--surface-bright) px-3 py-2 text-[0.82rem] font-bold text-(--on-surface-variant) transition hover:border-(--primary)/35 hover:text-(--primary) focus:outline-none focus:ring-2 focus:ring-(--primary)/25"
												data-schedule-exceptions-help
												aria-label="Guía de profesional, plantilla semanal y excepciones del calendario"
											>
												<span class="material-symbols-rounded text-[1.1rem]">help</span>
												<span class="hidden sm:inline">Guía</span>
											</button>
										</div>

										<div class="mt-0.5">
												<div
													class="mb-2 hidden rounded-xl border border-(--shell-border) bg-(--control-surface) px-3 py-2 text-[0.9rem] font-medium text-(--on-surface-variant)"
													data-schedule-loading
												>
													Cargando configuración de horarios...
												</div>

												<div data-schedule-view-template>
													<p class="mb-2 text-[0.88rem] font-medium text-(--on-surface-variant)">
														Horario habitual que se repite cada semana.
													</p>
													<details
														class="schedule-template-callout"
														data-schedule-template-notes
													>
														<summary class="schedule-template-callout__summary">
															<span
																class="schedule-template-callout__icon material-symbols-rounded"
																aria-hidden="true"
															>info</span>
															<span class="schedule-template-callout__title">Antes de guardar</span>
															<span
																class="schedule-template-callout__chevron material-symbols-rounded"
																aria-hidden="true"
															>expand_more</span>
														</summary>
														<div class="schedule-template-callout__body">
															<ul class="schedule-template-callout__list">
																<li>
																	Al guardar la plantilla, las citas ya agendadas no se mueven solas.
																</li>
																<li>
																	Si hay citas futuras desalineadas, el sistema te avisará antes de guardar.
																</li>
																<li>
																	Revisa el calendario y reprograma manualmente; avisa al cliente si cambias fecha u hora.
																</li>
															</ul>
														</div>
													</details>
													<div class="grid gap-4 sm:gap-5" data-weekly-planner></div>
												</div>

												<div class="hidden" data-schedule-view-exceptions>
													<p class="mb-3 text-[0.88rem] font-medium text-(--on-surface-variant)">
														Cambios puntuales por fecha. La excepción reemplaza la plantilla solo ese día.
													</p>

													<div
														class="mb-3 flex flex-wrap gap-3 text-[0.82rem] font-semibold text-(--on-surface-variant)"
														data-exception-legend
													>
														<span class="inline-flex items-center gap-1.5">
															<span class="schedule-cal-dot schedule-cal-dot--normal"></span>
															Usa plantilla
														</span>
														<span class="inline-flex items-center gap-1.5">
															<span class="schedule-cal-dot schedule-cal-dot--blocked"></span>
															Bloqueado
														</span>
														<span class="inline-flex items-center gap-1.5">
															<span class="schedule-cal-dot schedule-cal-dot--override"></span>
															Horario especial
														</span>
													</div>

													<div
														class="rounded-2xl border border-(--shell-border) bg-(--surface-bright) p-3 sm:p-4"
														data-exception-calendar-panel
													>
														<div class="mb-3 flex items-center justify-between gap-2">
															<button
																type="button"
																class="schedule-cal-nav"
																data-exception-cal-prev
																aria-label="Mes anterior"
															>
																<span class="material-symbols-rounded text-[1.2rem]">chevron_left</span>
															</button>
															<p
																class="text-[1rem] font-extrabold text-(--on-surface)"
																data-exception-cal-month
															></p>
															<button
																type="button"
																class="schedule-cal-nav"
																data-exception-cal-next
																aria-label="Mes siguiente"
															>
																<span class="material-symbols-rounded text-[1.2rem]">chevron_right</span>
															</button>
														</div>
														<div
															class="mb-1 grid grid-cols-7 gap-1 text-center text-[0.72rem] font-bold uppercase tracking-wide text-(--on-surface-variant)"
														>
															<span>Lun</span><span>Mar</span><span>Mié</span><span>Jue</span>
															<span>Vie</span><span>Sáb</span><span>Dom</span>
														</div>
														<div class="grid grid-cols-7 gap-1" data-exception-cal-grid></div>
													</div>
												</div>
											</div>

										<div
											class="schedule-exception-modal-backdrop fixed inset-0 z-50 hidden items-end justify-center bg-black/40 p-0 sm:items-center sm:p-4"
											data-exception-modal
											role="dialog"
											aria-modal="true"
											aria-labelledby="exception-modal-title"
										>
											<div
												class="schedule-exception-modal flex w-full max-w-none flex-col overflow-hidden rounded-t-[1.8rem] rounded-b-none border border-(--shell-border) border-b-0 bg-(--surface-bright) text-(--on-surface) shadow-[0_-12px_40px_rgba(0,0,0,0.18)] max-h-[80dvh] sm:max-h-[90vh] sm:max-w-[min(48rem,calc(100vw-2rem))] sm:rounded-[1.8rem] sm:border-b sm:shadow-xl md:max-w-[min(52rem,calc(100vw-2rem))]"
											>
												<div
													class="schedule-exception-modal-header shrink-0 border-b border-(--shell-border) bg-(--surface-bright) px-4 py-3 shadow-sm sm:px-7 sm:py-5"
												>
													<div class="flex items-start justify-between gap-4">
														<div class="flex min-w-0 items-center gap-3 sm:gap-4">
															<div
																class="flex size-11 shrink-0 items-center justify-center rounded-2xl bg-(--primary-soft) text-(--primary) sm:size-12"
															>
																<span class="material-symbols-rounded text-[1.35rem]"
																	>event_busy</span
																>
															</div>
															<div class="min-w-0">
																<h2
																	id="exception-modal-title"
																	class="text-[1.1rem] font-extrabold tracking-tight text-(--on-surface) sm:text-[1.2rem]"
																	data-exception-modal-title
																>
																	Excepción de horario
																</h2>
																<p
																	class="mt-0.5 truncate text-[0.85rem] font-medium text-(--on-surface-variant) sm:text-[0.9rem]"
																	data-exception-modal-subtitle
																></p>
															</div>
														</div>
														<div class="flex shrink-0 items-center gap-2">
															<button
																type="button"
																class="schedule-exceptions-help hidden inline-flex shrink-0 items-center gap-1.5 rounded-full border border-(--shell-border) bg-(--surface-bright) px-3 py-2 text-[0.82rem] font-bold text-(--on-surface-variant) transition hover:border-(--primary)/35 hover:text-(--primary) focus:outline-none focus:ring-2 focus:ring-(--primary)/25"
																data-exception-modal-tour-help
																aria-label="Guía del modal de excepción de horario"
															>
																<span class="material-symbols-rounded text-[1.1rem]">help</span>
																<span class="hidden sm:inline">Guía</span>
															</button>
															<button
																type="button"
																class="schedule-modal-close hidden shrink-0 sm:inline-flex"
																data-exception-modal-close
																aria-label="Cerrar"
															>
																<span class="material-symbols-rounded text-[1.3rem]"
																	>close</span
																>
															</button>
														</div>
													</div>
												</div>

												<div
													class="schedule-exception-modal-scroll relative min-h-0 flex-1 overflow-y-auto overscroll-contain bg-(--surface)/30 px-4 py-4 shadow-[inset_0_4px_10px_rgba(0,0,0,0.015)] sm:px-7 sm:py-5"
												>
													<div
														class="schedule-exception-modal-feedback"
														data-exception-modal-feedback
													>
														<div
															class="schedule-exception-modal-feedback__alert hidden ml-auto max-w-full items-center gap-2 rounded-2xl border border-rose-500/25 px-4 py-3 text-[0.9rem] font-bold text-rose-600 shadow-sm sm:max-w-md dark:border-rose-400/30 dark:text-rose-300"
															data-exception-modal-error
															role="alert"
															aria-live="polite"
														>
															<p
																class="m-0 min-w-0 flex-1 leading-snug font-bold"
																data-exception-modal-error-message
															></p>
															<button
																type="button"
																class="schedule-exception-modal-feedback__close shrink-0 rounded-full p-0.5 text-rose-500 transition hover:bg-rose-500/10 hover:text-rose-700 dark:text-rose-300 dark:hover:bg-rose-400/10 dark:hover:text-rose-100"
																data-dismiss-exception-modal-error
																aria-label="Cerrar mensaje de error"
															>
																<span class="material-symbols-rounded block text-[1.15rem] leading-none"
																	>close</span
																>
															</button>
														</div>
													</div>

													<div class="grid gap-4" data-exception-modal-body></div>
												</div>

												<div
													class="schedule-exception-modal-footer modal-footer shrink-0 border-t border-(--shell-border) bg-(--surface-bright) px-4 py-4 pb-[max(1rem,env(safe-area-inset-bottom))] sm:px-7 sm:py-5 sm:pb-5"
													data-exception-modal-actions
												></div>
											</div>
										</div>
									</div>
								)
							}
						</section>
					</main>
				</div>
			</div>
		</div>
	</schedule-manager>

	<AppAlert />
</Layout>

<script>
	import '../../scripts/schedule-manager';
</script>

<style is:global>
	schedule-manager {
		display: block;
	}

	.schedule-error-anchor {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		height: 0;
		overflow: visible;
		pointer-events: none;
		transform: translateY(100%);
		z-index: 25;
	}

	.schedule-error-anchor:not(:has(.schedule-error-banner:not(.hidden))) {
		display: none;
	}

	.schedule-error-banner {
		position: absolute;
		top: 0.5rem;
		left: 0.25rem;
		right: 0.25rem;
		pointer-events: auto;
		width: auto;
		max-width: none;
		height: auto;
		min-height: unset;
		margin: 0;
		box-shadow: none !important;
	}

	.schedule-error-banner.inline-feedback {
		align-items: center;
		padding: 0.7rem 0.85rem 0.7rem 1rem;
		height: auto;
		min-height: unset;
		line-height: 1.4;
	}

	.schedule-error-banner.inline-feedback .inline-feedback__text {
		line-height: 1.4;
		white-space: normal;
		overflow-wrap: anywhere;
	}

	.schedule-error-banner.inline-feedback.schedule-error-banner--wrap {
		align-items: flex-start;
		padding: 0.85rem 0.95rem 0.85rem 1.05rem;
		line-height: 1.45;
	}

	.schedule-error-banner.inline-feedback.schedule-error-banner--wrap .inline-feedback__text {
		line-height: 1.45;
	}

	.schedule-error-banner.inline-feedback.schedule-error-banner--wrap .inline-feedback__icon {
		margin-top: 0.08rem;
	}

	.schedule-error-banner.inline-feedback.schedule-error-banner--wrap .inline-feedback__close {
		align-self: flex-start;
	}

	.schedule-error-banner.hidden,
	.schedule-error-banner[hidden] {
		display: none !important;
	}

	.schedule-page-header__hero {
		min-width: 0;
		padding: 0.75rem 0.25rem 0;
		margin: 0 -0.25rem;
	}

	.schedule-page-header__intro {
		min-width: 0;
	}

	.schedule-page-header__sticky-bar {
		position: sticky;
		top: 0;
		z-index: 20;
		margin: 0 -0.25rem;
		padding: 0 0.25rem 0.65rem;
		background: var(--page-background);
		transition: box-shadow 240ms ease;
	}

	.schedule-page-header__sticky-bar.is-scrolled {
		box-shadow: 0 1px 0 color-mix(in srgb, var(--shell-border) 45%, transparent);
	}

	.schedule-page-header__toolbar {
		display: flex;
		align-items: end;
		gap: 0.75rem;
		min-width: 0;
		overflow: visible;
	}

	.schedule-page-header__professional {
		min-width: 0;
		overflow: visible;
	}

	.schedule-professional-select-field {
		position: relative;
		min-width: 0;
	}

	.schedule-page-header__professional .bookmate-searchable-select.ts-wrapper {
		position: relative;
		width: 100%;
	}

	.schedule-page-header__professional .bookmate-searchable-select.ts-wrapper .ts-dropdown {
		position: absolute;
		top: calc(100% + 0.25rem);
		left: 0;
		right: 0;
		width: 100%;
		z-index: 60;
	}

	.schedule-page-header__save {
		flex-shrink: 0;
	}

	.schedule-page-header__save.hidden {
		display: none !important;
	}

	@media (prefers-reduced-motion: reduce) {
		.schedule-page-header__sticky-bar {
			transition: none;
		}
	}

	@media (max-width: 639px) {
		.schedule-page-header__save {
			padding-inline: 0.85rem;
		}

		.schedule-page-header__save [data-save-schedule-label] {
			display: none;
		}
	}

	@media (min-width: 640px) {
		.schedule-page-header__hero {
			padding-top: 1rem;
		}
	}

	html[data-theme='dark'] .schedule-page-header__sticky-bar.is-scrolled {
		background: var(--page-background);
		box-shadow: 0 1px 0 color-mix(in srgb, var(--shell-border) 65%, transparent);
	}

	.schedule-template-callout {
		margin-bottom: 1rem;
		padding: 0.85rem 1rem;
		border-radius: 1rem;
		border: 1px solid color-mix(in srgb, var(--primary) 24%, var(--shell-border) 76%);
		background: color-mix(in srgb, var(--primary) 9%, var(--surface-bright) 91%);
		box-shadow: inset 0 1px 0 color-mix(in srgb, white 50%, transparent);
	}

	.schedule-template-callout__summary {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		cursor: pointer;
		list-style: none;
	}

	.schedule-template-callout__summary::-webkit-details-marker {
		display: none;
	}

	.schedule-template-callout__icon {
		flex-shrink: 0;
		font-size: 1.25rem;
		line-height: 1;
		color: var(--primary);
	}

	.schedule-template-callout__title {
		margin: 0;
		font-size: 0.84rem;
		font-weight: 800;
		letter-spacing: 0.01em;
		color: color-mix(in srgb, var(--primary) 78%, var(--on-surface) 22%);
	}

	.schedule-template-callout__chevron {
		margin-left: auto;
		flex-shrink: 0;
		font-size: 1.2rem;
		line-height: 1;
		color: color-mix(in srgb, var(--primary) 70%, var(--on-surface-variant) 30%);
		transition: transform 180ms ease;
	}

	.schedule-template-callout[open] .schedule-template-callout__chevron {
		transform: rotate(180deg);
	}

	.schedule-template-callout__body {
		min-width: 0;
		margin-top: 0.65rem;
		padding-left: calc(1.25rem + 0.75rem);
	}

	@media (prefers-reduced-motion: reduce) {
		.schedule-template-callout__chevron {
			transition: none;
		}
	}

	.schedule-template-callout__list {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.3rem;
		font-size: 0.82rem;
		font-weight: 600;
		line-height: 1.45;
		color: color-mix(in srgb, var(--on-surface-variant) 92%, var(--on-surface) 8%);
	}

	.schedule-template-callout__list li {
		position: relative;
		padding-left: 0.8rem;
	}

	.schedule-template-callout__list li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.58em;
		width: 0.28rem;
		height: 0.28rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--primary) 72%, transparent);
	}

	html[data-theme='dark'] .schedule-template-callout {
		background: color-mix(in srgb, var(--primary) 14%, #1e1f22 86%);
		border-color: color-mix(in srgb, var(--primary) 28%, transparent);
		box-shadow: inset 0 1px 0 color-mix(in srgb, white 6%, transparent);
	}

