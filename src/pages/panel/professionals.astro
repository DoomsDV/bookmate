<script>
	import TomSelect from 'tom-select';
	import {
		isAcceptedProfileImage,
		ProfileImageCropper,
	} from '../../lib/profile-image-crop';
	import {
		PARAGUAY_MOBILE_PHONE_ERROR,
		parseParaguayMobilePhone,
	} from '../../lib/paraguay-phone';
	import { reloadPageWithFlash } from '../../lib/flash';
	import { showProfessionalProfileUrlTour } from '../../lib/professional-profile-url-tour';

	type ProfessionalMode = 'create' | 'edit';

	class ProfessionalManager extends HTMLElement {
		private els!: {
			modal: HTMLDialogElement | null;
			form: HTMLFormElement | null;
			deleteBtn: HTMLButtonElement | null;
			deleteBtnIcon: HTMLElement | null;
			deleteBtnLabel: HTMLElement | null;
			statusSection: HTMLElement | null;
			permissionsBlock: HTMLElement | null;
			accountStatusActiveBtn: HTMLButtonElement | null;
			accountStatusInactiveBtn: HTMLButtonElement | null;
			loading: HTMLElement | null;
			error: HTMLElement | null;
			errorMessage: HTMLElement | null;
			errorFeedback: HTMLElement | null;
			title: HTMLElement | null;
			description: HTMLElement | null;
			submitIcon: HTMLElement | null;
			submitLabel: HTMLElement | null;
			imageFileName: HTMLElement | null;
			previewImg: HTMLImageElement | null;
			previewPlaceholder: HTMLElement | null;
			photoDropzone: HTMLElement | null;
			profileUploadIcon: HTMLElement | null;
			profileUploadButton: HTMLLabelElement | null;
			roleSelfAdminHint: HTMLElement | null;
			cropModal: HTMLDialogElement | null;
			cropMount: HTMLElement | null;
			confirmCropBtn: HTMLButtonElement | null;
		};

		private formEls!: {
			username: HTMLInputElement | null;
			email: HTMLInputElement | null;
			firstName: HTMLInputElement | null;
			lastName: HTMLInputElement | null;
			password: HTMLInputElement | null;
			role: HTMLSelectElement | null;
			phone: HTMLInputElement | null;
			specialty: HTMLSelectElement | null;
			userActive: HTMLInputElement | null;
			profActive: HTMLInputElement | null;
			panelAccessToggle: HTMLInputElement | null;
			publicVisibilityToggle: HTMLInputElement | null;
			slug: HTMLInputElement | null;
			image: HTMLInputElement | null;
			services: HTMLSelectElement | null;
			fieldsets: HTMLFieldSetElement[];
			fieldErrors: HTMLElement[];
		};

		private abortController: AbortController | null = null;
		private mode: ProfessionalMode = 'create';
		private editingMembershipStatus: 'active' | 'pending_invite' | null = null;
		private publicProfilePrefix = '';
		private currentUserId = 0;
		private adminRoleId = 1;
		private editingId: number | null = null;
		private editingUserId: number | null = null;
		private editingRoleId: number | null = null;
		private editingUserIsActive: 0 | 1 | null = null;
		private editingProfIsActive: 0 | 1 | null = null;
		private memberAccountActive: 0 | 1 = 1;
		private panelAccessEnabled: 0 | 1 = 1;
		private publicVisibilityEnabled: 0 | 1 = 1;
		private savedPermissionsBeforeInactive: { panel: 0 | 1; visibility: 0 | 1 } | null = null;
		private closeTimer: number | null = null;
		private slugSuggestTimer: number | null = null;
		private slugRequestSeq = 0;
		private slugManuallyEdited = false;
		private suppressSlugManualTracking = false;
		
		private rolesLoaded = false;
		private rolesLoadPromise: Promise<void> | null = null;
		
		private specialtiesLoaded = false;
		private specialtiesLoadPromise: Promise<void> | null = null;
		
		private servicesLoaded = false;
		private servicesLoadPromise: Promise<void> | null = null;
		private servicesTom: TomSelect | null = null;
		private servicesTouched = false;
		private editServicesAvailable = false;
		private suppressServicesTouched = false;

		private professionalReadRequestSeq = 0;
		private profileImageCropper: ProfileImageCropper | null = null;
		private pendingCropSource: File | null = null;
		private cropBusy = false;

		connectedCallback() {
			if (this.abortController) return;
			this.abortController = new AbortController();
			this.publicProfilePrefix = String(this.dataset.publicProfilePrefix || '').trim();
			this.currentUserId = Number(this.dataset.currentUserId || 0);
			this.adminRoleId = Number(this.dataset.adminRoleId || 1);
			const { signal } = this.abortController;

			this.els = {
				modal: this.querySelector<HTMLDialogElement>('[data-professional-modal]'),
				form: this.querySelector<HTMLFormElement>('[data-professional-form]'),
				deleteBtn: this.querySelector<HTMLButtonElement>('[data-delete-professional]'),
				deleteBtnIcon: this.querySelector<HTMLElement>('[data-delete-professional-icon]'),
				deleteBtnLabel: this.querySelector<HTMLElement>('[data-delete-professional-label]'),
				statusSection: this.querySelector<HTMLElement>('[data-professional-status-section]'),
				permissionsBlock: this.querySelector<HTMLElement>('[data-professional-permissions-block]'),
				accountStatusActiveBtn: this.querySelector<HTMLButtonElement>('[data-member-account-status="1"]'),
				accountStatusInactiveBtn: this.querySelector<HTMLButtonElement>('[data-member-account-status="0"]'),
				loading: this.querySelector<HTMLElement>('[data-professional-loading]'),
				error: this.querySelector<HTMLElement>('[data-form-error]'),
				errorMessage: this.querySelector<HTMLElement>('[data-form-error-message]'),
				errorFeedback: this.querySelector<HTMLElement>('[data-professional-form-feedback]'),
				title: this.querySelector<HTMLElement>('[data-professional-modal-title]'),
				description: this.querySelector<HTMLElement>('[data-professional-modal-description]'),
				submitIcon: this.querySelector<HTMLElement>('[data-submit-professional-icon]'),
				submitLabel: this.querySelector<HTMLElement>('[data-submit-professional-label]'),
				imageFileName: this.querySelector<HTMLElement>('[data-image-file-name]'),
				previewImg: this.querySelector<HTMLImageElement>('[data-profile-preview]'),
				previewPlaceholder: this.querySelector<HTMLElement>('[data-profile-placeholder]'),
				photoDropzone: this.querySelector<HTMLElement>('[data-profile-upload-dropzone]'),
				profileUploadIcon: this.querySelector<HTMLElement>('[data-profile-upload-icon]'),
				profileUploadButton: this.querySelector<HTMLLabelElement>('[data-profile-upload-button]'),
				roleSelfAdminHint: this.querySelector<HTMLElement>('[data-role-self-admin-hint]'),
				cropModal: this.querySelector<HTMLDialogElement>('[data-profile-crop-modal]'),
				cropMount: this.querySelector<HTMLElement>('[data-profile-crop-mount]'),
				confirmCropBtn: this.querySelector<HTMLButtonElement>('[data-confirm-profile-crop]'),
			};

			const formNode = this.els.form;
			this.formEls = {
				username: formNode?.querySelector<HTMLInputElement>('input[name="apex_user_name"]') || null,
				email: formNode?.querySelector<HTMLInputElement>('input[name="email"]') || null,
				firstName: formNode?.querySelector<HTMLInputElement>('input[name="first_name"]') || null,
				lastName: formNode?.querySelector<HTMLInputElement>('input[name="last_name"]') || null,
				password: formNode?.querySelector<HTMLInputElement>('input[name="password"]') || null,
				role: formNode?.querySelector<HTMLSelectElement>('select[name="rol_id_role"]') || null,
				phone: formNode?.querySelector<HTMLInputElement>('input[name="phone_number"]') || null,
				specialty: formNode?.querySelector<HTMLSelectElement>('select[name="spe_id_specialty"]') || null,
				userActive: formNode?.querySelector<HTMLInputElement>('input[name="user_is_active"]') || null,
				profActive: formNode?.querySelector<HTMLInputElement>('input[name="prof_is_active"]') || null,
				panelAccessToggle: formNode?.querySelector<HTMLInputElement>('[data-panel-access-toggle]') || null,
				publicVisibilityToggle:
					formNode?.querySelector<HTMLInputElement>('[data-public-visibility-toggle]') || null,
				slug: formNode?.querySelector<HTMLInputElement>('input[name="profile_slug"]') || null,
				image: formNode?.querySelector<HTMLInputElement>('input[name="profile_image"]') || null,
				services: formNode?.querySelector<HTMLSelectElement>('select[name="services"]') || null,
				fieldsets: formNode 
					? Array.from(formNode.querySelectorAll<HTMLFieldSetElement>('fieldset')) 
					: [],
				fieldErrors: Array.from(this.querySelectorAll<HTMLElement>('[data-field-error]')),
			};

			this.addEventListener('click', this.handleRootClick, { signal });
			this.addEventListener('keydown', this.handleRootKeydown, { signal });
			this.els.form?.addEventListener('submit', this.handleSubmit, { signal });
			this.els.accountStatusActiveBtn?.addEventListener('click', () => this.setMemberAccountActive(1), {
				signal,
			});
			this.els.accountStatusInactiveBtn?.addEventListener('click', () => this.setMemberAccountActive(0), {
				signal,
			});
			this.formEls.panelAccessToggle?.addEventListener('change', () => this.handlePanelAccessToggle(), {
				signal,
			});
			this.formEls.publicVisibilityToggle?.addEventListener(
				'change',
				() => this.handlePublicVisibilityToggle(),
				{ signal }
			);

			this.formEls.image?.addEventListener('change', () => this.handleProfileImageInputChange(), { signal });
			this.els.photoDropzone?.addEventListener('dragover', this.handlePhotoDragOver, { signal });
			this.els.photoDropzone?.addEventListener('dragleave', this.handlePhotoDragLeave, { signal });
			this.els.photoDropzone?.addEventListener('drop', this.handlePhotoDrop, { signal });
			this.formEls.phone?.addEventListener('input', this.handlePhoneInput, { signal });

			// Slug events
			this.formEls.slug?.addEventListener('input', () => {
				if (this.suppressSlugManualTracking) return;
				const val = String(this.formEls.slug?.value || '').trim();
				this.slugManuallyEdited = val !== '';
				if (!this.slugManuallyEdited) this.queueSlugSuggestion();
			}, { signal });
			this.formEls.firstName?.addEventListener('input', () => this.queueSlugSuggestion(), { signal });
			this.formEls.lastName?.addEventListener('input', () => this.queueSlugSuggestion(), { signal });

			this.querySelector<HTMLButtonElement>('[data-professional-profile-url-tour-help]')?.addEventListener(
				'click',
				() => showProfessionalProfileUrlTour(),
				{ signal }
			);
		}

		disconnectedCallback() {
			this.abortController?.abort();
			this.abortController = null;
			if (this.closeTimer) window.clearTimeout(this.closeTimer);
			this.clearSlugSuggestTimer();
			if (this.servicesTom) {
				this.servicesTom.destroy();
				this.servicesTom = null;
			}
			this.closeProfileImageCrop(true);
		}

		private async requestApi<T = any>(url: string, options?: RequestInit): Promise<any> {
			const response = await fetch(url, options);
			const contentType = response.headers.get('content-type') || '';
			let data: Record<string, unknown> | null = null;

			if (contentType.includes('application/json')) {
				try {
					data = await response.json();
				} catch {
					throw new Error('Error al interpretar respuesta del servidor.');
				}
			} else if (!response.ok) {
				throw new Error(
					response.status === 401
						? 'Tu sesión ha finalizado. Vuelve a iniciar sesión.'
						: `Error en la petición (${response.status}).`
				);
			}

			if (!response.ok || !data || data.status !== 'success') {
				if (data?.code === 'SESSION_EXPIRED') return null;
				const error = new Error(String(data?.message || 'Error en la petición.'));
				(error as any).apiData = data;
				throw error;
			}
			return data;
		}

		private handleRootClick = (event: MouseEvent) => {
			const target = event.target;
			if (!(target instanceof Element)) return;

			if (this.els.cropModal?.open && this.els.cropModal === target) {
				this.closeProfileImageCrop(true);
				return;
			}

			const closeCropTrigger = target.closest('[data-close-profile-crop]');
			if (closeCropTrigger && this.contains(closeCropTrigger)) {
				this.closeProfileImageCrop(true);
				return;
			}

			const confirmCropTrigger = target.closest('[data-confirm-profile-crop]');
			if (confirmCropTrigger && this.contains(confirmCropTrigger)) {
				void this.confirmProfileImageCrop();
				return;
			}

			if (this.els.modal && target === this.els.modal) {
				this.closeModal();
				return;
			}

			const closeTrigger = target.closest('[data-close-professional-modal]');
			if (closeTrigger && this.contains(closeTrigger)) {
				this.closeModal();
				return;
			}

			const deleteTrigger = target.closest('[data-delete-professional]');
			if (deleteTrigger && this.contains(deleteTrigger)) {
				void this.handleDelete();
				return;
			}

			const copyUrlTrigger = target.closest<HTMLButtonElement>('[data-copy-professional-profile-url]');
			if (copyUrlTrigger && this.contains(copyUrlTrigger)) {
				event.preventDefault();
				void this.copyPublicProfileUrl(copyUrlTrigger);
				return;
			}

			const dismissErrorTrigger = target.closest('[data-dismiss-form-error]');
			if (dismissErrorTrigger && this.contains(dismissErrorTrigger)) {
				event.preventDefault();
				this.clearFormError();
				return;
			}

			const openTrigger = target.closest('[data-open-professional-modal], [data-professional-card]');
			if (!openTrigger || !this.contains(openTrigger)) return;

			const card = openTrigger.closest('[data-professional-card]');
			if (card) {
				const id = Number(card.getAttribute('data-professional-id') || '0');
				if (id > 0) void this.openEditModal(id);
				return;
			}

			void this.openCreateModal();
		};

		private handleRootKeydown = (event: KeyboardEvent) => {
			if (event.key !== 'Enter' && event.key !== ' ') return;
			const target = event.target;
			if (!(target instanceof Element)) return;

			const card = target.closest('[data-professional-card]');
			if (card && this.contains(card)) {
				event.preventDefault();
				const id = Number(card.getAttribute('data-professional-id') || '0');
				if (id > 0) void this.openEditModal(id);
				return;
			}
		};

		private isEditingSelfAdmin() {
			return (
				this.mode === 'edit' &&
				this.editingUserId !== null &&
				this.editingUserId === this.currentUserId &&
				this.editingRoleId === this.adminRoleId
			);
		}

		private setFieldLocked(field: HTMLElement | null, locked: boolean) {
			if (!field) return;
			if (field instanceof HTMLSelectElement || field instanceof HTMLInputElement) {
				field.disabled = locked;
			}
			field.classList.toggle('is-locked', locked);
			field.closest('label')?.classList.toggle('is-locked', locked);
		}

		private resetMemberStatusDefaults() {
			this.memberAccountActive = 1;
			this.panelAccessEnabled = 1;
			this.publicVisibilityEnabled = 1;
			this.savedPermissionsBeforeInactive = null;
			this.renderMemberStatusUI();
		}

		private loadMemberStatusFromRecord(userIsActive: 0 | 1, profIsActive: 0 | 1) {
			const bothOff = userIsActive === 0 && profIsActive === 0;
			this.memberAccountActive = bothOff ? 0 : 1;
			this.panelAccessEnabled = userIsActive;
			this.publicVisibilityEnabled = profIsActive;
			this.savedPermissionsBeforeInactive = null;
			this.renderMemberStatusUI();
		}

		private setMemberAccountActive(value: 0 | 1) {
			if (this.isEditingSelfAdmin()) return;

			if (value === 0) {
				this.savedPermissionsBeforeInactive = {
					panel: this.panelAccessEnabled,
					visibility: this.publicVisibilityEnabled,
				};
				this.panelAccessEnabled = 0;
				this.publicVisibilityEnabled = 0;
			} else if (this.savedPermissionsBeforeInactive) {
				this.panelAccessEnabled = this.savedPermissionsBeforeInactive.panel;
				this.publicVisibilityEnabled = this.savedPermissionsBeforeInactive.visibility;
				this.savedPermissionsBeforeInactive = null;
			} else if (this.panelAccessEnabled === 0 && this.publicVisibilityEnabled === 0) {
				this.panelAccessEnabled = 1;
				this.publicVisibilityEnabled = 1;
			}

			this.memberAccountActive = value;
			this.renderMemberStatusUI();
		}

		private handlePanelAccessToggle() {
			if (this.memberAccountActive === 0 || this.isEditingSelfAdmin()) return;
			this.panelAccessEnabled = this.formEls.panelAccessToggle?.checked ? 1 : 0;
			this.syncHiddenActiveFields();
			this.editingUserIsActive = this.panelAccessEnabled;
		}

		private handlePublicVisibilityToggle() {
			if (this.memberAccountActive === 0 || this.isEditingSelfAdmin()) return;
			this.publicVisibilityEnabled = this.formEls.publicVisibilityToggle?.checked ? 1 : 0;
			this.syncHiddenActiveFields();
			this.editingProfIsActive = this.publicVisibilityEnabled;
		}

		private syncHiddenActiveFields() {
			const userValue = this.memberAccountActive === 1 ? this.panelAccessEnabled : 0;
			const profValue = this.memberAccountActive === 1 ? this.publicVisibilityEnabled : 0;
			if (this.formEls.userActive) this.formEls.userActive.value = String(userValue);
			if (this.formEls.profActive) this.formEls.profActive.value = String(profValue);
		}

		private renderMemberStatusUI() {
			const isSelfAdmin = this.isEditingSelfAdmin();
			const isAccountActive = this.memberAccountActive === 1;
			const permissionsDisabled = !isAccountActive || isSelfAdmin;

			this.els.accountStatusActiveBtn?.classList.toggle('is-selected', isAccountActive);
			this.els.accountStatusInactiveBtn?.classList.toggle('is-selected', !isAccountActive);
			this.els.accountStatusActiveBtn?.setAttribute('aria-pressed', isAccountActive ? 'true' : 'false');
			this.els.accountStatusInactiveBtn?.setAttribute('aria-pressed', isAccountActive ? 'false' : 'true');
			this.els.accountStatusActiveBtn?.toggleAttribute('disabled', isSelfAdmin);
			this.els.accountStatusInactiveBtn?.toggleAttribute('disabled', isSelfAdmin);

			this.els.permissionsBlock?.classList.toggle('is-disabled', !isAccountActive);

			if (this.formEls.panelAccessToggle) {
				this.formEls.panelAccessToggle.checked = this.panelAccessEnabled === 1;
				this.formEls.panelAccessToggle.disabled = permissionsDisabled;
			}
			if (this.formEls.publicVisibilityToggle) {
				this.formEls.publicVisibilityToggle.checked = this.publicVisibilityEnabled === 1;
				this.formEls.publicVisibilityToggle.disabled = permissionsDisabled;
			}

			this.syncHiddenActiveFields();
			this.editingUserIsActive = isAccountActive ? this.panelAccessEnabled : 0;
			this.editingProfIsActive = isAccountActive ? this.publicVisibilityEnabled : 0;
		}

		private resolveActiveFlagsForSubmit(isSelfAdmin: boolean): { user_is_active: 0 | 1; prof_is_active: 0 | 1 } {
			if (isSelfAdmin && this.editingUserIsActive !== null && this.editingProfIsActive !== null) {
				return {
					user_is_active: this.editingUserIsActive,
					prof_is_active: this.editingProfIsActive,
				};
			}

			if (this.memberAccountActive === 0) {
				return { user_is_active: 0, prof_is_active: 0 };
			}

			return {
				user_is_active: this.panelAccessEnabled,
				prof_is_active: this.publicVisibilityEnabled,
			};
		}

		private applyDeleteButtonVisibility() {
			const isPendingInvite =
				this.mode === 'edit' && this.editingMembershipStatus === 'pending_invite';
			const isSelfAdmin = this.isEditingSelfAdmin();
			const showCancelInvite = isPendingInvite && !isSelfAdmin;

			if (this.els.deleteBtnIcon) {
				this.els.deleteBtnIcon.textContent = showCancelInvite ? 'mail_off' : 'delete';
			}
			if (this.els.deleteBtnLabel) {
				this.els.deleteBtnLabel.textContent = showCancelInvite
					? 'Cancelar invitación'
					: 'Eliminar';
			}

			if (this.els.deleteBtn) {
				if (showCancelInvite) {
					this.els.deleteBtn.classList.remove('hidden');
					this.els.deleteBtn.disabled = false;
				} else {
					this.els.deleteBtn.classList.add('hidden');
					this.els.deleteBtn.disabled = true;
				}
			}
		}

		private applySelfAdminFieldRestrictions() {
			const isSelfAdmin = this.isEditingSelfAdmin();

			this.setFieldLocked(this.formEls.role, isSelfAdmin);

			if (this.els.roleSelfAdminHint) {
				this.els.roleSelfAdminHint.classList.toggle('hidden', !isSelfAdmin);
			}

			this.renderMemberStatusUI();
			this.applyDeleteButtonVisibility();
		}

		private updateUIMode(newMode: ProfessionalMode) {
			this.mode = newMode;
			const isEdit = this.mode === 'edit';

			if (this.els.title) this.els.title.textContent = isEdit ? 'Editar personal' : 'Invitar personal';
			if (this.els.description) {
				const isPendingInvite = isEdit && this.editingMembershipStatus === 'pending_invite';
				this.els.description.textContent = isEdit
					? isPendingInvite
						? 'Actualiza los datos de la invitación pendiente. El correo solo aplica hasta que la persona acepte.'
						: 'Modifica los datos del profesional en tu organización. Las credenciales de acceso no se editan desde aquí.'
					: 'Completa los datos básicos y envía una invitación por correo. La persona definirá su contraseña al aceptar.';
			}
			if (this.els.submitLabel) this.els.submitLabel.textContent = isEdit ? 'Guardar cambios' : 'Enviar invitación';
			if (this.els.submitIcon) this.els.submitIcon.textContent = isEdit ? 'save' : 'mail';

			if (!isEdit) {
				this.editingUserId = null;
				this.editingRoleId = null;
				this.editingUserIsActive = null;
				this.editingProfIsActive = null;
				this.editingMembershipStatus = null;
			}

			this.applySelfAdminFieldRestrictions();
			this.applyAccountFieldVisibility();
		}

		private applyAccountFieldVisibility() {
			const isCreate = this.mode === 'create';
			const isPendingInvite = this.mode === 'edit' && this.editingMembershipStatus === 'pending_invite';
			const isActiveMember = this.mode === 'edit' && this.editingMembershipStatus === 'active';
			const showStatusSection = isCreate || isActiveMember;

			const emailEditable = this.querySelector('[data-professional-email-editable]');
			const accountReadonly = this.querySelector('[data-professional-account-readonly]');
			const inviteHint = this.querySelector('[data-professional-invite-hint]');
			const pendingEmailHint = this.querySelector('[data-professional-pending-email-hint]');

			this.els.statusSection?.classList.toggle('hidden', !showStatusSection);
			emailEditable?.classList.toggle('hidden', isActiveMember);
			accountReadonly?.classList.toggle('hidden', !isActiveMember);
			inviteHint?.classList.toggle('hidden', !isCreate);
			pendingEmailHint?.classList.toggle('hidden', !isPendingInvite);

			if (this.formEls.email instanceof HTMLInputElement) {
				this.formEls.email.required = isCreate || isPendingInvite;
				this.formEls.email.disabled = isActiveMember;
			}
		}

		private toggleFormLoading(isLoading: boolean) {
			if (this.els.loading) {
				isLoading
					? this.els.loading.classList.replace('hidden', 'flex')
					: this.els.loading.classList.replace('flex', 'hidden');
			}
			for (const fieldset of this.formEls.fieldsets) {
				fieldset.disabled = isLoading;
			}
			for (const field of this.els.form?.querySelectorAll<HTMLInputElement>(
				'[name="first_name"], [name="last_name"], [name="profile_slug"], [name="profile_image"]'
			) ?? []) {
				field.disabled = isLoading;
			}
			if (this.els.deleteBtn) this.els.deleteBtn.disabled = isLoading;
			const submitBtn = this.els.form?.querySelector<HTMLButtonElement>('[data-submit-professional]');
			if (submitBtn) submitBtn.disabled = isLoading;
			
			if (this.servicesTom) {
				isLoading ? this.servicesTom.disable() : this.servicesTom.enable();
			}

			if (!isLoading) {
				this.applySelfAdminFieldRestrictions();
			}
		}

		private setLoadingMessage(message: string) {
			if (!this.els.loading) return;
			const textNode = this.els.loading.querySelector('div')?.lastChild;
			if (textNode) textNode.textContent = ` ${message}`;
		}

		private showFormError(message: string) {
			if (!this.els.error || !this.els.errorMessage) return;
			this.els.errorMessage.textContent = message;
			this.els.error.classList.remove('hidden');
			this.els.errorFeedback?.classList.add('is-visible');
		}

		private clearFormError() {
			if (this.els.errorMessage) this.els.errorMessage.textContent = '';
			this.els.error?.classList.add('hidden');
			this.els.errorFeedback?.classList.remove('is-visible');
		}

		private getPublicProfileUrl(): string {
			const slug = String(this.formEls.slug?.value || '').trim().replace(/^\/+/, '');
			if (!slug) return '';
			const prefix = String(this.publicProfilePrefix || '').trim();
			if (!prefix) return `/${slug}`;
			return `${prefix.replace(/\/+$/, '')}/${slug.replace(/^\/+/, '')}`;
		}

		private async writeClipboardText(value: string) {
			if (navigator.clipboard?.writeText) {
				await navigator.clipboard.writeText(value);
				return;
			}

			const textarea = document.createElement('textarea');
			textarea.value = value;
			textarea.setAttribute('readonly', '');
			textarea.style.position = 'fixed';
			textarea.style.opacity = '0';
			document.body.appendChild(textarea);
			textarea.select();
			document.execCommand('copy');
			textarea.remove();
		}

		private async copyPublicProfileUrl(button: HTMLButtonElement) {
			const url = this.getPublicProfileUrl();
			if (!url) {
				this.showFormError('Ingresa una URL de perfil público antes de copiar.');
				return;
			}

			const icon = button.querySelector<HTMLElement>('[data-copy-professional-profile-url-icon]');
			try {
				await this.writeClipboardText(url);
				if (icon) icon.textContent = 'check';
				button.classList.add('text-emerald-500');
				window.setTimeout(() => {
					if (icon) icon.textContent = 'content_copy';
					button.classList.remove('text-emerald-500');
				}, 1400);
			} catch {
				this.showFormError('No fue posible copiar la URL. Intenta nuevamente.');
			}
		}

		private clearErrors() {
			this.clearFormError();
			for (const node of this.formEls.fieldErrors) {
				node.textContent = '';
				node.classList.add('hidden');
			}
		}

		private toParaguayPhoneLocalDigits(rawValue: string) {
			const parsedPhone = parseParaguayMobilePhone(rawValue);
			if (parsedPhone.isValid) return parsedPhone.e164.slice(4);

			let digits = String(rawValue || '').replace(/\D/g, '');
			if (digits.startsWith('00595')) digits = digits.slice(5);
			if (digits.startsWith('595')) digits = digits.slice(3);
			if (digits.startsWith('0')) digits = digits.slice(1);
			return digits.slice(0, 9);
		}

		private formatParaguayPhoneLocal(rawValue: string) {
			const digits = this.toParaguayPhoneLocalDigits(rawValue);
			if (!digits) return '';
			if (digits.length <= 3) return digits;
			if (digits.length <= 6) return `${digits.slice(0, 3)} ${digits.slice(3)}`;
			return `${digits.slice(0, 3)} ${digits.slice(3, 6)} ${digits.slice(6, 9)}`;
		}

		private setPhoneFieldError(message: string) {
			const phoneFieldNode = this.formEls.fieldErrors.find(
				(el) => el.getAttribute('data-field-error') === 'phone_number'
			);
			if (!phoneFieldNode) return;
			phoneFieldNode.textContent = message;
			phoneFieldNode.classList.remove('hidden');
		}

		private handlePhoneInput = () => {
			if (!this.formEls.phone) return;
			this.formEls.phone.value = this.formatParaguayPhoneLocal(this.formEls.phone.value);
			const phoneFieldNode = this.formEls.fieldErrors.find(
				(el) => el.getAttribute('data-field-error') === 'phone_number'
			);
			if (phoneFieldNode) {
				phoneFieldNode.textContent = '';
				phoneFieldNode.classList.add('hidden');
			}
		}

		private renderFieldErrors(errors: unknown, fallbackMessage = '') {
			let rendered = false;
			const items = Array.isArray(errors) ? errors : [];

			for (const err of items) {
				if (!err || typeof err !== 'object') continue;
				const field = 'field' in err ? String(err.field || '') : '';
				const messageText = 'message' in err ? String(err.message || '') : '';
				if (!field || !messageText) continue;

				const fieldNode = this.formEls.fieldErrors.find((el) => el.getAttribute('data-field-error') === field);
				if (!fieldNode) continue;
				fieldNode.textContent = messageText;
				fieldNode.classList.remove('hidden');
				rendered = true;
			}

			if (rendered) return true;

			if (typeof fallbackMessage === 'string' && /slug|perfil/i.test(fallbackMessage)) {
				const slugFieldNode = this.formEls.fieldErrors.find((el) => el.getAttribute('data-field-error') === 'profile_slug');
				if (slugFieldNode) {
					slugFieldNode.textContent = fallbackMessage;
					slugFieldNode.classList.remove('hidden');
					return true;
				}
			}

			return false;
		}

		private setPreviewImage(url?: string | null) {
			const raw = String(url || '').trim();
			const normalized = ['null', 'undefined'].includes(raw.toLowerCase()) ? '' : raw;
			const hasImage = normalized.length > 0;

			if (this.els.previewImg) {
				this.els.previewImg.dataset.originalSrc = normalized;
				this.els.previewImg.onerror = () => this.setPreviewImage(null);
				if (hasImage) {
					this.els.previewImg.src = normalized;
					this.els.previewImg.classList.remove('hidden');
				} else {
					this.els.previewImg.src = '';
					this.els.previewImg.classList.add('hidden');
				}
			}

			if (this.els.previewPlaceholder) {
				this.els.previewPlaceholder.classList.toggle('hidden', hasImage);
			}
		}

		private resetFormValues() {
			if (this.els.form) this.els.form.reset();
			this.resetMemberStatusDefaults();
			this.setPreviewImage(null);
			this.setImageFileNameLabel();
			this.setSelectedServices([]);
			this.servicesTouched = false;
			this.editServicesAvailable = false;
			this.slugManuallyEdited = false;
			this.clearSlugSuggestTimer();
			this.slugRequestSeq += 1;
		}

		private setImageFileNameLabel() {
			if (!this.els.imageFileName) return;
			const file = this.formEls.image?.files?.[0];
			this.els.imageFileName.textContent = file ? file.name : 'Cambiar foto';
			const imageFieldNode = this.formEls.fieldErrors.find(
				(el) => el.getAttribute('data-field-error') === 'profile_image'
			);
			if (imageFieldNode) {
				imageFieldNode.textContent = '';
				imageFieldNode.classList.add('hidden');
			}

			if (file) {
				this.showPhotoUploadSuccess();
				const reader = new FileReader();
				reader.onload = (e) => {
					this.setPreviewImage(String(e.target?.result || ''));
				};
				reader.readAsDataURL(file);
			} else {
				this.resetPhotoUploadIcon();
				const persistedImage = String(this.els.previewImg?.dataset.originalSrc || '').trim();
				if (this.mode === 'edit' && persistedImage) {
					this.setPreviewImage(persistedImage);
				} else {
					this.setPreviewImage(null);
				}
			}
		}

		private resetPhotoUploadIcon() {
			if (this.els.profileUploadIcon) {
				this.els.profileUploadIcon.textContent = 'add_photo_alternate';
			}
			this.els.profileUploadButton?.classList.remove('is-success');
		}

		private showPhotoUploadSuccess() {
			if (this.els.profileUploadIcon) {
				this.els.profileUploadIcon.textContent = 'check';
			}
			this.els.profileUploadButton?.classList.add('is-success');
			window.setTimeout(() => this.resetPhotoUploadIcon(), 1400);
		}

		private setProfileImageFieldError(message: string) {
			const imageFieldNode = this.formEls.fieldErrors.find(
				(el) => el.getAttribute('data-field-error') === 'profile_image'
			);
			if (!imageFieldNode) return;
			imageFieldNode.textContent = message;
			imageFieldNode.classList.toggle('hidden', message.trim() === '');
		}

		private setProfileImageFile(file: File) {
			if (!this.formEls.image) return;
			const dataTransfer = new DataTransfer();
			dataTransfer.items.add(file);
			this.formEls.image.files = dataTransfer.files;
			this.setImageFileNameLabel();
		}

		private resetProfileImageInput() {
			if (this.formEls.image) {
				this.formEls.image.value = '';
			}
		}

		private handleProfileImageInputChange() {
			const file = this.formEls.image?.files?.[0] ?? null;
			this.resetProfileImageInput();
			if (!file) return;
			void this.openProfileImageCrop(file);
		}

		private async openProfileImageCrop(file: File) {
			if (this.formEls.image?.disabled) return;
			if (!isAcceptedProfileImage(file)) {
				this.setProfileImageFieldError('Selecciona una imagen JPG o PNG.');
				return;
			}

			if (!this.els.cropModal || !this.els.cropMount) {
				this.setProfileImageFile(file);
				return;
			}

			this.setProfileImageFieldError('');
			this.pendingCropSource = file;
			this.cropBusy = true;
			this.setCropModalBusy(true);

			if (!this.profileImageCropper) {
				this.profileImageCropper = new ProfileImageCropper(this.els.cropMount);
			}

			try {
				if (!this.els.cropModal.open) {
					this.els.cropModal.showModal();
				}
				await this.profileImageCropper.bindFile(file);
			} catch {
				this.setProfileImageFieldError('No se pudo preparar la imagen para recortar.');
				this.closeProfileImageCrop(true);
			} finally {
				this.cropBusy = false;
				this.setCropModalBusy(false);
			}
		}

		private setCropModalBusy(busy: boolean) {
			if (this.els.confirmCropBtn) {
				this.els.confirmCropBtn.disabled = busy;
			}
		}

		private closeProfileImageCrop(cancelled: boolean) {
			if (this.els.cropModal?.open) {
				this.els.cropModal.close();
			}
			this.profileImageCropper?.destroy();
			this.pendingCropSource = null;
			this.cropBusy = false;
			this.setCropModalBusy(false);
			if (cancelled) {
				this.resetProfileImageInput();
			}
		}

		private async confirmProfileImageCrop() {
			if (this.cropBusy || !this.pendingCropSource || !this.profileImageCropper) return;

			this.cropBusy = true;
			this.setCropModalBusy(true);

			try {
				const cropped = await this.profileImageCropper.exportJpeg(this.pendingCropSource.name);
				this.setProfileImageFile(cropped);
				this.closeProfileImageCrop(false);
			} catch {
				this.setProfileImageFieldError('No se pudo recortar la imagen. Intenta de nuevo.');
			} finally {
				this.cropBusy = false;
				this.setCropModalBusy(false);
			}
		}

		private handlePhotoDragOver = (event: DragEvent) => {
			if (this.formEls.image?.disabled) return;
			event.preventDefault();
			this.els.photoDropzone?.classList.add('is-dragover');
		}

		private handlePhotoDragLeave = (event: DragEvent) => {
			if (
				event.relatedTarget instanceof Node &&
				this.els.photoDropzone?.contains(event.relatedTarget)
			) {
				return;
			}
			this.els.photoDropzone?.classList.remove('is-dragover');
		}

		private handlePhotoDrop = (event: DragEvent) => {
			if (this.formEls.image?.disabled) return;
			event.preventDefault();
			this.els.photoDropzone?.classList.remove('is-dragover');
			const file = Array.from(event.dataTransfer?.files ?? []).find((item) =>
				['image/jpeg', 'image/png'].includes(item.type)
			);
			if (!file) {
				this.setProfileImageFieldError('Selecciona una imagen JPG o PNG.');
				return;
			}
			void this.openProfileImageCrop(file);
		}

		private clearSlugSuggestTimer() {
			if (this.slugSuggestTimer) {
				window.clearTimeout(this.slugSuggestTimer);
				this.slugSuggestTimer = null;
			}
		}

		private queueSlugSuggestion() {
			if (!this.formEls.slug) return;
			const first = String(this.formEls.firstName?.value || '').trim();
			const last = String(this.formEls.lastName?.value || '').trim();
			const fullName = `${first} ${last}`.trim();
			
			if (!fullName) return;
			if (this.slugManuallyEdited && this.formEls.slug.value.trim() !== '') return;

			this.clearSlugSuggestTimer();
			const currentRequest = ++this.slugRequestSeq;
			
			this.slugSuggestTimer = window.setTimeout(async () => {
				try {
					const response = await fetch(`/api/professionals/slug/suggest?name=${encodeURIComponent(fullName)}`, {
						headers: { Accept: 'application/json' },
					});
					const data = await response.json();
					if (currentRequest !== this.slugRequestSeq || !response.ok || data.status !== 'success' || !data.slug) return;
					if (this.slugManuallyEdited && this.formEls.slug!.value.trim() !== '') return;
					
					this.suppressSlugManualTracking = true;
					this.formEls.slug!.value = data.slug.trim();
					this.suppressSlugManualTracking = false;
				} catch {}
			}, 350);
		}

		private async ensureSpecialtiesLoaded() {
			if (this.specialtiesLoaded) return;
			if (this.specialtiesLoadPromise) return this.specialtiesLoadPromise;

			if (this.formEls.specialty) this.formEls.specialty.disabled = true;
			
			this.specialtiesLoadPromise = (async () => {
				const data = await this.requestApi('/api/specialties?page=1&limit=100');
				
				if (this.formEls.specialty) {
					this.formEls.specialty.innerHTML = '<option value="">Sin especialidad</option>';
					data.data.forEach((s: any) => {
						const option = document.createElement('option');
						option.value = String(s.id_specialty);
						option.textContent = s.name;
						this.formEls.specialty?.appendChild(option);
					});
				}
				this.specialtiesLoaded = true;
			})().finally(() => {
				if (this.formEls.specialty) this.formEls.specialty.disabled = false;
				this.specialtiesLoadPromise = null;
			});
			return this.specialtiesLoadPromise;
		}

		private async ensureRolesLoaded() {
			if (this.rolesLoaded) return;
			if (this.rolesLoadPromise) return this.rolesLoadPromise;

			if (this.formEls.role) this.formEls.role.disabled = true;
			
			this.rolesLoadPromise = (async () => {
				const data = await this.requestApi('/api/roles');
				
				if (this.formEls.role) {
					this.formEls.role.innerHTML = '<option value="">Selecciona un rol</option>';
					data.data.forEach((r: any) => {
						const option = document.createElement('option');
						option.value = String(r.id_role);
						option.textContent = r.name;
						this.formEls.role?.appendChild(option);
					});
				}
				this.rolesLoaded = true;
			})().finally(() => {
				this.applySelfAdminFieldRestrictions();
				this.rolesLoadPromise = null;
			});
			return this.rolesLoadPromise;
		}

		private ensureServicesControl() {
			if (!this.formEls.services || this.servicesTom) return;
			
			this.servicesTom = new TomSelect(this.formEls.services, {
				plugins: { remove_button: { title: 'Quitar' } },
				placeholder: 'Busca o selecciona servicios...',
				create: false,
				persist: false,
				maxOptions: 200,
				closeAfterSelect: false,
				hideSelected: true,
			});
			
			this.servicesTom.on('change', () => {
				if (!this.suppressServicesTouched) this.servicesTouched = true;
			});
		}

		private async ensureServicesLoaded() {
			this.ensureServicesControl();
			if (this.servicesLoaded) return;
			if (this.servicesLoadPromise) return this.servicesLoadPromise;

			this.servicesTom?.disable();
			
			this.servicesLoadPromise = (async () => {
				const data = await this.requestApi('/api/services/lov');
				
				this.servicesTom?.clear(true);
				this.servicesTom?.clearOptions();
				data.data.forEach((s: any) => {
					this.servicesTom?.addOption({ value: String(s.id_service), text: s.name });
				});
				this.servicesTom?.refreshOptions(false);
				
				this.servicesLoaded = true;
			})().finally(() => {
				this.servicesTom?.enable();
				this.servicesLoadPromise = null;
			});
			return this.servicesLoadPromise;
		}

		private setSelectedServices(serviceIds: number[]) {
			if (!this.servicesTom) return;
			this.suppressServicesTouched = true;
			this.servicesTom.setValue(serviceIds.map(String) as any, true);
			this.suppressServicesTouched = false;
		}

		private getSelectedServiceIds(): number[] {
			if (!this.servicesTom) return [];
			const val = this.servicesTom.getValue();
			const arr = Array.isArray(val) ? val : String(val || '').split(',');
			return arr.map(Number).filter(n => Number.isInteger(n) && n > 0);
		}

		private async openCreateModal() {
			this.updateUIMode('create');
			this.editingId = null;
			this.resetFormValues();
			this.clearErrors();
			this.toggleFormLoading(false);
			
			this.els.modal?.classList.remove('is-closing');
			if (this.closeTimer) {
				window.clearTimeout(this.closeTimer);
				this.closeTimer = null;
			}
			if (this.els.modal && !this.els.modal.open) this.els.modal.showModal();
			
			try {
				await Promise.all([this.ensureSpecialtiesLoaded(), this.ensureRolesLoaded(), this.ensureServicesLoaded()]);
			} catch (err) {
				this.showFormError(err instanceof Error ? err.message : 'Error al cargar catálogos.');
			}
		}

		private async openEditModal(id: number) {
			const reqId = ++this.professionalReadRequestSeq;
			this.updateUIMode('edit');
			this.editingId = id;
			this.resetFormValues();
			this.clearErrors();
			
			this.els.modal?.classList.remove('is-closing');
			if (this.closeTimer) {
				window.clearTimeout(this.closeTimer);
				this.closeTimer = null;
			}
			if (this.els.modal && !this.els.modal.open) this.els.modal.showModal();
			this.setLoadingMessage('Cargando...');
			this.toggleFormLoading(true);

			try {
				const data = await this.requestApi(`/api/professionals/${id}`);
				if (reqId !== this.professionalReadRequestSeq) return;
				
				await Promise.all([this.ensureSpecialtiesLoaded(), this.ensureRolesLoaded(), this.ensureServicesLoaded()]);
				if (reqId !== this.professionalReadRequestSeq) return;
				
				const prof = data.data;
				const user = prof.user || {};
				this.editingMembershipStatus =
					prof.membership_status === 'pending_invite' ? 'pending_invite' : 'active';
				this.applyAccountFieldVisibility();

				const readonlyEmail = this.querySelector('[data-readonly-account-email]');
				if (readonlyEmail) readonlyEmail.textContent = user.email || '—';
				
				const { formEls } = this;
				if (formEls.email) formEls.email.value = user.email || '';
				if (formEls.firstName) formEls.firstName.value = user.first_name || '';
				if (formEls.lastName) formEls.lastName.value = user.last_name || '';
				if (formEls.role) formEls.role.value = user.rol_id_role || '';
				this.editingUserId = Number(user.id_user || 0) || null;
				this.editingRoleId = Number(user.rol_id_role || 0) || null;
				this.editingUserIsActive = user.is_active === 0 ? 0 : 1;
				this.editingProfIsActive = prof.is_active === 0 ? 0 : 1;
				this.applySelfAdminFieldRestrictions();
				this.loadMemberStatusFromRecord(this.editingUserIsActive, this.editingProfIsActive);
				if (formEls.phone) formEls.phone.value = this.formatParaguayPhoneLocal(prof.phone_number || '');
				if (formEls.slug) formEls.slug.value = prof.profile_slug || '';
				
				this.setPreviewImage(prof.profile_image_url);

				const sId = prof.specialty?.id_specialty;
				if (formEls.specialty && sId) formEls.specialty.value = String(sId);
				
				const services = Array.isArray(prof.services) ? prof.services : [];
				this.editServicesAvailable = Array.isArray(prof.services);
				this.setSelectedServices(services);
				this.servicesTouched = false;
				this.slugManuallyEdited = false;
			} catch (err) {
				if (reqId !== this.professionalReadRequestSeq) return;
				this.updateUIMode('create');
				this.showFormError(err instanceof Error ? err.message : 'Error de carga.');
			} finally {
				if (reqId === this.professionalReadRequestSeq) {
					this.toggleFormLoading(false);
				}
			}
		}

		private closeModal() {
			if (!this.els.modal?.open) return;
			this.closeProfileImageCrop(true);
			this.professionalReadRequestSeq++;
			this.els.modal.classList.add('is-closing');
			this.clearSlugSuggestTimer();

			this.closeTimer = window.setTimeout(() => {
				this.els.modal?.close();
				this.els.modal?.classList.remove('is-closing');
				if (this.els.form) this.els.form.reset();
				this.resetFormValues();
				this.updateUIMode('create');
				this.toggleFormLoading(false);
				this.clearErrors();
				this.closeTimer = null;
			}, 140);
		}

		private async fileToBase64(file: File): Promise<string> {
			return new Promise((resolve, reject) => {
				const r = new FileReader();
				r.onload = () => {
					const res = String(r.result || '');
					resolve(res.includes(',') ? res.split(',')[1] : res);
				};
				r.onerror = () => reject(new Error('No se pudo procesar la imagen'));
				r.readAsDataURL(file);
			});
		}

		private handleSubmit = async (event: SubmitEvent) => {
			event.preventDefault();
			this.clearErrors();
			if (!this.els.form) return;
			
			const fd = new FormData(this.els.form);
			const isSelfAdmin = this.isEditingSelfAdmin();
			const roleRaw = isSelfAdmin && this.editingRoleId
				? String(this.editingRoleId)
				: String(fd.get('rol_id_role') || '').trim();
			const rawPhone = String(fd.get('phone_number') || '').trim();
			const parsedPhone = parseParaguayMobilePhone(rawPhone);
			if (!parsedPhone.isValid) {
				this.setPhoneFieldError(PARAGUAY_MOBILE_PHONE_ERROR);
				return;
			}
			
			const { user_is_active: userIsActive, prof_is_active: profIsActive } =
				this.resolveActiveFlagsForSubmit(isSelfAdmin);

			const payload: any = {
				rol_id_role: Number(roleRaw),
				first_name: String(fd.get('first_name') || '').trim(),
				last_name: String(fd.get('last_name') || '').trim(),
				phone_number: parsedPhone.e164,
				user_is_active: userIsActive,
				prof_is_active: profIsActive,
			};

			if (this.mode === 'create' || this.editingMembershipStatus === 'pending_invite') {
				payload.email = String(fd.get('email') || '').trim();
			}
			
			const slug = String(fd.get('profile_slug') || '').trim();
			if (slug) payload.profile_slug = slug;
			
			const sId = Number(fd.get('spe_id_specialty'));
			if (sId > 0) payload.spe_id_specialty = sId;
			
			if (this.mode === 'create' || this.editServicesAvailable || this.servicesTouched) {
				payload.services = this.getSelectedServiceIds();
			}
			
			const imgFile = this.formEls.image?.files?.[0];
			if (imgFile) {
				payload.image_base64 = await this.fileToBase64(imgFile);
				payload.image_name = imgFile.name;
				payload.image_mime = imgFile.type;
			}
			
			const method = this.mode === 'edit' ? 'PUT' : 'POST';
			const url = this.mode === 'edit' ? `/api/professionals/${this.editingId}` : '/api/professionals';
			
			this.setLoadingMessage(this.mode === 'edit' ? 'Guardando...' : 'Enviando invitación...');
			this.toggleFormLoading(true);
			
			try {
				const result = await this.requestApi(url, {
					method,
					headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
					body: JSON.stringify(payload)
				});
				if (!result) return;

				this.closeModal();
				void reloadPageWithFlash({
					message:
						String(result.message || '').trim() ||
						(this.mode === 'edit'
							? 'Profesional actualizado correctamente.'
							: 'Profesional creado correctamente.'),
					type: 'success',
				});
			} catch (err: any) {
				const apiData = err?.apiData;
				if (apiData?.can_reactivate === 1 || apiData?.can_reactivate === true) {
					const reactivateId = Number(apiData?.reactivate_professional_id || 0);
					const baseMessage = String(
						apiData?.message ||
							'Esta persona ya estuvo en tu organización. Reactivala desde su ficha.'
					);
					if (reactivateId > 0) {
						this.showFormError(baseMessage);
						void this.openEditModal(reactivateId);
					} else {
						this.showFormError(baseMessage);
					}
				} else if (apiData && apiData.errors) {
					const msg = err.message || 'Error al guardar.';
					const hasFieldErrors = this.renderFieldErrors(apiData.errors, msg);
					if (!hasFieldErrors || !msg.includes('verificar los campos')) {
						this.showFormError(msg);
					}
				} else {
					this.showFormError(err instanceof Error ? err.message : 'Error inesperado.');
				}
			} finally {
				this.toggleFormLoading(false);
			}
		};

		private async handleDelete() {
			if (!this.editingId) return;

			const isPendingInvite = this.editingMembershipStatus === 'pending_invite';
			if (!isPendingInvite) {
				this.showFormError(
					'Este profesional ya tiene cuenta en la organización. Abrí su ficha y activá el estado de la cuenta para reactivarlo.'
				);
				return;
			}
			
			const confirmed = await (window as any).BookmateAlert?.confirm?.({
				type: 'error',
				title: 'Cancelar invitación',
				message:
					'Se eliminará la invitación pendiente y el registro provisional. La persona no habrá ingresado aún a tu organización. ¿Continuar?',
				confirmText: 'Cancelar invitación',
				cancelText: 'Volver',
			});
			if (!confirmed) return;

			this.setLoadingMessage('Cancelando invitación...');
			this.toggleFormLoading(true);
			
			try {
				const result = await this.requestApi(`/api/professionals/${this.editingId}`, { method: 'DELETE' });
				void reloadPageWithFlash({
					message:
						String(result?.message || '').trim() ||
						'Invitación cancelada correctamente.',
					type: 'success',
				});
			} catch (err: any) {
				const apiData = err?.apiData;
				if (apiData?.deactivate === 1 || apiData?.deactivate === true) {
					this.showFormError(
						String(
							apiData?.message ||
								'Este profesional ya tiene cuenta. Usá los controles de estado para desactivar o reactivar.'
						)
					);
				} else {
					this.showFormError(err instanceof Error ? err.message : 'Error al cancelar la invitación');
				}
				this.toggleFormLoading(false);
			}
		}
	}

	if (!customElements.get('professional-manager')) {
		customElements.define('professional-manager', ProfessionalManager);
	}
</script>
