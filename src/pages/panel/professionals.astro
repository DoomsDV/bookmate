---
import AppAlert from '../../components/AppAlert.astro';
import FlashMessage from '../../components/FlashMessage.astro';
import ProfessionalsGrid from '../../components/ProfessionalsGrid.astro';
import SideNav from '../../components/SideNav.astro';
import TopBar from '../../components/TopBar.astro';
import { ProfessionalsApiError, listProfessionals, type Professional } from '../../lib/professionals';
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import 'tom-select/dist/css/tom-select.css';

const token = Astro.locals.token ?? '';
const PAGE_SIZE = 9;
const rawPage = Number(Astro.url.searchParams.get('page') || '1');
const currentPage = Number.isInteger(rawPage) && rawPage > 0 ? rawPage : 1;
const rawPublicProfilePrefix = String(import.meta.env.PUBLIC_PROFILE_DOMAIN ?? '').trim();
const publicProfilePrefix = rawPublicProfilePrefix
	? `${rawPublicProfilePrefix.replace(/\/+$/, '')}/`
	: `${Astro.url.origin.replace(/\/+$/, '')}/p/`;

let professionals: Professional[] = [];
let loadError = '';
let pagination = {
	current_page: currentPage,
	per_page: PAGE_SIZE,
	total_records: 0,
	total_pages: 1,
};

if (!token) {
	loadError = 'No hay sesión válida para consultar personal.';
} else {
	try {
		const listResult = await listProfessionals(token, { page: currentPage, limit: PAGE_SIZE });
		professionals = listResult.data;
		pagination = listResult.meta;
	} catch (error) {
		loadError =
			error instanceof ProfessionalsApiError
				? error.message
				: 'No fue posible cargar el listado de personal.';
	}
}

const totalPages = Math.max(1, pagination.total_pages);
const safeCurrentPage = Math.min(Math.max(1, pagination.current_page), totalPages);
const canPrevPage = safeCurrentPage > 1;
const canNextPage = safeCurrentPage < totalPages;

const toPageHref = (page: number) => {
	const nextUrl = new URL(Astro.url);
	nextUrl.searchParams.set('page', String(page));
	nextUrl.searchParams.delete('flash_message');
	nextUrl.searchParams.delete('flash_type');
	return `${nextUrl.pathname}${nextUrl.search}`;
};

const pageWindowStart = Math.max(1, safeCurrentPage - 1);
const pageWindowEnd = Math.min(totalPages, safeCurrentPage + 1);
const visiblePages = Array.from(
	{ length: pageWindowEnd - pageWindowStart + 1 },
	(_, index) => pageWindowStart + index
);
---

<Layout>
	<professional-manager>
	<div class="min-h-screen">
		<div
			class="app-shell grid min-h-screen overflow-hidden border border-(--shell-border) bg-(--shell-surface) shadow-[0_30px_80px_rgba(15,23,42,0.12)] backdrop-blur-xl"
			data-app-shell
			data-sidebar-state="expanded"
		>
			<SideNav currentPath={Astro.url.pathname} />

			<div class="grid min-h-full grid-rows-[auto_1fr]">
				<TopBar />

				<main class="bg-(--content-surface) px-4 py-4 sm:px-6 sm:py-6">
					<section class="grid gap-4 sm:gap-5">
						{
							loadError ? (
								<FlashMessage message={loadError} type="error" expand={true} dismissible={false} />
							) : (
								<div class="grid gap-4">
									<ProfessionalsGrid professionals={professionals} showCreateAction={true} />

									<div class="material-inline-panel flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
										<p class="text-sm text-(--on-surface-variant)">
											Página <span class="font-semibold text-(--on-surface)">{safeCurrentPage}</span> de
											<span class="font-semibold text-(--on-surface)"> {totalPages}</span>
											<span class="mx-2">-</span>
											Total de
											<span class="font-semibold text-(--on-surface)">
												{` ${pagination.total_records} `}
											</span>
											profesionales
										</p>

										<nav class="flex items-center gap-2" aria-label="Paginación personal">
											{
												canPrevPage ? (
													<a
														href={toPageHref(safeCurrentPage - 1)}
														class="rounded-lg border border-(--shell-border) px-3 py-1.5 text-sm font-semibold text-(--on-surface) no-underline transition hover:bg-(--control-surface)"
													>
														Anterior
													</a>
												) : (
													<span class="cursor-not-allowed rounded-lg border border-(--shell-border) px-3 py-1.5 text-sm font-semibold text-(--on-surface-variant)/60">
														Anterior
													</span>
												)
											}

											{
												visiblePages.map((page) =>
													page === safeCurrentPage ? (
														<span class="rounded-lg border border-(--primary-container) bg-(--primary-soft) px-3 py-1.5 text-sm font-bold text-(--primary)">
															{page}
														</span>
													) : (
														<a
															href={toPageHref(page)}
															class="rounded-lg border border-(--shell-border) px-3 py-1.5 text-sm font-semibold text-(--on-surface) no-underline transition hover:bg-(--control-surface)"
														>
															{page}
														</a>
													)
												)
											}

											{
												canNextPage ? (
													<a
														href={toPageHref(safeCurrentPage + 1)}
														class="rounded-lg border border-(--shell-border) px-3 py-1.5 text-sm font-semibold text-(--on-surface) no-underline transition hover:bg-(--control-surface)"
													>
														Siguiente
													</a>
												) : (
													<span class="cursor-not-allowed rounded-lg border border-(--shell-border) px-3 py-1.5 text-sm font-semibold text-(--on-surface-variant)/60">
														Siguiente
													</span>
												)
											}
										</nav>
									</div>
								</div>
							)
						}
							</section>
						</main>
					</div>
				</div>
			</div>

	<dialog
		class="m-0 mt-auto mb-0 w-screen max-w-none sm:m-auto sm:w-[min(48rem,calc(100vw-2rem))] sm:max-w-[min(48rem,calc(100vw-2rem))] open:flex open:flex-col max-h-[80vh] sm:max-h-[90vh] overflow-hidden rounded-t-[1.8rem] rounded-b-none sm:rounded-[1.8rem] border border-(--shell-border) bg-(--surface-bright) p-0 text-(--on-surface) shadow-[0_24px_80px_rgba(0,0,0,0.2)]"
		data-professional-modal
	>
		<!-- Drag handle para mobile -->
		<div class="w-full pt-3 pb-1 sm:hidden flex justify-center bg-(--surface-bright) cursor-grab active:cursor-grabbing shrink-0" data-bottom-sheet-handle="true" style="touch-action: none;">
			<div class="h-1.5 w-12 rounded-full bg-(--on-surface-variant)/30"></div>
		</div>

		<div class="shrink-0 z-10 shadow-sm border-b border-(--shell-border) bg-(--surface-bright) px-4 py-3 sm:px-7 sm:py-6">
			<div class="flex items-start justify-between gap-4">
				<div class="flex items-center gap-4">
					<div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-(--primary-soft) text-(--primary)">
						<span class="material-symbols-rounded text-[1.4rem]">badge</span>
					</div>
					<div>
						<h2 class="text-[1.2rem] font-extrabold tracking-tight text-(--on-surface)" data-professional-modal-title>Crear personal</h2>
						<p class="text-[0.9rem] font-medium text-(--on-surface-variant) mt-0.5 hidden sm:block" data-professional-modal-description>Completa los datos para registrar profesional y cuenta en una sola operación.</p>
					</div>
				</div>
				<button type="button" class="flex size-9 shrink-0 items-center justify-center rounded-full text-(--on-surface-variant) transition-colors hover:bg-(--surface-variant) hover:text-(--on-surface) focus:outline-none focus:ring-2 focus:ring-(--primary)" data-close-professional-modal aria-label="Cerrar modal">
					<span class="material-symbols-rounded text-[1.3rem]">close</span>
				</button>
			</div>
		</div>

		<form class="relative flex flex-col bg-(--surface)/30 overflow-y-auto overscroll-contain min-h-0 shadow-[inset_0_4px_10px_rgba(0,0,0,0.015)]" data-professional-form>
			<div class="pointer-events-none absolute inset-0 z-10 hidden items-center justify-center bg-(--surface-bright)/80 backdrop-blur-[2px] transition-all" data-professional-loading>
				<div class="inline-flex items-center gap-3 rounded-2xl border border-(--shell-border) bg-(--surface-bright) px-5 py-3.5 text-[0.95rem] font-extrabold text-(--on-surface) shadow-[0_12px_32px_rgba(0,0,0,0.12)]">
					<span class="material-symbols-rounded animate-spin text-[1.2rem] text-(--primary)">progress_activity</span>
					<div>Procesando...</div>
				</div>
			</div>

			<div class="flex-1 px-7 py-7">
			<div class="hidden rounded-2xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 mb-5 text-[0.9rem] font-bold text-rose-500 shadow-sm" data-form-error></div>

			<!-- Sección del Avatar Superior -->
			<div class="mb-5 sm:mb-7 flex flex-col sm:flex-row items-center sm:items-start gap-3.5 sm:gap-6 rounded-[1.2rem] sm:rounded-[1.4rem] border border-(--shell-border) bg-(--surface) p-3.5 sm:p-5 shadow-sm">
				<div class="relative shrink-0 size-18 sm:size-24 rounded-full overflow-hidden border-2 sm:border-4 border-(--surface-bright) shadow-[0_3px_10px_rgba(0,0,0,0.08)] bg-(--surface-variant)">
					<img src="" alt="Vista previa" class="absolute inset-0 hidden h-full w-full rounded-full object-cover object-center" data-profile-preview />
					<div class="absolute inset-0 grid place-items-center" data-profile-placeholder>
						<span class="material-symbols-rounded text-[2rem] sm:text-[2.5rem] text-(--on-surface-variant)">account_circle</span>
					</div>
				</div>
				<div class="flex-1 text-center sm:text-left flex flex-col justify-center h-full pt-0 sm:pt-1">
					<h3 class="text-[1rem] sm:text-[1.05rem] font-bold text-(--on-surface)">Foto de perfil</h3>
					<p class="text-[0.82rem] sm:text-[0.85rem] text-(--on-surface-variant) mt-0.5 mb-2.5 sm:mb-3 leading-snug">Sube una imagen representativa. Solo formatos JPG o PNG.</p>
					<div>
						<label for="file-upload" class="inline-flex cursor-pointer items-center justify-center gap-2 rounded-xl bg-(--surface-bright) border border-(--shell-border) px-3.5 sm:px-4 py-2 text-sm font-bold text-(--on-surface) shadow-sm transition hover:bg-(--surface-variant) focus-within:ring-2 focus-within:ring-(--primary) focus-within:ring-offset-2 focus-within:ring-offset-(--surface)">
							<span class="material-symbols-rounded text-[1.2rem] text-(--primary)">upload</span>
							<span data-image-file-name>Cambiar foto</span>
							<input id="file-upload" name="profile_image" type="file" class="sr-only" accept=".jpg,.jpeg,.png" />
						</label>
					</div>
					<div class="hidden mt-2 text-xs font-semibold text-rose-600" data-field-error="profile_image"></div>
				</div>
			</div>

			<div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
				<!-- Primera columna: Datos Personales y de Usuario -->
				<fieldset class="flex flex-col gap-4 border-0 p-0 m-0">
					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span class="inline-flex items-center gap-1">Nombre(s) <span class="text-rose-500">*</span></span>
						<input type="text" name="first_name" maxlength="150" required autocomplete="off" class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10" placeholder="Ej: Dra. Sarah"/>
						<span class="hidden text-xs font-semibold text-rose-600" data-field-error="first_name"></span>
					</label>
					
					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span class="inline-flex items-center gap-1">Apellido(s) <span class="text-rose-500">*</span></span>
						<input type="text" name="last_name" maxlength="150" required autocomplete="off" class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10" placeholder="Ej: Gómez"/>
						<span class="hidden text-xs font-semibold text-rose-600" data-field-error="last_name"></span>
					</label>

					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span class="inline-flex items-center gap-1">Teléfono <span class="text-rose-500">*</span></span>
						<div class="flex rounded-2xl shadow-sm transition-shadow focus-within:ring-4 focus-within:ring-(--primary)/10">
							<span class="inline-flex items-center rounded-l-2xl border border-r-0 border-(--shell-border) bg-(--control-surface) px-4 text-[0.95rem] font-semibold text-(--on-surface-variant)">
								+595
							</span>
							<input
								type="tel"
								name="phone_number"
								inputmode="numeric"
								autocomplete="tel-national"
								maxlength="11"
								required
								placeholder="981 123 456"
								class="min-w-0 flex-1 rounded-none rounded-r-2xl border border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary)"
							/>
						</div>
						<span class="text-[0.85rem] font-medium text-(--on-surface-variant)">Se guardará como número paraguayo con prefijo internacional.</span>
						<span class="hidden text-xs font-semibold text-rose-600" data-field-error="phone_number"></span>
					</label>
					
					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span class="inline-flex items-center gap-1">Nombre de usuario <span class="text-rose-500">*</span></span>
						<input type="text" name="apex_user_name" maxlength="150" required autocomplete="off" class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10" placeholder="Ej: sarahg"/>
						<span class="hidden text-xs font-semibold text-rose-600" data-field-error="apex_user_name"></span>
					</label>

					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span class="inline-flex items-center gap-1">Correo electrónico <span class="text-rose-500">*</span></span>
						<input type="email" name="email" maxlength="255" required autocomplete="off" class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10" placeholder="Ej: sarah@clinica.com"/>
						<span class="hidden text-xs font-semibold text-rose-600" data-field-error="email"></span>
					</label>
					
					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span class="inline-flex items-center gap-1">Contraseña <span class="text-rose-500" data-password-required-indicator>*</span></span>
						<div class="relative">
							<input type="password" name="password" minlength="8" maxlength="20" class="w-full rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 pr-10" placeholder="********" autocomplete="new-password"/>
							<button type="button" class="absolute inset-y-0 right-2 flex items-center p-1 text-(--on-surface-variant) hover:text-(--on-surface) bg-transparent border-0" onclick="const i = this.previousElementSibling; const isPwd = i.type === 'password'; i.type = isPwd ? 'text' : 'password'; this.querySelector('span').textContent = isPwd ? 'visibility_off' : 'visibility';" aria-label="Alternar visibilidad de contraseña">
								<span class="material-symbols-rounded text-lg pointer-events-none">visibility</span>
							</button>
						</div>
						<span class="hidden text-xs font-semibold text-rose-600" data-field-error="password"></span>
					</label>

				</fieldset>
				
				<!-- Segunda columna: App, Roles y Configuración -->
				<fieldset class="flex flex-col gap-4 border-0 p-0 m-0">
					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span class="inline-flex items-center gap-1">Rol principal <span class="text-rose-500">*</span></span>
						<div class="relative">
							<select name="rol_id_role" required class="w-full cursor-pointer appearance-none rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 text-[0.95rem] font-bold text-(--on-surface) outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10">
								<option value="">Cargando roles...</option>
							</select>
							<span class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-(--on-surface-variant)">
								<span class="material-symbols-rounded">expand_more</span>
							</span>
						</div>
						<span class="hidden text-xs font-semibold text-rose-600" data-field-error="rol_id_role"></span>
					</label>

					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span class="inline-flex items-center gap-1">Especialidad</span>
						<div class="relative">
							<select name="spe_id_specialty" class="w-full cursor-pointer appearance-none rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 text-[0.95rem] font-bold text-(--on-surface) outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10">
								<option value="">Cargando especialidades...</option>
							</select>
							<span class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-(--on-surface-variant)">
								<span class="material-symbols-rounded">expand_more</span>
							</span>
						</div>
						<span class="hidden text-xs font-semibold text-rose-600" data-field-error="spe_id_specialty"></span>
					</label>

					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span class="inline-flex items-center gap-1">URL del Perfil Público (Opcional)</span>
						<div class="flex">
							<span class="inline-flex max-w-[55%] sm:max-w-[65%] items-center truncate rounded-l-2xl border border-r-0 border-(--shell-border) bg-(--control-surface) px-3 text-xs sm:text-sm text-(--on-surface-variant) shadow-sm" title={publicProfilePrefix}>
								{publicProfilePrefix}
							</span>
							<input type="text" name="profile_slug" maxlength="80" class="block w-full min-w-0 flex-1 rounded-none rounded-r-2xl border border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 text-[0.95rem] outline-none transition focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10" placeholder="sarah-gomez"/>
						</div>
						<span class="hidden text-xs font-semibold text-rose-600" data-field-error="profile_slug"></span>
					</label>
					
					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span class="inline-flex items-center gap-1">Servicios Asignados</span>
						<div class="relative w-full">
							<select name="services" multiple class="w-full"></select>
						</div>
						<p class="mt-1 text-xs text-(--on-surface-variant)">Cargando servicios disponibles...</p>
					</label>

					<div class="grid grid-cols-2 gap-4">
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
							<span class="inline-flex items-center gap-1">Visible en app</span>
							<div class="relative">
								<select name="prof_is_active" class="w-full cursor-pointer appearance-none rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 text-[0.95rem] font-bold text-(--on-surface) outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10">
									<option value="1">Sí</option>
									<option value="0">No</option>
								</select>
								<span class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-(--on-surface-variant)">
									<span class="material-symbols-rounded">expand_more</span>
								</span>
							</div>
						</label>
						
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
							<span class="inline-flex items-center gap-1">Acceso activo</span>
							<div class="relative">
								<select name="user_is_active" class="w-full cursor-pointer appearance-none rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 text-[0.95rem] font-bold text-(--on-surface) outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10">
									<option value="1">Sí</option>
									<option value="0">No</option>
								</select>
								<span class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-(--on-surface-variant)">
									<span class="material-symbols-rounded">expand_more</span>
								</span>
							</div>
						</label>
					</div>
				</fieldset>
			</div>
			</div>
			
			<div class="sticky bottom-0 z-20 mt-auto flex flex-col-reverse sm:flex-row shrink-0 sm:items-center gap-3 border-t border-(--shell-border) bg-(--surface-bright) px-7 py-5">
				<button type="button" class="hidden items-center justify-center w-full sm:w-auto sm:mr-auto rounded-2xl border border-rose-500/20 bg-rose-500/10 px-5 py-3 text-[0.95rem] font-extrabold text-rose-500 transition hover:bg-rose-500/20 hover:border-rose-500/30 disabled:opacity-50 disabled:pointer-events-none" data-delete-professional>
					<span class="material-symbols-rounded mr-1.5 align-[-0.22em] text-[1.15rem]">delete</span>
					Eliminar
				</button>
				<button type="button" class="w-full sm:w-auto rounded-2xl border border-transparent px-5 py-3 text-[0.95rem] font-extrabold text-(--on-surface-variant) transition hover:bg-(--surface-variant) hover:text-(--on-surface) focus:outline-none focus:ring-2 focus:ring-(--shell-border) hidden sm:block" data-close-professional-modal>
					Cancelar
				</button>
				<button type="submit" class="btn-primary-soft w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-2xl px-6 py-3 text-[0.95rem] font-extrabold transition shadow-sm hover:shadow-md focus:outline-none focus:ring-2 focus:ring-(--primary) focus:ring-offset-2 focus:ring-offset-(--surface-bright) disabled:opacity-60 disabled:pointer-events-none" data-submit-professional>
					<span class="material-symbols-rounded text-[1.2rem] hidden sm:inline" data-submit-professional-icon>check</span>
					<span data-submit-professional-label>Crear personal</span>
				</button>
			</div>
		</form>
	</dialog>
</professional-manager>

<AppAlert />
</Layout>

<script>
	import TomSelect from 'tom-select';
	import {
		PARAGUAY_MOBILE_PHONE_ERROR,
		parseParaguayMobilePhone,
	} from '../../lib/paraguay-phone';

	type ProfessionalMode = 'create' | 'edit';

	class ProfessionalManager extends HTMLElement {
		private els!: {
			modal: HTMLDialogElement | null;
			form: HTMLFormElement | null;
			deleteBtn: HTMLButtonElement | null;
			loading: HTMLElement | null;
			error: HTMLElement | null;
			title: HTMLElement | null;
			description: HTMLElement | null;
			submitIcon: HTMLElement | null;
			submitLabel: HTMLElement | null;
			imageFileName: HTMLElement | null;
			previewImg: HTMLImageElement | null;
			previewPlaceholder: HTMLElement | null;
		};

		private formEls!: {
			username: HTMLInputElement | null;
			email: HTMLInputElement | null;
			firstName: HTMLInputElement | null;
			lastName: HTMLInputElement | null;
			password: HTMLInputElement | null;
			role: HTMLSelectElement | null;
			phone: HTMLInputElement | null;
			specialty: HTMLSelectElement | null;
			userActive: HTMLSelectElement | null;
			profActive: HTMLSelectElement | null;
			slug: HTMLInputElement | null;
			image: HTMLInputElement | null;
			services: HTMLSelectElement | null;
			fieldsets: HTMLFieldSetElement[];
			fieldErrors: HTMLElement[];
		};

		private abortController: AbortController | null = null;
		private mode: ProfessionalMode = 'create';
		private editingId: number | null = null;
		private closeTimer: number | null = null;
		private slugSuggestTimer: number | null = null;
		private slugRequestSeq = 0;
		private slugManuallyEdited = false;
		private suppressSlugManualTracking = false;
		
		private rolesLoaded = false;
		private rolesLoadPromise: Promise<void> | null = null;
		
		private specialtiesLoaded = false;
		private specialtiesLoadPromise: Promise<void> | null = null;
		
		private servicesLoaded = false;
		private servicesLoadPromise: Promise<void> | null = null;
		private servicesTom: TomSelect | null = null;
		private servicesTouched = false;
		private editServicesAvailable = false;
		private suppressServicesTouched = false;

		private professionalReadRequestSeq = 0;

		connectedCallback() {
			if (this.abortController) return;
			this.abortController = new AbortController();
			const { signal } = this.abortController;

			this.els = {
				modal: this.querySelector<HTMLDialogElement>('[data-professional-modal]'),
				form: this.querySelector<HTMLFormElement>('[data-professional-form]'),
				deleteBtn: this.querySelector<HTMLButtonElement>('[data-delete-professional]'),
				loading: this.querySelector<HTMLElement>('[data-professional-loading]'),
				error: this.querySelector<HTMLElement>('[data-form-error]'),
				title: this.querySelector<HTMLElement>('[data-professional-modal-title]'),
				description: this.querySelector<HTMLElement>('[data-professional-modal-description]'),
				submitIcon: this.querySelector<HTMLElement>('[data-submit-professional-icon]'),
				submitLabel: this.querySelector<HTMLElement>('[data-submit-professional-label]'),
				imageFileName: this.querySelector<HTMLElement>('[data-image-file-name]'),
				previewImg: this.querySelector<HTMLImageElement>('[data-profile-preview]'),
				previewPlaceholder: this.querySelector<HTMLElement>('[data-profile-placeholder]'),
			};

			const formNode = this.els.form;
			this.formEls = {
				username: formNode?.querySelector<HTMLInputElement>('input[name="apex_user_name"]') || null,
				email: formNode?.querySelector<HTMLInputElement>('input[name="email"]') || null,
				firstName: formNode?.querySelector<HTMLInputElement>('input[name="first_name"]') || null,
				lastName: formNode?.querySelector<HTMLInputElement>('input[name="last_name"]') || null,
				password: formNode?.querySelector<HTMLInputElement>('input[name="password"]') || null,
				role: formNode?.querySelector<HTMLSelectElement>('select[name="rol_id_role"]') || null,
				phone: formNode?.querySelector<HTMLInputElement>('input[name="phone_number"]') || null,
				specialty: formNode?.querySelector<HTMLSelectElement>('select[name="spe_id_specialty"]') || null,
				userActive: formNode?.querySelector<HTMLSelectElement>('select[name="user_is_active"]') || null,
				profActive: formNode?.querySelector<HTMLSelectElement>('select[name="prof_is_active"]') || null,
				slug: formNode?.querySelector<HTMLInputElement>('input[name="profile_slug"]') || null,
				image: formNode?.querySelector<HTMLInputElement>('input[name="profile_image"]') || null,
				services: formNode?.querySelector<HTMLSelectElement>('select[name="services"]') || null,
				fieldsets: formNode 
					? Array.from(formNode.querySelectorAll<HTMLFieldSetElement>('fieldset')) 
					: [],
				fieldErrors: Array.from(this.querySelectorAll<HTMLElement>('[data-field-error]')),
			};

			this.addEventListener('click', this.handleRootClick, { signal });
			this.addEventListener('keydown', this.handleRootKeydown, { signal });
			this.els.form?.addEventListener('submit', this.handleSubmit, { signal });

			this.formEls.image?.addEventListener('change', () => this.setImageFileNameLabel(), { signal });
			this.formEls.phone?.addEventListener('input', this.handlePhoneInput, { signal });

			// Slug events
			this.formEls.slug?.addEventListener('input', () => {
				if (this.suppressSlugManualTracking) return;
				const val = String(this.formEls.slug?.value || '').trim();
				this.slugManuallyEdited = val !== '';
				if (!this.slugManuallyEdited) this.queueSlugSuggestion();
			}, { signal });
			this.formEls.firstName?.addEventListener('input', () => this.queueSlugSuggestion(), { signal });
			this.formEls.lastName?.addEventListener('input', () => this.queueSlugSuggestion(), { signal });
		}

		disconnectedCallback() {
			this.abortController?.abort();
			this.abortController = null;
			if (this.closeTimer) window.clearTimeout(this.closeTimer);
			this.clearSlugSuggestTimer();
			if (this.servicesTom) {
				this.servicesTom.destroy();
				this.servicesTom = null;
			}
		}

		private async requestApi<T = any>(url: string, options?: RequestInit): Promise<any> {
			const response = await fetch(url, options);
			let data = null;
			try { data = await response.json(); } catch { throw new Error("Error al interpretar respuesta del servidor."); }
			if (!response.ok || !data || data.status !== 'success') {
				const error = new Error(data?.message || "Error en la petición.");
				(error as any).apiData = data;
				throw error;
			}
			return data;
		}

		private handleRootClick = (event: MouseEvent) => {
			const target = event.target;
			if (!(target instanceof Element)) return;

			if (this.els.modal && target === this.els.modal) {
				this.closeModal();
				return;
			}

			const closeTrigger = target.closest('[data-close-professional-modal]');
			if (closeTrigger && this.contains(closeTrigger)) {
				this.closeModal();
				return;
			}

			const deleteTrigger = target.closest('[data-delete-professional]');
			if (deleteTrigger && this.contains(deleteTrigger)) {
				void this.handleDelete();
				return;
			}

			const openTrigger = target.closest('[data-open-professional-modal], [data-professional-card]');
			if (!openTrigger || !this.contains(openTrigger)) return;

			const card = openTrigger.closest('[data-professional-card]');
			if (card) {
				const id = Number(card.getAttribute('data-professional-id') || '0');
				if (id > 0) void this.openEditModal(id);
				return;
			}

			void this.openCreateModal();
		};

		private handleRootKeydown = (event: KeyboardEvent) => {
			if (event.key !== 'Enter' && event.key !== ' ') return;
			const target = event.target;
			if (!(target instanceof Element)) return;

			const card = target.closest('[data-professional-card]');
			if (card && this.contains(card)) {
				event.preventDefault();
				const id = Number(card.getAttribute('data-professional-id') || '0');
				if (id > 0) void this.openEditModal(id);
				return;
			}
		};

		private updateUIMode(newMode: ProfessionalMode) {
			this.mode = newMode;
			const isEdit = this.mode === 'edit';

			if (this.els.title) this.els.title.textContent = isEdit ? 'Editar personal' : 'Crear personal';
			if (this.els.description) {
				this.els.description.textContent = isEdit 
					? 'Modifica los datos del profesional y su cuenta.' 
					: 'Completa los datos para registrar profesional y cuenta en una sola operación.';
			}
			if (this.els.submitLabel) this.els.submitLabel.textContent = isEdit ? 'Guardar cambios' : 'Crear personal';
			if (this.els.submitIcon) this.els.submitIcon.textContent = isEdit ? 'save' : 'check';
			
			if (this.els.deleteBtn) {
				if (isEdit) {
					this.els.deleteBtn.classList.remove('hidden');
					this.els.deleteBtn.classList.add('inline-flex');
					this.els.deleteBtn.disabled = false;
				} else {
					this.els.deleteBtn.classList.add('hidden');
					this.els.deleteBtn.classList.remove('inline-flex');
					this.els.deleteBtn.disabled = true;
				}
			}

			if (this.formEls.password) {
				const requiredIndicator = this.querySelector('[data-password-required-indicator]');
				if (isEdit) {
					this.formEls.password.required = false;
					this.formEls.password.placeholder = 'Dejar en blanco para mantener';
					if (requiredIndicator) requiredIndicator.classList.add('hidden');
				} else {
					this.formEls.password.required = true;
					this.formEls.password.placeholder = '********';
					if (requiredIndicator) requiredIndicator.classList.remove('hidden');
				}
			}
		}

		private toggleFormLoading(isLoading: boolean) {
			if (this.els.loading) {
				isLoading
					? this.els.loading.classList.replace('hidden', 'flex')
					: this.els.loading.classList.replace('flex', 'hidden');
			}
			for (const fieldset of this.formEls.fieldsets) {
				fieldset.disabled = isLoading;
			}
			if (this.els.deleteBtn) this.els.deleteBtn.disabled = isLoading;
			const submitBtn = this.els.form?.querySelector<HTMLButtonElement>('[data-submit-professional]');
			if (submitBtn) submitBtn.disabled = isLoading;
			
			if (this.servicesTom) {
				isLoading ? this.servicesTom.disable() : this.servicesTom.enable();
			}

		}

		private setLoadingMessage(message: string) {
			if (!this.els.loading) return;
			const textNode = this.els.loading.querySelector('div')?.lastChild;
			if (textNode) textNode.textContent = ` ${message}`;
		}

		private showFormError(message: string) {
			if (!this.els.error) return;
			this.els.error.textContent = message;
			this.els.error.classList.remove('hidden');
		}

		private clearErrors() {
			if (this.els.error) {
				this.els.error.textContent = '';
				this.els.error.classList.add('hidden');
			}
			for (const node of this.formEls.fieldErrors) {
				node.textContent = '';
				node.classList.add('hidden');
			}
		}

		private toParaguayPhoneLocalDigits(rawValue: string) {
			const parsedPhone = parseParaguayMobilePhone(rawValue);
			if (parsedPhone.isValid) return parsedPhone.e164.slice(4);

			let digits = String(rawValue || '').replace(/\D/g, '');
			if (digits.startsWith('00595')) digits = digits.slice(5);
			if (digits.startsWith('595')) digits = digits.slice(3);
			if (digits.startsWith('0')) digits = digits.slice(1);
			return digits.slice(0, 9);
		}

		private formatParaguayPhoneLocal(rawValue: string) {
			const digits = this.toParaguayPhoneLocalDigits(rawValue);
			if (!digits) return '';
			if (digits.length <= 3) return digits;
			if (digits.length <= 6) return `${digits.slice(0, 3)} ${digits.slice(3)}`;
			return `${digits.slice(0, 3)} ${digits.slice(3, 6)} ${digits.slice(6, 9)}`;
		}

		private setPhoneFieldError(message: string) {
			const phoneFieldNode = this.formEls.fieldErrors.find(
				(el) => el.getAttribute('data-field-error') === 'phone_number'
			);
			if (!phoneFieldNode) return;
			phoneFieldNode.textContent = message;
			phoneFieldNode.classList.remove('hidden');
		}

		private handlePhoneInput = () => {
			if (!this.formEls.phone) return;
			this.formEls.phone.value = this.formatParaguayPhoneLocal(this.formEls.phone.value);
			const phoneFieldNode = this.formEls.fieldErrors.find(
				(el) => el.getAttribute('data-field-error') === 'phone_number'
			);
			if (phoneFieldNode) {
				phoneFieldNode.textContent = '';
				phoneFieldNode.classList.add('hidden');
			}
		}

		private renderFieldErrors(errors: unknown, fallbackMessage = '') {
			let rendered = false;
			const items = Array.isArray(errors) ? errors : [];

			for (const err of items) {
				if (!err || typeof err !== 'object') continue;
				const field = 'field' in err ? String(err.field || '') : '';
				const messageText = 'message' in err ? String(err.message || '') : '';
				if (!field || !messageText) continue;

				const fieldNode = this.formEls.fieldErrors.find((el) => el.getAttribute('data-field-error') === field);
				if (!fieldNode) continue;
				fieldNode.textContent = messageText;
				fieldNode.classList.remove('hidden');
				rendered = true;
			}

			if (rendered) return true;

			if (typeof fallbackMessage === 'string' && /slug|perfil/i.test(fallbackMessage)) {
				const slugFieldNode = this.formEls.fieldErrors.find((el) => el.getAttribute('data-field-error') === 'profile_slug');
				if (slugFieldNode) {
					slugFieldNode.textContent = fallbackMessage;
					slugFieldNode.classList.remove('hidden');
					return true;
				}
			}

			return false;
		}

		private setPreviewImage(url?: string | null) {
			const raw = String(url || '').trim();
			const normalized = ['null', 'undefined'].includes(raw.toLowerCase()) ? '' : raw;
			const hasImage = normalized.length > 0;

			if (this.els.previewImg) {
				this.els.previewImg.dataset.originalSrc = normalized;
				this.els.previewImg.onerror = () => this.setPreviewImage(null);
				if (hasImage) {
					this.els.previewImg.src = normalized;
					this.els.previewImg.classList.remove('hidden');
				} else {
					this.els.previewImg.src = '';
					this.els.previewImg.classList.add('hidden');
				}
			}

			if (this.els.previewPlaceholder) {
				this.els.previewPlaceholder.classList.toggle('hidden', hasImage);
			}
		}

		private resetFormValues() {
			if (this.els.form) this.els.form.reset();
			this.setPreviewImage(null);
			this.setImageFileNameLabel();
			this.setSelectedServices([]);
			this.servicesTouched = false;
			this.editServicesAvailable = false;
			this.slugManuallyEdited = false;
			this.clearSlugSuggestTimer();
			this.slugRequestSeq += 1;
		}

		private setImageFileNameLabel() {
			if (!this.els.imageFileName) return;
			const file = this.formEls.image?.files?.[0];
			this.els.imageFileName.textContent = file ? file.name : 'No se eligio ningun archivo';

			if (file) {
				const reader = new FileReader();
				reader.onload = (e) => {
					this.setPreviewImage(String(e.target?.result || ''));
				};
				reader.readAsDataURL(file);
			} else {
				const persistedImage = String(this.els.previewImg?.dataset.originalSrc || '').trim();
				if (this.mode === 'edit' && persistedImage) {
					this.setPreviewImage(persistedImage);
				} else {
					this.setPreviewImage(null);
				}
			}
		}

		private clearSlugSuggestTimer() {
			if (this.slugSuggestTimer) {
				window.clearTimeout(this.slugSuggestTimer);
				this.slugSuggestTimer = null;
			}
		}

		private queueSlugSuggestion() {
			if (!this.formEls.slug) return;
			const first = String(this.formEls.firstName?.value || '').trim();
			const last = String(this.formEls.lastName?.value || '').trim();
			const fullName = `${first} ${last}`.trim();
			
			if (!fullName) return;
			if (this.slugManuallyEdited && this.formEls.slug.value.trim() !== '') return;

			this.clearSlugSuggestTimer();
			const currentRequest = ++this.slugRequestSeq;
			
			this.slugSuggestTimer = window.setTimeout(async () => {
				try {
					const response = await fetch(`/api/professionals/slug/suggest?name=${encodeURIComponent(fullName)}`, {
						headers: { Accept: 'application/json' },
					});
					const data = await response.json();
					if (currentRequest !== this.slugRequestSeq || !response.ok || data.status !== 'success' || !data.slug) return;
					if (this.slugManuallyEdited && this.formEls.slug!.value.trim() !== '') return;
					
					this.suppressSlugManualTracking = true;
					this.formEls.slug!.value = data.slug.trim();
					this.suppressSlugManualTracking = false;
				} catch {}
			}, 350);
		}

		private async ensureSpecialtiesLoaded() {
			if (this.specialtiesLoaded) return;
			if (this.specialtiesLoadPromise) return this.specialtiesLoadPromise;

			if (this.formEls.specialty) this.formEls.specialty.disabled = true;
			
			this.specialtiesLoadPromise = (async () => {
				const data = await this.requestApi('/api/specialties?page=1&limit=100');
				
				if (this.formEls.specialty) {
					this.formEls.specialty.innerHTML = '<option value="">Sin especialidad</option>';
					data.data.forEach((s: any) => {
						const option = document.createElement('option');
						option.value = String(s.id_specialty);
						option.textContent = s.name;
						this.formEls.specialty?.appendChild(option);
					});
				}
				this.specialtiesLoaded = true;
			})().finally(() => {
				if (this.formEls.specialty) this.formEls.specialty.disabled = false;
				this.specialtiesLoadPromise = null;
			});
			return this.specialtiesLoadPromise;
		}

		private async ensureRolesLoaded() {
			if (this.rolesLoaded) return;
			if (this.rolesLoadPromise) return this.rolesLoadPromise;

			if (this.formEls.role) this.formEls.role.disabled = true;
			
			this.rolesLoadPromise = (async () => {
				const data = await this.requestApi('/api/roles');
				
				if (this.formEls.role) {
					this.formEls.role.innerHTML = '<option value="">Selecciona un rol</option>';
					data.data.forEach((r: any) => {
						const option = document.createElement('option');
						option.value = String(r.id_role);
						option.textContent = r.name;
						this.formEls.role?.appendChild(option);
					});
				}
				this.rolesLoaded = true;
			})().finally(() => {
				if (this.formEls.role) this.formEls.role.disabled = false;
				this.rolesLoadPromise = null;
			});
			return this.rolesLoadPromise;
		}

		private ensureServicesControl() {
			if (!this.formEls.services || this.servicesTom) return;
			
			this.servicesTom = new TomSelect(this.formEls.services, {
				plugins: { remove_button: { title: 'Quitar' } },
				placeholder: 'Busca o selecciona servicios...',
				create: false,
				persist: false,
				maxOptions: 200,
				closeAfterSelect: false,
				hideSelected: true,
			});
			
			this.servicesTom.on('change', () => {
				if (!this.suppressServicesTouched) this.servicesTouched = true;
			});
		}

		private async ensureServicesLoaded() {
			this.ensureServicesControl();
			if (this.servicesLoaded) return;
			if (this.servicesLoadPromise) return this.servicesLoadPromise;

			this.servicesTom?.disable();
			
			this.servicesLoadPromise = (async () => {
				const data = await this.requestApi('/api/services/lov');
				
				this.servicesTom?.clear(true);
				this.servicesTom?.clearOptions();
				data.data.forEach((s: any) => {
					this.servicesTom?.addOption({ value: String(s.id_service), text: s.name });
				});
				this.servicesTom?.refreshOptions(false);
				
				this.servicesLoaded = true;
			})().finally(() => {
				this.servicesTom?.enable();
				this.servicesLoadPromise = null;
			});
			return this.servicesLoadPromise;
		}

		private setSelectedServices(serviceIds: number[]) {
			if (!this.servicesTom) return;
			this.suppressServicesTouched = true;
			this.servicesTom.setValue(serviceIds.map(String) as any, true);
			this.suppressServicesTouched = false;
		}

		private getSelectedServiceIds(): number[] {
			if (!this.servicesTom) return [];
			const val = this.servicesTom.getValue();
			const arr = Array.isArray(val) ? val : String(val || '').split(',');
			return arr.map(Number).filter(n => Number.isInteger(n) && n > 0);
		}

		private async openCreateModal() {
			this.updateUIMode('create');
			this.editingId = null;
			this.resetFormValues();
			this.clearErrors();
			this.toggleFormLoading(false);
			
			this.els.modal?.classList.remove('is-closing');
			if (this.closeTimer) window.clearTimeout(this.closeTimer);
			if (this.els.modal && !this.els.modal.open) this.els.modal.showModal();
			
			try {
				await Promise.all([this.ensureSpecialtiesLoaded(), this.ensureRolesLoaded(), this.ensureServicesLoaded()]);
			} catch (err) {
				this.showFormError(err instanceof Error ? err.message : 'Error al cargar catálogos.');
			}
		}

		private async openEditModal(id: number) {
			const reqId = ++this.professionalReadRequestSeq;
			this.updateUIMode('edit');
			this.editingId = id;
			this.resetFormValues();
			this.clearErrors();
			
			this.els.modal?.classList.remove('is-closing');
			if (this.closeTimer) window.clearTimeout(this.closeTimer);
			if (this.els.modal && !this.els.modal.open) this.els.modal.showModal();
			this.setLoadingMessage('Cargando...');
			this.toggleFormLoading(true);

			try {
				const data = await this.requestApi(`/api/professionals/${id}`);
				if (reqId !== this.professionalReadRequestSeq) return;
				
				await Promise.all([this.ensureSpecialtiesLoaded(), this.ensureRolesLoaded(), this.ensureServicesLoaded()]);
				if (reqId !== this.professionalReadRequestSeq) return;
				
				const prof = data.data;
				const user = prof.user || {};
				
				const { formEls } = this;
				if (formEls.username) formEls.username.value = user.apex_user_name || '';
				if (formEls.email) formEls.email.value = user.email || '';
				if (formEls.firstName) formEls.firstName.value = user.first_name || '';
				if (formEls.lastName) formEls.lastName.value = user.last_name || '';
				if (formEls.role) formEls.role.value = user.rol_id_role || '';
				if (formEls.phone) formEls.phone.value = this.formatParaguayPhoneLocal(prof.phone_number || '');
				if (formEls.slug) formEls.slug.value = prof.profile_slug || '';
				if (formEls.userActive) formEls.userActive.value = user.is_active === 0 ? '0' : '1';
				if (formEls.profActive) formEls.profActive.value = prof.is_active === 0 ? '0' : '1';
				
				this.setPreviewImage(prof.profile_image_url);

				const sId = prof.specialty?.id_specialty;
				if (formEls.specialty && sId) formEls.specialty.value = String(sId);
				
				const services = Array.isArray(prof.services) ? prof.services : [];
				this.editServicesAvailable = Array.isArray(prof.services);
				this.setSelectedServices(services);
				this.servicesTouched = false;
				this.slugManuallyEdited = false;
			} catch (err) {
				if (reqId !== this.professionalReadRequestSeq) return;
				this.updateUIMode('create');
				this.showFormError(err instanceof Error ? err.message : 'Error de carga.');
			} finally {
				if (reqId === this.professionalReadRequestSeq) {
					this.toggleFormLoading(false);
				}
			}
		}

		private closeModal() {
			if (!this.els.modal?.open) return;
			this.professionalReadRequestSeq++;
			this.els.modal.classList.add('is-closing');
			this.clearSlugSuggestTimer();
			
			this.closeTimer = window.setTimeout(() => {
				this.els.modal?.close();
				this.els.modal?.classList.remove('is-closing');
				if (this.els.form) this.els.form.reset();
				this.resetFormValues();
				this.updateUIMode('create');
				this.toggleFormLoading(false);
				this.clearErrors();
				this.closeTimer = null;
			}, 160);
		}

		private async fileToBase64(file: File): Promise<string> {
			return new Promise((resolve, reject) => {
				const r = new FileReader();
				r.onload = () => {
					const res = String(r.result || '');
					resolve(res.includes(',') ? res.split(',')[1] : res);
				};
				r.onerror = () => reject(new Error('No se pudo procesar la imagen'));
				r.readAsDataURL(file);
			});
		}

		private handleSubmit = async (event: SubmitEvent) => {
			event.preventDefault();
			this.clearErrors();
			if (!this.els.form) return;
			
			const fd = new FormData(this.els.form);
			const roleRaw = String(fd.get('rol_id_role') || '').trim();
			const pass = String(fd.get('password') || '');
			
			if (this.mode === 'create' && !pass) {
				this.showFormError('La contraseña es obligatoria para nuevos registros.');
				return;
			}

			const rawPhone = String(fd.get('phone_number') || '').trim();
			const parsedPhone = parseParaguayMobilePhone(rawPhone);
			if (!parsedPhone.isValid) {
				this.setPhoneFieldError(PARAGUAY_MOBILE_PHONE_ERROR);
				return;
			}
			
			const payload: any = {
				rol_id_role: Number(roleRaw),
				apex_user_name: String(fd.get('apex_user_name') || '').trim(),
				first_name: String(fd.get('first_name') || '').trim(),
				last_name: String(fd.get('last_name') || '').trim(),
				email: String(fd.get('email') || '').trim(),
				phone_number: parsedPhone.e164,
				user_is_active: fd.get('user_is_active') === '0' ? 0 : 1,
				prof_is_active: fd.get('prof_is_active') === '0' ? 0 : 1,
			};
			
			if (this.mode === 'create' || pass) payload.password = pass;
			
			const slug = String(fd.get('profile_slug') || '').trim();
			if (slug) payload.profile_slug = slug;
			
			const sId = Number(fd.get('spe_id_specialty'));
			if (sId > 0) payload.spe_id_specialty = sId;
			
			if (this.mode === 'create' || this.editServicesAvailable || this.servicesTouched) {
				payload.services = this.getSelectedServiceIds();
			}
			
			const imgFile = this.formEls.image?.files?.[0];
			if (imgFile) {
				payload.image_base64 = await this.fileToBase64(imgFile);
				payload.image_name = imgFile.name;
				payload.image_mime = imgFile.type;
			}
			
			const method = this.mode === 'edit' ? 'PUT' : 'POST';
			const url = this.mode === 'edit' ? `/api/professionals/${this.editingId}` : '/api/professionals';
			
			this.setLoadingMessage(this.mode === 'edit' ? 'Guardando...' : 'Creando...');
			this.toggleFormLoading(true);
			
			try {
				await this.requestApi(url, {
					method,
					headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
					body: JSON.stringify(payload)
				});
				
				this.closeModal();
				window.location.reload();
			} catch (err: any) {
				if (err.apiData && err.apiData.errors) {
					const msg = err.message || 'Error al guardar.';
					const hasFieldErrors = this.renderFieldErrors(err.apiData.errors, msg);
					if (!hasFieldErrors || !msg.includes('verificar los campos')) {
						this.showFormError(msg);
					}
				} else {
					this.showFormError(err instanceof Error ? err.message : 'Error inesperado.');
				}
			} finally {
				this.toggleFormLoading(false);
			}
		};

		private async handleDelete() {
			if (!this.editingId) return;
			
			const confirmed = await (window as any).BookmateAlert?.confirm?.({
				type: 'error',
				title: 'Eliminar personal',
				message: 'Esta acción eliminará al profesional de forma permanente. ¿Deseas continuar?',
				confirmText: 'Eliminar',
				cancelText: 'Cancelar',
			});
			if (!confirmed) return;

			this.setLoadingMessage('Eliminando...');
			this.toggleFormLoading(true);
			
			try {
				await this.requestApi(`/api/professionals/${this.editingId}`, { method: 'DELETE' });
				window.location.reload();
			} catch (err) {
				this.showFormError(err instanceof Error ? err.message : 'Error al eliminar');
				this.toggleFormLoading(false);
			}
		}
	}

	if (!customElements.get('professional-manager')) {
		customElements.define('professional-manager', ProfessionalManager);
	}
</script>
