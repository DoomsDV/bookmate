---
import AppAlert from '../../components/AppAlert.astro';
import FlashMessage from '../../components/FlashMessage.astro';
import ProfessionalsGrid from '../../components/ProfessionalsGrid.astro';
import SideNav from '../../components/SideNav.astro';
import TopBar from '../../components/TopBar.astro';
import { ProfessionalsApiError, listProfessionals, type Professional } from '../../lib/professionals';
import {
	buildPublicProfilePrefix,
	formatPublicProfilePrefixDisplay,
} from '../../lib/public-profile-url';
import { ROLES } from '../../config/roles';
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import 'tom-select/dist/css/tom-select.css';

const token = Astro.locals.token ?? '';
const currentUserId = Number(Astro.locals.userId ?? 0);
const adminRoleId = ROLES.ADMIN;
const PAGE_SIZE = 9;
const rawPage = Number(Astro.url.searchParams.get('page') || '1');
const currentPage = Number.isInteger(rawPage) && rawPage > 0 ? rawPage : 1;

const organizationSlug = String(Astro.cookies.get('org_slug')?.value || '').trim();
const rawPublicProfileDomain = String(import.meta.env.PUBLIC_BOOKMATE_PUBLIC_DOMAIN ?? '').trim();
const publicProfileDomain =
	rawPublicProfileDomain.replace(/^https?:\/\//i, '').replace(/\/+$/, '') ||
	Astro.url.host;
const publicProfilePrefix = buildPublicProfilePrefix(
	rawPublicProfileDomain || Astro.url.origin,
	organizationSlug
);
const publicProfilePrefixDisplay = formatPublicProfilePrefixDisplay(publicProfilePrefix);

let professionals: Professional[] = [];
let loadError = '';
let pagination = {
	current_page: currentPage,
	per_page: PAGE_SIZE,
	total_records: 0,
	total_pages: 1,
};

if (!token) {
	loadError = 'No hay sesión válida para consultar personal.';
} else {
	try {
		const listResult = await listProfessionals(token, { page: currentPage, limit: PAGE_SIZE });
		professionals = listResult.data;
		pagination = listResult.meta;
	} catch (error) {
		loadError =
			error instanceof ProfessionalsApiError
				? error.message
				: 'No fue posible cargar el listado de personal.';
	}
}

const totalPages = Math.max(1, pagination.total_pages);
const safeCurrentPage = Math.min(Math.max(1, pagination.current_page), totalPages);
const canPrevPage = safeCurrentPage > 1;
const canNextPage = safeCurrentPage < totalPages;

const toPageHref = (page: number) => {
	const nextUrl = new URL(Astro.url);
	nextUrl.searchParams.set('page', String(page));
	return `${nextUrl.pathname}${nextUrl.search}`;
};

---

<Layout>
	<professional-manager
		data-public-profile-prefix={publicProfilePrefix}
		data-current-user-id={String(currentUserId)}
		data-admin-role-id={String(adminRoleId)}
	>
	<div class="min-h-screen bg-(--page-background) transition-colors duration-300">
		<div
			class="app-shell grid min-h-screen overflow-hidden bg-transparent"
			data-app-shell
			data-sidebar-state="expanded"
		>
			<SideNav currentPath={Astro.url.pathname} />

			<div class="grid min-h-full grid-rows-[auto_1fr]">
				<TopBar />

				<main class="px-4 py-4 sm:px-6 sm:py-6">
					<section class="grid gap-4 sm:gap-5">
						{
							loadError ? (
								<FlashMessage message={loadError} type="error" expand={true} dismissible={false} />
							) : (
								<div class="grid gap-4">
									<ProfessionalsGrid professionals={professionals} showCreateAction={true} />

									<div class="app-pagination">
										<p class="app-pagination__summary">
											Página <strong>{safeCurrentPage}</strong> de <strong>{totalPages}</strong>
											<span aria-hidden="true">-</span>
											Total: <strong>{pagination.total_records}</strong> profesionales
										</p>

										<nav class="app-pagination__controls" aria-label="Paginación personal">
											{
												canPrevPage ? (
													<a
														href={toPageHref(safeCurrentPage - 1)}
														class="app-pagination__icon-button"
														aria-label="Página anterior"
													>
														<svg viewBox="0 0 24 24" aria-hidden="true">
															<path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6z"></path>
														</svg>
													</a>
												) : (
													<span class="app-pagination__icon-button is-disabled" aria-disabled="true">
														<svg viewBox="0 0 24 24" aria-hidden="true">
															<path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6z"></path>
														</svg>
													</span>
												)
											}

											<span class="app-pagination__current" aria-current="page">{safeCurrentPage}</span>

											{
												canNextPage ? (
													<a
														href={toPageHref(safeCurrentPage + 1)}
														class="app-pagination__icon-button"
														aria-label="Página siguiente"
													>
														<svg viewBox="0 0 24 24" aria-hidden="true">
															<path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"></path>
														</svg>
													</a>
												) : (
													<span class="app-pagination__icon-button is-disabled" aria-disabled="true">
														<svg viewBox="0 0 24 24" aria-hidden="true">
															<path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"></path>
														</svg>
													</span>
												)
											}
										</nav>
									</div>
								</div>
							)
						}
							</section>
						</main>
					</div>
				</div>
			</div>

	<dialog
		class="m-0 mt-auto mb-0 w-screen max-w-none max-h-[min(92dvh,100%)] sm:m-auto sm:w-[min(48rem,calc(100vw-2rem))] sm:max-w-[min(48rem,calc(100vw-2rem))] sm:max-h-[90vh] open:flex open:flex-col overflow-hidden rounded-t-[1.35rem] rounded-b-none sm:rounded-[1.8rem] border border-(--shell-border) bg-(--surface-bright) p-0 text-(--on-surface) shadow-[0_24px_80px_rgba(0,0,0,0.2)]"
		data-professional-modal
	>
		<div class="shrink-0 z-10 shadow-sm border-b border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 sm:px-7 sm:py-6">
			<div class="flex items-start justify-between gap-3 sm:gap-4">
				<div class="flex min-w-0 items-center gap-3 sm:gap-4">
					<div class="flex size-10 shrink-0 items-center justify-center rounded-xl bg-(--primary-soft) text-(--primary) sm:size-12 sm:rounded-2xl">
						<span class="material-symbols-rounded text-[1.25rem] sm:text-[1.4rem]">badge</span>
					</div>
					<div class="min-w-0">
						<h2 class="text-[1.05rem] font-extrabold tracking-tight text-(--on-surface) sm:text-[1.2rem]" data-professional-modal-title>Crear personal</h2>
						<p class="text-[0.9rem] font-medium text-(--on-surface-variant) mt-0.5 hidden sm:block" data-professional-modal-description>Completa los datos para registrar profesional y cuenta en una sola operación.</p>
					</div>
				</div>
				<div class="flex shrink-0 items-center gap-2">
					<button
						type="button"
						class="schedule-exceptions-help inline-flex shrink-0 items-center gap-1.5 rounded-full border border-(--shell-border) bg-(--surface-bright) px-3 py-2 text-[0.82rem] font-bold text-(--on-surface-variant) transition hover:border-(--primary)/35 hover:text-(--primary) focus:outline-none focus:ring-2 focus:ring-(--primary)/25"
						data-professional-profile-url-tour-help
						aria-label="Guía de URL del perfil público"
					>
						<span class="material-symbols-rounded text-[1.1rem]">help</span>
						<span class="hidden sm:inline">Guía</span>
					</button>
					<button type="button" class="flex size-9 shrink-0 items-center justify-center rounded-full text-(--on-surface-variant) transition-colors hover:bg-(--surface-variant) hover:text-(--on-surface) focus:outline-none focus:ring-2 focus:ring-(--primary)" data-close-professional-modal aria-label="Cerrar modal">
						<span class="material-symbols-rounded text-[1.3rem]">close</span>
					</button>
				</div>
			</div>
		</div>

		<form class="relative flex flex-col overflow-hidden bg-(--surface)/30 min-h-0 shadow-[inset_0_4px_10px_rgba(0,0,0,0.015)]" data-professional-form>
			<div class="pointer-events-none fixed inset-0 z-10 hidden items-center justify-center bg-(--surface-bright)/80 backdrop-blur-[2px] transition-all" data-professional-loading>
				<div class="inline-flex items-center gap-3 rounded-2xl border border-(--shell-border) bg-(--surface-bright) px-5 py-3.5 text-[0.95rem] font-extrabold text-(--on-surface) shadow-[0_12px_32px_rgba(0,0,0,0.12)]">
					<span class="material-symbols-rounded animate-spin text-[1.2rem] text-(--primary)">progress_activity</span>
					<div>Procesando...</div>
				</div>
			</div>

			<div
				class="professional-modal-feedback absolute top-0 z-20 flex justify-end"
				data-professional-form-feedback
			>
				<div
					class="professional-modal-feedback__alert hidden ml-auto max-w-md items-center gap-2 rounded-2xl border border-rose-500/25 px-4 py-2 text-[0.9rem] font-bold text-rose-600 shadow-sm dark:border-rose-400/30 dark:text-rose-300"
					data-form-error
					role="alert"
					aria-live="polite"
				>
					<p class="m-0 min-w-0 flex-1 leading-snug font-bold" data-form-error-message></p>
					<button
						type="button"
						class="professional-modal-feedback__close shrink-0 rounded-full p-0.5 text-rose-500 transition hover:bg-rose-500/10 hover:text-rose-700 dark:text-rose-300 dark:hover:bg-rose-400/10 dark:hover:text-rose-100"
						data-dismiss-form-error
						aria-label="Cerrar mensaje de error"
					>
						<span class="material-symbols-rounded block text-[1.15rem] leading-none">close</span>
					</button>
				</div>
			</div>

			<div class="flex-1 overflow-y-auto overscroll-contain px-4 py-4 sm:px-7 sm:py-7">

			<div class="profile-photo-uploader mb-4 sm:mb-7" data-profile-upload-dropzone>
				<div class="profile-photo-uploader__avatar">
					<img src="" alt="Vista previa" class="absolute inset-0 hidden h-full w-full rounded-full object-cover object-center" data-profile-preview />
					<div class="absolute inset-0 grid place-items-center" data-profile-placeholder>
						<span class="material-symbols-rounded text-[2rem] sm:text-[2.5rem]">account_circle</span>
					</div>
				</div>
				<div class="profile-photo-uploader__content">
					<h3 class="profile-photo-uploader__title">Foto de perfil</h3>
					<div class="profile-photo-uploader__actions">
						<label for="file-upload" class="profile-photo-uploader__button" data-profile-upload-button>
							<span class="material-symbols-rounded text-[1.2rem]" data-profile-upload-icon>add_photo_alternate</span>
							<span data-image-file-name>Cambiar foto</span>
							<input id="file-upload" name="profile_image" type="file" class="sr-only" accept=".jpg,.jpeg,.png" />
						</label>
						<span class="profile-photo-uploader__meta">JPG o PNG · máx. 2 MB</span>
					</div>
					<div class="hidden text-xs font-semibold text-rose-600" data-field-error="profile_image"></div>
				</div>
			</div>

			<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5">
				<div class="sm:col-span-2 grid gap-4 sm:gap-5">
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5">
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
							<span class="inline-flex items-center gap-1">Nombre <span class="text-rose-500">*</span></span>
							<input type="text" name="first_name" maxlength="50" required autocomplete="off" class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10" placeholder="Ej: Sarah"/>
							<span class="hidden text-xs font-semibold text-rose-600" data-field-error="first_name"></span>
						</label>

						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
							<span class="inline-flex items-center gap-1">Apellido <span class="text-rose-500">*</span></span>
							<input type="text" name="last_name" maxlength="50" required autocomplete="off" class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10" placeholder="Ej: Gómez"/>
							<span class="hidden text-xs font-semibold text-rose-600" data-field-error="last_name"></span>
						</label>
					</div>

					<label class="professional-public-profile-field" data-professional-public-profile-field>
						<span class="inline-flex items-center gap-1 text-[0.95rem] font-bold text-(--on-surface)">URL del perfil público <span class="font-semibold text-(--on-surface-variant)">(Opcional)</span></span>
						<div class="flex min-w-0">
							<span
								class="public-profile-url-prefix inline-flex shrink-0 items-center rounded-l-2xl border border-r-0 border-(--shell-border) bg-(--control-surface) px-2.5 text-xs font-semibold text-(--on-surface-variant) shadow-sm sm:px-3 sm:text-sm"
								title={publicProfilePrefix}
							>
								{publicProfilePrefixDisplay}
							</span>
							<input type="text" name="profile_slug" maxlength="100" class="block w-full min-w-0 flex-1 rounded-none border border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 text-[0.95rem] outline-none transition focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10" placeholder="sarah-gomez"/>
							<button
								type="button"
								class="inline-flex w-12 shrink-0 items-center justify-center rounded-r-2xl border border-l-0 border-(--shell-border) bg-(--control-surface) text-(--on-surface-variant) transition hover:bg-(--surface-container-high) hover:text-(--primary) focus:outline-none focus:ring-4 focus:ring-(--primary)/10"
								data-copy-professional-profile-url
								aria-label="Copiar URL del perfil público"
								title="Copiar URL"
							>
								<span class="material-symbols-rounded text-[1.1rem]" data-copy-professional-profile-url-icon>content_copy</span>
							</button>
						</div>
						<span class="text-[0.84rem] font-semibold text-(--on-surface-variant)">Este enlace es el perfil público que tus clientes usarán para reservar contigo.</span>
						<span class="hidden text-xs font-semibold text-rose-600" data-field-error="profile_slug"></span>
					</label>
				</div>

				<fieldset class="flex flex-col gap-4 border-0 p-0 m-0">
					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span class="inline-flex items-center gap-1">Teléfono <span class="text-rose-500">*</span></span>
						<div class="flex rounded-2xl shadow-sm transition-shadow focus-within:ring-4 focus-within:ring-(--primary)/10">
							<span class="inline-flex items-center rounded-l-2xl border border-r-0 border-(--shell-border) bg-(--control-surface) px-4 text-[0.95rem] font-semibold text-(--on-surface-variant)">
								+595
							</span>
							<input
								type="tel"
								name="phone_number"
								inputmode="numeric"
								autocomplete="tel-national"
								maxlength="20"
								required
								placeholder="981 123 456"
								class="min-w-0 flex-1 rounded-none rounded-r-2xl border border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary)"
							/>
						</div>
						<span class="text-[0.85rem] font-medium text-(--on-surface-variant)">Se guardará como número paraguayo con prefijo internacional.</span>
						<span class="hidden text-xs font-semibold text-rose-600" data-field-error="phone_number"></span>
					</label>
				</fieldset>

				<fieldset class="flex flex-col gap-4 border-0 p-0 m-0">
					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span class="inline-flex items-center gap-1">Rol principal <span class="text-rose-500">*</span></span>
						<div class="professional-select-wrap">
							<select name="rol_id_role" required class="professional-native-select w-full cursor-pointer rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 pr-11 text-[0.95rem] font-bold text-(--on-surface) outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10">
								<option value="">Cargando roles...</option>
							</select>
							<span class="professional-select-arrow" aria-hidden="true">
								<span class="material-symbols-rounded">expand_more</span>
							</span>
						</div>
						<p class="hidden text-xs font-medium text-(--on-surface-variant)" data-role-self-admin-hint>
							Como administrador no puedes modificar tu propio rol, estado ni eliminar tu cuenta desde aquí.
						</p>
						<span class="hidden text-xs font-semibold text-rose-600" data-field-error="rol_id_role"></span>
					</label>
				</fieldset>

				<div class="sm:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5">
					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span class="inline-flex items-center gap-1">Especialidad</span>
						<div class="professional-select-wrap">
							<select name="spe_id_specialty" class="professional-native-select w-full cursor-pointer rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 pr-11 text-[0.95rem] font-bold text-(--on-surface) outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10">
								<option value="">Cargando especialidades...</option>
							</select>
							<span class="professional-select-arrow" aria-hidden="true">
								<span class="material-symbols-rounded">expand_more</span>
							</span>
						</div>
						<span class="hidden text-xs font-semibold text-rose-600" data-field-error="spe_id_specialty"></span>
					</label>

					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span class="inline-flex items-center gap-1">Servicios asignados</span>
						<div class="relative w-full">
							<select name="services" multiple class="w-full"></select>
						</div>
					</label>
				</div>

				<div class="sm:col-span-2 flex flex-col gap-4">
					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)" data-professional-email-editable>
						<span class="inline-flex items-center gap-1">Correo electrónico <span class="text-rose-500">*</span></span>
						<input type="email" name="email" maxlength="150" required autocomplete="off" class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10" placeholder="Ej: sarah@clinica.com"/>
						<span class="text-[0.85rem] font-medium text-(--on-surface-variant)" data-professional-invite-hint>Se enviará una invitación a este correo para que la persona cree su acceso.</span>
						<span class="hidden text-[0.85rem] font-medium text-(--on-surface-variant)" data-professional-pending-email-hint>Puedes corregir el correo mientras la invitación siga pendiente.</span>
						<span class="hidden text-xs font-semibold text-rose-600" data-field-error="email"></span>
					</label>

					<div class="hidden grid gap-1.5 rounded-2xl border border-(--shell-border) bg-(--control-surface) px-4 py-3" data-professional-account-readonly>
						<span class="text-[0.85rem] font-bold uppercase tracking-wide text-(--on-surface-variant)">Cuenta de acceso</span>
						<p class="m-0 text-[0.95rem] font-semibold text-(--on-surface)" data-readonly-account-email>—</p>
						<p class="m-0 text-[0.82rem] leading-snug text-(--on-surface-variant)">
							El correo y la contraseña son credenciales globales. La persona los gestiona desde su perfil o recuperación de contraseña.
						</p>
					</div>
				</div>

				<div class="sm:col-span-2 hidden professional-account-status" data-professional-status-section>
					<div class="professional-status-stack">
						<section class="professional-status-card">
							<div class="professional-status-card__layout">
								<div class="grid min-w-0 gap-1">
									<h4 class="m-0 text-[0.95rem] font-bold text-(--on-surface) sm:text-[0.98rem]">Estado de la cuenta</h4>
									<p class="m-0 text-[0.82rem] font-medium leading-relaxed text-(--on-surface-variant) sm:text-[0.84rem]">
										Un miembro inactivo no puede ingresar ni aparecer en reservas.
									</p>
								</div>
								<div
									class="professional-status-segment"
									role="group"
									aria-label="Estado de la cuenta"
									data-member-account-segment
								>
									<button
										type="button"
										class="professional-status-segment__btn is-selected"
										data-member-account-status="1"
										aria-pressed="true"
									>
										Activo
									</button>
									<button
										type="button"
										class="professional-status-segment__btn"
										data-member-account-status="0"
										aria-pressed="false"
									>
										Inactivo
									</button>
								</div>
							</div>
						</section>

						<section class="professional-permissions-card" data-professional-permissions-block>
							<div class="grid gap-1">
								<h4 class="m-0 text-[0.95rem] font-bold text-(--on-surface) sm:text-[0.98rem]">Permisos</h4>
								<p class="m-0 text-[0.82rem] font-medium leading-relaxed text-(--on-surface-variant) sm:text-[0.84rem]">
									Visibilidad pública y acceso interno son independientes mientras la cuenta esté activa.
								</p>
							</div>

							<div class="professional-permissions-list">
								<div class="professional-permission-row">
									<div class="professional-permission-row__copy">
										<span class="professional-permission-row__title">Acceso al panel administrativo</span>
										<span class="professional-permission-row__hint">Puede iniciar sesión en esta organización.</span>
									</div>
									<label class="settings-switch shrink-0">
										<input
											type="checkbox"
											role="switch"
											class="settings-switch__input sr-only"
											data-panel-access-toggle
											checked
										/>
										<span class="settings-switch__track" aria-hidden="true"></span>
									</label>
								</div>

								<div class="professional-permission-row">
									<div class="professional-permission-row__copy">
										<span class="professional-permission-row__title">Visible en la app pública</span>
										<span class="professional-permission-row__hint">Los clientes pueden reservar con esta persona.</span>
									</div>
									<label class="settings-switch shrink-0">
										<input
											type="checkbox"
											role="switch"
											class="settings-switch__input sr-only"
											data-public-visibility-toggle
											checked
										/>
										<span class="settings-switch__track" aria-hidden="true"></span>
									</label>
