---
import SideNav from '../../components/SideNav.astro';
import TopBar from '../../components/TopBar.astro';
import { DashboardApiError, getMainDashboardWithOrds, type DashboardMainData } from '../../lib/dashboard';
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';

const token = Astro.locals.token ?? '';
const organizationName = String(Astro.locals.organizationName || 'Workspace').trim() || 'Workspace';

let dashboard: DashboardMainData = {
	kpis: {
		today_appointments: 0,
		pending_appointments: 0,
		my_customers: 0,
		total_customers: null,
	},
	upcoming_appointments: [],
};
let loadError = '';

if (!token) {
	loadError = 'No hay sesion valida para consultar el dashboard.';
} else {
	try {
		dashboard = await getMainDashboardWithOrds(token);
	} catch (error) {
		loadError =
			error instanceof DashboardApiError
				? error.message
				: 'No fue posible cargar los datos del dashboard.';
	}
}

const dashboardDate = new Intl.DateTimeFormat('es-PY', {
	weekday: 'long',
	year: 'numeric',
	month: 'long',
	day: 'numeric',
}).format(new Date());

const metrics = [
	{
		label: 'Citas de hoy',
		value: dashboard.kpis.today_appointments,
		description: 'Turnos no cancelados para la jornada actual.',
		icon: 'today',
	},
	{
		label: 'Citas pendientes',
		value: dashboard.kpis.pending_appointments,
		description: 'Turnos por atender desde este momento en adelante.',
		icon: 'schedule',
	},
	{
		label: 'Mis clientes',
		value: dashboard.kpis.my_customers,
		description: 'Clientes únicos que has atendido personalmente.',
		icon: 'group',
	},
	...(dashboard.kpis.total_customers !== null
		? [
				{
					label: 'Total de clientes',
					value: dashboard.kpis.total_customers,
					description: 'Base total de clientes registrados.',
					icon: 'hub',
				},
			]
		: []),
];

const getStatusLabel = (status: string) => {
	switch (status) {
		case 'CONFIRMADO':
			return 'Confirmado';
		case 'PENDIENTE':
			return 'Pendiente';
		case 'COMPLETADO':
			return 'Completado';
		case 'CANCELADO':
			return 'Cancelado';
		default:
			return status || 'Estado';
	}
};

const getStatusTone = (status: string) => {
	switch (status) {
		case 'CONFIRMADO':
			return 'border-emerald-200 bg-emerald-50 text-emerald-700';
		case 'PENDIENTE':
				return 'border-[color:var(--status-pending-border)] bg-[color:var(--status-pending-bg)] text-[color:var(--status-pending-text)]';
		case 'COMPLETADO':
			return 'border-sky-200 bg-sky-50 text-sky-700';
		case 'CANCELADO':
			return 'border-rose-200 bg-rose-50 text-rose-700';
		default:
			return 'border-[color:var(--shell-border)] bg-[color:var(--control-surface)] text-[color:var(--on-surface-variant)]';
	}
};
---

<Layout>
	<div class="min-h-screen w-full max-w-full overflow-x-hidden bg-[#F8F9FA] dark:bg-[#131314] transition-colors duration-300">
		<div
			class="app-shell grid min-h-screen overflow-hidden bg-transparent"
			data-app-shell
			data-sidebar-state="expanded"
		>
			<SideNav currentPath={Astro.url.pathname} />

			<div class="grid min-h-full grid-rows-[auto_1fr] bg-[#F8F9FA] dark:bg-[#131314] transition-colors duration-300">
				<TopBar />

				<main class="w-full max-w-full overflow-x-hidden px-4 py-4 sm:px-8 sm:py-8 lg:px-10">
					<div class="mx-auto max-w-7xl">
						<section class="grid w-full min-w-0 gap-6 sm:gap-8">
							<section class="rounded-[2rem] bg-white dark:bg-[#1E1F22] p-6 sm:p-8 shadow-[0_8px_30px_rgba(0,0,0,0.03)] dark:shadow-[0_8px_30px_rgba(0,0,0,0.4)] transition-all duration-300">
								<div class="flex flex-col justify-between gap-4 sm:flex-row sm:items-center">
									<div class="grid gap-1">
										<p class="text-xs font-bold uppercase tracking-[0.2em] text-[#5f6368] dark:text-[#C4C7C5]">
											Dashboard
										</p>
										<h1 class="text-3xl font-extrabold text-[#202124] dark:text-[#E3E3E3] tracking-tight sm:text-4xl">
											Resumen diario
										</h1>
										<p class="text-[0.95rem] font-medium text-[#5f6368] dark:text-[#C4C7C5]">
											{organizationName} - {dashboardDate}
										</p>
									</div>

									<a
										href="/panel/calendar"
										class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-[#E8F0FE] hover:bg-[#D2E3FC] text-[#1967D2] dark:bg-[#1A2D42] dark:text-[#A8C7FA] px-6 py-3 text-sm font-bold no-underline transition dark:hover:bg-[#152538] sm:w-auto shadow-sm"
									>
										<span class="material-symbols-rounded text-lg">calendar_month</span>
										Ir al calendario
									</a>
								</div>

								<div class="mt-6 pt-6">
									<div
										class="rounded-[2rem] bg-[#EEF2F6] dark:bg-[#161C24] p-6 shadow-none transition-all duration-300"
										data-ai-summary-card
									>
										<div class="mb-3 inline-flex items-center gap-1.5 opacity-80 mix-blend-multiply dark:mix-blend-normal dark:opacity-90">
											<span class="material-symbols-rounded text-[#1967D2] dark:text-[#A8C7FA] text-[1.1rem]">auto_awesome</span>
											<h2 class="text-xs text-[#1967D2] dark:text-[#A8C7FA] font-bold uppercase tracking-wider">
												Resumen de IA
											</h2>
										</div>
										<p
											class="inline-flex items-center gap-2 text-[0.95rem] font-medium leading-relaxed text-[#5f6368] dark:text-[#C4C7C5] sm:text-base mt-1"
											data-ai-summary-state
										>
											<span class="material-symbols-rounded animate-spin text-base text-[#1967D2] dark:text-[#A8C7FA]">
												autorenew
											</span>
											Cargando resumen inteligente...
										</p>
										<p
											class="hidden whitespace-pre-line text-[0.95rem] font-medium leading-relaxed text-[#202124] dark:text-[#E3E3E3] sm:text-base max-w-4xl mt-1"
											data-ai-summary-text
										></p>
									</div>
								</div>
							</section>

							{
								loadError ? (
									<div class="rounded-[1.5rem] bg-rose-50 px-5 py-4 text-sm font-semibold text-rose-700 dark:bg-[#3B191E] dark:text-[#FFB4AB] shadow-sm">
										{loadError}
									</div>
								) : (
									<>
										<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
											{
												metrics.map((metric, metricIndex) => {
													const tones = [
														'bg-[#F3E8FF] text-[#4A154B] dark:bg-[#231F2A] dark:text-[#D0BCFF]', 
														'bg-[#E0F2F1] text-[#006064] dark:bg-[#1C2526] dark:text-[#80DEEA]', 
														'bg-[#E8F5E9] text-[#1B5E20] dark:bg-[#1D2521] dark:text-[#81C995]', 
														'bg-[#FBE9E7] text-[#BF360C] dark:bg-[#2A1F1D] dark:text-[#FFB4A2]'  
													];
													const iconTones = [
														'text-[#4A154B] dark:text-[#D0BCFF]', 
														'text-[#006064] dark:text-[#80DEEA]', 
														'text-[#1B5E20] dark:text-[#81C995]', 
														'text-[#BF360C] dark:text-[#FFB4A2]'  
													];
													const tone = tones[metricIndex % tones.length];
													const iconTone = iconTones[metricIndex % iconTones.length];

													return (
														<article class={`rounded-[2rem] p-6 shadow-[0_8px_30px_rgba(0,0,0,0.03)] dark:shadow-[0_8px_30px_rgba(0,0,0,0.15)] transition-all duration-300 hover:-translate-y-1 ${tone}`} data-metric-index={metricIndex}>
															<div class="flex items-start justify-between gap-3 mb-6">
																<p class="text-[0.75rem] font-extrabold uppercase tracking-widest opacity-90 sm:text-[0.8rem] leading-tight max-w-25 text-[#5f6368] dark:text-[#C4C7C5]">
																	{metric.label}
																</p>
																<span class={`material-symbols-rounded text-3xl opacity-80 dark:opacity-90 ${iconTone}`}>
																	{metric.icon}
																</span>
															</div>
															<div class="mt-auto">
																<p class="text-5xl sm:text-[3.5rem] font-black leading-none tracking-tighter mb-2">
																	{metric.value}
																</p>
																<p class="text-[0.85rem] font-medium opacity-60 mix-blend-multiply dark:opacity-70 dark:mix-blend-normal leading-snug sm:text-[0.9rem] text-[#5f6368] dark:text-[#C4C7C5]">
																	{metric.description}
																</p>
															</div>
														</article>
													);
												})
											}
										</div>

									<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
										<section class="rounded-[2rem] bg-white dark:bg-[#1E1F22] p-6 shadow-[0_8px_30px_rgba(0,0,0,0.03)] dark:shadow-[0_8px_30px_rgba(0,0,0,0.2)] flex flex-col gap-4 transition-colors duration-300" aria-labelledby="team-overview-title" data-team-card>
											<div class="flex items-center justify-between gap-3">
												<h2 id="team-overview-title" class="text-xl font-bold text-[#202124] dark:text-[#E3E3E3]">Equipo de trabajo</h2>
												<a href="/panel/professionals" class="text-[0.8rem] font-bold text-[#1A73E8] bg-[#E8F0FE] hover:bg-[#D2E3FC] dark:text-[#A8C7FA] dark:bg-[#1A2D42] px-4 py-1.5 rounded-full dark:hover:bg-[#152538] transition">
													Ver todos
												</a>
											</div>

											<div class="flex items-center gap-3 mt-2 bg-[#F8F9FA] dark:bg-[#2B2D31] p-3 pr-5 rounded-full shadow-[0_2px_10px_rgba(0,0,0,0.02)] dark:shadow-[0_2px_10px_rgba(0,0,0,0.2)] self-start transition-colors duration-300">
												<div class="flex -space-x-3" data-team-avatar-stack aria-label="Vista previa del equipo">
													<span class="w-10 h-10 rounded-full bg-[#E8EAED] dark:bg-[#444746] border-2 border-white dark:border-[#1E1F22] shrink-0 z-30 shadow-sm transition-colors duration-300"></span>
													<span class="w-10 h-10 rounded-full bg-[#DADCE0] dark:bg-[#5F6368] border-2 border-white dark:border-[#1E1F22] shrink-0 z-20 shadow-sm transition-colors duration-300"></span>
													<span class="w-10 h-10 rounded-full bg-[#BDC1C6] dark:bg-[#747775] border-2 border-white dark:border-[#1E1F22] shrink-0 z-10 shadow-sm transition-colors duration-300"></span>
												</div>
												<p class="text-[0.9rem] font-bold text-[#3c4043] dark:text-[#E3E3E3]" data-team-summary>
													Cargando equipo...
												</p>
											</div>
											<p class="text-sm font-medium text-rose-500 hidden mt-2 dark:text-[#FFB4AB]" data-team-state></p>
										</section>

										<div class="xl:col-span-2 rounded-[2rem] bg-white dark:bg-[#1E1F22] p-6 shadow-[0_8px_30px_rgba(0,0,0,0.03)] dark:shadow-[0_8px_30px_rgba(0,0,0,0.2)] transition-colors duration-300">
											<div class="mb-6 flex items-center justify-between gap-3">
												<h2 class="text-xl font-bold text-[#202124] dark:text-[#E3E3E3]">Próximas citas del dia</h2>
												<span class="rounded-full bg-[#E8EAED] dark:bg-[#2B2D31] px-4 py-1.5 text-[0.8rem] font-black text-[#5f6368] dark:text-[#C4C7C5] tracking-wide shadow-sm transition-colors duration-300">
													{dashboard.upcoming_appointments.length} registro(s)
												</span>
											</div>

											{
												dashboard.upcoming_appointments.length === 0 ? (
													<div class="rounded-[1.5rem] bg-[#F8F9FA] dark:bg-[#131314] px-6 py-8 text-center transition-colors duration-300">
														<div class="w-14 h-14 bg-white dark:bg-[#2B2D31] rounded-full flex items-center justify-center mx-auto mb-3 shadow-[0_4px_15px_rgba(0,0,0,0.03)] dark:shadow-[0_4px_15px_rgba(0,0,0,0.2)] transition-colors duration-300">
															<span class="material-symbols-rounded text-[#BDC1C6] dark:text-[#C4C7C5] text-2xl">event_busy</span>
														</div>
														<p class="text-base font-bold text-[#5f6368] dark:text-[#C4C7C5]">No hay citas próximas para mostrar en este momento.</p>
													</div>
												) : (
													<div class="w-full max-w-full overflow-x-auto">
														<table class="w-full min-w-full">
															<thead>
																<tr class="border-b-2 border-[#F1F3F4] dark:border-[#2B2D31] text-left text-[0.75rem] font-extrabold uppercase tracking-widest text-[#80868B] dark:text-[#8E918F] transition-colors duration-300">
																	<th class="px-4 py-3">Cliente</th>
																	<th class="px-4 py-3">Hora</th>
																	<th class="px-4 py-3">Servicio</th>
																	<th class="px-4 py-3">Estado</th>
																</tr>
															</thead>
															<tbody>
																{
																	dashboard.upcoming_appointments.map((appointment) => (
																		<tr class="border-b border-[#F8F9FA] dark:border-[#2B2D31] transition-colors hover:bg-[#F8F9FA] dark:hover:bg-[#2B2D31] last:border-none">
																			<td class="px-4 py-4">
																				<div class="font-bold text-[#202124] dark:text-[#E3E3E3] text-[0.95rem]">{appointment.customer_name}</div>
																			</td>
																			<td class="px-4 py-4 text-[0.95rem] font-bold text-[#5f6368] dark:text-[#C4C7C5]">
																				{appointment.time_start} - {appointment.time_end}
																			</td>
																			<td class="px-4 py-4 text-[0.95rem] font-medium text-[#3c4043] dark:text-[#C4C7C5]">
																				{appointment.service_name}
																			</td>
																			<td class="px-4 py-4">
																				<span
																					class:list={[
																						'inline-flex rounded-full px-3 py-1 text-[0.75rem] font-bold uppercase tracking-wider shadow-[0_2px_8px_rgba(0,0,0,0.04)] dark:shadow-[0_2px_8px_rgba(0,0,0,0.2)] transition-colors duration-300',
																						appointment.status === 'CONFIRMADO' ? 'bg-[#E6F4EA] text-[#137333] dark:bg-[#0F5223] dark:text-[#6DD58C]' : 
																						appointment.status === 'PENDIENTE' ? 'bg-[#FEF7E0] text-[#E37400] dark:bg-[#4D2E00] dark:text-[#FFB74D]' : 
																						appointment.status === 'CANCELADO' ? 'bg-[#FCE8E6] text-[#C5221F] dark:bg-[#5C1A16] dark:text-[#FFB4AB]' :
																						'bg-[#F1F3F4] text-[#5F6368] dark:bg-[#2B2D31] dark:text-[#C4C7C5]'
																					]}
																				>
																					{getStatusLabel(appointment.status)}
																				</span>
																			</td>
																		</tr>
																	))
																}
															</tbody>
														</table>
													</div>
												)
											}
										</div>
									</div>
								</>
							)
						}
					</div>
				</main>
			</div>
		</div>
	</div>
</Layout>

<script>
	const sanitizeAiSummary = (value: unknown): string =>
		String(value ?? '')
			.replace(/\*+/g, '')
			.replace(/\\r\\n|\\n|\\r/g, '\n')
			.replace(/\r\n|\r/g, '\n')
			.replace(/\t/g, ' ')
			.replace(/\u0000/g, '')
			.replace(/[ ]{2,}/g, ' ')
			.replace(/\n{3,}/g, '\n\n')
			.replace(/^\s*["'`]/, '')
			.replace(/["'`]\s*$/, '')
			.trim();

	const splitSummaryIntoTokens = (text: string): string[] =>
		String(text || '')
			.split(/(\s+)/)
			.filter((token) => token.length > 0);

	const wait = (ms: number): Promise<void> => new Promise((resolve) => window.setTimeout(resolve, ms));

	const getTokenDelayMs = () => 28 + Math.floor(Math.random() * 53);

	const streamSummaryTokens = async (node: HTMLElement, text: string): Promise<void> => {
		node.replaceChildren();

		const tokens = splitSummaryIntoTokens(text);
		for (const token of tokens) {
			if (/^\s+$/.test(token)) {
				node.appendChild(document.createTextNode(token));
				continue;
			}

			const tokenNode = document.createElement('span');
			tokenNode.className = 'ai-summary-token';
			tokenNode.textContent = token;
			node.appendChild(tokenNode);

			await wait(getTokenDelayMs());
		}
	};

	interface TeamMemberPreview {
		avatarUrl: string;
		label: string;
	}

	interface TeamOverviewPayload {
		totalRecords: number;
		members: TeamMemberPreview[];
	}

	interface TeamOverviewCache {
		expiresAt: number;
		payload: TeamOverviewPayload;
	}

	const TEAM_OVERVIEW_CACHE_KEY = 'hasel:dashboard-team-overview:v1';
	const TEAM_OVERVIEW_TTL_MS = 120000;
	const TEAM_OVERVIEW_LIMIT = 4;
	const TEAM_AVATAR_FALLBACK_PALETTE = ['#2563eb', '#0f766e', '#be185d', '#7c3aed'];

	const toRecord = (value: unknown): Record<string, unknown> =>
		typeof value === 'object' && value !== null ? (value as Record<string, unknown>) : {};

	const toNonNegativeInt = (value: unknown, fallback = 0): number => {
		const parsed = Number(value);
		if (!Number.isFinite(parsed) || parsed < 0) return fallback;
		return Math.floor(parsed);
	};

	const getTeamMemberLabel = (member: Record<string, unknown>, index: number): string => {
		const user = toRecord(member.user);
		const firstName = String(user.first_name ?? '').trim();
		const lastName = String(user.last_name ?? '').trim();
		const fullName = `${firstName} ${lastName}`.trim();
		const apexUserName = String(user.apex_user_name ?? '').trim();
		return fullName || apexUserName || `Miembro ${index + 1}`;
	};

	const normalizeTeamPayload = (value: unknown): TeamOverviewPayload => {
		const source = toRecord(value);
		const rawMembers = Array.isArray(source.members) ? source.members : [];

		const members = rawMembers.slice(0, TEAM_OVERVIEW_LIMIT).map((entry, index) => {
			const sourceMember = toRecord(entry);
			return {
				avatarUrl: String(sourceMember.avatarUrl ?? '').trim(),
				label: String(sourceMember.label ?? '').trim() || `Miembro ${index + 1}`,
			};
		});

		const totalRecords = Math.max(
			members.length,
			toNonNegativeInt(source.totalRecords, members.length)
		);

		return { totalRecords, members };
	};

	const parseTeamOverviewResponse = (value: unknown): TeamOverviewPayload => {
		const source = toRecord(value);
		const data = Array.isArray(source.data) ? source.data : [];
		const meta = toRecord(source.meta);

		const members: TeamMemberPreview[] = data.slice(0, TEAM_OVERVIEW_LIMIT).map((entry, index) => {
			const member = toRecord(entry);
			return {
				avatarUrl: String(
					member.avatar_url ?? member.profile_image_url ?? member.avatarUrl ?? ''
				).trim(),
				label: getTeamMemberLabel(member, index),
			};
		});

		const totalRecords = Math.max(
			members.length,
			toNonNegativeInt(meta.total_records, data.length)
		);

		return { totalRecords, members };
	};

	const readTeamOverviewCache = (): TeamOverviewPayload | null => {
		try {
			const rawCache = window.sessionStorage.getItem(TEAM_OVERVIEW_CACHE_KEY);
			if (!rawCache) return null;

			const parsed = JSON.parse(rawCache) as TeamOverviewCache;
			const expiresAt = Number(parsed?.expiresAt ?? 0);

			if (!Number.isFinite(expiresAt) || expiresAt <= Date.now()) {
				window.sessionStorage.removeItem(TEAM_OVERVIEW_CACHE_KEY);
				return null;
			}

			return normalizeTeamPayload(parsed?.payload);
		} catch {
			return null;
		}
	};

	const saveTeamOverviewCache = (payload: TeamOverviewPayload) => {
		try {
			const cacheEntry: TeamOverviewCache = {
				expiresAt: Date.now() + TEAM_OVERVIEW_TTL_MS,
				payload,
			};
			window.sessionStorage.setItem(TEAM_OVERVIEW_CACHE_KEY, JSON.stringify(cacheEntry));
		} catch {
			// Ignore storage errors (private mode, quota, or blocked storage).
		}
	};

	const getTeamSummaryText = (totalRecords: number): string => {
		const extraMembers = Math.max(0, totalRecords - 1);
		return `Tú y ${extraMembers} ${extraMembers === 1 ? 'miembro más' : 'miembros más'}`;
	};

	const getMemberInitials = (label: string): string => {
		const tokens = String(label || '')
			.split(/\s+/)
			.filter(Boolean);
		if (tokens.length === 0) return 'TM';
		if (tokens.length === 1) return tokens[0].slice(0, 2).toUpperCase();
		return `${tokens[0][0] || ''}${tokens[1][0] || ''}`.toUpperCase();
	};

	const renderAvatarStack = (stackNode: HTMLElement, payload: TeamOverviewPayload) => {
		stackNode.replaceChildren();

		const visibleMembers = payload.members.slice(0, TEAM_OVERVIEW_LIMIT);
		for (const [index, member] of visibleMembers.entries()) {
			const avatar = document.createElement('span');
			avatar.className = 'team-avatar';
			avatar.title = member.label;
			avatar.setAttribute('aria-label', member.label);

			if (member.avatarUrl) {
				const image = document.createElement('img');
				image.src = member.avatarUrl;
				image.alt = member.label;
				image.loading = 'lazy';
				image.decoding = 'async';
				avatar.appendChild(image);
			} else {
				avatar.classList.add('team-avatar--fallback');
				avatar.style.background =
					TEAM_AVATAR_FALLBACK_PALETTE[index % TEAM_AVATAR_FALLBACK_PALETTE.length];
				avatar.textContent = getMemberInitials(member.label);
			}

			stackNode.appendChild(avatar);
		}

		const extraCount = Math.max(0, payload.totalRecords - visibleMembers.length);
		if (extraCount > 0) {
			const more = document.createElement('span');
			more.className = 'team-avatar team-avatar--more';
			more.textContent = `+${extraCount}`;
			more.setAttribute('aria-label', `${extraCount} miembros mas`);
			stackNode.appendChild(more);
		}

		if (stackNode.childElementCount === 0) {
			const placeholder = document.createElement('span');
			placeholder.className = 'team-avatar team-avatar--placeholder';
			stackNode.appendChild(placeholder);
		}
	};

	const renderTeamOverview = (
		card: HTMLElement,
		payload: TeamOverviewPayload,
		source: 'cache' | 'network'
	) => {
		const summaryNode = card.querySelector<HTMLElement>('[data-team-summary]');
		const stateNode = card.querySelector<HTMLElement>('[data-team-state]');
		const avatarStackNode = card.querySelector<HTMLElement>('[data-team-avatar-stack]');

		if (!summaryNode || !stateNode || !avatarStackNode) return;

		summaryNode.textContent = getTeamSummaryText(payload.totalRecords);
		renderAvatarStack(avatarStackNode, payload);
		stateNode.classList.remove('team-overview-state--error');

		if (payload.totalRecords === 0) {
			stateNode.textContent = 'Aún no hay profesionales registrados.';
			stateNode.classList.remove('hidden');
			stateNode.classList.add('team-overview-state--empty');
			return;
		}

		stateNode.classList.add('hidden');
		stateNode.classList.remove('team-overview-state--empty');
		stateNode.textContent = '';
	};

	const fetchTeamOverview = async (): Promise<TeamOverviewPayload> => {
		const response = await fetch(`/api/professionals?page=1&limit=${TEAM_OVERVIEW_LIMIT}`, {
			headers: { Accept: 'application/json' },
		});
		const payload = await response.json();

		if (!response.ok || payload?.status !== 'success') {
			throw new Error(payload?.message || 'No fue posible cargar el equipo.');
		}

		return parseTeamOverviewResponse(payload);
	};

	const loadTeamOverview = async () => {
		const card = document.querySelector<HTMLElement>('[data-team-card]');
		if (!card) return;

		const stateNode = card.querySelector<HTMLElement>('[data-team-state]');
		if (!stateNode) return;

		const cachedPayload = readTeamOverviewCache();
		if (cachedPayload) {
			renderTeamOverview(card, cachedPayload, 'cache');
			return;
		}

		try {
			const teamPayload = await fetchTeamOverview();
			saveTeamOverviewCache(teamPayload);
			renderTeamOverview(card, teamPayload, 'network');
		} catch (error) {
			stateNode.classList.remove('team-overview-state--empty');
			stateNode.classList.remove('hidden');
			stateNode.textContent =
				error instanceof Error ? error.message : 'No fue posible cargar el equipo de trabajo.';
			stateNode.classList.add('team-overview-state--error');
		}
	};

	const loadAiSummary = async () => {
		const card = document.querySelector<HTMLElement>('[data-ai-summary-card]');
		if (!card) return;

		if (card.getAttribute('data-ai-summary-loaded') === '1') return;
		card.setAttribute('data-ai-summary-loaded', '1');

		const stateNode = card.querySelector<HTMLElement>('[data-ai-summary-state]');
		const textNode = card.querySelector<HTMLElement>('[data-ai-summary-text]');

		if (!stateNode || !textNode) return;

		const revealSummary = async (summaryText: string) => {
			stateNode.classList.add('hidden');
			stateNode.setAttribute('aria-hidden', 'true');
			stateNode.style.display = 'none';
			textNode.classList.remove('hidden');
			textNode.style.display = 'block';
			await streamSummaryTokens(textNode, summaryText);
		};

		try {
			const response = await fetch('/api/dashboard/ai-summary', {
				headers: { Accept: 'application/json' },
			});
			const payload = await response.json();

			if (!response.ok || payload?.status !== 'success') {
				throw new Error(payload?.message || 'No fue posible recuperar el resumen IA.');
			}

			const summary = sanitizeAiSummary(payload?.data?.ai_summary);
			if (!summary) {
				throw new Error('El resumen IA no está disponible en este momento.');
			}

			await revealSummary(summary);
		} catch (error) {
			stateNode.textContent =
				error instanceof Error
					? error.message
					: 'No fue posible recuperar el resumen IA.';
		}
	};

	loadAiSummary();
	loadTeamOverview();
	document.addEventListener('astro:page-load', loadAiSummary);
	document.addEventListener('astro:page-load', loadTeamOverview);
</script>

