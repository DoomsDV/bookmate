---
import { ROLES } from '../../config/roles';
import SideNav from '../../components/SideNav.astro';
import AppAlert from '../../components/AppAlert.astro';
import AiChatPanel from '../../components/AiChatPanel.astro';
import TopBar from '../../components/TopBar.astro';
import { DashboardApiError, getMainDashboardWithOrds, type DashboardMainData } from '../../lib/dashboard';
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';

const token = Astro.locals.token ?? '';
const roleId = Number(Astro.locals.roleId ?? 0);
const showTeamOverview = roleId !== ROLES.PROFESIONAL;
const organizationName = String(Astro.locals.organizationName || 'Workspace').trim() || 'Workspace';
const PAGE_SIZE = 5;
const rawPage = Number(Astro.url.searchParams.get('page') || '1');
const currentPage = Number.isInteger(rawPage) && rawPage > 0 ? rawPage : 1;

let dashboard: DashboardMainData = {
	kpis: {
		today_appointments: 0,
		pending_appointments: 0,
		my_customers: 2,
		total_customers: 6,
	},
	upcoming_appointments: [],
	pagination: {
		current_page: currentPage,
		per_page: PAGE_SIZE,
		total_records: 0,
		total_pages: 1,
	},
};
let loadError = '';
const defaultAiSummaryShort = '¡Buen día! Preparate para una excelente jornada de trabajo.';
const defaultAiSummaryFull = defaultAiSummaryShort;

if (!token) {
	loadError = 'No hay sesion valida para consultar el dashboard.';
} else {
	try {
		dashboard = await getMainDashboardWithOrds(token, {
			page: currentPage,
			limit: PAGE_SIZE,
		});
	} catch (error) {
		loadError =
			error instanceof DashboardApiError
				? error.message
				: 'No fue posible cargar los datos del dashboard.';
	}
}

const dashboardDate = '17 de abril del 2026';

const metrics = [
	{
		label: 'Citas de hoy',
		value: dashboard.kpis.today_appointments,
		description: 'Turnos no cancelados para la jornada actual.',
		zeroStateDescription: 'Tu agenda está libre para hoy.',
		icon: 'calendar_month',
		accent: 'violet',
	},
	{
		label: 'Próximas citas',
		value: dashboard.kpis.pending_appointments,
		description: 'Turnos por atender desde este momento en adelante.',
		zeroStateDescription: 'No hay pendientes. Puedes crear una nueva cita.',
		zeroStateActionLabel: 'Crear cita',
		zeroStateActionHref: '/panel/calendar',
		icon: 'schedule',
		accent: 'green',
	},
	...(roleId !== ROLES.RECEPCIONISTA
		? [
				{
					label: 'Mis clientes',
					value: dashboard.kpis.my_customers,
					description: 'Clientes con historial de citas contigo (incluye canceladas).',
					icon: 'groups',
					accent: 'green',
				},
			]
		: []),
	...(dashboard.kpis.total_customers !== null
		? [
				{
					label: 'Total de clientes',
					value: dashboard.kpis.total_customers,
					description: 'Base total de clientes registrados.',
					icon: 'hub',
					accent: 'orange',
				},
			]
		: []),
];

const getStatusLabel = (status: string) => {
	switch (status) {
		case 'CONFIRMADO':
			return 'Confirmado';
		case 'PENDIENTE':
			return 'Pendiente';
		case 'COMPLETADO':
			return 'Completado';
		case 'CANCELADO':
			return 'Cancelado';
		default:
			return status || 'Estado';
	}
};

const formatUpcomingAppointmentDate = (value: string) => {
	const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(String(value || '').trim());
	if (!match) return '';

	const year = Number(match[1]);
	const month = Number(match[2]);
	const day = Number(match[3]);
	const date = new Date(year, month - 1, day);
	if (Number.isNaN(date.getTime())) return '';

	const weekDays = ['Dom', 'Lun', 'Mar', 'Mie', 'Jue', 'Vie', 'Sab'];
	return `${weekDays[date.getDay()]} ${String(day).padStart(2, '0')}/${String(month).padStart(2, '0')}`;
};

const appointmentPagination = dashboard.pagination;
const totalAppointmentPages = Math.max(1, appointmentPagination.total_pages);
const safeCurrentPage = Math.min(
	Math.max(1, appointmentPagination.current_page),
	totalAppointmentPages
);
const canPrevPage = safeCurrentPage > 1;
const canNextPage = safeCurrentPage < totalAppointmentPages;
const appointmentsCountText =
	appointmentPagination.total_records === 1
		? '1 cita'
		: `${appointmentPagination.total_records} citas`;

const toPageHref = (page: number) => {
	const nextUrl = new URL(Astro.url);
	nextUrl.searchParams.set('page', String(page));
	nextUrl.hash = 'dashboard-upcoming-appointments';
	return `${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`;
};

---

<Layout>
	<div class="dashboard-canvas min-h-screen w-full max-w-full overflow-x-hidden bg-(--page-background) transition-colors duration-300">
		<div
			class="app-shell grid min-h-screen overflow-hidden bg-transparent"
			data-app-shell
			data-sidebar-state="expanded"
		>
			<SideNav currentPath={Astro.url.pathname} />

			<div class="dashboard-content-canvas grid min-h-full grid-rows-[auto_1fr] bg-(--page-background) transition-colors duration-300">
				<TopBar />

				<main class="w-full max-w-full overflow-x-hidden px-4 py-4 sm:px-8 sm:py-8 lg:px-10">
					<div class="mx-auto max-w-7xl">
						<section class="grid w-full min-w-0 gap-6 sm:gap-8">
							<section class="dashboard-summary-card mb-0 transition-all duration-300">
								<div class="flex flex-col justify-between gap-4 lg:flex-row lg:items-center">
									<div class="flex min-w-0 flex-col gap-4 lg:flex-row lg:items-center">
										<div class="grid gap-1">
											<p class="text-xs font-bold uppercase tracking-[0.2em] text-[#5f6368] dark:text-[#C4C7C5]">
												Dashboard
											</p>
											<h1 class="text-3xl font-extrabold text-[#202124] dark:text-[#E3E3E3] tracking-tight sm:text-4xl">
												Resumen diario
											</h1>
											<p class="text-[0.95rem] font-medium text-[#5f6368] dark:text-[#C4C7C5]">
												{organizationName} - {dashboardDate}
											</p>
										</div>

										{showTeamOverview && (
										<div
											class="dashboard-team-chip h-fit lg:ml-8"
											data-team-card
										>
											<div class="flex items-center gap-3">
												<div class="flex -space-x-2" data-team-avatar-stack aria-label="Vista previa del equipo">
													<span class="w-8 h-8 rounded-full bg-[#E8EAED] dark:bg-[#444746] border-2 border-white dark:border-[#1E1F22] shrink-0 z-30 transition-colors duration-300"></span>
													<span class="w-8 h-8 rounded-full bg-[#DADCE0] dark:bg-[#5F6368] border-2 border-white dark:border-[#1E1F22] shrink-0 z-20 transition-colors duration-300"></span>
													<span class="w-8 h-8 rounded-full bg-[#BDC1C6] dark:bg-[#747775] border-2 border-white dark:border-[#1E1F22] shrink-0 z-10 transition-colors duration-300"></span>
												</div>
												<p class="dashboard-team-summary" data-team-summary>
													Equipo activo
												</p>
											</div>
											<p class="team-overview-state text-[0.75rem] font-medium hidden mt-1" data-team-state></p>
										</div>
										)}
									</div>

									<div class="dashboard-header-actions">
										<a
											href="/panel/calendar"
											class="dashboard-primary-cta dashboard-header-cta inline-flex w-full items-center justify-center gap-2 rounded-full px-6 py-3 text-sm font-bold no-underline transition sm:w-auto"
										>
											<span class="material-symbols-rounded text-lg">calendar_month</span>
											Ir al calendario
										</a>
									</div>
								</div>

								<div class="mt-8">
									<div
										class="dashboard-ai-card rounded-4xl transition-all duration-300"
										data-ai-summary-card
										data-role-id={String(roleId)}
										data-default-summary-short={defaultAiSummaryShort}
										data-default-summary-full={defaultAiSummaryFull}
									>
										<div class="dashboard-ai-border-glow" aria-hidden="true"></div>
										<div class="dashboard-ai-orbs" aria-hidden="true">
											<span class="dashboard-ai-orb dashboard-ai-orb--1"></span>
											<span class="dashboard-ai-orb dashboard-ai-orb--2"></span>
											<span class="dashboard-ai-orb dashboard-ai-orb--3"></span>
											<span class="dashboard-ai-spark dashboard-ai-spark--1"></span>
											<span class="dashboard-ai-spark dashboard-ai-spark--2"></span>
											<span class="dashboard-ai-spark dashboard-ai-spark--3"></span>
										</div>
										<div class="dashboard-ai-shimmer-top" aria-hidden="true"></div>
										<div class="dashboard-ai-header mb-3">
											<div class="inline-flex items-center gap-1.5 opacity-95">
												<span class="dashboard-ai-sparkle material-symbols-rounded text-[1.1rem] text-(--primary)">auto_awesome</span>
												<h2 class="text-sm font-semibold tracking-[0.01em] text-(--primary)">
													Resumen inteligente del día
												</h2>
											</div>
										</div>
										<div
											class="dashboard-ai-state mt-1"
											data-ai-summary-state
											aria-live="polite"
										>
											<div class="dashboard-ai-loading">
												<p class="dashboard-ai-loading-label">
													<span class="material-symbols-rounded dashboard-ai-loading-icon">auto_awesome</span>
													Generando resumen inteligente...
												</p>
												<div class="dashboard-ai-skeleton" aria-hidden="true">
													<span class="dashboard-ai-skeleton-line dashboard-ai-skeleton-line--lg"></span>
													<span class="dashboard-ai-skeleton-line dashboard-ai-skeleton-line--md"></span>
													<span class="dashboard-ai-skeleton-line dashboard-ai-skeleton-line--sm"></span>
												</div>
											</div>
										</div>
										<div class="dashboard-ai-body hidden mt-1" data-ai-summary-body>
											<div class="dashboard-ai-preview-wrap">
												<div
													class="dashboard-ai-text dashboard-ai-text--preview text-[0.95rem] font-medium leading-relaxed sm:text-base max-w-4xl"
													data-ai-summary-preview
												>
													<p class="dashboard-ai-preview-intro">{defaultAiSummaryShort}</p>
												</div>
											</div>
											<button
												type="button"
												class="dashboard-ai-more-btn"
												data-open-ai-summary-modal
												hidden
											>
												<span class="dashboard-ai-more-btn__label">Ver análisis completo</span>
												<span class="material-symbols-rounded dashboard-ai-more-btn__icon">expand_more</span>
											</button>
										</div>
									</div>
								</div>
							</section>

							{
								loadError ? (
									<div class="rounded-3xl bg-rose-50 px-5 py-4 text-sm font-semibold text-rose-700 dark:bg-[#3B191E] dark:text-[#FFB4AB] shadow-sm">
										{loadError}
									</div>
								) : (
									<>
										<div class="dashboard-metrics-grid grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
											{
												metrics.map((metric) => {
													const numericValue = Number(metric.value ?? 0);
													const isZeroState = Number.isFinite(numericValue) && numericValue === 0;
													const supportingText =
														isZeroState && metric.zeroStateDescription
															? metric.zeroStateDescription
															: metric.description;

													return (
														<article class="dashboard-metric-card flex h-full flex-col rounded-4xl p-6 pb-7 transition-all duration-300" data-metric-accent={metric.accent}>
															<div class="mb-6 flex items-start justify-between gap-3">
																<p class="dashboard-metric-label text-[0.75rem] font-extrabold uppercase tracking-widest sm:text-[0.8rem] leading-tight max-w-25">
																	{metric.label}
																</p>
																<span class="dashboard-metric-icon material-symbols-rounded text-[1.5rem]">
																	{metric.icon}
																</span>
															</div>
															<div class="dashboard-metric-content">
																<p class="dashboard-metric-value mb-2">
																	{metric.value}
																</p>
																<p class="dashboard-metric-description text-[0.84rem] font-semibold leading-snug sm:text-[0.9rem]">
																	{supportingText}
																</p>
																{
																	isZeroState && metric.zeroStateActionHref && metric.zeroStateActionLabel ? (
																		<div class="dashboard-metric-zero-link-wrap mt-auto">
																			<a href={metric.zeroStateActionHref} class="dashboard-metric-zero-link">
																				{metric.zeroStateActionLabel}
																				<span class="material-symbols-rounded text-[0.95rem]">chevron_right</span>
																			</a>
																		</div>
																	) : null
																}
															</div>
														</article>
													);
												})
											}
										</div>

									<div class="grid grid-cols-1 gap-6">
										<div
											id="dashboard-upcoming-appointments"
											class="dashboard-report-shell rounded-4xl p-6 transition-colors duration-300"
										>
											<div class="mb-6 flex items-center justify-between gap-3">
												<h2 class="text-xl font-bold text-[#202124] dark:text-[#E3E3E3]">Próximas citas de los siguientes 7 días</h2>
												<span class="whitespace-nowrap rounded-full bg-[#E8EAED] dark:bg-[#2B2D31] px-4 py-1.5 text-[0.8rem] font-black text-[#5f6368] dark:text-[#C4C7C5] tracking-wide shadow-sm transition-colors duration-300">
													{appointmentsCountText}
												</span>
											</div>

											{
												dashboard.upcoming_appointments.length === 0 ? (
													<div class="rounded-3xl bg-[#F8F9FA] dark:bg-(--surface-container) px-6 py-8 text-center transition-colors duration-300">
														<div class="w-14 h-14 bg-white dark:bg-[#2B2D31] rounded-full flex items-center justify-center mx-auto mb-3 shadow-[0_4px_15px_rgba(0,0,0,0.03)] dark:shadow-[0_4px_15px_rgba(0,0,0,0.2)] transition-colors duration-300">
															<span class="material-symbols-rounded text-[#BDC1C6] dark:text-[#C4C7C5] text-2xl">event_busy</span>
														</div>
														<p class="text-base font-bold text-[#5f6368] dark:text-[#C4C7C5]">No hay citas programadas para los siguientes 7 días.</p>
													</div>
												) : (
													<div class="dashboard-report-list">
														{
															dashboard.upcoming_appointments.map((appointment) => {
																const appointmentDateLabel = formatUpcomingAppointmentDate(
																	appointment.appointment_date || ''
																);

																return (
																	<article class="dashboard-report-card">
																		<div class="dashboard-report-row">
																			<div class="dashboard-report-main">
																				<h3 class="dashboard-report-title">{appointment.customer_name}</h3>
																				<p class="dashboard-report-meta">
																					{appointmentDateLabel}
																					{appointmentDateLabel ? ' · ' : ''}
																					{appointment.time_start} - {appointment.time_end}
																				</p>
																			</div>
																			<span
																				class:list={[
																					'dashboard-report-status',
																					appointment.status === 'CONFIRMADO' ? 'dashboard-report-status--confirmed' :
																					appointment.status === 'PENDIENTE' ? 'dashboard-report-status--pending' :
																					appointment.status === 'CANCELADO' ? 'dashboard-report-status--canceled' :
																					'dashboard-report-status--default'
																				]}
																			>
																				{getStatusLabel(appointment.status)}
																			</span>
																		</div>
																		<p class="dashboard-report-service">{appointment.service_name}</p>
																	</article>
																);
															})
														}
													</div>
												)
											}

											<div class="app-pagination">
												<p class="app-pagination__summary">
													Página <strong>{safeCurrentPage}</strong> de <strong>{totalAppointmentPages}</strong>
													<span aria-hidden="true">-</span>
													Total: <strong>{appointmentPagination.total_records}</strong> citas
												</p>

												<nav class="app-pagination__controls" aria-label="Paginación próximas citas">
													{canPrevPage ? (
														<a
															href={toPageHref(safeCurrentPage - 1)}
															class="app-pagination__icon-button"
															aria-label="Página anterior"
														>
															<svg viewBox="0 0 24 24" aria-hidden="true">
																<path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6z"></path>
															</svg>
														</a>
													) : (
														<span class="app-pagination__icon-button is-disabled" aria-disabled="true">
															<svg viewBox="0 0 24 24" aria-hidden="true">
																<path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6z"></path>
															</svg>
														</span>
													)}

													<span class="app-pagination__current" aria-current="page">{safeCurrentPage}</span>

													{canNextPage ? (
														<a
															href={toPageHref(safeCurrentPage + 1)}
															class="app-pagination__icon-button"
															aria-label="Página siguiente"
														>
															<svg viewBox="0 0 24 24" aria-hidden="true">
																<path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"></path>
															</svg>
														</a>
													) : (
														<span class="app-pagination__icon-button is-disabled" aria-disabled="true">
															<svg viewBox="0 0 24 24" aria-hidden="true">
																<path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"></path>
															</svg>
														</span>
													)}
												</nav>
											</div>
										</div>
									</div>
								</>
							)
						}
					</div>
				</main>
			</div>
		</div>
	</div>
	<AiChatPanel />
	<AppAlert />

	<dialog
		class="dashboard-ai-modal m-auto h-[min(78dvh,40rem)] w-[min(42rem,calc(100vw-2rem))] max-w-[min(42rem,calc(100vw-2rem))] open:flex open:flex-col max-h-[85vh] overflow-hidden rounded-[1.8rem] border border-(--shell-border) bg-(--surface-bright) p-0 text-(--on-surface) shadow-[0_24px_80px_rgba(0,0,0,0.2)] max-md:mt-auto max-md:mb-0 max-md:w-screen max-md:max-w-none max-md:rounded-t-[1.8rem] max-md:rounded-b-none"
		data-ai-summary-modal
	>
		<div class="shrink-0 z-10 border-b border-(--shell-border) bg-(--surface-bright) px-4 py-3 sm:px-7 sm:py-5">
			<div class="flex items-start justify-between gap-4">
				<div class="flex items-center gap-3">
					<div class="flex size-11 shrink-0 items-center justify-center rounded-2xl bg-(--primary-soft) text-(--primary)">
						<span class="material-symbols-rounded text-[1.35rem]">auto_awesome</span>
					</div>
					<div>
						<h2 class="text-[1.1rem] font-extrabold tracking-tight text-(--on-surface)">
							Resumen del día
						</h2>
					</div>
				</div>
				<button
					type="button"
					class="flex size-9 shrink-0 items-center justify-center rounded-full text-(--on-surface-variant) transition-colors hover:bg-(--surface-variant) hover:text-(--on-surface) focus:outline-none focus:ring-2 focus:ring-(--primary)"
					data-close-ai-summary-modal
					aria-label="Cerrar resumen"
				>
					<span class="material-symbols-rounded text-[1.3rem]">close</span>
				</button>
			</div>
		</div>
		<div class="overflow-y-auto overscroll-contain min-h-0 px-4 py-5 sm:px-7 sm:py-6">
			<div
				class="dashboard-ai-sections dashboard-ai-sections--modal"
				data-ai-summary-modal-sections
				aria-live="polite"
			></div>
		</div>
	</dialog>
</Layout>

<script>
	const sanitizeAiSummary = (value: unknown): string =>
		String(value ?? '')
			.replace(/\*+/g, '')
			.replace(/\\r\\n|\\n|\\r/g, '\n')
			.replace(/\r\n|\r/g, '\n')
			.replace(/\t/g, ' ')
			.replace(/\u0000/g, '')
			.replace(/[ ]{2,}/g, ' ')
			.replace(/[ \t]*\n[ \t]*/g, '\n')
			.replace(/\n{2,}/g, '\n')
			.replace(/^\s*["'`]/, '')
			.replace(/["'`]\s*$/, '')
			.trim();

	const splitSummaryIntoTokens = (text: string): string[] =>
		String(text || '')
			.split(/(\s+)/)
			.filter((token) => token.length > 0);

	type AiSummarySectionType = 'panorama' | 'contexto' | 'sugerencia';

	interface AiSummarySection {
		type: AiSummarySectionType;
		text?: string;
		items?: string[];
	}

	interface AiSummaryPayload {
		summaryShort: string;
		summaryFull: string;
		sections: AiSummarySection[];
	}

	const AI_SUMMARY_SECTION_UI: Record<
		AiSummarySectionType,
		{ title: string; icon: string }
	> = {
		panorama: { title: 'Panorama', icon: 'insights' },
		contexto: { title: 'Contexto', icon: 'fact_check' },
		sugerencia: { title: 'Sugerencia', icon: 'tips_and_updates' },
	};

	const normalizeAiSummarySection = (value: unknown): AiSummarySection | null => {
		if (!value || typeof value !== 'object') return null;

		const source = value as Record<string, unknown>;
		const typeRaw = String(source.type ?? '').trim().toLowerCase();
		if (typeRaw !== 'panorama' && typeRaw !== 'contexto' && typeRaw !== 'sugerencia') {
			return null;
		}

		if (typeRaw === 'contexto') {
			const items = (Array.isArray(source.items) ? source.items : [])
				.map((item) => sanitizeAiSummary(item))
				.filter(Boolean)
				.slice(0, 3);
			return { type: typeRaw, items };
		}

		const text = sanitizeAiSummary(source.text);
		if (!text) return null;
		return { type: typeRaw, text };
	};

	const buildSectionsFromLegacy = (legacyFull: string): AiSummarySection[] => {
		const lines = String(legacyFull || '')
			.replace(/\r\n|\r/g, '\n')
			.split('\n')
			.map((line) => sanitizeAiSummary(line))
			.filter(Boolean);

		if (lines.length === 0) {
			return [
				{ type: 'panorama', text: 'Tu jornada está lista para arrancar con buen pie.' },
				{ type: 'contexto', items: [] },
				{
					type: 'sugerencia',
					text: 'Conviene revisar tu agenda y confirmar los turnos pendientes.',
				},
			];
		}

		if (lines.length === 1 && lines[0].length > 180) {
			const sentences =
				lines[0].match(/[^.!?]+[.!?]+(?:\s|$)|[^.!?]+$/g)?.map((part) => sanitizeAiSummary(part)).filter(Boolean) ??
				[lines[0]];
			if (sentences.length >= 3) {
				return [
					{ type: 'panorama', text: sentences[0] },
					{ type: 'contexto', items: sentences.slice(1, -1).slice(0, 3) },
					{ type: 'sugerencia', text: sentences[sentences.length - 1] },
				];
			}
			if (sentences.length === 2) {
				return [
					{ type: 'panorama', text: sentences[0] },
					{ type: 'contexto', items: [] },
					{ type: 'sugerencia', text: sentences[1] },
				];
			}
		}

		return [
			{ type: 'panorama', text: lines[0] },
			{ type: 'contexto', items: lines.length > 2 ? lines.slice(1, -1) : [] },
			{
				type: 'sugerencia',
				text:
					lines.length >= 2
						? lines[lines.length - 1]
						: 'Conviene revisar tu agenda y confirmar los turnos pendientes.',
			},
		];
	};

	const truncatePreviewText = (text: string, maxChars = 320): string => {
		const clean = sanitizeAiSummary(text);
		if (clean.length <= maxChars) return clean;

		const slice = clean.slice(0, maxChars);
		const lastSpace = slice.lastIndexOf(' ');
		const safeCut = lastSpace > 200 ? slice.slice(0, lastSpace) : slice;
		return `${safeCut.trim()}…`;
	};

	const normalizeForCompare = (text: string): string =>
		sanitizeAiSummary(text).toLowerCase().replace(/\s+/g, ' ');

	const textsAreRedundant = (candidate: string, existing: string): boolean => {
		const c = normalizeForCompare(candidate);
		const e = normalizeForCompare(existing);
		if (!c || !e) return true;
		if (e === c || e.includes(c) || c.includes(e)) return true;

		const cWords = c.split(' ').filter((word) => word.length > 3);
		const eWords = new Set(e.split(' ').filter((word) => word.length > 3));
		if (cWords.length === 0) return true;

		const shared = cWords.filter((word) => eWords.has(word)).length;
		if (shared / cWords.length >= 0.55) return true;

		const greeting = c.match(/^(buenos días|buenas tardes|buenas noches)[,!.\s]+/i);
		if (greeting && e.includes(greeting[0].toLowerCase().trim())) {
			const cBody = c.slice(greeting[0].length).trim();
			const eBody = e.replace(/^(buenos días|buenas tardes|buenas noches)[,!.\s]+/i, '').trim();
			if (!cBody || eBody.includes(cBody.slice(0, Math.min(cBody.length, 40)))) return true;

			const cBodyWords = cBody.split(' ').filter((word) => word.length > 3);
			const eBodyWords = new Set(eBody.split(' ').filter((word) => word.length > 3));
			const bodyShared = cBodyWords.filter((word) => eBodyWords.has(word)).length;
			if (cBodyWords.length > 0 && bodyShared / cBodyWords.length >= 0.5) return true;
		}

		return false;
	};

	const buildMobilePreviewContent = (
		summaryShort: string,
		summaryFull: string,
		sections: AiSummarySection[]
	): { intro: string; highlights: string[] } => {
		const short = sanitizeAiSummary(summaryShort);
		const highlights: string[] = [];
		const combined = () => [short, ...highlights].filter(Boolean).join(' ');

		const tryAddExtra = (text: string) => {
			const clean = sanitizeAiSummary(text);
			if (!clean || textsAreRedundant(clean, combined())) return;
			highlights.push(clean);
		};

		for (const item of sections.find((section) => section.type === 'contexto')?.items ?? []) {
			tryAddExtra(item);
			if (highlights.length >= 2) break;
		}

		if (highlights.length < 2) {
			const sugerencia = sections.find((section) => section.type === 'sugerencia')?.text;
			if (sugerencia) tryAddExtra(sugerencia);
		}

		return {
			intro: truncatePreviewText(short || summaryFull, 220),
			highlights,
		};
	};

	const renderMobilePreview = (
		container: HTMLElement,
		content: { intro: string; highlights: string[] }
	) => {
		container.replaceChildren();

		if (content.intro) {
			const intro = document.createElement('p');
			intro.className = 'dashboard-ai-preview-intro';
			intro.textContent = content.intro;
			container.appendChild(intro);
		}

		if (content.highlights.length === 0) return;

		const list = document.createElement('ul');
		list.className = 'dashboard-ai-preview-highlights';
		for (const item of content.highlights) {
			const listItem = document.createElement('li');
			listItem.textContent = item;
			list.appendChild(listItem);
		}
		container.appendChild(list);
	};

	const summaryHasExpandedDetail = (
		summaryShort: string,
		summaryFull: string,
		sections: AiSummarySection[]
	): boolean => {
		if (sections.some((section) => sectionHasVisibleContent(section))) {
			return sections.length > 1 || (sections[0]?.text?.length ?? 0) > summaryShort.length + 24;
		}

		return summaryFull.replace(/\s+/g, ' ').trim() !== summaryShort.replace(/\s+/g, ' ').trim();
	};

	const normalizeAiSummarySections = (
		value: unknown,
		legacyFull: string
	): AiSummarySection[] => {
		const sections = (Array.isArray(value) ? value : [])
			.map(normalizeAiSummarySection)
			.filter((item): item is AiSummarySection => item !== null);

		if (sections.length > 0) return sections;
		return buildSectionsFromLegacy(legacyFull);
	};

	const sectionHasVisibleContent = (section: AiSummarySection): boolean => {
		if (section.type === 'contexto') {
			return (section.items ?? []).some((item) => Boolean(sanitizeAiSummary(item)));
		}
		return Boolean(sanitizeAiSummary(section.text));
	};

	const renderAiSummarySections = (
		container: HTMLElement,
		sections: AiSummarySection[],
		variant: 'card' | 'modal'
	) => {
		container.replaceChildren();

		for (const section of sections) {
			if (!sectionHasVisibleContent(section)) continue;

			const meta = AI_SUMMARY_SECTION_UI[section.type];
			const article = document.createElement('article');
			article.className = `dashboard-ai-section dashboard-ai-section--${section.type}`;

			const header = document.createElement('div');
			header.className = 'dashboard-ai-section__header';

			const iconWrap = document.createElement('span');
			iconWrap.className = 'dashboard-ai-section__icon';
			iconWrap.setAttribute('aria-hidden', 'true');
			const icon = document.createElement('span');
			icon.className = 'material-symbols-rounded';
			icon.textContent = meta.icon;
			iconWrap.appendChild(icon);

			const title = document.createElement('h3');
			title.className = 'dashboard-ai-section__title';
			title.textContent = meta.title;

			header.appendChild(iconWrap);
			header.appendChild(title);
			article.appendChild(header);

			if (section.type === 'contexto') {
				const list = document.createElement('ul');
				list.className = 'dashboard-ai-section__list';
				for (const item of section.items ?? []) {
					const cleanItem = sanitizeAiSummary(item);
					if (!cleanItem) continue;
					const listItem = document.createElement('li');
					listItem.textContent = cleanItem;
					list.appendChild(listItem);
				}
				if (list.childElementCount === 0) continue;
				article.appendChild(list);
			} else {
				const body = document.createElement('p');
				body.className = 'dashboard-ai-section__text';
				body.textContent = sanitizeAiSummary(section.text);
				article.appendChild(body);
			}

			container.appendChild(article);
		}
	};

	const wait = (ms: number): Promise<void> => new Promise((resolve) => window.setTimeout(resolve, ms));

	const getTokenDelayMs = () => 28 + Math.floor(Math.random() * 53);

	const streamSummaryTokens = async (node: HTMLElement, text: string): Promise<void> => {
		node.replaceChildren();

		const tokens = splitSummaryIntoTokens(text);
		for (const token of tokens) {
			if (/^\s+$/.test(token)) {
				node.appendChild(document.createTextNode(token));
				continue;
			}

			const tokenNode = document.createElement('span');
			tokenNode.className = 'ai-summary-token';
			tokenNode.textContent = token;
			node.appendChild(tokenNode);

			await wait(getTokenDelayMs());
		}
	};

	interface TeamMemberPreview {
		avatarUrl: string;
		label: string;
	}

	interface TeamOverviewPayload {
		totalRecords: number;
		members: TeamMemberPreview[];
	}

	interface TeamOverviewCache {
		expiresAt: number;
		payload: TeamOverviewPayload;
	}

	interface AiSummaryCache {
		dateKey: string;
		roleId: number;
		summaryShort: string;
		summaryFull: string;
		sections: AiSummarySection[];
		savedAt: number;
		expiresAt: number;
	}

	const TEAM_OVERVIEW_CACHE_KEY = 'hasel:dashboard-team-overview:v1';
	const TEAM_OVERVIEW_TTL_MS = 120000;
	const TEAM_OVERVIEW_LIMIT = 4;
	const TEAM_AVATAR_FALLBACK_PALETTE = ['#2563eb', '#0f766e', '#be185d', '#7c3aed'];
	const AI_SUMMARY_CACHE_KEY = 'hasel:dashboard-ai-summary:v4';
	const AI_SUMMARY_TTL_MS = 10 * 60 * 1000;
	const DEFAULT_AI_SUMMARY_SHORT = '¡Buen día! Preparate para una excelente jornada de trabajo.';
	const DEFAULT_AI_SUMMARY_FULL = DEFAULT_AI_SUMMARY_SHORT;
	const DEFAULT_AI_SUMMARY_SECTIONS: AiSummarySection[] = buildSectionsFromLegacy(DEFAULT_AI_SUMMARY_FULL);
	const AI_MODAL_CLOSE_MS = 140;

	let aiSummaryModalSections: AiSummarySection[] = [];
	let aiSummaryModalCloseTimer: number | null = null;

	const applyAiSummaryContent = async (payload: AiSummaryPayload) => {
		const card = document.querySelector<HTMLElement>('[data-ai-summary-card]');
		if (!card) return;

		const previewNode = card.querySelector<HTMLElement>('[data-ai-summary-preview]');
		const moreButton = card.querySelector<HTMLButtonElement>('[data-open-ai-summary-modal]');
		const fallbackShort =
			sanitizeAiSummary(card.getAttribute('data-default-summary-short')) || DEFAULT_AI_SUMMARY_SHORT;
		const fallbackFull =
			sanitizeAiSummary(card.getAttribute('data-default-summary-full')) || fallbackShort;

		if (!previewNode) return;

		const summaryShort = sanitizeAiSummary(payload.summaryShort) || fallbackShort;
		const summaryFull = sanitizeAiSummary(payload.summaryFull) || summaryShort || fallbackFull;
		const sections =
			payload.sections.length > 0
				? payload.sections
				: buildSectionsFromLegacy(summaryFull || summaryShort);

		aiSummaryModalSections = sections;

		const hasExpandedContent = summaryHasExpandedDetail(summaryShort, summaryFull, sections);

		if (moreButton) {
			moreButton.hidden = !hasExpandedContent;
		}

		const previewWrap = card.querySelector<HTMLElement>('.dashboard-ai-preview-wrap');
		if (previewWrap) {
			previewWrap.classList.toggle('has-more', hasExpandedContent);
		}

		renderMobilePreview(
			previewNode,
			buildMobilePreviewContent(summaryShort, summaryFull, sections)
		);
	};

	const toRecord = (value: unknown): Record<string, unknown> =>
		typeof value === 'object' && value !== null ? (value as Record<string, unknown>) : {};

	const padDatePart = (value: number): string => String(value).padStart(2, '0');

	const getLocalDateKey = (date = new Date()): string =>
		`${date.getFullYear()}-${padDatePart(date.getMonth() + 1)}-${padDatePart(date.getDate())}`;

	const readAiSummaryCache = (dateKey: string, roleId: number): AiSummaryPayload | null => {
		try {
			const rawCache = window.localStorage.getItem(AI_SUMMARY_CACHE_KEY);
			if (!rawCache) return null;

			const parsed = JSON.parse(rawCache) as Partial<AiSummaryCache>;
			if (parsed?.dateKey !== dateKey || Number(parsed?.roleId ?? -1) !== roleId) {
				window.localStorage.removeItem(AI_SUMMARY_CACHE_KEY);
				return null;
			}

			const savedAt = Number(parsed?.savedAt ?? 0);
			const expiresAt = Number(parsed?.expiresAt ?? savedAt + AI_SUMMARY_TTL_MS);
			if (!Number.isFinite(expiresAt) || expiresAt <= Date.now()) {
				window.localStorage.removeItem(AI_SUMMARY_CACHE_KEY);
				return null;
			}

			const summaryShort = sanitizeAiSummary(parsed?.summaryShort);
			const summaryFull = sanitizeAiSummary(parsed?.summaryFull) || summaryShort;
			const sections = normalizeAiSummarySections(parsed?.sections, summaryFull || summaryShort);
			if (!summaryShort && !summaryFull && sections.length === 0) return null;

			return {
				summaryShort: summaryShort || summaryFull,
				summaryFull: summaryFull || summaryShort,
				sections,
			};
		} catch {
			return null;
		}
	};

	const saveAiSummaryCache = (dateKey: string, roleId: number, payload: AiSummaryPayload) => {
		const summaryShort = sanitizeAiSummary(payload.summaryShort);
		const summaryFull = sanitizeAiSummary(payload.summaryFull) || summaryShort;
		const sections = payload.sections.length
			? payload.sections
			: buildSectionsFromLegacy(summaryFull || summaryShort);
		if (!summaryShort && !summaryFull && sections.length === 0) return;

		try {
			const savedAt = Date.now();
			const cacheEntry: AiSummaryCache = {
				dateKey,
				roleId,
				summaryShort: summaryShort || summaryFull,
				summaryFull: summaryFull || summaryShort,
				sections,
				savedAt,
				expiresAt: savedAt + AI_SUMMARY_TTL_MS,
			};
			window.localStorage.setItem(AI_SUMMARY_CACHE_KEY, JSON.stringify(cacheEntry));
		} catch {
			// Ignore storage errors (private mode, quota, or blocked storage).
		}
	};

	const toNonNegativeInt = (value: unknown, fallback = 0): number => {
		const parsed = Number(value);
		if (!Number.isFinite(parsed) || parsed < 0) return fallback;
		return Math.floor(parsed);
	};

	const getTeamMemberLabel = (member: Record<string, unknown>, index: number): string => {
		const user = toRecord(member.user);
		const firstName = String(user.first_name ?? '').trim();
		const lastName = String(user.last_name ?? '').trim();
		const fullName = `${firstName} ${lastName}`.trim();
		const email = String(user.email ?? '').trim();
		return fullName || email || `Miembro ${index + 1}`;
	};

	const normalizeTeamPayload = (value: unknown): TeamOverviewPayload => {
		const source = toRecord(value);
		const rawMembers = Array.isArray(source.members) ? source.members : [];

		const members = rawMembers.slice(0, TEAM_OVERVIEW_LIMIT).map((entry, index) => {
			const sourceMember = toRecord(entry);
			return {
				avatarUrl: String(sourceMember.avatarUrl ?? '').trim(),
				label: String(sourceMember.label ?? '').trim() || `Miembro ${index + 1}`,
			};
		});

		const totalRecords = Math.max(
			members.length,
			toNonNegativeInt(source.totalRecords, members.length)
		);

		return { totalRecords, members };
	};

	const parseTeamOverviewResponse = (value: unknown): TeamOverviewPayload => {
		const source = toRecord(value);
		const data = Array.isArray(source.data) ? source.data : [];
		const meta = toRecord(source.meta);

		const members: TeamMemberPreview[] = data.slice(0, TEAM_OVERVIEW_LIMIT).map((entry, index) => {
			const member = toRecord(entry);
			return {
				avatarUrl: String(
					member.avatar_url ?? member.profile_image_url ?? member.avatarUrl ?? ''
				).trim(),
				label: getTeamMemberLabel(member, index),
			};
		});

		const totalRecords = Math.max(
			members.length,
			toNonNegativeInt(meta.total_records, data.length)
		);

		return { totalRecords, members };
	};

	const readTeamOverviewCache = (): TeamOverviewPayload | null => {
		try {
			const rawCache = window.sessionStorage.getItem(TEAM_OVERVIEW_CACHE_KEY);
			if (!rawCache) return null;

			const parsed = JSON.parse(rawCache) as TeamOverviewCache;
			const expiresAt = Number(parsed?.expiresAt ?? 0);

			if (!Number.isFinite(expiresAt) || expiresAt <= Date.now()) {
				window.sessionStorage.removeItem(TEAM_OVERVIEW_CACHE_KEY);
				return null;
			}

			return normalizeTeamPayload(parsed?.payload);
		} catch {
			return null;
		}
	};

	const saveTeamOverviewCache = (payload: TeamOverviewPayload) => {
		try {
			const cacheEntry: TeamOverviewCache = {
				expiresAt: Date.now() + TEAM_OVERVIEW_TTL_MS,
				payload,
			};
			window.sessionStorage.setItem(TEAM_OVERVIEW_CACHE_KEY, JSON.stringify(cacheEntry));
		} catch {
			// Ignore storage errors (private mode, quota, or blocked storage).
		}
	};

	const getTeamSummaryText = (totalRecords: number): string => {
		const extraMembers = Math.max(0, totalRecords - 1);
		if (totalRecords <= 0) return 'Equipo activo';
		if (extraMembers <= 0) return 'Equipo activo';
		return `Equipo activo · +${extraMembers} ${extraMembers === 1 ? 'miembro' : 'miembros'}`;
	};

	const getMemberInitials = (label: string): string => {
		const tokens = String(label || '')
			.split(/\s+/)
			.filter(Boolean);
		if (tokens.length === 0) return 'TM';
		if (tokens.length === 1) return tokens[0].slice(0, 2).toUpperCase();
		return `${tokens[0][0] || ''}${tokens[1][0] || ''}`.toUpperCase();
	};

	const renderAvatarStack = (stackNode: HTMLElement, payload: TeamOverviewPayload) => {
		stackNode.replaceChildren();

		const visibleMembers = payload.members.slice(0, TEAM_OVERVIEW_LIMIT);
		for (const [index, member] of visibleMembers.entries()) {
			const avatar = document.createElement('span');
			avatar.className = 'team-avatar';
			avatar.title = member.label;
			avatar.setAttribute('aria-label', member.label);

			if (member.avatarUrl) {
				const image = document.createElement('img');
				image.src = member.avatarUrl;
				image.alt = member.label;
				image.loading = 'lazy';
				image.decoding = 'async';
				avatar.appendChild(image);
			} else {
				avatar.classList.add('team-avatar--fallback');
				avatar.style.background =
					TEAM_AVATAR_FALLBACK_PALETTE[index % TEAM_AVATAR_FALLBACK_PALETTE.length];
				avatar.textContent = getMemberInitials(member.label);
			}

			stackNode.appendChild(avatar);
		}

		const extraCount = Math.max(0, payload.totalRecords - visibleMembers.length);
		if (extraCount > 0) {
			const more = document.createElement('span');
			more.className = 'team-avatar team-avatar--more';
			more.textContent = `+${extraCount}`;
			more.setAttribute('aria-label', `${extraCount} miembros mas`);
			stackNode.appendChild(more);
		}

		if (stackNode.childElementCount === 0) {
			const placeholder = document.createElement('span');
			placeholder.className = 'team-avatar team-avatar--placeholder';
			stackNode.appendChild(placeholder);
		}
	};

	const renderTeamOverview = (
		card: HTMLElement,
		payload: TeamOverviewPayload,
		source: 'cache' | 'network'
	) => {
		const summaryNode = card.querySelector<HTMLElement>('[data-team-summary]');
		const stateNode = card.querySelector<HTMLElement>('[data-team-state]');
		const avatarStackNode = card.querySelector<HTMLElement>('[data-team-avatar-stack]');

		if (!summaryNode || !stateNode || !avatarStackNode) return;

		summaryNode.textContent = getTeamSummaryText(payload.totalRecords);
		renderAvatarStack(avatarStackNode, payload);
		stateNode.classList.remove('team-overview-state--error');

		if (payload.totalRecords === 0) {
			stateNode.textContent = 'Aún no hay profesionales registrados.';
			stateNode.classList.remove('hidden');
			stateNode.classList.add('team-overview-state--empty');
			return;
		}

		stateNode.classList.add('hidden');
		stateNode.classList.remove('team-overview-state--empty');
		stateNode.textContent = '';
	};

	const fetchTeamOverview = async (): Promise<TeamOverviewPayload> => {
		const response = await fetch(`/api/professionals?page=1&limit=${TEAM_OVERVIEW_LIMIT}`, {
			headers: { Accept: 'application/json' },
		});
		const payload = await response.json();

		if (!response.ok || payload?.status !== 'success') {
			throw new Error(payload?.message || 'No fue posible cargar el equipo.');
		}

		return parseTeamOverviewResponse(payload);
	};

	const loadTeamOverview = async () => {
		const card = document.querySelector<HTMLElement>('[data-team-card]');
		if (!card) return;

		const stateNode = card.querySelector<HTMLElement>('[data-team-state]');
		if (!stateNode) return;

		const cachedPayload = readTeamOverviewCache();
		if (cachedPayload) {
			renderTeamOverview(card, cachedPayload, 'cache');
			return;
		}

		try {
			const teamPayload = await fetchTeamOverview();
			saveTeamOverviewCache(teamPayload);
			renderTeamOverview(card, teamPayload, 'network');
		} catch (error) {
			stateNode.classList.remove('team-overview-state--empty');
			stateNode.classList.remove('hidden');
			stateNode.textContent =
				error instanceof Error ? error.message : 'No fue posible cargar el equipo de trabajo.';
			stateNode.classList.add('team-overview-state--error');
		}
	};

	const openAiSummaryModal = () => {
		const modal = document.querySelector<HTMLDialogElement>('[data-ai-summary-modal]');
		const modalSections = document.querySelector<HTMLElement>('[data-ai-summary-modal-sections]');
		if (!modal || !modalSections) return;

		renderAiSummarySections(modalSections, aiSummaryModalSections, 'modal');
		modal.classList.remove('is-closing');

		if (aiSummaryModalCloseTimer) {
			window.clearTimeout(aiSummaryModalCloseTimer);
			aiSummaryModalCloseTimer = null;
		}

		if (!modal.open) modal.showModal();
	};

	const closeAiSummaryModal = () => {
		const modal = document.querySelector<HTMLDialogElement>('[data-ai-summary-modal]');
		if (!modal?.open) return;

		modal.classList.add('is-closing');
		if (aiSummaryModalCloseTimer) window.clearTimeout(aiSummaryModalCloseTimer);

		aiSummaryModalCloseTimer = window.setTimeout(() => {
			modal.close();
			modal.classList.remove('is-closing');
			aiSummaryModalCloseTimer = null;
		}, AI_MODAL_CLOSE_MS);
	};

	const bindAiSummaryModalEvents = () => {
		const modal = document.querySelector<HTMLDialogElement>('[data-ai-summary-modal]');
		if (!modal || modal.dataset.bound === '1') return;
		modal.dataset.bound = '1';

		modal.addEventListener('click', (event) => {
			const target = event.target;
			if (!(target instanceof Element)) return;
			if (target.closest('[data-close-ai-summary-modal]')) {
				closeAiSummaryModal();
				return;
			}
			if (target === modal) closeAiSummaryModal();
		});

		modal.addEventListener('cancel', (event) => {
			event.preventDefault();
			closeAiSummaryModal();
		});

		document.addEventListener('click', (event) => {
			const target = event.target;
			if (!(target instanceof Element)) return;
			if (target.closest('[data-open-ai-summary-modal]')) {
				openAiSummaryModal();
			}
		});
	};

	const loadAiSummary = async () => {
		const card = document.querySelector<HTMLElement>('[data-ai-summary-card]');
		if (!card) return;

		if (card.getAttribute('data-ai-summary-loaded') === '1') return;
		card.setAttribute('data-ai-summary-loaded', '1');

		const stateNode = card.querySelector<HTMLElement>('[data-ai-summary-state]');
		const bodyNode = card.querySelector<HTMLElement>('[data-ai-summary-body]');
		const previewNode = card.querySelector<HTMLElement>('[data-ai-summary-preview]');
		const roleId = Number(card.getAttribute('data-role-id') ?? '0');
		const fallbackShort =
			sanitizeAiSummary(card.getAttribute('data-default-summary-short')) || DEFAULT_AI_SUMMARY_SHORT;
		const fallbackFull =
			sanitizeAiSummary(card.getAttribute('data-default-summary-full')) || fallbackShort;
		const fallbackSections = buildSectionsFromLegacy(fallbackFull);

		if (!stateNode || !bodyNode || !previewNode) return;

		bindAiSummaryModalEvents();
		card.classList.add('is-generating');

		const revealSummary = async (payload: AiSummaryPayload) => {
			card.classList.remove('is-generating');
			stateNode.classList.add('hidden');
			stateNode.setAttribute('aria-hidden', 'true');
			stateNode.style.display = 'none';
			bodyNode.classList.remove('hidden');
			bodyNode.style.display = 'block';

			await applyAiSummaryContent(payload);
		};

		const todayKey = getLocalDateKey();
		const cachedSummary = readAiSummaryCache(todayKey, roleId);

		if (cachedSummary) {
			await revealSummary(cachedSummary);
			return;
		}

		try {
			const response = await fetch('/api/dashboard/ai-summary', {
				headers: { Accept: 'application/json' },
			});
			const payload = await response.json();

			if (!response.ok || payload?.status !== 'success') {
				throw new Error(payload?.message || 'No fue posible recuperar el resumen IA.');
			}

			const summaryShort = sanitizeAiSummary(payload?.data?.ai_summary_short);
			const summaryFull = sanitizeAiSummary(payload?.data?.ai_summary);
			const sections = normalizeAiSummarySections(
				payload?.data?.ai_summary_sections,
				summaryFull || summaryShort
			);
			if (!summaryShort && !summaryFull && sections.length === 0) {
				throw new Error('El resumen IA no está disponible en este momento.');
			}

			const normalizedSummary: AiSummaryPayload = {
				summaryShort: summaryShort || summaryFull,
				summaryFull: summaryFull || summaryShort,
				sections,
			};

			saveAiSummaryCache(todayKey, roleId, normalizedSummary);
			await revealSummary(normalizedSummary);
		} catch {
			await revealSummary({
				summaryShort: fallbackShort,
				summaryFull: fallbackFull,
				sections: fallbackSections,
			});
		} finally {
			card.classList.remove('is-generating');
		}
	};

	const initializeDashboardPage = () => {
		loadAiSummary();
		loadTeamOverview();
		scrollToUpcomingAppointmentsIfNeeded();
	};

	const UPCOMING_APPOINTMENTS_ANCHOR_ID = 'dashboard-upcoming-appointments';
	const UPCOMING_APPOINTMENTS_SCROLL_OFFSET = 12;

	const getDashboardScrollContainer = (): HTMLElement | null =>
		document.querySelector<HTMLElement>('.app-shell > :last-child > main');

	const shouldScrollToUpcomingAppointments = (): boolean => {
		const url = new URL(window.location.href);
		return (
			url.hash === `#${UPCOMING_APPOINTMENTS_ANCHOR_ID}` ||
			url.searchParams.has('page')
		);
	};

	const scrollToUpcomingAppointments = (behavior: ScrollBehavior = 'smooth') => {
		const target = document.getElementById(UPCOMING_APPOINTMENTS_ANCHOR_ID);
		const container = getDashboardScrollContainer();
		if (!target || !container) return;

		const containerTop = container.getBoundingClientRect().top;
		const targetTop = target.getBoundingClientRect().top;
		const nextScrollTop =
			container.scrollTop + (targetTop - containerTop) - UPCOMING_APPOINTMENTS_SCROLL_OFFSET;

		container.scrollTo({
			top: Math.max(0, nextScrollTop),
			behavior,
		});
	};

	const scrollToUpcomingAppointmentsIfNeeded = () => {
		if (!shouldScrollToUpcomingAppointments()) return;

		const behavior: ScrollBehavior = window.matchMedia('(prefers-reduced-motion: reduce)').matches
			? 'auto'
			: 'smooth';

		requestAnimationFrame(() => {
			requestAnimationFrame(() => {
				scrollToUpcomingAppointments(behavior);
			});
		});
	};

	initializeDashboardPage();
	document.addEventListener('astro:page-load', initializeDashboardPage);
</script>

