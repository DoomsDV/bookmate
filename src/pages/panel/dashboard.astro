	dialog[data-ai-summary-modal] {
		position: fixed;
		inset: 0;
		animation: ai-summary-modal-in var(--modal-open-duration, 220ms) var(--modal-easing, cubic-bezier(0.16, 1, 0.3, 1));
	}

	dialog[data-ai-summary-modal]::backdrop {
		animation: ai-summary-backdrop-in var(--modal-open-duration, 220ms) var(--modal-easing, cubic-bezier(0.16, 1, 0.3, 1));
	}

	dialog[data-ai-summary-modal].is-closing {
		animation: ai-summary-modal-out var(--modal-close-duration, 140ms) var(--modal-easing, cubic-bezier(0.16, 1, 0.3, 1)) forwards;
	}

	dialog[data-ai-summary-modal].is-closing::backdrop {
		animation: ai-summary-backdrop-out var(--modal-close-duration, 140ms) var(--modal-easing, cubic-bezier(0.16, 1, 0.3, 1)) forwards;
	}

	@keyframes ai-summary-modal-in {
		from {
			opacity: 0;
			transform: translateY(100%);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes ai-summary-modal-out {
		from {
			opacity: 1;
			transform: translateY(0);
		}

		to {
			opacity: 0;
			transform: translateY(100%);
		}
	}

	@keyframes ai-summary-backdrop-in {
		from { opacity: 0; }
		to { opacity: 1; }
	}

	@keyframes ai-summary-backdrop-out {
		from { opacity: 1; }
		to { opacity: 0; }
	}

	@media (min-width: 640px) {
		@keyframes ai-summary-modal-in {
			from {
				opacity: 0;
				transform: translateY(10px) scale(0.98);
			}

			to {
				opacity: 1;
				transform: translateY(0) scale(1);
			}
		}

		@keyframes ai-summary-modal-out {
			from {
				opacity: 1;
				transform: translateY(0) scale(1);
			}

			to {
				opacity: 0;
				transform: translateY(8px) scale(0.98);
			}
		}
	}

