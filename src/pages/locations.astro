---
import AppAlert from '../components/AppAlert.astro';
import FlashMessage from '../components/FlashMessage.astro';
import LocationsGrid from '../components/LocationsGrid.astro';
import SideNav from '../components/SideNav.astro';
import TopBar from '../components/TopBar.astro';
import { LocationsApiError, LocationsClient, type Location } from '../lib/locations';
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const token = Astro.locals.token ?? '';
const PAGE_SIZE = 9;
const rawPage = Number(Astro.url.searchParams.get('page') || '1');
const currentPage = Number.isInteger(rawPage) && rawPage > 0 ? rawPage : 1;
const flashMessage = Astro.url.searchParams.get('flash_message') ?? '';
const flashTypeRaw = Astro.url.searchParams.get('flash_type') ?? 'success';
const validFlashTypes = ['success', 'error', 'info', 'warning'] as const;
type FlashType = (typeof validFlashTypes)[number];
const flashType: FlashType = validFlashTypes.includes(flashTypeRaw as FlashType)
	? (flashTypeRaw as FlashType)
	: 'info';

let locations: Location[] = [];
let loadError = '';
let pagination = {
	current_page: currentPage,
	per_page: PAGE_SIZE,
	total_records: 0,
	total_pages: 1,
};

if (!token) {
	loadError = 'No hay sesión válida para consultar sucursales.';
} else {
	try {
		const apiClient = new LocationsClient(token);
		const listResult = await apiClient.list(currentPage, PAGE_SIZE);
		locations = listResult.data;
		pagination = listResult.meta;
	} catch (error) {
		loadError =
			error instanceof LocationsApiError
				? error.message
				: 'No fue posible cargar el listado de sucursales.';
	}
}

const totalPages = Math.max(1, pagination.total_pages);
const safeCurrentPage = Math.min(Math.max(1, pagination.current_page), totalPages);
const canPrevPage = safeCurrentPage > 1;
const canNextPage = safeCurrentPage < totalPages;

const toPageHref = (page: number) => {
	const nextUrl = new URL(Astro.url);
	nextUrl.searchParams.set('page', String(page));
	nextUrl.searchParams.delete('flash_message');
	nextUrl.searchParams.delete('flash_type');
	return `${nextUrl.pathname}${nextUrl.search}`;
};

const pageWindowStart = Math.max(1, safeCurrentPage - 1);
const pageWindowEnd = Math.min(totalPages, safeCurrentPage + 1);
const visiblePages = Array.from(
	{ length: pageWindowEnd - pageWindowStart + 1 },
	(_, index) => pageWindowStart + index
);
const googleMapsApiKey =
	import.meta.env.PUBLIC_G_MAPS_API_KEY ??
	import.meta.env.PUBLIC_G_MAPS_API_KEYS ??
	'';
---

<Layout>
	<location-manager data-google-maps-api-key={googleMapsApiKey}>
	<div class="min-h-screen">
		<div
			class="app-shell grid min-h-screen overflow-hidden border border-[color:var(--shell-border)] bg-[color:var(--shell-surface)] shadow-[0_30px_80px_rgba(15,23,42,0.12)] backdrop-blur-xl"
			data-app-shell
			data-sidebar-state="expanded"
		>
			<SideNav currentPath={Astro.url.pathname} />

			<div class="grid min-h-full grid-rows-[auto_1fr]">
				<TopBar />

				<main class="bg-[color:var(--content-surface)] px-5 py-5 sm:px-7 sm:py-7">
					<section class="grid gap-6">
						{
							flashMessage ? (
								<div class="pointer-events-auto fixed right-4 top-24 z-[70] w-[min(calc(100vw-2rem),30rem)] sm:right-6 sm:top-28">
									<FlashMessage message={flashMessage} type={flashType} autoHideMs={4200} />
								</div>
							) : null
						}

						{
							loadError ? (
								<FlashMessage message={loadError} type="error" expand={true} dismissible={false} />
							) : (
								<div class="grid gap-5">
									<LocationsGrid locations={locations} showCreateAction={true} />

									<div class="flex flex-col gap-3 rounded-[1.2rem] border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
										<p class="text-sm text-[color:var(--on-surface-variant)]">
											Pagina <span class="font-semibold text-[color:var(--on-surface)]">{safeCurrentPage}</span> de
											<span class="font-semibold text-[color:var(--on-surface)]"> {totalPages}</span>
											<span class="mx-2">-</span>
											Total de
											<span class="font-semibold text-[color:var(--on-surface)]">
												{` ${pagination.total_records} `}
											</span>
											sucursales
										</p>

										<nav class="flex items-center gap-2" aria-label="Paginación sucursales">
											{
												canPrevPage ? (
													<a
														href={toPageHref(safeCurrentPage - 1)}
														class="rounded-lg border border-[color:var(--shell-border)] px-3 py-1.5 text-sm font-semibold text-[color:var(--on-surface)] no-underline transition hover:bg-[color:var(--control-surface)]"
													>
														Anterior
													</a>
												) : (
													<span class="cursor-not-allowed rounded-lg border border-[color:var(--shell-border)] px-3 py-1.5 text-sm font-semibold text-[color:var(--on-surface-variant)]/60">
														Anterior
													</span>
												)
											}

											{
												visiblePages.map((page) =>
													page === safeCurrentPage ? (
														<span class="rounded-lg border border-[color:var(--primary-container)] bg-[color:var(--primary-soft)] px-3 py-1.5 text-sm font-bold text-[color:var(--primary)]">
															{page}
														</span>
													) : (
														<a
															href={toPageHref(page)}
															class="rounded-lg border border-[color:var(--shell-border)] px-3 py-1.5 text-sm font-semibold text-[color:var(--on-surface)] no-underline transition hover:bg-[color:var(--control-surface)]"
														>
															{page}
														</a>
													)
												)
											}

											{
												canNextPage ? (
													<a
														href={toPageHref(safeCurrentPage + 1)}
														class="rounded-lg border border-[color:var(--shell-border)] px-3 py-1.5 text-sm font-semibold text-[color:var(--on-surface)] no-underline transition hover:bg-[color:var(--control-surface)]"
													>
														Siguiente
													</a>
												) : (
													<span class="cursor-not-allowed rounded-lg border border-[color:var(--shell-border)] px-3 py-1.5 text-sm font-semibold text-[color:var(--on-surface-variant)]/60">
														Siguiente
													</span>
												)
											}
										</nav>
									</div>
								</div>
							)
						}
					</section>
				</main>
			</div>
		</div>
	</div>

	<dialog
		class="w-[min(42rem,calc(100vw-2rem))] rounded-[1.25rem] border border-[color:var(--shell-border)] bg-[color:var(--surface-bright)] p-0 text-[color:var(--on-surface)] shadow-[0_26px_80px_rgba(15,23,42,0.28)] backdrop:bg-slate-950/40"
		data-location-modal
	>
		<div class="border-b border-[color:var(--shell-border)] px-5 py-4">
			<h2 class="text-lg font-bold" data-location-modal-title>Crear sucursal</h2>
			<p class="mt-1 text-sm text-[color:var(--on-surface-variant)]" data-location-modal-description>
				Completa los campos para registrar una nueva sucursal.
			</p>
		</div>

		<form class="relative grid gap-3 px-5 py-5" data-location-form>
			<div
				class="pointer-events-none absolute inset-0 z-20 hidden items-center justify-center rounded-b-[1.25rem] bg-[color:var(--surface-bright)]/78 backdrop-blur-[1px]"
				data-location-loading
			>
				<div class="inline-flex items-center gap-2 rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--surface-bright)] px-3 py-2 text-sm font-semibold text-[color:var(--on-surface)] shadow-[0_10px_24px_rgba(15,23,42,0.12)]">
					<span class="material-symbols-rounded animate-spin text-[1rem]">progress_activity</span>
					Cargando sucursal...
				</div>
			</div>

			<div class="hidden rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700 dark:border-rose-900/60 dark:bg-rose-950/25 dark:text-rose-300" data-form-error></div>

			<label class="grid gap-1 text-sm font-semibold">
				<span class="inline-flex items-center gap-1">
					Nombre
					<span class="text-rose-600">*</span>
				</span>
				<input
					type="text"
					name="name"
					maxlength="100"
					required
					class="rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-3 py-2.5 text-sm outline-none transition focus:border-[color:var(--primary)]"
					placeholder="Ej: Casa Central"
				/>
				<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="name"></span>
			</label>

			<label class="grid gap-1 text-sm font-semibold">
				<span class="inline-flex items-center gap-1">
					Dirección
					<span class="text-rose-600">*</span>
				</span>
				<input
					type="text"
					name="address"
					maxlength="255"
					required
					class="rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-3 py-2.5 text-sm outline-none transition focus:border-[color:var(--primary)]"
					placeholder="Ej: Av. Principal 123"
				/>
				<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="address"></span>
			</label>

			<div class="grid gap-3 sm:grid-cols-2">
				<label class="grid gap-1 text-sm font-semibold">
					<span class="inline-flex items-center gap-1">
						Departamento
						<span class="text-rose-600">*</span>
					</span>
					<select
						name="dep_id_department"
						required
						data-department-select
						class="rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-3 py-2.5 text-sm outline-none transition focus:border-[color:var(--primary)]"
					>
						<option value="">Selecciona un departamento</option>
					</select>
					<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="dep_id_department"></span>
				</label>

				<label class="grid gap-1 text-sm font-semibold">
					<span class="inline-flex items-center gap-1">
						Ciudad
						<span class="text-rose-600">*</span>
					</span>
					<select
						name="cit_id_city"
						required
						disabled
						data-city-select
						class="rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-3 py-2.5 text-sm outline-none transition focus:border-[color:var(--primary)] disabled:cursor-not-allowed disabled:opacity-70"
					>
						<option value="">Selecciona un departamento primero</option>
					</select>
					<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="cit_id_city"></span>
				</label>
			</div>

			<div class="grid gap-2">
				<div class="flex items-center justify-between gap-2">
					<p class="text-sm font-semibold">Ubicación en mapa (opcional)</p>
					<button
						type="button"
						class="rounded-lg border border-[color:var(--shell-border)] px-2.5 py-1 text-xs font-semibold text-[color:var(--on-surface-variant)] transition hover:bg-[color:var(--control-surface)] disabled:cursor-not-allowed disabled:opacity-60"
						data-clear-location-point
					>
						Limpiar punto
					</button>
				</div>

				<div class="overflow-hidden rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--control-surface)]">
					<div class="h-56 w-full" data-location-map></div>
				</div>

				<p class="text-xs text-[color:var(--on-surface-variant)]" data-location-map-status>
					Haz clic en el mapa para seleccionar coordenadas.
				</p>

				<input type="hidden" name="latitude" data-location-latitude />
				<input type="hidden" name="longitude" data-location-longitude />
				<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="latitude"></span>
				<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="longitude"></span>
			</div>

			<label class="grid gap-1 text-sm font-semibold">
				Estado
				<select
					name="is_active"
					class="rounded-xl border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] px-3 py-2.5 text-sm outline-none transition focus:border-[color:var(--primary)]"
				>
					<option value="1">Activa</option>
					<option value="0">Inactiva</option>
				</select>
				<span class="hidden text-xs text-rose-600 dark:text-rose-300" data-field-error="is_active"></span>
			</label>

			<div class="mt-1 flex items-center justify-between gap-2">
				<button
					type="button"
					class="hidden rounded-xl border border-rose-500/30 bg-rose-500 px-4 py-2 text-sm font-semibold text-white transition hover:brightness-105 disabled:cursor-not-allowed disabled:opacity-60"
					data-delete-location
				>
					<span class="material-symbols-rounded mr-1 align-[-0.2em] text-[1rem]">delete</span>
					Eliminar
				</button>

				<div class="ml-auto flex items-center justify-end gap-2">
					<button
						type="button"
						class="rounded-xl border border-[color:var(--shell-border)] px-4 py-2 text-sm font-semibold text-[color:var(--on-surface)] transition hover:bg-[color:var(--control-surface)]"
						data-close-location-modal
					>
						Cancelar
					</button>
					<button
						type="submit"
						class="btn-primary-soft inline-flex items-center gap-2 rounded-xl px-4 py-2 text-sm font-semibold transition disabled:cursor-not-allowed disabled:opacity-60"
						data-submit-location
					>
						<span class="material-symbols-rounded text-[1rem]" data-submit-location-icon>check</span>
						<span data-submit-location-label>Crear sucursal</span>
					</button>
				</div>
			</div>
		</form>
	</dialog>
	</location-manager>

	<AppAlert />
</Layout>

<script>
	import { navigate } from 'astro:transitions/client';

	class LocationManager extends HTMLElement {
		#bound = false;
		#closeTimer: number | null = null;
		#listenerController: AbortController | null = null;

		connectedCallback() {
			if (this.#bound) return;
			this.#bound = true;
			this.#listenerController = new AbortController();
			const listenerSignal = this.#listenerController.signal;

	const modal = this.querySelector<HTMLDialogElement>('[data-location-modal]');
	if (!modal) {
		this.#bound = false;
		this.#listenerController = null;
		return;
	}
	const openButton = this.querySelector<HTMLButtonElement>('[data-open-location-modal]');
	const closeButton = this.querySelector<HTMLButtonElement>('[data-close-location-modal]');
	const deleteButton = this.querySelector<HTMLButtonElement>('[data-delete-location]');
	const form = this.querySelector<HTMLFormElement>('[data-location-form]');
	const submitButton = this.querySelector<HTMLButtonElement>('[data-submit-location]');
	const submitLabel = this.querySelector<HTMLElement>('[data-submit-location-label]');
	const submitIcon = this.querySelector<HTMLElement>('[data-submit-location-icon]');
	const formErrorNode = this.querySelector<HTMLElement>('[data-form-error]');
	const fieldErrorNodes = this.querySelectorAll<HTMLElement>('[data-field-error]');
	const loadingNode = this.querySelector<HTMLElement>('[data-location-loading]');
	const modalTitle = this.querySelector<HTMLElement>('[data-location-modal-title]');
	const modalDescription = this.querySelector<HTMLElement>('[data-location-modal-description]');
	const locationCards = this.querySelectorAll<HTMLElement>('[data-location-card]');
	const nameInput = form ? form.querySelector<HTMLInputElement>('[name="name"]') : null;
	const addressInput = form ? form.querySelector<HTMLInputElement>('[name="address"]') : null;
	const citySelect = form ? form.querySelector<HTMLSelectElement>('[data-city-select]') : null;
	const departmentSelect = form
		? form.querySelector<HTMLSelectElement>('[data-department-select]')
		: null;
	const latitudeInput = form ? form.querySelector<HTMLInputElement>('[data-location-latitude]') : null;
	const longitudeInput = form ? form.querySelector<HTMLInputElement>('[data-location-longitude]') : null;
	const statusInput = form ? form.querySelector<HTMLSelectElement>('[name="is_active"]') : null;
	const mapContainer = form ? form.querySelector<HTMLElement>('[data-location-map]') : null;
	const mapStatusNode = form ? form.querySelector<HTMLElement>('[data-location-map-status]') : null;
	const clearMapPointButton = form
		? form.querySelector<HTMLButtonElement>('[data-clear-location-point]')
		: null;
	type DepartmentOption = { id_department: number; description?: string };
	type CityOption = { id_city: number; description?: string };
	type GoogleMapsNamespace = {
		Map: new (container: HTMLElement, options: Record<string, unknown>) => {
			setCenter: (coords: { lat: number; lng: number }) => void;
			setZoom: (zoom: number) => void;
			addListener: (eventName: string, handler: (event: unknown) => void) => void;
		};
		Marker: new (options: Record<string, unknown>) => {
			setPosition: (coords: { lat: number; lng: number }) => void;
			setMap: (map: unknown | null) => void;
		};
		event?: {
			trigger?: (instance: unknown, eventName: string) => void;
		};
	};
	type WindowWithGoogleMaps = Window & {
		google?: {
			maps?: GoogleMapsNamespace;
		};
		__bookmateGoogleMapsLoader?: Promise<GoogleMapsNamespace> | null;
	};
	type Coordinates = {
		lat: number;
		lng: number;
	};
	const formFields =
		form?.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(
			'input, select, textarea'
		);
	let mode = 'create';
	let editingLocationId = 0;
	let locationReadRequestSeq = 0;
	let citiesRequestSeq = 0;
	let departmentsLoaded = false;
	let departmentsLoadPromise: Promise<void> | null = null;
	const citiesByDepartment = new Map<number, CityOption[]>();
	const mapsApiKey = String(this.dataset.googleMapsApiKey || '').trim();
	const defaultMapCenter: Coordinates = { lat: -25.28646, lng: -57.647 };
	let selectedCoordinates: Coordinates | null = null;
	let mapInstance: {
		setCenter: (coords: Coordinates) => void;
		setZoom: (zoom: number) => void;
		addListener: (eventName: string, handler: (event: unknown) => void) => void;
	} | null = null;
	let mapMarker: {
		setPosition: (coords: Coordinates) => void;
		setMap: (map: unknown | null) => void;
	} | null = null;

	const currentUrl = new URL(window.location.href);
	if (currentUrl.searchParams.has('flash_message')) {
		currentUrl.searchParams.delete('flash_message');
		currentUrl.searchParams.delete('flash_type');
		window.history.replaceState({}, '', `${currentUrl.pathname}${currentUrl.search}${currentUrl.hash}`);
	}

	const redirectWithFlash = (message: string, type = 'success') => {
		const nextUrl = new URL(window.location.href);
		nextUrl.searchParams.set('flash_message', message);
		nextUrl.searchParams.set('flash_type', type);
		void navigate(`${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`);
	};

	const clearErrors = () => {
		if (formErrorNode) {
			formErrorNode.textContent = '';
			formErrorNode.classList.add('hidden');
		}

		for (const node of fieldErrorNodes) {
			node.textContent = '';
			node.classList.add('hidden');
		}
	};

	const showFormError = (message: string) => {
		if (!formErrorNode) return;
		formErrorNode.textContent = message;
		formErrorNode.classList.remove('hidden');
	};

	const setMapStatus = (message: string, isError = false) => {
		if (!mapStatusNode) return;
		mapStatusNode.textContent = message;
		if (isError) {
			mapStatusNode.classList.add('text-rose-600', 'dark:text-rose-300');
			return;
		}
		mapStatusNode.classList.remove('text-rose-600', 'dark:text-rose-300');
	};

	const formatCoordinate = (value: number) => value.toFixed(6);

	const setSelectedCoordinates = (
		latitude: number | null,
		longitude: number | null,
		options: { center?: boolean; zoom?: number } = {}
	) => {
		const hasCoordinates = Number.isFinite(latitude) && Number.isFinite(longitude);

		if (!hasCoordinates) {
			selectedCoordinates = null;
			if (latitudeInput) latitudeInput.value = '';
			if (longitudeInput) longitudeInput.value = '';
			setMapStatus('Haz clic en el mapa para seleccionar coordenadas.');
			if (mapMarker) mapMarker.setMap(null);
			mapMarker = null;
			return;
		}

		const coords: Coordinates = {
			lat: Number(latitude),
			lng: Number(longitude),
		};
		selectedCoordinates = coords;
		if (latitudeInput) latitudeInput.value = formatCoordinate(coords.lat);
		if (longitudeInput) longitudeInput.value = formatCoordinate(coords.lng);
		setMapStatus(`Coordenadas seleccionadas: ${coords.lat.toFixed(6)}, ${coords.lng.toFixed(6)}`);

		if (!mapInstance) return;
		if (!mapMarker) {
			const maps = (window as WindowWithGoogleMaps).google?.maps;
			if (!maps) return;
			mapMarker = new maps.Marker({
				map: mapInstance,
				position: coords,
			});
		} else {
			mapMarker.setMap(mapInstance);
			mapMarker.setPosition(coords);
		}

		if (options.center !== false) {
			mapInstance.setCenter(coords);
			mapInstance.setZoom(options.zoom ?? 15);
		}
	};

	const loadGoogleMaps = async (): Promise<GoogleMapsNamespace> => {
		if (!mapsApiKey) {
			throw new Error('No se encontro la API key de Google Maps para el mapa de sucursales.');
		}

		const win = window as WindowWithGoogleMaps;
		if (win.google?.maps) return win.google.maps;
		if (win.__bookmateGoogleMapsLoader) return win.__bookmateGoogleMapsLoader;

		win.__bookmateGoogleMapsLoader = new Promise<GoogleMapsNamespace>((resolve, reject) => {
			const handleLoad = () => {
				const maps = (window as WindowWithGoogleMaps).google?.maps;
				if (!maps) {
					reject(new Error('Google Maps cargo, pero no se encontro la libreria maps.'));
					return;
				}
				resolve(maps);
			};

			const existingScript = document.querySelector<HTMLScriptElement>('script[data-google-maps-loader]');
			if (existingScript) {
				existingScript.addEventListener('load', handleLoad, { once: true });
				existingScript.addEventListener(
					'error',
					() => reject(new Error('No fue posible cargar Google Maps.')),
					{ once: true }
				);
				return;
			}

			const script = document.createElement('script');
			script.src = `https://maps.googleapis.com/maps/api/js?key=${encodeURIComponent(mapsApiKey)}&v=weekly`;
			script.async = true;
			script.defer = true;
			script.dataset.googleMapsLoader = 'true';
			script.addEventListener('load', handleLoad, { once: true });
			script.addEventListener(
				'error',
				() => reject(new Error('No fue posible cargar Google Maps.')),
				{ once: true }
			);
			document.head.appendChild(script);
		});

		try {
			return await win.__bookmateGoogleMapsLoader;
		} catch (error) {
			win.__bookmateGoogleMapsLoader = null;
			throw error;
		}
	};

	const ensureMapReady = async () => {
		if (!mapContainer) return;

		const maps = await loadGoogleMaps();
		if (!mapInstance) {
			mapInstance = new maps.Map(mapContainer, {
				center: defaultMapCenter,
				zoom: 12,
				mapTypeControl: false,
				streetViewControl: false,
				fullscreenControl: false,
				gestureHandling: 'greedy',
			});

			mapInstance.addListener('click', (event: unknown) => {
				const source = event as { latLng?: { lat?: () => number; lng?: () => number } };
				const latitude = source?.latLng?.lat?.();
				const longitude = source?.latLng?.lng?.();
				if (!Number.isFinite(latitude) || !Number.isFinite(longitude)) return;
				setSelectedCoordinates(Number(latitude), Number(longitude), { center: false });
			});
		}

		window.setTimeout(() => {
			if (!mapInstance) return;
			if (maps.event?.trigger) maps.event.trigger(mapInstance, 'resize');
			mapInstance.setCenter(selectedCoordinates ?? defaultMapCenter);
			if (selectedCoordinates) mapInstance.setZoom(15);
		}, 60);

		if (selectedCoordinates) {
			setSelectedCoordinates(selectedCoordinates.lat, selectedCoordinates.lng, { center: true, zoom: 15 });
			return;
		}

		setMapStatus('Haz clic en el mapa para seleccionar coordenadas.');
	};

	type SelectOptionsConfig<T> = {
		placeholder: string;
		selectedValue?: string | number | null;
		getValue: (item: T) => string | number;
		getLabel: (item: T) => string;
	};

	const setSelectOptions = <T,>(
		selectNode: HTMLSelectElement | null | undefined,
		items: T[],
		config: SelectOptionsConfig<T>
	) => {
		if (!selectNode) return;

		selectNode.innerHTML = '';
		const placeholderOption = document.createElement('option');
		placeholderOption.value = '';
		placeholderOption.textContent = config.placeholder;
		selectNode.appendChild(placeholderOption);

		for (const item of items) {
			const option = document.createElement('option');
			option.value = String(config.getValue(item));
			option.textContent = config.getLabel(item);
			selectNode.appendChild(option);
		}

		const hasSelectedValue =
			config.selectedValue !== undefined &&
			config.selectedValue !== null &&
			String(config.selectedValue).trim() !== '';

		if (hasSelectedValue) {
			const candidate = String(config.selectedValue);
			const hasOption = Array.from(selectNode.options).some((option) => option.value === candidate);
			selectNode.value = hasOption ? candidate : '';
			return;
		}

		selectNode.value = '';
	};

	const renderDepartmentOptions = (
		departments: DepartmentOption[],
		selectedDepartmentId = 0,
		placeholder = 'Selecciona un departamento'
	) => {
		setSelectOptions(departmentSelect, departments, {
			placeholder,
			selectedValue: selectedDepartmentId > 0 ? selectedDepartmentId : '',
			getValue: (item: DepartmentOption) => item.id_department,
			getLabel: (item: DepartmentOption) => item.description || `Departamento #${item.id_department}`,
		});
	};

	const renderCityOptions = (
		cities: CityOption[],
		selectedCityId = 0,
		placeholder = 'Selecciona una ciudad'
	) => {
		setSelectOptions(citySelect, cities, {
			placeholder,
			selectedValue: selectedCityId > 0 ? selectedCityId : '',
			getValue: (item: CityOption) => item.id_city,
			getLabel: (item: CityOption) => item.description || `Ciudad #${item.id_city}`,
		});
		citySelect?.removeAttribute('data-loading');
	};

	const setCityLoadingState = (label = 'Cargando ciudades...') => {
		if (!citySelect) return;
		citySelect.innerHTML = '';
		const loadingOption = document.createElement('option');
		loadingOption.value = '';
		loadingOption.textContent = label;
		loadingOption.selected = true;
		loadingOption.disabled = true;
		citySelect.appendChild(loadingOption);
		citySelect.selectedIndex = 0;
		citySelect.setAttribute('data-loading', 'true');
	};

	const fetchCatalogResource = async <T = unknown,>(url: string): Promise<T[]> => {
		const response = await fetch(url, {
			method: 'GET',
			headers: { Accept: 'application/json' },
		});

		let data = null;
		try {
			data = await response.json();
		} catch {
			throw new Error('No fue posible interpretar la respuesta de catalogos.');
		}

		if (!response.ok || !data || data.status !== 'success' || !Array.isArray(data.data)) {
			throw new Error(data?.message || 'No fue posible cargar catalogos.');
		}

		return data.data as T[];
	};

	const ensureDepartmentsLoaded = async () => {
		if (departmentsLoaded) return;
		if (departmentsLoadPromise) return departmentsLoadPromise;

		renderDepartmentOptions([], 0, 'Cargando departamentos...');
		if (departmentSelect) departmentSelect.disabled = true;

		departmentsLoadPromise = (async () => {
			const departments = await fetchCatalogResource<DepartmentOption>('/api/catalog/departments');
			departmentsLoaded = true;
			renderDepartmentOptions(departments);
		})()
			.catch((error) => {
				renderDepartmentOptions([], 0, 'No fue posible cargar departamentos');
				throw error;
			})
			.finally(() => {
				departmentsLoadPromise = null;
				if (departmentSelect) departmentSelect.disabled = false;
			});

		return departmentsLoadPromise;
	};

	const loadCitiesByDepartment = async (
		departmentId: number,
		options: { selectedCityId?: number; showErrors?: boolean } = { selectedCityId: 0, showErrors: true }
	) => {
		if (!citySelect) return;

		const selectedCityId = Number(options?.selectedCityId || 0);
		const showErrors = options?.showErrors !== false;

		if (!Number.isInteger(departmentId) || departmentId <= 0) {
			citySelect.disabled = true;
			renderCityOptions([], 0, 'Selecciona un departamento primero');
			return;
		}

		const cachedCities = citiesByDepartment.get(departmentId);
		if (Array.isArray(cachedCities)) {
			citySelect.disabled = cachedCities.length === 0;
			renderCityOptions(
				cachedCities,
				selectedCityId,
				cachedCities.length > 0 ? 'Selecciona una ciudad' : 'Sin ciudades disponibles'
			);
			return;
		}

		const requestId = ++citiesRequestSeq;
		citySelect.disabled = true;
		setCityLoadingState();

		try {
			const cities = await fetchCatalogResource<CityOption>(`/api/catalog/departments/${departmentId}/cities`);
			if (requestId !== citiesRequestSeq) return;
			citiesByDepartment.set(departmentId, cities);
			citySelect.disabled = cities.length === 0;
			renderCityOptions(
				cities,
				selectedCityId,
				cities.length > 0 ? 'Selecciona una ciudad' : 'Sin ciudades disponibles'
			);
		} catch (error) {
			if (requestId !== citiesRequestSeq) return;
			citySelect.disabled = true;
			renderCityOptions([], 0, 'No fue posible cargar ciudades');
			if (showErrors) {
				showFormError(
					error instanceof Error
						? error.message
						: 'No fue posible cargar las ciudades del departamento.'
				);
			}
		}
	};

	const setCreateMode = () => {
		mode = 'create';
		editingLocationId = 0;
		if (modalTitle) modalTitle.textContent = 'Crear sucursal';
		if (modalDescription) {
			modalDescription.textContent = 'Completa los campos para registrar una nueva sucursal.';
		}
		if (submitLabel) submitLabel.textContent = 'Crear sucursal';
		if (submitIcon) submitIcon.textContent = 'check';
		deleteButton?.classList.add('hidden');
		deleteButton?.setAttribute('disabled', 'true');
		loadingNode?.classList.add('hidden');
	};

	const setEditMode = (locationId: number) => {
		mode = 'edit';
		editingLocationId = locationId;
		if (modalTitle) modalTitle.textContent = 'Editar sucursal';
		if (modalDescription) {
			modalDescription.textContent = 'Actualiza la informacion de la sucursal seleccionada.';
		}
		if (submitLabel) submitLabel.textContent = 'Guardar cambios';
		if (submitIcon) submitIcon.textContent = 'save';
		deleteButton?.classList.remove('hidden');
		deleteButton?.removeAttribute('disabled');
	};

	const setFormLoadingState = (isLoading: boolean) => {
		if (isLoading) {
			loadingNode?.classList.add('flex');
			loadingNode?.classList.remove('hidden');
		} else {
			loadingNode?.classList.add('hidden');
			loadingNode?.classList.remove('flex');
		}

		for (const field of formFields ?? []) {
			field.disabled = isLoading;
		}
		if (clearMapPointButton) clearMapPointButton.disabled = isLoading;
		if (mapContainer) mapContainer.style.pointerEvents = isLoading ? 'none' : 'auto';
	};

	const setLoadingMode = (label = 'Procesando...') => {
		if (submitButton) submitButton.disabled = true;
		if (deleteButton && mode === 'edit') deleteButton.disabled = true;
		if (submitLabel) submitLabel.textContent = label;
		if (submitIcon) submitIcon.textContent = 'hourglass_top';
	};

	const restoreButtons = () => {
		if (submitButton) submitButton.disabled = false;
		if (mode === 'create') {
			if (submitLabel) submitLabel.textContent = 'Crear sucursal';
			if (submitIcon) submitIcon.textContent = 'check';
			return;
		}

		if (submitLabel) submitLabel.textContent = 'Guardar cambios';
		if (submitIcon) submitIcon.textContent = 'save';
		if (deleteButton) deleteButton.disabled = false;
	};

	const openModalShell = () => {
		modal?.classList.remove('is-closing');
		if (this.#closeTimer) {
			window.clearTimeout(this.#closeTimer);
			this.#closeTimer = null;
		}
		if (!modal?.open) modal?.showModal();
	};

	const closeModal = () => {
		if (!modal?.open) return;
		locationReadRequestSeq += 1;
		citiesRequestSeq += 1;
		modal.classList.add('is-closing');

		this.#closeTimer = window.setTimeout(() => {
			modal.close();
			modal.classList.remove('is-closing');
			form?.reset();
			setCreateMode();
			setFormLoadingState(false);
			clearErrors();
			this.#closeTimer = null;
		}, 160);
	};

	const resetFormValues = () => {
		if (nameInput) nameInput.value = '';
		if (addressInput) addressInput.value = '';
		if (departmentSelect) departmentSelect.value = '';
		if (citySelect) {
			citySelect.disabled = true;
			renderCityOptions([], 0, 'Selecciona un departamento primero');
		}
		setSelectedCoordinates(null, null);
		if (statusInput) statusInput.value = '1';
	};

	const openCreateModal = async () => {
		setCreateMode();
		resetFormValues();
		setFormLoadingState(false);
		clearErrors();
		openModalShell();
		try {
			await Promise.all([ensureDepartmentsLoaded(), ensureMapReady()]);
		} catch (error) {
			const errorMessage =
				error instanceof Error ? error.message : 'No fue posible cargar recursos del formulario.';
			if (errorMessage.toLowerCase().includes('google maps')) {
				setMapStatus(errorMessage, true);
				return;
			}
			showFormError(errorMessage);
		}
	};

	const fillFormWithLocation = (location: any) => {
		if (nameInput) nameInput.value = String(location?.name || '');
		if (addressInput) addressInput.value = String(location?.address || '');
		const latitude = typeof location?.latitude === 'number' ? location.latitude : null;
		const longitude = typeof location?.longitude === 'number' ? location.longitude : null;
		setSelectedCoordinates(latitude, longitude, { center: false });
		if (statusInput) {
			statusInput.value = String(location?.is_active === 0 ? 0 : 1);
		}

		const departmentId =
			typeof location?.department?.id_department === 'number' &&
			location.department.id_department > 0
				? location.department.id_department
				: 0;

		const cityId =
			typeof location?.city?.id_city === 'number' && location.city.id_city > 0
				? location.city.id_city
				: 0;

		return {
			departmentId,
			cityId,
		};
	};

	const openEditModal = async (locationId: number) => {
		if (!locationId) return;
		const requestId = ++locationReadRequestSeq;
		setEditMode(locationId);
		resetFormValues();
		clearErrors();
		openModalShell();
		setFormLoadingState(true);
		setLoadingMode('Cargando...');

		try {
			const response = await fetch(`/api/locations/${locationId}`, {
				method: 'GET',
				headers: { Accept: 'application/json' },
			});

			let data = null;
			try {
				data = await response.json();
			} catch {
				throw new Error('No fue posible interpretar la respuesta del servidor.');
			}

			if (!response.ok || !data || data.status !== 'success' || !data.data) {
				throw new Error(data?.message || 'No fue posible obtener la sucursal seleccionada.');
			}

			if (requestId !== locationReadRequestSeq) return;
			const { departmentId, cityId } = fillFormWithLocation(data.data);
			await Promise.all([ensureDepartmentsLoaded(), ensureMapReady()]);
			if (requestId !== locationReadRequestSeq) return;
			if (departmentSelect) {
				departmentSelect.value = departmentId > 0 ? String(departmentId) : '';
			}
			await loadCitiesByDepartment(departmentId, { selectedCityId: cityId, showErrors: true });
		} catch (error) {
			if (requestId !== locationReadRequestSeq) return;
			const errorMessage =
				error instanceof Error ? error.message : 'No fue posible obtener la sucursal.';
			if (errorMessage.toLowerCase().includes('google maps')) {
				setMapStatus(errorMessage, true);
			} else {
				setCreateMode();
				showFormError(errorMessage);
			}
		} finally {
			if (requestId !== locationReadRequestSeq) return;
			setFormLoadingState(false);
			restoreButtons();
		}
	};

	openButton?.addEventListener('click', openCreateModal, { signal: listenerSignal });
	closeButton?.addEventListener('click', closeModal, { signal: listenerSignal });
	clearMapPointButton?.addEventListener('click', () => {
		setSelectedCoordinates(null, null);
	}, { signal: listenerSignal });

	modal?.addEventListener('click', (event: MouseEvent) => {
		const target = event.target;
		if (target instanceof HTMLDialogElement) closeModal();
	}, { signal: listenerSignal });

	departmentSelect?.addEventListener('change', async () => {
		const selectedDepartmentId = Number(departmentSelect.value || '0');
		const departmentErrorNode = this.querySelector('[data-field-error="dep_id_department"]');
		const cityErrorNode = this.querySelector('[data-field-error="cit_id_city"]');
		if (departmentErrorNode) {
			departmentErrorNode.textContent = '';
			departmentErrorNode.classList.add('hidden');
		}
		if (cityErrorNode) {
			cityErrorNode.textContent = '';
			cityErrorNode.classList.add('hidden');
		}
		await loadCitiesByDepartment(selectedDepartmentId, { selectedCityId: 0, showErrors: true });
	}, { signal: listenerSignal });

	for (const card of locationCards) {
		const openFromCard = () => {
			const locationId = Number(card.getAttribute('data-location-id') || '0');
			if (locationId > 0) openEditModal(locationId);
		};

		card.addEventListener('click', openFromCard, { signal: listenerSignal });
		card.addEventListener('keydown', (event: KeyboardEvent) => {
			if (event.key !== 'Enter' && event.key !== ' ') return;
			event.preventDefault();
			openFromCard();
		}, { signal: listenerSignal });
	}

	form?.addEventListener('submit', async (event: SubmitEvent) => {
		event.preventDefault();
		clearErrors();

		if (!form) return;
		const formData = new FormData(form);

		const name = String(formData.get('name') || '').trim();
		const address = String(formData.get('address') || '').trim();
		const cityRaw = String(formData.get('cit_id_city') || '').trim();
		const departmentRaw = String(formData.get('dep_id_department') || '').trim();
		const latitudeRaw = String(formData.get('latitude') || '').trim();
		const longitudeRaw = String(formData.get('longitude') || '').trim();
		const isActiveRaw = String(formData.get('is_active') || '1').trim();

		const cityId = Number(cityRaw);
		const departmentId = Number(departmentRaw);

		if (
			!name ||
			!address ||
			!cityRaw ||
			!departmentRaw ||
			!Number.isInteger(cityId) ||
			cityId <= 0 ||
			!Number.isInteger(departmentId) ||
			departmentId <= 0
		) {
			showFormError('Completa los campos requeridos antes de continuar.');
			return;
		}

		type LocationSubmitPayload = {
			name: string;
			address: string;
			cit_id_city: number;
			dep_id_department: number;
			is_active: 0 | 1;
			latitude?: number;
			longitude?: number;
		};

		const payload: LocationSubmitPayload = {
			name,
			address,
			cit_id_city: cityId,
			dep_id_department: departmentId,
			is_active: (isActiveRaw === '0' ? 0 : 1) as 0 | 1,
		};

		if (latitudeRaw !== '') {
			const latitude = Number(latitudeRaw);
			if (Number.isFinite(latitude)) payload.latitude = latitude;
		}

		if (longitudeRaw !== '') {
			const longitude = Number(longitudeRaw);
			if (Number.isFinite(longitude)) payload.longitude = longitude;
		}

		const endpoint =
			mode === 'edit' && editingLocationId
				? `/api/locations/${editingLocationId}`
				: '/api/locations';
		const httpMethod = mode === 'edit' && editingLocationId ? 'PUT' : 'POST';
		setLoadingMode(mode === 'edit' ? 'Guardando...' : 'Creando...');

		try {
			const response = await fetch(endpoint, {
				method: httpMethod,
				headers: {
					'Content-Type': 'application/json',
					Accept: 'application/json',
				},
				body: JSON.stringify(payload),
			});

			let data = null;
			try {
				data = await response.json();
			} catch {
				throw new Error('No fue posible interpretar la respuesta del servidor.');
			}

			if (!response.ok || !data || data.status !== 'success') {
				const message = data?.message || 'No fue posible guardar la sucursal.';
				showFormError(message);

				const fieldErrors = Array.isArray(data?.errors) ? data.errors : [];
				for (const error of fieldErrors) {
					if (!error || typeof error !== 'object') continue;
					const field = 'field' in error ? String(error.field || '') : '';
					const messageText = 'message' in error ? String(error.message || '') : '';
					if (!field || !messageText) continue;

					const fieldNode = this.querySelector(`[data-field-error="${field}"]`);
					if (fieldNode) {
						fieldNode.textContent = messageText;
						fieldNode.classList.remove('hidden');
					}
				}

				return;
			}

			const successMessage =
				typeof data?.message === 'string' && data.message.trim()
					? data.message
					: mode === 'edit'
						? 'Sucursal actualizada correctamente.'
						: 'Sucursal creada correctamente.';

			closeModal();
			redirectWithFlash(successMessage, 'success');
		} catch (error) {
			const message = error instanceof Error ? error.message : 'No fue posible guardar la sucursal.';
			showFormError(message);
		} finally {
			restoreButtons();
		}
	}, { signal: listenerSignal });

	deleteButton?.addEventListener('click', async () => {
		if (!editingLocationId || mode !== 'edit') return;

		const confirmed = await window.BookmateAlert?.confirm({
			type: 'error',
			title: 'Eliminar sucursal',
			message: 'Esta accion eliminara la sucursal de forma permanente. Deseas continuar?',
			confirmText: 'Eliminar',
			cancelText: 'Cancelar',
		});
		if (!confirmed) return;

		clearErrors();
		setLoadingMode('Eliminando...');

		try {
			const response = await fetch(`/api/locations/${editingLocationId}`, {
				method: 'DELETE',
				headers: { Accept: 'application/json' },
			});

			let data = null;
			try {
				data = await response.json();
			} catch {
				throw new Error('No fue posible interpretar la respuesta del servidor.');
			}

			if (!response.ok || !data || data.status !== 'success') {
				throw new Error(data?.message || 'No fue posible eliminar la sucursal.');
			}

			const successMessage =
				typeof data?.message === 'string' && data.message.trim()
					? data.message
					: 'Sucursal eliminada correctamente.';

			closeModal();
			redirectWithFlash(successMessage, 'success');
		} catch (error) {
			showFormError(
				error instanceof Error ? error.message : 'No fue posible eliminar la sucursal.'
			);
			restoreButtons();
		}
	}, { signal: listenerSignal });
		}

		disconnectedCallback() {
			this.#bound = false;
			this.#listenerController?.abort();
			this.#listenerController = null;
			if (this.#closeTimer) {
				window.clearTimeout(this.#closeTimer);
				this.#closeTimer = null;
			}
		}
	}

	if (!customElements.get('location-manager')) {
		customElements.define('location-manager', LocationManager);
	}
</script>

<style is:global>
	location-manager {
		display: block;
	}

	dialog[data-location-modal] {
		position: fixed;
		inset: 0;
		margin: auto;
		animation: location-modal-in 180ms ease-out;
	}

	dialog[data-location-modal]::backdrop {
		animation: location-backdrop-in 180ms ease-out;
	}

	dialog[data-location-modal].is-closing {
		animation: location-modal-out 160ms ease-in forwards;
	}

	dialog[data-location-modal].is-closing::backdrop {
		animation: location-backdrop-out 160ms ease-in forwards;
	}

	@keyframes location-modal-in {
		from {
			opacity: 0;
			transform: translateY(10px) scale(0.98);
		}

		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	@keyframes location-modal-out {
		from {
			opacity: 1;
			transform: translateY(0) scale(1);
		}

		to {
			opacity: 0;
			transform: translateY(8px) scale(0.98);
		}
	}

	@keyframes location-backdrop-in {
		from {
			opacity: 0;
		}

		to {
			opacity: 1;
		}
	}

	@keyframes location-backdrop-out {
		from {
			opacity: 1;
		}

		to {
			opacity: 0;
		}
	}
</style>

