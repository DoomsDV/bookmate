---
import ResetPasswordForm from '../../components/ResetPasswordForm.astro';
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';

const token = Astro.url.searchParams.get('token') ?? '';
const error = Astro.url.searchParams.get('error') ?? '';
const newPasswordError = Astro.url.searchParams.get('new_password_error') ?? '';
const confirmPasswordError = Astro.url.searchParams.get('confirm_password_error') ?? '';
---

<Layout>
	<ResetPasswordForm
		token={token}
		error={error}
		newPasswordError={newPasswordError}
		confirmPasswordError={confirmPasswordError}
	/>
</Layout>

<script is:inline>
	if (typeof window !== 'undefined') {
		const currentUrl = new URL(window.location.href);
		const transientParams = ['error', 'new_password_error', 'confirm_password_error'];
		let hasTransientParams = false;

		for (const param of transientParams) {
			if (currentUrl.searchParams.has(param)) {
				currentUrl.searchParams.delete(param);
				hasTransientParams = true;
			}
		}

		if (hasTransientParams) {
			window.history.replaceState({}, '', `${currentUrl.pathname}${currentUrl.search}${currentUrl.hash}`);
		}
	}
</script>
