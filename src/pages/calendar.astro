---
import AppAlert from '../components/AppAlert.astro';
import FlashMessage from '../components/FlashMessage.astro';
import SideNav from '../components/SideNav.astro';
import TopBar from '../components/TopBar.astro';
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const token = Astro.locals.token ?? '';
const flashMessage = Astro.url.searchParams.get('flash_message') ?? '';
const flashTypeRaw = Astro.url.searchParams.get('flash_type') ?? 'success';
const validFlashTypes = ['success', 'error', 'info', 'warning'] as const;
type FlashType = (typeof validFlashTypes)[number];
const flashType: FlashType = validFlashTypes.includes(flashTypeRaw as FlashType)
	? (flashTypeRaw as FlashType)
	: 'info';
const initialLoadError = token ? '' : 'No hay sesión válida para consultar el calendario.';
---

<Layout>
	<calendar-manager>
		<div class="min-h-screen">
			<div
				class="app-shell grid min-h-screen overflow-hidden border border-(--shell-border) bg-(--shell-surface) shadow-[0_30px_80px_rgba(15,23,42,0.12)] backdrop-blur-xl"
				data-app-shell
				data-sidebar-state="expanded"
			>
				<SideNav currentPath={Astro.url.pathname} />

				<div class="grid min-h-full grid-rows-[auto_1fr]">
					<TopBar />

				<main class="bg-(--content-surface) px-4 py-4 sm:px-6 sm:py-6">
					<section class="material-region dark:shadow-none" data-calendar-root>
						{
							flashMessage ? (
								<div class="pointer-events-none fixed bottom-6 left-1/2 z-70 -translate-x-1/2 w-max max-w-[calc(100vw-2rem)]">
									<FlashMessage message={flashMessage} type={flashType} autoHideMs={4200} />
								</div>
							) : null
						}

						{
							initialLoadError ? (
								<FlashMessage message={initialLoadError} type="error" expand={true} dismissible={false} />
							) : (
								<div class="grid gap-4 sm:gap-5">
									<header class="flex flex-col justify-between gap-3 sm:flex-row sm:items-center sm:gap-4">
										<div class="grid gap-1">
											<h1 class="text-[1.3rem] font-extrabold text-(--on-surface)">
												Calendario de citas
											</h1>
											<p class="text-[0.95rem] text-(--on-surface-variant) leading-relaxed">
												Gestiona reservas por profesional y sucursal con vista semanal.
											</p>
										</div>

										<button
											type="button"
											class="btn-primary-soft inline-flex items-center justify-center gap-2 rounded-2xl px-5 py-3 text-[0.95rem] font-extrabold shadow-sm transition hover:shadow-md focus:outline-none focus:ring-2 focus:ring-(--primary) focus:ring-offset-2 focus:ring-offset-(--surface-bright) sm:w-auto w-full"
											data-open-appointment-modal
										>
											<span class="material-symbols-rounded text-[1.2rem]">add</span>
											<span>Nueva cita</span>
										</button>
									</header>

									<div class="grid gap-3 sm:gap-4 sm:grid-cols-2">
										<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)" data-professional-filter-wrap>
											Profesional
											<select
												data-professional-filter
												class="cursor-pointer appearance-none w-full rounded-2xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] font-semibold outline-none transition hover:border-(--on-surface-variant) focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 shadow-sm bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M7%2010l5%205%205-5%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-position-[calc(100%-12px)_center] bg-no-repeat pr-10"
											>
												<option value="">Todos los profesionales</option>
											</select>
										</label>

										<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
											Sucursal
											<select
												data-location-filter
												class="cursor-pointer appearance-none w-full rounded-2xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] font-semibold outline-none transition hover:border-(--on-surface-variant) focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 shadow-sm bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M7%2010l5%205%205-5%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-position-[calc(100%-12px)_center] bg-no-repeat pr-10"
											>
												<option value="">Todas las sucursales</option>
											</select>
										</label>
									</div>

									<div
										class="hidden rounded-2xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-[0.9rem] font-bold text-rose-500 shadow-sm"
										data-calendar-error
									></div>

									<div class="mt-1.5 border-t border-(--shell-border) border-dashed pt-4">
										<div
											class="mb-2 hidden rounded-xl border border-(--shell-border) bg-(--control-surface) px-3 py-2 text-[0.9rem] font-medium text-(--on-surface-variant)"
											data-calendar-loading
										>
											Cargando calendario...
										</div>
										<div data-calendar-el class="calendar-host min-h-136"></div>
									</div>
								</div>
							)
						}
					</section>
					</main>
				</div>
			</div>
		</div>

		<appointment-modal>
		<dialog
			class="m-0 mt-auto mb-0 w-screen max-w-none sm:m-auto sm:w-[min(42rem,calc(100vw-2rem))] sm:max-w-[min(42rem,calc(100vw-2rem))] open:flex open:flex-col max-h-[80vh] sm:max-h-[90vh] overflow-hidden rounded-t-[1.8rem] rounded-b-none sm:rounded-[1.8rem] border border-(--shell-border) bg-(--surface-bright) p-0 text-(--on-surface) shadow-[0_24px_80px_rgba(0,0,0,0.2)]"
			data-appointment-modal
		>
			<div class="shrink-0 z-10 shadow-sm border-b border-(--shell-border) bg-(--surface-bright) px-4 py-3 sm:px-7 sm:py-6 ">
				<div class="flex items-start justify-between gap-4">
					<div class="flex items-center gap-4">
						<div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-(--primary-soft) text-(--primary)">
							<span class="material-symbols-rounded text-[1.4rem]">calendar_add_on</span>
						</div>
						<div>
							<h2 class="text-[1.2rem] font-extrabold tracking-tight text-(--on-surface)" data-appointment-modal-title>Crear cita</h2>
							<p class="text-[0.9rem] font-medium text-(--on-surface-variant) mt-0.5 hidden sm:block" data-appointment-modal-description>
								Completa los datos para registrar una nueva reserva.
							</p>
						</div>
					</div>
					<button type="button" class="flex size-9 shrink-0 items-center justify-center rounded-full text-(--on-surface-variant) transition-colors hover:bg-(--surface-variant) hover:text-(--on-surface) focus:outline-none focus:ring-2 focus:ring-(--primary)" data-close-appointment-modal aria-label="Cerrar modal">
						<span class="material-symbols-rounded text-[1.3rem]">close</span>
					</button>
				</div>
			</div>

			<form class="relative flex flex-col bg-(--surface)/30 overflow-y-auto overscroll-contain min-h-0 shadow-[inset_0_4px_10px_rgba(0,0,0,0.015)]" data-appointment-form>
				<div
					class="pointer-events-none absolute inset-0 z-20 hidden items-center justify-center bg-(--surface-bright)/80 backdrop-blur-[2px] transition-all"
					data-appointment-loading
				>
					<div class="inline-flex items-center gap-3 rounded-2xl border border-(--shell-border) bg-(--surface-bright) px-5 py-3.5 text-[0.95rem] font-extrabold text-(--on-surface) shadow-[0_12px_32px_rgba(0,0,0,0.12)]">
						<span class="material-symbols-rounded animate-spin text-[1.2rem] text-(--primary)">progress_activity</span>
						Procesando...
					</div>
				</div>

				<div class="flex-1 px-7 py-7 grid gap-5">
					<div class="hidden rounded-2xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-[0.9rem] font-bold text-rose-500 shadow-sm" data-form-error></div>

					<div class="grid gap-5 sm:grid-cols-2">
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
							<span class="inline-flex items-center gap-1">
								Cliente
								<span class="text-rose-500">*</span>
							</span>
							<input
								type="text"
								name="customer_name"
								required
								maxlength="100"
								class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
								placeholder="Ej: Carlos Gomez"
							/>
							<span class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400" data-field-error="customer_name"></span>
						</label>

						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
								<span class="inline-flex items-center gap-1">
									Teléfono
									<span class="text-rose-500">*</span>
								</span>
							<input
								type="tel"
								name="customer_phone"
								maxlength="20"
								inputmode="tel"
								class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
								placeholder="Ej: 0981 123 456"
							/>
							<span class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400" data-field-error="customer_phone"></span>
						</label>
					</div>

					<div class="grid gap-5 sm:grid-cols-2">
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)" data-modal-professional-wrap>
							<span class="inline-flex items-center gap-1">
								Profesional
								<span class="text-rose-500">*</span>
							</span>
							<select
								name="pro_id_professional"
								data-modal-professional
								required
								class="cursor-pointer appearance-none rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] font-semibold outline-none transition hover:border-(--on-surface-variant) focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M7%2010l5%205%205-5%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-position-[calc(100%-12px)_center] bg-no-repeat pr-10"
							>
								<option value="">Selecciona un profesional</option>
							</select>
							<span class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400" data-field-error="pro_id_professional"></span>
						</label>

						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
							<span class="inline-flex items-center gap-1">
								Sucursal
								<span class="text-rose-500">*</span>
							</span>
							<select
								name="loc_id_location"
								data-modal-location
								required
								class="cursor-pointer appearance-none rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] font-semibold outline-none transition hover:border-(--on-surface-variant) focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M7%2010l5%205%205-5%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-position-[calc(100%-12px)_center] bg-no-repeat pr-10"
							>
								<option value="">Selecciona una sucursal</option>
							</select>
							<span class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400" data-field-error="loc_id_location"></span>
						</label>
					</div>

					<div class="grid gap-5 sm:grid-cols-2">
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
							<span class="inline-flex items-center gap-1">
								Servicio
								<span class="text-rose-500">*</span>
							</span>
							<select
								name="ser_id_service"
								data-modal-service
								required
								class="cursor-pointer appearance-none rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] font-semibold outline-none transition hover:border-(--on-surface-variant) focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M7%2010l5%205%205-5%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-position-[calc(100%-12px)_center] bg-no-repeat pr-10"
							>
								<option value="">Selecciona un servicio</option>
							</select>
							<span class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400" data-field-error="ser_id_service"></span>
						</label>

						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)" data-modal-status-wrap hidden>
							Estado
							<select
								name="status"
								data-modal-status
								class="cursor-pointer appearance-none rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] font-semibold outline-none transition hover:border-(--on-surface-variant) focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M7%2010l5%205%205-5%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-position-[calc(100%-12px)_center] bg-no-repeat pr-10"
							>
								<option value="PENDIENTE">Pendiente</option>
								<option value="CONFIRMADO">Confirmado</option>
								<option value="COMPLETADO">Completado</option>
								<option value="CANCELADO">Cancelado</option>
							</select>
							<span class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400" data-field-error="status"></span>
						</label>
					</div>

					<div class="grid gap-5 sm:grid-cols-2">
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
							<span class="inline-flex items-center gap-1">
								Inicio
								<span class="text-rose-500">*</span>
							</span>
							<input
								type="datetime-local"
								name="start_time"
								required
								class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
							/>
							<span class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400" data-field-error="start_time"></span>
						</label>

						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
							<span class="inline-flex items-center gap-1">
								Fin
								<span class="text-rose-500">*</span>
							</span>
							<input
								type="datetime-local"
								name="end_time"
								required
								class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
							/>
							<span class="hidden text-xs font-semibold text-rose-600 dark:text-rose-400" data-field-error="end_time"></span>
						</label>
					</div>
				</div>

				<div class="sticky bottom-0 z-20 mt-auto flex flex-col-reverse sm:flex-row shrink-0 sm:items-center gap-3 border-t border-(--shell-border) bg-(--surface-bright) px-7 py-5">
					<button
						type="button"
						class="hidden w-full sm:w-auto sm:mr-auto rounded-2xl border border-rose-500/20 bg-rose-500/10 px-5 py-3 text-[0.95rem] font-extrabold text-rose-500 transition hover:bg-rose-500/20 hover:border-rose-500/30 disabled:opacity-50 disabled:pointer-events-none"
						data-delete-appointment
					>
						<span class="material-symbols-rounded mr-1.5 align-[-0.22em] text-[1.15rem]">delete</span>
						Eliminar
					</button>

					<div class="w-full sm:w-auto flex flex-col sm:flex-row items-center gap-3">
						<button
							type="button"
							class="w-full sm:w-auto rounded-2xl border border-transparent px-5 py-3 text-[0.95rem] font-extrabold text-(--on-surface-variant) transition hover:bg-(--surface-variant) hover:text-(--on-surface) focus:outline-none focus:ring-2 focus:ring-(--shell-border) hidden sm:block"
							data-close-appointment-modal
						>
							Cancelar
						</button>
						<button
							type="submit"
							class="btn-primary-soft w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-2xl px-6 py-3 text-[0.95rem] font-extrabold transition shadow-sm hover:shadow-md focus:outline-none focus:ring-2 focus:ring-(--primary) focus:ring-offset-2 focus:ring-offset-(--surface-bright) disabled:opacity-60 disabled:pointer-events-none"
							data-submit-appointment
						>
							<span class="material-symbols-rounded text-[1.2rem] hidden sm:inline" data-submit-appointment-icon>check</span>
							<span data-submit-appointment-label>Crear cita</span>
						</button>
					</div>
				</div>
			</form>
		</dialog>
		</appointment-modal>
	</calendar-manager>

	<AppAlert />
</Layout>

<script>
	import '../scripts/calendar-page';
</script>

<style is:global>
	calendar-manager,
	appointment-modal {
		display: block;
	}

	dialog[data-appointment-modal] {
		position: fixed;
		inset: 0;
		animation: appointment-modal-in 180ms ease-out;
	}

	dialog[data-appointment-modal]::backdrop {
		animation: appointment-backdrop-in 180ms ease-out;
	}

	dialog[data-appointment-modal].is-closing {
		animation: appointment-modal-out 160ms ease-in forwards;
	}

	dialog[data-appointment-modal].is-closing::backdrop {
		animation: appointment-backdrop-out 160ms ease-in forwards;
	}

	[data-calendar-root] .fc-theme-standard .fc-scrollgrid,
	[data-calendar-root] .fc-theme-standard td,
	[data-calendar-root] .fc-theme-standard th,
	[data-calendar-root] .fc-theme-standard .fc-list {
		border-color: var(--shell-border);
	}

	[data-calendar-root] .fc .fc-toolbar-title {
		font-size: 1.05rem;
		font-weight: 700;
		color: var(--on-surface);
	}

	[data-calendar-root] .fc .fc-toolbar {
		gap: 0.6rem;
	}

	[data-calendar-root] .fc .fc-button {
		border-color: var(--shell-border);
		background: var(--control-surface);
		color: var(--on-surface);
		box-shadow: none;
		text-transform: none;
		font-weight: 600;
	}

	[data-calendar-root] .fc .fc-button:hover,
	[data-calendar-root] .fc .fc-button:focus {
		background: var(--control-surface-strong);
		color: var(--on-surface);
		box-shadow: none;
	}

	[data-calendar-root] .fc .fc-button.fc-button-active {
		background: var(--primary-soft);
		border-color: var(--primary-container);
		color: var(--primary);
	}

	[data-calendar-root] .fc .fc-col-header-cell-cushion {
		display: block !important;
		padding: 8px 4px !important;
		text-decoration: none !important;
	}

	[data-calendar-root] .custom-cal-header {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 4px;
	}

	[data-calendar-root] .cal-day-name {
		text-transform: capitalize;
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--on-surface-variant);
	}

	[data-calendar-root] .cal-day-number {
		font-size: 1.4rem;
		font-weight: 400;
		color: var(--on-surface);
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		transition: background-color 0.2s ease;
	}

	[data-calendar-root] .fc-day-today .cal-day-name {
		color: var(--primary);
	}

	[data-calendar-root] .fc-day-today .cal-day-number {
		background-color: var(--primary);
		color: #ffffff;
		font-weight: 700;
