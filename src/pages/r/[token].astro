---
import Layout from '../../layouts/Layout.astro';
import AppAlert from '../../components/AppAlert.astro';
import {
	getPublicProfileWithOrds,
	getPublicReservationWithOrds,
	normalizePublicBookingLocations,
	PublicBookingApiError,
	type PublicBookingLocation,
	type PublicReservationDetail,
} from '../../lib/public-booking';
import { buildPublicProfilePath } from '../../lib/public-profile-url';
import '../../styles/global.css';

const token = String(Astro.params.token || '').trim();

let reservation: PublicReservationDetail | null = null;
let loadError = '';

try {
	reservation = await getPublicReservationWithOrds(token);
} catch (error) {
	const bookingError =
		error instanceof PublicBookingApiError
			? error
			: new PublicBookingApiError('No fue posible cargar esta reserva.', 500);
	loadError = bookingError.message;
	Astro.response.status = bookingError.status >= 400 && bookingError.status < 500 ? bookingError.status : 200;
}

const serializedReservation = reservation
	? JSON.stringify(reservation).replace(/</g, '\\u003c').replace(/-->/g, '--\\>')
	: '';

const isCancelled =
	Boolean(reservation) && String(reservation?.status || '').trim().toUpperCase() === 'CANCELADO';
const professionalSlug = String(reservation?.professional_slug || '').trim();
const organizationSlug = String(reservation?.organization_slug || '').trim();
const rebookHref =
	organizationSlug && professionalSlug
		? buildPublicProfilePath(organizationSlug, professionalSlug)
		: professionalSlug
			? `/p/${professionalSlug}`
			: '/';
const googleMapsApiKey =
	import.meta.env.PUBLIC_G_MAPS_API_KEY ??
	import.meta.env.PUBLIC_G_MAPS_API_KEYS ??
	'';

let reservationLocations: PublicBookingLocation[] = [];

if (reservation && organizationSlug && professionalSlug) {
	try {
		const profile = await getPublicProfileWithOrds(organizationSlug, professionalSlug);
		reservationLocations = normalizePublicBookingLocations(profile.locations);
	} catch {
		reservationLocations = [];
	}
}

if (reservation && reservationLocations.length === 0) {
	reservationLocations = [
		{
			id_location: reservation.loc_id_location,
			name: reservation.location_name,
			address: reservation.location_address,
		},
	];
}

const serializedLocations = reservation
	? JSON.stringify(reservationLocations).replace(/</g, '\\u003c').replace(/-->/g, '--\\>')
	: '';
---

<Layout>
	<main class="public-booking-shell reservation-shell relative z-10 mx-auto min-h-screen w-full max-w-4xl px-2 py-6 sm:px-4 md:px-6 lg:py-8">
		<div aria-hidden="true" class="pointer-events-none fixed inset-0 z-[-1] bg-(--surface-background)"></div>
		<section
			class="reservation-card grid gap-4"
			data-reservation-root
			data-token={token}
			data-google-maps-api-key={googleMapsApiKey}
		>
			{loadError || !reservation ? (
				<div class="reservation-state rounded-[28px] bg-(--surface-container) p-6 shadow-sm">
					<span class="material-symbols-rounded">event_busy</span>
					<h1>No encontramos esta reserva</h1>
					<p>{loadError || 'El enlace puede haber expirado o no existe.'}</p>
					<a href="/" class="reservation-link">Volver al inicio</a>
				</div>
			) : (
				<>
					<script type="application/json" id="reservation-json" set:html={serializedReservation}></script>
					<script type="application/json" id="reservation-locations-json" set:html={serializedLocations}></script>

					<header class="reservation-header rounded-[28px] bg-(--surface-container) p-5 shadow-sm sm:p-6">
						<div class="reservation-header-content">
							<div class="grid gap-1">
								<p class="reservation-eyebrow">Gestionar reserva</p>
								<h1>Tu reserva en Hasel</h1>
								<p>Revisa los datos, cambia la fecha o cancela tu turno si ya no puedes asistir.</p>
							</div>
						</div>
					</header>

					<div class="reservation-summary rounded-[28px] bg-(--surface-container) p-4 shadow-sm sm:p-5">
						<div>
							<span>Cliente</span>
							<strong>{reservation.customer_name}</strong>
						</div>
						<div>
							<span>Servicio</span>
							<strong>{reservation.service_name}</strong>
						</div>
						<div>
							<span>Profesional</span>
							<strong>{reservation.professional_name}</strong>
						</div>
						<div>
							<span>Sucursal</span>
							<strong data-location-name>{reservation.location_name}</strong>
						</div>
						<div>
							<span>Estado</span>
							<strong data-status-text>{reservation.status}</strong>
						</div>
						<div>
							<span>Horario actual</span>
							<strong data-current-date></strong>
						</div>
					</div>
					{isCancelled ? (
						<div class="reservation-cancelled rounded-[28px] bg-(--surface-container) p-5 shadow-sm sm:p-6" data-reservation-cancelled>
							<p class="reservation-cancelled-text">
								Esta reserva se encuentra cancelada. Si deseas, puedes agendar un nuevo turno con el profesional.
							</p>
							<a href={rebookHref} class="reservation-link">Volver a reservar</a>
						</div>
					) : (
					<form class="reservation-form rounded-[28px] bg-(--surface-container) p-4 shadow-sm sm:p-5" data-reservation-form>
						<div>
							<h2 class="text-xl font-normal tracking-tight text-(--on-surface) sm:text-2xl">Selecciona una nueva fecha</h2>
							<p class="mt-1 text-sm text-(--on-surface-variant) sm:text-base">
								Elige el día en el calendario para ver los horarios disponibles.
							</p>
						</div>

						<div class="mt-4 rounded-3xl border border-(--outline-variant) bg-(--surface-container-low) p-4 sm:mt-6 sm:p-6">
							<div class="mb-5 flex items-center justify-between gap-3">
								<button
									type="button"
									data-calendar-prev
									class="flex h-10 items-center rounded-full px-5 text-sm font-medium text-(--primary) transition hover:bg-(--primary-container) hover:text-(--on-primary-container)"
								>
									Anterior
								</button>
								<p class="text-base font-medium capitalize tracking-wide text-(--on-surface)" data-calendar-month></p>
								<button
									type="button"
									data-calendar-next
									class="flex h-10 items-center rounded-full px-5 text-sm font-medium text-(--primary) transition hover:bg-(--primary-container) hover:text-(--on-primary-container)"
								>
									Siguiente
								</button>
							</div>
							<div class="mb-3 grid grid-cols-7 gap-1 text-center text-xs font-medium uppercase tracking-wider text-(--on-surface-variant) sm:text-sm">
								<span>Lun</span>
								<span>Mar</span>
								<span>Mie</span>
								<span>Jue</span>
								<span>Vie</span>
								<span>Sab</span>
								<span>Dom</span>
							</div>
							<div class="grid grid-cols-7 gap-1 sm:gap-2" data-calendar-grid></div>
						</div>

						<input type="hidden" name="date" required data-reservation-date />
						<div class="hidden grid gap-3" data-reservation-slots-panel>
							<div>
								<h2 class="text-xl font-normal tracking-tight text-(--on-surface) sm:text-2xl">Selecciona un horario</h2>
								<p class="mt-1 text-sm text-(--on-surface-variant) sm:text-base">
									<span class="font-medium text-(--on-surface)" data-reservation-selected-date></span>
								</p>
							</div>

							<div
								data-reservation-slots-loading
								class="hidden rounded-2xl bg-(--surface-container-high) px-5 py-4 text-base font-medium text-(--on-surface-variant)"
							>
								Consultando horarios disponibles...
							</div>

							<div class="grid gap-6" data-reservation-slots-container></div>
							<input type="hidden" id="reservation_slot" name="slot" required data-reservation-slot />
							<input type="hidden" name="loc_id_location" data-reservation-location />
							<p data-no-reservation-slots class="hidden rounded-2xl border border-(--error-container) bg-(--error-container) px-4 py-3 text-sm font-medium text-(--on-error-container)">
								No hay horarios disponibles para este día.
							</p>
						</div>

						<div class="reservation-actions">
							<button type="button" class="reservation-danger" data-cancel-reservation>
								<span class="material-symbols-rounded">event_busy</span>
								Cancelar reserva
							</button>
							<button
								type="submit"
								class="inline-flex h-12 w-full items-center justify-center rounded-full bg-(--primary) px-8 text-base font-medium text-(--on-primary) transition hover:bg-(--primary-hover) disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto"
							>
								Guardar cambios
							</button>
						</div>
					</form>

					<dialog
						class="public-map-modal rounded-[28px] border border-(--outline-variant) bg-(--surface-container) p-0 text-(--on-surface) shadow-2xl backdrop:bg-black/70"
						data-public-map-modal
					>
						<div class="grid gap-4 p-5 sm:p-6">
							<div class="flex items-start justify-between gap-4">
								<div>
									<h2 class="text-xl font-semibold tracking-tight">Ubicación</h2>
									<p class="mt-1 text-sm text-(--on-surface-variant)" data-public-map-address></p>
								</div>
								<button
									type="button"
									class="grid h-10 w-10 place-items-center rounded-full text-(--on-surface-variant) transition hover:bg-(--surface-container-highest) hover:text-(--on-surface)"
									data-public-map-close
									aria-label="Cerrar mapa"
								>
									<span class="material-symbols-rounded">close</span>
								</button>
							</div>
							<div class="public-map-modal-divider"></div>
							<div class="public-map-canvas-wrap relative h-80 overflow-hidden rounded-3xl border border-(--outline-variant) bg-(--surface-container-high)">
								<div class="h-full w-full" data-public-map-canvas></div>
								<div
									class="public-map-loading absolute inset-0 z-10 hidden place-items-center bg-(--surface-container-high)/85 backdrop-blur-[2px]"
									data-public-map-loading
									aria-hidden="true"
									aria-live="polite"
									aria-label="Cargando mapa"
								>
									<span class="material-symbols-rounded animate-spin text-[1.75rem] text-(--primary)" aria-hidden="true">progress_activity</span>
								</div>
							</div>
							<p
								class="hidden rounded-2xl bg-(--error-container) px-4 py-3 text-sm font-medium text-(--on-error-container)"
								data-public-map-status
							></p>
						</div>
					</dialog>
					)}

				</>
			)}
		</section>
	</main>
	<AppAlert />
</Layout>

<script>
	import { initializePublicReservationPage } from '../../scripts/public-reservation-page';

	initializePublicReservationPage();
	document.addEventListener('astro:page-load', initializePublicReservationPage);
</script>


<style is:global>
.reservation-shell {
	font-family: 'Nunito Sans', Roboto, system-ui, sans-serif;
	--surface-background: #141414;
	--surface-container-lowest: #1b1b1b;
	--surface-container-low: #1b1b1b;
	--surface-container: #1b1b1b;
	--surface-container-high: #1b1b1b;
	--surface-container-highest: #1b1b1b;
	--outline: #44474e;
	--outline-variant: #44474e;
	--on-surface: #e2e2e9;
	--on-surface-variant: #c4c6d0;
	--primary: #a8c7fa;
	--on-primary: #062e6f;
	--primary-container: #0842a0;
	--on-primary-container: #d3e3fd;
	--primary-hover: #b9d4fa;
	--tertiary: #c7eccb;
	--on-tertiary: #0c381c;
	--tertiary-container: #225031;
	--on-tertiary-container: #e3ffe6;
	--error: #ffb4ab;
	--error-container: #93000a;
	--on-error-container: #ffdad6;
}

.reservation-card {
	width: 100%;
}

.reservation-header-content {
	display: flex;
	align-items: center;
	gap: 0.9rem;
}

.reservation-header h1,
.reservation-state h1 {
	margin: 0;
	font-size: clamp(1.75rem, 3.4vw, 2.2rem);
	line-height: 1.05;
	letter-spacing: -0.03em;
	color: var(--on-surface);
}

.reservation-header p,
.reservation-state p {
	margin: 0.3rem 0 0;
	color: var(--on-surface-variant);
	line-height: 1.45;
}

.reservation-eyebrow {
	color: var(--primary) !important;
	font-size: 0.72rem;
	font-weight: 800;
	letter-spacing: 0.12em;
	text-transform: uppercase;
}

.reservation-summary {
	display: grid;
	grid-template-columns: repeat(2, minmax(0, 1fr));
	gap: 0.55rem;
}

.reservation-summary div {
	border-radius: 0.8rem;
	background: var(--surface-container-high);
	padding: 0.65rem 0.75rem;
}

.reservation-summary span {
	display: block;
	color: var(--on-surface-variant);
	font-size: 0.72rem;
	font-weight: 700;
	margin-bottom: 0.28rem;
}

.reservation-summary strong {
	display: block;
	color: var(--on-surface);
	font-size: 0.96rem;
	line-height: 1.25;
}

.reservation-form {
	display: grid;
	gap: 1rem;
}

.reservation-actions {
	display: flex;
	gap: 0.8rem;
	justify-content: space-between;
	margin-top: 0.75rem;
}

.reservation-danger,
.reservation-link {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	gap: 0.5rem;
	border: 0;
	border-radius: 999px;
	font: inherit;
	font-weight: 500;
	padding: 0.78rem 1.25rem;
	cursor: pointer;
	text-decoration: none;
}

.reservation-danger {
	background: rgba(127, 29, 29, 0.18);
	color: #fca5a5;
	border: 1px solid rgba(248, 113, 113, 0.28);
	box-shadow: none;
	transition: background 0.2s ease, border-color 0.2s ease;
}

.reservation-danger:hover {
	background: rgba(127, 29, 29, 0.28);
	border-color: rgba(248, 113, 113, 0.42);
}

.reservation-cancelled {
	display: grid;
	gap: 1rem;
}

.reservation-cancelled-text {
	margin: 0;
	color: var(--on-surface-variant);
	line-height: 1.5;
	font-size: 0.98rem;
}

.reservation-link {
	margin-top: 0;
	background: var(--primary);
	color: var(--on-primary);
	justify-self: start;
}

.is-hidden {
	display: none;
}

.reservation-state {
	text-align: center;
}

.reservation-state .material-symbols-rounded {
	color: var(--primary);
	font-size: 3rem;
}

@media (max-width: 640px) {
	.reservation-header-content,
	.reservation-actions {
		flex-direction: column;
		align-items: stretch;
	}

	.reservation-summary {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.5rem;
	}

	.reservation-summary div {
		padding: 0.62rem 0.7rem;
	}
}

@media (min-width: 768px) {
	.reservation-summary {
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.65rem;
	}
}

.public-map-modal {
	width: min(92vw, 44rem);
	max-height: min(90vh, 42rem);
	margin: auto;
}

.public-map-modal-divider {
	height: 1px;
	width: 100%;
	border-radius: 999px;
	background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--outline-variant) 72%, white 28%), transparent);
	opacity: 0.9;
}

.public-map-canvas-wrap.is-loading [data-public-map-canvas] {
	visibility: hidden;
}

.public-map-loading {
	display: grid;
}

.public-map-loading.hidden {
	display: none;
}

.public-location-link {
	display: inline-flex;
	align-items: center;
	gap: 0.25rem;
	width: fit-content;
	border: 0;
	background: transparent;
	padding: 0;
	font: inherit;
	color: var(--primary);
	text-decoration: none;
	transition: color 0.15s ease;
	cursor: pointer;
}

.public-location-link:hover .public-location-link__label {
	text-decoration: underline;
	text-underline-offset: 0.2em;
}
</style>

