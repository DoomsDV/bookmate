---
import Layout from '../../layouts/Layout.astro';

const hash = String(Astro.params.hash || '').trim();
let status: 'success' | 'error' = 'success';
let message = '';
let data: any = null;

if (!hash) {
	status = 'error';
	message = 'Enlace de pago inválido.';
	Astro.response.status = 404;
} else {
	try {
		const res = await fetch(new URL(`/api/public/payments/${encodeURIComponent(hash)}`, Astro.url), {
			method: 'GET',
			headers: { Accept: 'application/json' },
		});
		const json = await res.json().catch(() => null);
		if (!res.ok || !json || json.status !== 'success') {
			status = 'error';
			message = String(json?.message || 'No fue posible verificar el pago.').trim();
		} else {
			data = json.data ?? null;
			const paymentStatus = String(data?.payment_status || '').trim().toUpperCase();
			if (paymentStatus === 'PAID') {
				message = 'Pago confirmado. Tu reserva fue registrada correctamente.';
			} else if (paymentStatus === 'PENDING') {
				message = 'Estamos confirmando tu pago. Si recién pagaste, puede tardar unos segundos.';
			} else if (paymentStatus === 'EXPIRED') {
				status = 'error';
				message = 'El pago no se completó a tiempo y la reserva fue liberada.';
			} else {
				message = 'Estado de pago recibido.';
			}
		}
	} catch {
		status = 'error';
		message = 'No fue posible verificar el pago en este momento.';
	}
}

const paymentStatus = String(data?.payment_status || '').trim().toUpperCase();
const title = status === 'error' ? 'No pudimos confirmar el pago' : 'Reserva y pago';
---

<Layout>
	<main class="public-booking-shell relative z-10 mx-auto min-h-screen w-full max-w-3xl px-2 py-8 sm:px-4 md:px-8 lg:py-12">
		<div aria-hidden="true" class="pointer-events-none fixed inset-0 z-[-1] bg-(--surface-background)"></div>

		<section
			class:list={[
				'rounded-3xl border px-8 py-10 shadow-sm',
				status === 'error'
					? 'border-rose-200 bg-rose-50 text-rose-900'
					: 'border-emerald-200 bg-emerald-50 text-emerald-900',
			]}
		>
			<h1 class="text-3xl font-semibold tracking-tight">{title}</h1>
			<p class="mt-3 text-base font-medium">{message}</p>

			{data ? (
				<div class="mt-6 rounded-2xl bg-white/60 p-6 text-(--on-surface) shadow-sm">
					<ul class="grid gap-3 text-base">
						<li class="grid">
							<span class="text-sm font-semibold text-(--on-surface-variant)">Servicio</span>
							<span>{String(data?.service_name || '-')}</span>
						</li>
						<li class="grid">
							<span class="text-sm font-semibold text-(--on-surface-variant)">Cliente</span>
							<span>{String(data?.customer_name || '-')}</span>
						</li>
						<li class="grid">
							<span class="text-sm font-semibold text-(--on-surface-variant)">Seña</span>
							<span>{data?.deposit_amount ? `${Number(data.deposit_amount).toLocaleString('es-PY')} Gs` : '-'}</span>
						</li>
						<li class="grid">
							<span class="text-sm font-semibold text-(--on-surface-variant)">Estado</span>
							<span>{paymentStatus || '-'}</span>
						</li>
					</ul>
				</div>
			) : null}

			<div class="mt-7 flex flex-wrap gap-3">
				<a
					href="/"
					class="inline-flex h-11 items-center justify-center rounded-full bg-white/70 px-6 text-sm font-semibold text-(--on-surface) no-underline transition hover:bg-white"
				>
					Volver al inicio
				</a>
				{paymentStatus === 'PENDING' ? (
					<a
						href={Astro.url.pathname}
						class="inline-flex h-11 items-center justify-center rounded-full bg-white/70 px-6 text-sm font-semibold text-(--on-surface) no-underline transition hover:bg-white"
					>
						Actualizar estado
					</a>
				) : null}
			</div>
		</section>
	</main>
</Layout>

