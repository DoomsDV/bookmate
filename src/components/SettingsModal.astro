<script>
	import { formatPublicProfilePrefixDisplay } from '../lib/public-profile-url';
	import { FEATURE_FLAGS } from '../config/feature-flags';
	import {
		PARAGUAY_MOBILE_PHONE_ERROR,
		parseParaguayMobilePhone,
	} from '../lib/paraguay-phone';
	import {
		getCancelWaitOptionsForReminder,
		getReminderHoursValue,
		type WorkspaceCatalogs,
		type WorkspaceSettingsData,
	} from '../lib/workspace-settings-shared';
	import { showSettingsModalTour } from '../lib/settings-modal-tour';
	import { destroyActiveBookmateTour } from '../lib/product-tour';
	import {
		disablePushNotifications,
		enablePushNotifications,
		getPushNotificationUiState,
	} from '../lib/fcm-client';
	import {
		isAcceptedProfileImage,
		ProfileImageCropper,
	} from '../lib/profile-image-crop';

	interface ApiErrorDetail {
		field?: string;
		message?: string;
	}

	interface ApiResponse<T = unknown> {
		status?: string;
		message?: string;
		data?: T;
		errors?: ApiErrorDetail[];
		details?: unknown;
		slug?: string;
	}

	class SettingsApiError extends Error {
		status: number;
		errors: ApiErrorDetail[];
		details: unknown;

		constructor(message: string, status = 400, errors: ApiErrorDetail[] = [], details: unknown = null) {
			super(message);
			this.name = 'SettingsApiError';
			this.status = status;
			this.errors = errors;
			this.details = details;
		}
	}

	class SettingsManager extends HTMLElement {
		private abortController: AbortController | null = null;
		private isAdmin = false;
		private publicProfileDomain = '';
		private organizationSlug = '';
		private globalPublicProfilePrefix = '';

		private els!: {
			modal: HTMLDialogElement | null;
			closeBtn: HTMLButtonElement | null;
			appearanceSaveBtn: HTMLButtonElement | null;
			tabButtons: NodeListOf<HTMLElement>;
			panels: NodeListOf<HTMLElement>;
			profileForm: HTMLFormElement | null;
			securityForm: HTMLFormElement | null;
			preferencesForm: HTMLFormElement | null;
			workspaceForm: HTMLFormElement | null;
			brandingForm: HTMLFormElement | null;
			systemForm: HTMLFormElement | null;
			integrationsForm: HTMLFormElement | null;
			loadingOverlay: HTMLElement | null;
			profilePreview: HTMLImageElement | null;
			profilePlaceholder: HTMLElement | null;
			profileDropzone: HTMLElement | null;
			logoPreview: HTMLImageElement | null;
			logoPlaceholder: HTMLElement | null;
			logoDropzone: HTMLElement | null;
			logoFileName: HTMLElement | null;
			cropModal: HTMLDialogElement | null;
			cropMount: HTMLElement | null;
			confirmCropBtn: HTMLButtonElement | null;
			pushToggle: HTMLInputElement | null;
			pushToggleLabel: HTMLLabelElement | null;
			pushHint: HTMLElement | null;
		};

		private formEls!: {
			firstNameInput: HTMLInputElement | null;
			lastNameInput: HTMLInputElement | null;
			phoneInput: HTMLInputElement | null;
			profileSlugInput: HTMLInputElement | null;
			profileSlugPrefix: HTMLElement | null;
			phoneError: HTMLElement | null;
			profileSlugError: HTMLElement | null;
			profileImageInput: HTMLInputElement | null;
			brandingLogoInput: HTMLInputElement | null;
		};

		private profilePreviewObjectUrl = '';
		private logoPreviewObjectUrl = '';
		private slugSuggestTimer: number | null = null;
		private slugRequestSeq = 0;
		private slugManuallyEdited = false;
		private suppressSlugManualTracking = false;
		private closingTimer: number | null = null;
		private feedbackHideTimer: number | null = null;
		private systemCatalogs: WorkspaceCatalogs | null = null;
		private profileImageCropper: ProfileImageCropper | null = null;
		private pendingCropSource: File | null = null;
		private pendingCropTarget: 'profile' | 'logo' | null = null;
		private cropBusy = false;
		private pushToggleBusy = false;
		private scrollHintsObserver: ResizeObserver | null = null;

		connectedCallback() {
			const roleId = Number(this.dataset.roleId || '0');
			this.isAdmin = roleId === 1;
			this.publicProfileDomain = String(this.dataset.publicProfileDomain || '');
			this.organizationSlug = String(this.dataset.organizationSlug || '').trim();
			this.globalPublicProfilePrefix = String(this.dataset.globalPublicProfilePrefix || '').trim();

			this.els = {
				modal: this.querySelector<HTMLDialogElement>('[data-settings-modal]'),
				closeBtn: this.querySelector<HTMLButtonElement>('[data-settings-close]'),
				appearanceSaveBtn: this.querySelector<HTMLButtonElement>('[data-settings-appearance-save]'),
				tabButtons: this.querySelectorAll<HTMLElement>('[data-settings-tab-trigger]'),
				panels: this.querySelectorAll<HTMLElement>('[data-settings-panel]'),
				profileForm: this.querySelector<HTMLFormElement>('[data-settings-profile-form]'),
				securityForm: this.querySelector<HTMLFormElement>('[data-settings-security-form]'),
				preferencesForm: this.querySelector<HTMLFormElement>('[data-settings-preferences-form]'),
				workspaceForm: this.querySelector<HTMLFormElement>('[data-settings-workspace-form]'),
				brandingForm: this.querySelector<HTMLFormElement>('[data-settings-branding-form]'),
				systemForm: this.querySelector<HTMLFormElement>('[data-settings-system-form]'),
				integrationsForm: this.querySelector<HTMLFormElement>('[data-settings-integrations-form]'),
				loadingOverlay: this.querySelector<HTMLElement>('[data-settings-loading]'),
				profilePreview: this.querySelector<HTMLImageElement>('[data-settings-profile-preview]'),
				profilePlaceholder: this.querySelector<HTMLElement>('[data-settings-profile-placeholder]'),
				profileDropzone: this.querySelector<HTMLElement>('[data-settings-profile-dropzone]'),
				logoPreview: this.querySelector<HTMLImageElement>('[data-settings-logo-preview]'),
				logoPlaceholder: this.querySelector<HTMLElement>('[data-settings-logo-placeholder]'),
				logoDropzone: this.querySelector<HTMLElement>('[data-settings-logo-dropzone]'),
				logoFileName: this.querySelector<HTMLElement>('[data-settings-logo-file-name]'),
				cropModal: this.querySelector<HTMLDialogElement>('[data-settings-profile-crop-modal]'),
				cropMount: this.querySelector<HTMLElement>('[data-settings-profile-crop-mount]'),
				confirmCropBtn: this.querySelector<HTMLButtonElement>('[data-confirm-settings-profile-crop]'),
				pushToggle:
					this.querySelector<HTMLInputElement>('[data-settings-push-toggle]') ?? null,
				pushToggleLabel:
					this.querySelector<HTMLLabelElement>('[data-settings-push-switch-label]') ?? null,
				pushHint: this.querySelector<HTMLElement>('[data-settings-push-hint]') ?? null,
			};

			this.formEls = {
				firstNameInput: this.els.profileForm?.querySelector<HTMLInputElement>('[name="first_name"]') ?? null,
				lastNameInput: this.els.profileForm?.querySelector<HTMLInputElement>('[name="last_name"]') ?? null,
				phoneInput: this.els.profileForm?.querySelector<HTMLInputElement>('[name="phone_number"]') ?? null,
				profileSlugInput: this.els.profileForm?.querySelector<HTMLInputElement>('[name="public_slug"]') ?? null,
				profileSlugPrefix: this.els.profileForm?.querySelector<HTMLElement>('[data-settings-profile-slug-prefix]') ?? null,
				phoneError: this.els.profileForm?.querySelector<HTMLElement>('[data-settings-profile-field-error="phone_number"]') ?? null,
				profileSlugError: this.els.profileForm?.querySelector<HTMLElement>('[data-settings-profile-field-error="public_slug"]') ?? null,
				profileImageInput: this.els.profileForm?.querySelector<HTMLInputElement>('[name="profile_image"]') ?? null,
				brandingLogoInput: this.els.brandingForm?.querySelector<HTMLInputElement>('[name="logo_file"]') ?? null,
			};

			if (!this.abortController) {
				this.abortController = new AbortController();
			}
			const { signal } = this.abortController;

			document.addEventListener('click', this.handleDocumentClick, { signal });
			this.els.closeBtn?.addEventListener('click', this.closeModal, { signal });
			this.els.modal?.addEventListener('click', this.handleBackdropClick, { signal });
			this.els.modal?.addEventListener('close', () => destroyActiveBookmateTour(), { signal });
			this.querySelector<HTMLButtonElement>('[data-settings-modal-tour-help]')?.addEventListener(
				'click',
				this.handleSettingsModalTourHelp,
				{ signal },
			);
			
			this.els.tabButtons.forEach(btn => 
				btn.addEventListener('click', () => this.setActiveTab(btn.dataset.settingsTab || 'profile'), { signal })
			);

			this.formEls.profileSlugInput?.addEventListener('input', this.handleSlugInput, { signal });
			this.formEls.firstNameInput?.addEventListener('input', this.queueSlugSuggestion, { signal });
			this.formEls.lastNameInput?.addEventListener('input', this.queueSlugSuggestion, { signal });
			this.formEls.phoneInput?.addEventListener('input', this.handlePhoneInput, { signal });
			this.formEls.profileImageInput?.addEventListener('change', this.handleProfileImageChange, { signal });
			this.formEls.brandingLogoInput?.addEventListener('change', this.handleLogoImageChange, { signal });
			this.bindUploadDropzone(this.els.profileDropzone, 'profile', signal);
			this.bindUploadDropzone(this.els.logoDropzone, 'logo', signal);

			this.els.pushToggle?.addEventListener('change', this.handlePushToggleChange, { signal });
			this.els.profileForm?.addEventListener('submit', this.handleProfileSubmit, { signal });
			this.els.securityForm?.addEventListener('submit', this.handleSecuritySubmit, { signal });
			this.els.appearanceSaveBtn?.addEventListener('click', this.handleAppearanceSave, { signal });
			this.els.workspaceForm?.addEventListener('submit', this.handleWorkspaceSubmit, { signal });
			this.els.systemForm?.addEventListener('submit', this.handleSystemSubmit, { signal });
			this.els.systemForm?.addEventListener('change', this.handleSystemFormChange, { signal });
			this.els.integrationsForm?.addEventListener('submit', this.handleIntegrationsSubmit, { signal });
			this.bindScrollHints(signal);
		}

		disconnectedCallback() {
			this.abortController?.abort();
			this.abortController = null;
			this.clearSlugSuggestTimer();
			this.releaseProfilePreviewObjectUrl();
			this.releaseLogoPreviewObjectUrl();
			this.profileImageCropper?.destroy();
			this.profileImageCropper = null;
			this.pendingCropSource = null;
			this.pendingCropTarget = null;
			if (this.closingTimer) window.clearTimeout(this.closingTimer);
			if (this.feedbackHideTimer) window.clearTimeout(this.feedbackHideTimer);
			this.scrollHintsObserver?.disconnect();
			this.scrollHintsObserver = null;
		}

		private updateScrollHints = () => {};

		private bindScrollHints(signal: AbortSignal) {
			const content = this.querySelector<HTMLElement>('[data-settings-content]');
			const contentShell = this.querySelector<HTMLElement>('[data-settings-content-shell]');
			const tabsGrid = this.querySelector<HTMLElement>('[data-settings-tabs-scroll]');
			const tabsNav = this.querySelector<HTMLElement>('[data-settings-nav]');
			const scrollHint = this.querySelector<HTMLElement>('.settings-content-scroll-hint');

			if (!content || !contentShell) return;

			const updateContentScrollHint = () => {
				const hasOverflow = content.scrollHeight - content.clientHeight > 12;
				const canScrollDown =
					content.scrollHeight - content.scrollTop - content.clientHeight > 12;
				const showHint = hasOverflow && canScrollDown;

				contentShell.classList.toggle('has-scroll-below', showHint);
				scrollHint?.setAttribute('aria-hidden', showHint ? 'false' : 'true');
			};

			const updateTabsScrollHint = () => {
				if (!tabsGrid || !tabsNav) return;

				const hasOverflow = tabsGrid.scrollWidth - tabsGrid.clientWidth > 8;
				const canScrollRight =
					tabsGrid.scrollWidth - tabsGrid.scrollLeft - tabsGrid.clientWidth > 8;

				tabsNav.classList.toggle('has-tabs-scroll', hasOverflow && canScrollRight);
			};

			this.updateScrollHints = () => {
				updateContentScrollHint();
				updateTabsScrollHint();
			};

			content.addEventListener('scroll', updateContentScrollHint, { passive: true, signal });
			tabsGrid?.addEventListener('scroll', updateTabsScrollHint, { passive: true, signal });
			window.addEventListener('resize', this.updateScrollHints, { signal });

			this.scrollHintsObserver = new ResizeObserver(this.updateScrollHints);
			this.scrollHintsObserver.observe(content);
			if (tabsGrid) this.scrollHintsObserver.observe(tabsGrid);
			this.els.panels.forEach((panel) => this.scrollHintsObserver?.observe(panel));

			requestAnimationFrame(this.updateScrollHints);
		}

		private handleDocumentClick = (event: MouseEvent) => {
			const target = event.target;
			if (!(target instanceof Element)) return;

			if (this.els.cropModal?.open && this.els.cropModal === target) {
				this.closeProfileImageCrop(true);
				return;
			}

			const closeCropTrigger = target.closest('[data-close-settings-profile-crop]');
			if (closeCropTrigger && this.contains(closeCropTrigger)) {
				this.closeProfileImageCrop(true);
				return;
			}

			const confirmCropTrigger = target.closest('[data-confirm-settings-profile-crop]');
			if (confirmCropTrigger && this.contains(confirmCropTrigger)) {
				void this.confirmProfileImageCrop();
				return;
			}

			const closeActionBtn = target.closest('[data-settings-close-action]');
			if (closeActionBtn && this.contains(closeActionBtn)) {
				event.preventDefault();
				this.closeModal();
				return;
			}

			const copyUrlBtn = target.closest<HTMLButtonElement>('[data-copy-settings-profile-url]');
			if (copyUrlBtn && this.contains(copyUrlBtn)) {
				event.preventDefault();
				void this.copyPublicProfileUrl(copyUrlBtn);
				return;
			}

			const openBtn = target.closest('[data-open-settings-modal]');
			if (openBtn) {
				event.preventDefault();
				openBtn.closest('details')?.removeAttribute('open');
				this.openModal();
			}
		};

		private handleSettingsModalTourHelp = () => {
			if (!this.els.modal?.open) return;
			showSettingsModalTour({
				activateProfileTab: () => this.setActiveTab('profile'),
			});
		};

		private resetModalScroll() {
			const content = this.querySelector<HTMLElement>('[data-settings-content]');
			if (content) content.scrollTop = 0;
		}

		private openModal = () => {
			destroyActiveBookmateTour({ persistCompletion: false });
			this.setActiveTab('profile');
			this.clearFeedback();
			this.resetSecurityForm();
			this.syncPushNotificationToggle();
			this.els.modal?.classList.remove('is-closing');
			if (this.closingTimer) {
				window.clearTimeout(this.closingTimer);
				this.closingTimer = null;
			}
			if (this.els.modal && !this.els.modal.open) this.els.modal.showModal();
			this.resetModalScroll();
			void this.loadData();
			requestAnimationFrame(() => {
				this.resetModalScroll();
				requestAnimationFrame(this.updateScrollHints);
			});
		};

		private syncPushNotificationToggle() {
			const toggle = this.els.pushToggle;
			if (!toggle) return;

			const state = getPushNotificationUiState();
			toggle.checked = state.switchChecked;
			toggle.disabled = this.pushToggleBusy || !state.switchEnabled;

			const hint = this.els.pushHint;
			if (!hint) return;

			let hintMessage = '';
			if (!state.pwaInstalled) {
				hintMessage =
					'Instalá Hasel en tu dispositivo para gestionar las notificaciones desde aquí.';
			} else if (!state.browserSupported) {
				hintMessage = 'Este navegador no admite notificaciones push.';
			} else if (state.permission === 'denied') {
				hintMessage =
					'Las notificaciones están bloqueadas en el sistema. Habilitalas en los ajustes del dispositivo o del navegador.';
			}

			if (hintMessage) {
				hint.textContent = hintMessage;
				hint.classList.remove('hidden');
			} else {
				hint.textContent = '';
				hint.classList.add('hidden');
			}

			this.els.pushToggleLabel?.classList.toggle('is-disabled', !state.switchEnabled);
		}

		private handlePushToggleChange = async () => {
			const toggle = this.els.pushToggle;
			if (!toggle || this.pushToggleBusy) return;

			const shouldEnable = toggle.checked;
			const previousChecked = !shouldEnable;
			this.pushToggleBusy = true;
			this.syncPushNotificationToggle();

			try {
				if (shouldEnable) {
					await enablePushNotifications({ fromSettings: true });
					this.showFeedback(
						'profile',
						'Notificaciones activadas en este dispositivo.',
						'success'
					);
				} else {
					await disablePushNotifications();
					this.showFeedback(
						'profile',
						'Notificaciones desactivadas en este dispositivo.',
						'success'
					);
				}
				document.dispatchEvent(new CustomEvent('bookmate:fcm-state-changed'));
			} catch (error) {
				toggle.checked = previousChecked;
				const message =
					error instanceof Error
						? error.message
						: 'No fue posible actualizar las notificaciones.';
				this.showFeedback('profile', message, 'error');
			} finally {
				this.pushToggleBusy = false;
				this.syncPushNotificationToggle();
			}
		};

		private handleBackdropClick = (event: MouseEvent) => {
			if (event.target instanceof HTMLDialogElement) {
				this.closeModal();
			}
		};

		private closeModal = () => {
			if (!this.els.modal?.open) return;
			destroyActiveBookmateTour();
			this.els.modal.classList.add('is-closing');

			this.closingTimer = window.setTimeout(() => {
				this.els.modal?.close();
				this.els.modal?.classList.remove('is-closing');
				this.resetSecurityForm();
				this.releaseProfilePreviewObjectUrl();
				this.releaseLogoPreviewObjectUrl();
				this.clearSlugSuggestTimer();
				this.setLoadingState(false);
				this.slugRequestSeq += 1;
				this.closingTimer = null;
			}, 140);
		};

		private readApiMessage(data: ApiResponse | null, fallback: string): string {
			return typeof data?.message === 'string' && data.message.trim() ? data.message.trim() : fallback;
		}

		private getPublicProfileUrl() {
			const slug = String(this.formEls.profileSlugInput?.value || '').trim().replace(/^\/+/, '');
			if (!slug) return '';
			const prefix = String(this.globalPublicProfilePrefix || this.getPublicProfilePrefix()).trim();
			if (!prefix) return `/${slug}`;
			return `${prefix.replace(/\/+$/, '')}/${slug.replace(/^\/+/, '')}`;
		}

		private async writeClipboardText(value: string) {
			if (navigator.clipboard?.writeText) {
				await navigator.clipboard.writeText(value);
				return;
			}

			const textarea = document.createElement('textarea');
			textarea.value = value;
			textarea.setAttribute('readonly', '');
			textarea.style.position = 'fixed';
			textarea.style.opacity = '0';
			document.body.appendChild(textarea);
			textarea.select();
			document.execCommand('copy');
			textarea.remove();
		}

		private async copyPublicProfileUrl(button: HTMLButtonElement) {
			const url = this.getPublicProfileUrl();
			if (!url) {
				this.showFeedback('profile', 'Ingresa una URL de perfil público antes de copiar.', 'error');
				return;
			}

			const icon = button.querySelector<HTMLElement>('[data-copy-settings-profile-url-icon]');
			try {
				await this.writeClipboardText(url);
				if (icon) icon.textContent = 'check';
				button.classList.add('text-emerald-500');
				this.showFeedback('profile', 'URL copiada al portapapeles.', 'success');
				window.setTimeout(() => {
					if (icon) icon.textContent = 'content_copy';
					button.classList.remove('text-emerald-500');
				}, 1400);
			} catch {
				this.showFeedback('profile', 'No fue posible copiar la URL. Intenta nuevamente.', 'error');
			}
		}

		private normalizeSecurityMessage(message: string, kind: 'success' | 'error') {
			const raw = String(message || '').trim();
			if (!raw) {
				return kind === 'success'
					? 'Tu contraseña se actualizó correctamente.'
					: 'No pudimos actualizar tu contraseña. Intenta nuevamente.';
			}

			const normalized = raw
				.normalize('NFD')
				.replace(/[\u0300-\u036f]/g, '')
				.toLowerCase();

			if (kind === 'success') {
				if (normalized.includes('contrasena actualizada correctamente')) {
					return 'Tu contraseña se actualizó correctamente.';
				}
				return raw;
			}

			if (normalized.includes('debes completar') || normalized.includes('contrasena actual y la nueva')) {
				return 'Ingresa tu contraseña actual y la nueva contraseña.';
			}
			if (normalized.includes('no fue posible actualizar la contrasena')) {
				return 'No pudimos actualizar tu contraseña. Intenta nuevamente.';
			}

			return raw;
		}

		private async fileToBase64(file: File): Promise<string> {
			return new Promise((resolve, reject) => {
				const reader = new FileReader();
				reader.onload = () => {
					const result = String(reader.result || '');
					resolve(result.includes(',') ? result.split(',')[1] : result);
				};
				reader.onerror = () => reject(new Error('No fue posible leer el archivo.'));
				reader.readAsDataURL(file);
			});
		}

		private setLoadingState(isLoading: boolean) {
			this.els.loadingOverlay?.classList.toggle('hidden', !isLoading);
			this.els.loadingOverlay?.classList.toggle('flex', isLoading);
			this.els.tabButtons.forEach((button) => {
				if (button instanceof HTMLButtonElement) button.disabled = isLoading;
			});
			if (!isLoading) {
				requestAnimationFrame(this.updateScrollHints);
			}
		}

		private isAllowedImageFile(file: File): boolean {
			return ['image/jpeg', 'image/png'].includes(file.type);
		}

		private bindUploadDropzone(
			dropzone: HTMLElement | null,
			target: 'profile' | 'logo',
			signal: AbortSignal
		) {
			if (!dropzone) return;
			dropzone.addEventListener('dragover', (event) => {
				event.preventDefault();
				dropzone.classList.add('is-dragover');
			}, { signal });
			dropzone.addEventListener('dragleave', (event) => {
				if (event.relatedTarget instanceof Node && dropzone.contains(event.relatedTarget)) return;
				dropzone.classList.remove('is-dragover');
			}, { signal });
			dropzone.addEventListener('drop', (event) => {
				event.preventDefault();
				dropzone.classList.remove('is-dragover');
				const file = Array.from(event.dataTransfer?.files ?? []).find((item) =>
					this.isAllowedImageFile(item)
				);
				if (!file) {
					this.showFeedback(
						target === 'profile' ? 'profile' : 'preferences',
						'Selecciona una imagen JPG o PNG.',
						'error'
					);
					return;
				}
				void this.openImageCrop(file, target);
			}, { signal });
		}

		private resetProfileImageInput() {
			if (this.formEls.profileImageInput) {
				this.formEls.profileImageInput.value = '';
			}
		}

		private setProfileImageFile(file: File) {
			if (!this.formEls.profileImageInput) return;
			const dataTransfer = new DataTransfer();
			dataTransfer.items.add(file);
			this.formEls.profileImageInput.files = dataTransfer.files;
			this.releaseProfilePreviewObjectUrl();
			this.profilePreviewObjectUrl = URL.createObjectURL(file);
			this.setProfilePreview(this.profilePreviewObjectUrl);
		}

		private setLogoImageFile(file: File) {
			if (!this.formEls.brandingLogoInput) return;
			const dataTransfer = new DataTransfer();
			dataTransfer.items.add(file);
			this.formEls.brandingLogoInput.files = dataTransfer.files;
			this.releaseLogoPreviewObjectUrl();
			this.logoPreviewObjectUrl = URL.createObjectURL(file);
			this.setLogoPreview(this.logoPreviewObjectUrl);
			if (this.els.logoFileName) this.els.logoFileName.textContent = file.name;
		}

		private async openImageCrop(file: File, target: 'profile' | 'logo') {
			if (!isAcceptedProfileImage(file)) {
				this.showFeedback(target === 'profile' ? 'profile' : 'preferences', 'Selecciona una imagen JPG o PNG.', 'error');
				return;
			}

			if (!this.els.cropModal || !this.els.cropMount) {
				if (target === 'profile') {
					this.setProfileImageFile(file);
				} else {
					this.setLogoImageFile(file);
				}
				return;
			}

			this.pendingCropSource = file;
			this.pendingCropTarget = target;
			this.cropBusy = true;
			this.setCropModalBusy(true);

			if (!this.profileImageCropper) {
				this.profileImageCropper = new ProfileImageCropper(this.els.cropMount);
			}

			try {
				if (!this.els.cropModal.open) {
					this.els.cropModal.showModal();
				}
				await this.profileImageCropper.bindFile(file);
			} catch {
				this.showFeedback(target === 'profile' ? 'profile' : 'preferences', 'No se pudo preparar la imagen para recortar.', 'error');
				this.closeProfileImageCrop(true);
			} finally {
				this.cropBusy = false;
				this.setCropModalBusy(false);
			}
		}

		private setCropModalBusy(busy: boolean) {
			if (this.els.confirmCropBtn) {
				this.els.confirmCropBtn.disabled = busy;
			}
		}

		private closeProfileImageCrop(cancelled: boolean) {
			const cancelledTarget = this.pendingCropTarget;
			if (this.els.cropModal?.open) {
				this.els.cropModal.close();
			}
			this.profileImageCropper?.destroy();
			this.profileImageCropper = null;
			this.pendingCropSource = null;
			this.pendingCropTarget = null;
			this.cropBusy = false;
			this.setCropModalBusy(false);
			if (cancelled) {
				if (cancelledTarget === 'profile') {
					this.resetProfileImageInput();
				}
				if (cancelledTarget === 'logo' && this.formEls.brandingLogoInput) {
					this.formEls.brandingLogoInput.value = '';
				}
			}
		}

		private async confirmProfileImageCrop() {
			if (this.cropBusy || !this.pendingCropSource || !this.profileImageCropper || !this.pendingCropTarget) return;

			this.cropBusy = true;
			this.setCropModalBusy(true);

			try {
				const cropped = await this.profileImageCropper.exportJpeg(this.pendingCropSource.name);
				if (this.pendingCropTarget === 'profile') {
					this.setProfileImageFile(cropped);
				} else {
					this.setLogoImageFile(cropped);
				}
				this.closeProfileImageCrop(false);
			} catch {
				this.showFeedback(
					this.pendingCropTarget === 'profile' ? 'profile' : 'preferences',
					'No se pudo recortar la imagen. Intenta de nuevo.',
					'error'
				);
			} finally {
				this.cropBusy = false;
				this.setCropModalBusy(false);
			}
		}

		private setUploadFile(target: 'profile' | 'logo', file: File) {
			const input = target === 'profile' ? this.formEls.profileImageInput : this.formEls.brandingLogoInput;
			if (!input) return;
			const dataTransfer = new DataTransfer();
			dataTransfer.items.add(file);
			input.files = dataTransfer.files;
			target === 'profile' ? this.handleProfileImageChange() : this.handleLogoImageChange();
		}

		private setProfilePreview(src: string) {
			const cleanSrc = String(src || '').trim();
			const hasImage = cleanSrc.length > 0;
			if (this.els.profilePreview) {
				this.els.profilePreview.src = hasImage ? cleanSrc : '';
				this.els.profilePreview.classList.toggle('hidden', !hasImage);
			}
			this.els.profilePlaceholder?.classList.toggle('hidden', hasImage);
		}

		private setLogoPreview(src: string) {
			const cleanSrc = String(src || '').trim();
			const hasImage = cleanSrc.length > 0;
			if (this.els.logoPreview) {
				this.els.logoPreview.src = hasImage ? cleanSrc : '';
				this.els.logoPreview.classList.toggle('hidden', !hasImage);
			}
			this.els.logoPlaceholder?.classList.toggle('hidden', hasImage);
		}

		private releaseProfilePreviewObjectUrl() {
			if (!this.profilePreviewObjectUrl) return;
			URL.revokeObjectURL(this.profilePreviewObjectUrl);
			this.profilePreviewObjectUrl = '';
		}

		private releaseLogoPreviewObjectUrl() {
			if (!this.logoPreviewObjectUrl) return;
			URL.revokeObjectURL(this.logoPreviewObjectUrl);
			this.logoPreviewObjectUrl = '';
		}

		private clearSlugSuggestTimer() {
			if (!this.slugSuggestTimer) return;
			window.clearTimeout(this.slugSuggestTimer);
			this.slugSuggestTimer = null;
		}

		private getPublicProfilePrefix() {
			if (this.globalPublicProfilePrefix) return this.globalPublicProfilePrefix;
			const configuredDomain = String(this.publicProfileDomain || '')
				.replace(/^https?:\/\//i, '')
				.replace(/\/+$/, '')
				.trim();
			const host = configuredDomain || String(window.location?.host || '').trim();
			const pathSuffix = '/u/';
			if (!host) return pathSuffix;
			return `https://${host}${pathSuffix}`;
		}

		private getSlugSourceName() {
			return `${String(this.formEls.firstNameInput?.value || '').trim()} ${String(this.formEls.lastNameInput?.value || '').trim()}`.trim();
		}

		private setSuggestedSlug(slug: string) {
			if (!this.formEls.profileSlugInput) return;
			this.suppressSlugManualTracking = true;
			this.formEls.profileSlugInput.value = slug;
			this.suppressSlugManualTracking = false;
		}

		private toParaguayPhoneLocalDigits(rawValue: string) {
			const parsedPhone = parseParaguayMobilePhone(rawValue);
			if (parsedPhone.isValid) return parsedPhone.e164.slice(4);

			let digits = String(rawValue || '').replace(/\D/g, '');
			if (digits.startsWith('00595')) digits = digits.slice(5);
			if (digits.startsWith('595')) digits = digits.slice(3);
			if (digits.startsWith('0')) digits = digits.slice(1);
			return digits.slice(0, 9);
		}

		private formatParaguayPhoneLocal(rawValue: string) {
			const digits = this.toParaguayPhoneLocalDigits(rawValue);
			if (!digits) return '';
			if (digits.length <= 3) return digits;
			if (digits.length <= 6) return `${digits.slice(0, 3)} ${digits.slice(3)}`;
			return `${digits.slice(0, 3)} ${digits.slice(3, 6)} ${digits.slice(6, 9)}`;
		}

		private setPhoneFieldError(message: string) {
			if (!this.formEls.phoneError) return;
			this.formEls.phoneError.textContent = message;
			this.formEls.phoneError.classList.remove('hidden');
		}

		private clearProfileFieldErrors() {
			if (this.formEls.profileSlugError) {
				this.formEls.profileSlugError.textContent = '';
				this.formEls.profileSlugError.classList.add('hidden');
			}
			if (this.formEls.phoneError) {
				this.formEls.phoneError.textContent = '';
				this.formEls.phoneError.classList.add('hidden');
			}
		}

		private isGenericValidationMessage(message: unknown): boolean {
			const normalized = String(message || '').trim().toLowerCase();
			return (
				normalized === 'errores de validacion.' ||
				normalized === 'errores de validacion' ||
				normalized === 'errores de validacion.' ||
				normalized === 'errores de validacion'
			);
		}

		private renderProfileFieldErrors(errors: unknown, fallbackMessage = ''): boolean {
			let rendered = false;
			const items = Array.isArray(errors) ? errors : [];
			for (const item of items) {
				if (!item || typeof item !== 'object') continue;
				const field = 'field' in item ? String((item as Record<string, unknown>).field || '').trim() : '';
				const message = 'message' in item ? String((item as Record<string, unknown>).message || '').trim() : '';
				if (!field || !message) continue;
				if (field === 'phone_number' && this.formEls.phoneError) {
					this.formEls.phoneError.textContent = message;
					this.formEls.phoneError.classList.remove('hidden');
					rendered = true;
				}
				if (field === 'public_slug' && this.formEls.profileSlugError) {
					this.formEls.profileSlugError.textContent = message;
					this.formEls.profileSlugError.classList.remove('hidden');
					rendered = true;
				}
			}
			if (rendered) return true;
			if (typeof fallbackMessage === 'string' && /slug|perfil/i.test(fallbackMessage) && this.formEls.profileSlugError) {
				this.formEls.profileSlugError.textContent = fallbackMessage;
				this.formEls.profileSlugError.classList.remove('hidden');
				return true;
			}
			return false;
		}

		private getFeedbackHost(): HTMLElement | null {
			return this.querySelector<HTMLElement>('[data-settings-feedback-host]');
		}

		private hideFeedbackNode(node: HTMLElement) {
			if (this.feedbackHideTimer) {
				window.clearTimeout(this.feedbackHideTimer);
				this.feedbackHideTimer = null;
			}
			node.className = 'settings-feedback-host hidden';
			node.hidden = true;
			node.textContent = '';
		}

		private showFeedback(_key: string, message: string, kind: 'success' | 'error' = 'success') {
			const node = this.getFeedbackHost();
			if (!node) return;
			if (this.feedbackHideTimer) {
				window.clearTimeout(this.feedbackHideTimer);
				this.feedbackHideTimer = null;
			}

			const tone =
				kind === 'success'
					? { icon: 'check_circle', modifier: 'inline-feedback--success' }
					: { icon: 'error', modifier: 'inline-feedback--error' };

			node.hidden = false;
			node.className = `settings-feedback-host inline-feedback ${tone.modifier}`;
			node.innerHTML = `
				<span class="material-symbols-rounded inline-feedback__icon">${tone.icon}</span>
				<p class="inline-feedback__text"></p>
				<button type="button" class="inline-feedback__close" aria-label="Cerrar mensaje" data-inline-feedback-close>
					<span class="material-symbols-rounded">close</span>
				</button>
			`;

			const textNode = node.querySelector('.inline-feedback__text');
			if (textNode) textNode.textContent = message;

			node.querySelector('[data-inline-feedback-close]')?.addEventListener('click', () => {
				this.hideFeedbackNode(node);
			});

			if (kind === 'success') {
				this.feedbackHideTimer = window.setTimeout(() => {
					this.hideFeedbackNode(node);
				}, 3200);
			}
		}

		private clearFeedback() {
			const node = this.getFeedbackHost();
			if (node) this.hideFeedbackNode(node);
			this.clearProfileFieldErrors();
		}

		private async requestApi<T = unknown>(url: string, options: RequestInit, fallbackMessage: string): Promise<ApiResponse<T>> {
			const response = await fetch(url, options);
			let data: ApiResponse<T> | null = null;
			try {
				data = await response.json();
			} catch {
				throw new SettingsApiError('No fue posible interpretar la respuesta.', response.status || 502);
			}
			if (!response.ok || !data || data.status !== 'success') {
				throw new SettingsApiError(
					this.readApiMessage(data, fallbackMessage),
					response.status || 400,
					data?.errors,
					data?.details
				);
			}
			return data;
		}

		private handleSlugInput = () => {
			if (this.suppressSlugManualTracking) return;
			const currentValue = String(this.formEls.profileSlugInput?.value || '').trim();
			this.slugManuallyEdited = currentValue !== '';
			this.clearProfileFieldErrors();
			if (!this.slugManuallyEdited) this.queueSlugSuggestion();
		};

		private queueSlugSuggestion = () => {
			if (!this.formEls.profileSlugInput) return;
			const fullName = this.getSlugSourceName();
			if (!fullName) return;
			if (this.slugManuallyEdited && this.formEls.profileSlugInput.value.trim() !== '') return;
			
			this.clearSlugSuggestTimer();
			const currentRequest = ++this.slugRequestSeq;
			this.slugSuggestTimer = window.setTimeout(async () => {
				try {
					const response = await fetch(
						`/api/profile/public-slug/suggest?name=${encodeURIComponent(fullName)}`,
						{ method: 'GET', headers: { Accept: 'application/json' } }
					);
					let data: ApiResponse | null = null;
					try {
						data = await response.json();
					} catch {
						return;
					}
					if (currentRequest !== this.slugRequestSeq) return;
					if (!response.ok || !data || data.status !== 'success' || typeof data.slug !== 'string') return;
					if (this.slugManuallyEdited && this.formEls.profileSlugInput!.value.trim() !== '') return;
					const suggestedSlug = String(data.slug || '').trim();
					if (!suggestedSlug) return;
					this.setSuggestedSlug(suggestedSlug);
				} catch {
					// Ignoramos errores de red
				}
			}, 350);
		};

		private handlePhoneInput = () => {
			if (!this.formEls.phoneInput) return;
			this.formEls.phoneInput.value = this.formatParaguayPhoneLocal(this.formEls.phoneInput.value);
			this.clearProfileFieldErrors();
		};

		private handleProfileImageChange = () => {
			const imageFile = this.formEls.profileImageInput?.files?.[0];
			this.resetProfileImageInput();
			if (!imageFile) return;
			void this.openImageCrop(imageFile, 'profile');
		};

		private handleLogoImageChange = () => {
			const logoFile = this.formEls.brandingLogoInput?.files?.[0];
			if (!logoFile) return;
			if (this.formEls.brandingLogoInput) this.formEls.brandingLogoInput.value = '';
			void this.openImageCrop(logoFile, 'logo');
		};

		private setActiveTab(tabId: string) {
			this.els.tabButtons.forEach((btn) => btn.classList.toggle('is-active', btn.dataset.settingsTab === tabId));
			this.els.panels.forEach((panel) => panel.classList.toggle('hidden', panel.dataset.settingsPanel !== tabId));
			if (tabId === 'profile') this.syncPushNotificationToggle();

			const content = this.querySelector<HTMLElement>('[data-settings-content]');
			if (content) content.scrollTop = 0;
			requestAnimationFrame(this.updateScrollHints);
		}

		private resetSecurityForm() {
			if (!this.els.securityForm) return;
			const current = this.els.securityForm.querySelector<HTMLInputElement>('[name="current_password"]');
			const next = this.els.securityForm.querySelector<HTMLInputElement>('[name="new_password"]');
			const confirm = this.els.securityForm.querySelector<HTMLInputElement>('[name="confirm_password"]');
			if (current) current.value = '';
			if (next) next.value = '';
			if (confirm) confirm.value = '';
		}

		private fillProfile(profile: any) {
			if (!this.els.profileForm) return;
			const email = this.els.profileForm.querySelector<HTMLInputElement>('[name="email"]');
			const phone = this.els.profileForm.querySelector<HTMLInputElement>('[name="phone_number"]');

			if (this.formEls.firstNameInput) this.formEls.firstNameInput.value = profile?.first_name || '';
			if (this.formEls.lastNameInput) this.formEls.lastNameInput.value = profile?.last_name || '';
			if (email) email.value = profile?.email || '';
			if (this.formEls.profileImageInput) this.formEls.profileImageInput.value = '';
			if (this.formEls.profileSlugPrefix) {
				const fullPrefix = this.getPublicProfilePrefix();
				this.formEls.profileSlugPrefix.textContent = formatPublicProfilePrefixDisplay(fullPrefix);
				this.formEls.profileSlugPrefix.title = fullPrefix;
			}
			
			this.clearSlugSuggestTimer();
			this.slugRequestSeq += 1;
			this.slugManuallyEdited = false;
			this.releaseProfilePreviewObjectUrl();

			const publicProfile = profile?.public_profile;
			if (this.formEls.profileSlugInput) {
				this.setSuggestedSlug(String(publicProfile?.public_slug || '').trim());
				if (this.formEls.profileSlugInput.value.trim() === '') this.queueSlugSuggestion();
			}
			this.setProfilePreview(publicProfile?.image_url || '');

			const phoneNumber = String(
				profile?.phone_number || profile?.professional_profile?.phone_number || ''
			).trim();
			if (phone) phone.value = this.formatParaguayPhoneLocal(phoneNumber);
		}

		private populateSystemSelect(
			select: HTMLSelectElement | null,
			options: Array<{ id: number; label: string }>,
			selectedId: number | null
		) {
			if (!select) return;
			select.replaceChildren();
			for (const option of options) {
				const node = document.createElement('option');
				node.value = String(option.id);
				node.textContent = option.label;
				select.appendChild(node);
			}
			if (selectedId && options.some((item) => item.id === selectedId)) {
				select.value = String(selectedId);
			} else if (options[0]) {
				select.value = String(options[0].id);
			}
		}

		private getSystemSelectValue(selector: string) {
			const select = this.querySelector<HTMLSelectElement>(selector);
			const parsed = Number(select?.value || 0);
			return Number.isInteger(parsed) && parsed > 0 ? parsed : null;
		}

		private fillSystemSettings(workspace: WorkspaceSettingsData | null) {
			if (!this.els.systemForm || !workspace) return;

			this.systemCatalogs = workspace.catalogs ?? null;

			this.populateSystemSelect(
				this.querySelector<HTMLSelectElement>('[data-settings-system-slot-interval]'),
				this.systemCatalogs?.slot_intervals ?? [],
				workspace.rsi_id_slot_interval
			);
			this.renderSystemSlotPreview();
			this.populateSystemSelect(
				this.querySelector<HTMLSelectElement>('[data-settings-system-reminder-hours]'),
				this.systemCatalogs?.reminder_hours ?? [],
				workspace.rh_id_reminder_hours
			);

			const timeFormat = String(workspace.time_format || '24H').trim().toLowerCase();
			const timeFormatSelect = this.els.systemForm.querySelector<HTMLSelectElement>('[name="time_format"]');
			if (timeFormatSelect) timeFormatSelect.value = timeFormat === '12h' ? '12H' : '24H';

			const alertSelect = this.querySelector<HTMLSelectElement>('[data-settings-system-alert-action]');
			if (alertSelect) {
				alertSelect.value = workspace.unanswered_alert_action === 'CANCEL' ? 'CANCEL' : 'KEEP';
			}

			this.refreshSystemCancelWaitField(workspace.cwh_id_cancel_wait_hours);
		}

		private getSelectedSlotIntervalMinutes() {
			const slotId = this.getSystemSelectValue('[data-settings-system-slot-interval]');
			const match = this.systemCatalogs?.slot_intervals.find((item) => item.id === slotId);
			const minutes = Number(match?.minutes ?? 0);
			return Number.isInteger(minutes) && minutes > 0 ? minutes : 30;
		}

		private buildExampleSlotTimes(minutes: number, count = 5) {
			let totalMinutes = 9 * 60;
			const times: string[] = [];
			for (let index = 0; index < count; index += 1) {
				const hours = Math.floor(totalMinutes / 60) % 24;
				const mins = totalMinutes % 60;
				times.push(`${String(hours).padStart(2, '0')}:${String(mins).padStart(2, '0')}`);
				totalMinutes += minutes;
			}
			return times;
		}

		private renderSystemSlotPreview() {
			const chipsHost = this.querySelector<HTMLElement>(
				'[data-settings-system-slot-preview-chips]'
			);
			if (!chipsHost) return;

			const minutes = this.getSelectedSlotIntervalMinutes();
			const exampleTimes = this.buildExampleSlotTimes(minutes);
			chipsHost.replaceChildren();

			for (const time of exampleTimes) {
				const chip = document.createElement('span');
				chip.className = 'settings-slot-preview-chip';
				chip.textContent = time;
				chipsHost.appendChild(chip);
			}
		}

		private refreshSystemCancelWaitField(preferredCancelWaitId: number | null = null) {
			const alertAction =
				this.querySelector<HTMLSelectElement>('[data-settings-system-alert-action]')?.value || 'KEEP';
			const cancelField = this.querySelector<HTMLElement>('[data-settings-system-cancel-wait-field]');
			const cancelSelect = this.querySelector<HTMLSelectElement>('[data-settings-system-cancel-wait]');
			const reminderId = this.getSystemSelectValue('[data-settings-system-reminder-hours]');
			const showCancel = alertAction === 'CANCEL';

			cancelField?.classList.toggle('hidden', !showCancel);
			if (!showCancel) {
				if (cancelSelect) cancelSelect.value = '';
				return;
			}

			const options = getCancelWaitOptionsForReminder(this.systemCatalogs ?? undefined, reminderId);
			this.populateSystemSelect(cancelSelect, options, preferredCancelWaitId);
		}

		private validateSystemFormPayload() {
			if (!this.els.systemForm) return { ok: false, message: 'Formulario de sistema no disponible.' };

			const slotId = this.getSystemSelectValue('[data-settings-system-slot-interval]');
			const reminderId = this.getSystemSelectValue('[data-settings-system-reminder-hours]');
			const alertAction =
				this.querySelector<HTMLSelectElement>('[data-settings-system-alert-action]')?.value || 'KEEP';
			const cancelId =
				alertAction === 'CANCEL'
					? this.getSystemSelectValue('[data-settings-system-cancel-wait]')
					: null;

			if (!slotId) return { ok: false, message: 'Selecciona un intervalo de reserva.' };
			if (!reminderId) return { ok: false, message: 'Selecciona un tiempo de recordatorio.' };
			if (alertAction === 'CANCEL' && !cancelId) {
				return { ok: false, message: 'Selecciona el tiempo límite de espera para cancelar.' };
			}

			const reminderHours = getReminderHoursValue(this.systemCatalogs ?? undefined, reminderId);
			const cancelHours =
				cancelId && this.systemCatalogs
					? this.systemCatalogs.cancel_wait_hours.find((item) => item.id === cancelId)?.hours ?? 0
					: 0;

			if (alertAction === 'CANCEL' && cancelHours >= reminderHours) {
				return {
					ok: false,
					message: 'El tiempo de espera debe ser menor que el tiempo de recordatorio.',
				};
			}

			return {
				ok: true,
				payload: {
					rsi_id_slot_interval: slotId,
					rh_id_reminder_hours: reminderId,
					unanswered_alert_action: alertAction,
					cwh_id_cancel_wait_hours: alertAction === 'CANCEL' ? cancelId : null,
				},
			};
		}

		private handleSystemFormChange = (event: Event) => {
			const target = event.target;
			if (
				target instanceof HTMLSelectElement &&
				target.matches('[data-settings-system-slot-interval]')
			) {
				this.renderSystemSlotPreview();
				return;
			}

			if (
				target instanceof HTMLSelectElement &&
				target.matches('[data-settings-system-cancel-wait]')
			) {
				return;
			}

			const preserveCancelWaitId = this.getSystemSelectValue('[data-settings-system-cancel-wait]');
			this.refreshSystemCancelWaitField(preserveCancelWaitId);
		};

		private fillWorkspace(workspace: WorkspaceSettingsData | null) {
			const setValue = (selector: string, value: string) => {
				const input = this.querySelector<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(selector);
				if (input) input.value = value || '';
			};
			
			setValue('[data-settings-workspace-form] [name="name"]', String(workspace?.name ?? ''));
			setValue('[data-settings-workspace-form] [name="profile_slug"]', String(workspace?.profile_slug ?? ''));
			setValue('[data-settings-workspace-form] [name="description"]', String(workspace?.description ?? ''));
			this.fillSystemSettings(workspace);
			
			this.releaseLogoPreviewObjectUrl();

			this.setLogoPreview(workspace?.logo_url || '');
			if (this.els.logoFileName) this.els.logoFileName.textContent = 'Subir logo';
			const logoFile = this.formEls.brandingLogoInput;
			if (logoFile) logoFile.value = '';
		}

		private getPanelAppearanceValues(): { theme: 'light' | 'dark' } {
			const theme: 'light' | 'dark' =
				this.els.preferencesForm?.querySelector<HTMLSelectElement>('[name="panel_theme"]')?.value === 'dark'
					? 'dark'
					: 'light';
			return { theme };
		}

		private persistPanelAppearance(theme: string) {
			const safeTheme = theme === 'dark' ? 'dark' : 'light';
			document.documentElement.dataset.theme = safeTheme;
			localStorage.setItem('bookmate-theme', safeTheme);
		}

		private reloadAfterWorkspaceSave() {
			window.setTimeout(() => {
				window.location.reload();
			}, 650);
		}

		private getFormPayload(form: HTMLFormElement | null): Record<string, string> {
			const payload: Record<string, string> = {};
			if (!form) return payload;

			const formData = new FormData(form);
			for (const [key, value] of formData.entries()) {
				if (typeof value === 'string') {
					payload[key] = value.trim();
				}
			}

			return payload;
		}

		private getAppearancePayload(): Record<string, string> {
			const payload = this.getFormPayload(this.els.preferencesForm);
			if (this.els.brandingForm) {
				Object.assign(payload, this.getFormPayload(this.els.brandingForm));
			}
			return payload;
		}


		private getWorkspacePayload(): Record<string, string> {
			const payload: Record<string, string> = {};
			const forms = [this.els.workspaceForm, this.els.systemForm, this.els.brandingForm];

			for (const form of forms) {
				Object.assign(payload, this.getFormPayload(form));
			}
			return payload;
		}

		private async loadData() {
			this.setLoadingState(true);
			try {
				const profileRes = await this.requestApi('/api/profile/me', { method: 'GET', headers: { Accept: 'application/json' } }, 'No fue posible cargar perfil.');
				this.fillProfile(profileRes.data || {});

				if (this.els.preferencesForm) {
					const panelTheme = this.els.preferencesForm.querySelector<HTMLSelectElement>('[name="panel_theme"]');
					if (panelTheme) {
						const storedTheme = localStorage.getItem('bookmate-theme');
						panelTheme.value = storedTheme === 'dark' || storedTheme === 'light' ? storedTheme : 'dark';
					}
				}

				if (this.isAdmin) {
					const workspaceRes = await this.requestApi('/api/workspace', { method: 'GET', headers: { Accept: 'application/json' } }, 'No fue posible cargar negocio.');
					this.fillWorkspace((workspaceRes.data as unknown as WorkspaceSettingsData | null) ?? null);
					if (FEATURE_FLAGS.INTEGRATIONS_SETTINGS) {
						await this.loadIntegrations();
					}
				}
			} catch (error) {
				this.showFeedback('profile', error instanceof Error ? error.message : 'No fue posible cargar ajustes.', 'error');
			} finally {
				this.setLoadingState(false);
			}
		}

		private async loadIntegrations() {
			if (!this.isAdmin || !this.els.integrationsForm) return;

			try {
				const data = await this.requestApi(
					'/api/org-integrations/pagopar',
					{ method: 'GET', headers: { Accept: 'application/json' } },
					'No fue posible cargar Pagopar.'
				);

				const raw = (data as any)?.data ?? {};
				const publicKey = String(raw?.public_key || '').trim();
				const privateConfigured = Boolean(raw?.private_key_configured);

				const publicKeyInput = this.els.integrationsForm.querySelector<HTMLInputElement>('[name="public_key"]');
				const privateKeyInput = this.els.integrationsForm.querySelector<HTMLInputElement>('[name="private_key"]');

				if (publicKeyInput) publicKeyInput.value = publicKey;
				if (privateKeyInput) privateKeyInput.value = '';

				if (privateConfigured) {
					privateKeyInput?.setAttribute('placeholder', 'Clave privada configurada (reemplaza para actualizar)');
				}
			} catch (error) {
				// 404: integración no configurada aún → no es error para UI.
				const status = error instanceof SettingsApiError ? error.status : 0;
				if (status === 404) return;
				this.showFeedback('integrations', error instanceof Error ? error.message : 'No fue posible cargar Pagopar.', 'error');
			}
		}

		private handleIntegrationsSubmit = async (event: SubmitEvent) => {
			event.preventDefault();
			this.clearFeedback();
			if (!this.els.integrationsForm) return;

			const publicKey = String(
				this.els.integrationsForm.querySelector<HTMLInputElement>('[name="public_key"]')?.value || ''
			).trim();
			const privateKey = String(
				this.els.integrationsForm.querySelector<HTMLInputElement>('[name="private_key"]')?.value || ''
			).trim();

			if (!publicKey || !privateKey) {
				this.showFeedback('integrations', 'Clave pública y clave privada son obligatorias.', 'error');
				return;
			}

			try {
				const data = await this.requestApi(
					'/api/org-integrations/pagopar',
					{
						method: 'PUT',
						headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
						body: JSON.stringify({ provider: 'pagopar', public_key: publicKey, private_key: privateKey }),
					},
					'No fue posible guardar Pagopar.'
				);
				this.showFeedback('integrations', this.readApiMessage(data, 'Pagopar configurado correctamente.'), 'success');
				await this.loadIntegrations();
			} catch (error) {
				this.showFeedback('integrations', error instanceof Error ? error.message : 'No fue posible guardar Pagopar.', 'error');
			}
		};

		private handleProfileSubmit = async (event: SubmitEvent) => {
			event.preventDefault();
			this.clearFeedback();
			if (!this.els.profileForm) return;

			const first = String(this.els.profileForm.querySelector<HTMLInputElement>('[name="first_name"]')?.value || '').trim();
			const last = String(this.els.profileForm.querySelector<HTMLInputElement>('[name="last_name"]')?.value || '').trim();
			if (!first || !last) {
				this.showFeedback('profile', 'Nombre y apellido son obligatorios.', 'error');
				return;
			}

			const payload: Record<string, string | number> = { first_name: first, last_name: last };

			const publicSlug = String(this.formEls.profileSlugInput?.value || '').trim();
			if (publicSlug) payload.public_slug = publicSlug;

			const imageFile = this.els.profileForm.querySelector<HTMLInputElement>('[name="profile_image"]')?.files?.[0];
			if (imageFile) {
				payload.image_base64 = await this.fileToBase64(imageFile);
				payload.image_name = imageFile.name;
				payload.image_mime = imageFile.type || 'application/octet-stream';
			}

			const rawPhone = String(this.formEls.phoneInput?.value || '').trim();
			if (rawPhone !== '') {
				const parsedPhone = parseParaguayMobilePhone(rawPhone);
				if (!parsedPhone.isValid) {
					this.setPhoneFieldError(PARAGUAY_MOBILE_PHONE_ERROR);
					return;
				}
				payload.phone_number = parsedPhone.e164;
			} else {
				payload.phone_number = '';
			}

			try {
				const data = await this.requestApi('/api/profile/me', {
					method: 'PUT',
					headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
					body: JSON.stringify(payload),
				}, 'No fue posible guardar perfil.');
				this.showFeedback('profile', this.readApiMessage(data, 'Perfil actualizado correctamente.'), 'success');
				await this.loadData();
			} catch (error) {
				const message = error instanceof Error ? error.message : 'No fue posible guardar perfil.';
				const hasFieldErrors = this.renderProfileFieldErrors(
					error instanceof SettingsApiError ? error.errors : [],
					message
				);
				if (!hasFieldErrors || !this.isGenericValidationMessage(message)) {
					this.showFeedback('profile', message, 'error');
				}
			}
		};

		private handleSecuritySubmit = async (event: SubmitEvent) => {
			event.preventDefault();
			this.clearFeedback();
			if (!this.els.securityForm) return;

			const currentPassword = String(this.els.securityForm.querySelector<HTMLInputElement>('[name="current_password"]')?.value || '').trim();
			const newPassword = String(this.els.securityForm.querySelector<HTMLInputElement>('[name="new_password"]')?.value || '').trim();
			const confirmPassword = String(this.els.securityForm.querySelector<HTMLInputElement>('[name="confirm_password"]')?.value || '').trim();

			if (!currentPassword || !newPassword || !confirmPassword) {
				this.showFeedback('security', 'Ingresa la contraseña actual, la nueva y su confirmación.', 'error');
				return;
			}

			if (newPassword.length < 8) {
				this.showFeedback('security', 'La nueva contraseña debe tener al menos 8 caracteres.', 'error');
				return;
			}

			if (newPassword !== confirmPassword) {
				this.showFeedback('security', 'La confirmación no coincide. Verifica ambos campos.', 'error');
				return;
			}

			if (newPassword === currentPassword) {
				this.showFeedback('security', 'La nueva contraseña no puede ser igual a la actual.', 'error');
				return;
			}

			try {
				const data = await this.requestApi(
					'/api/profile/change-password',
					{
						method: 'PUT',
						headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
						body: JSON.stringify({ current_password: currentPassword, new_password: newPassword }),
					},
					'No pudimos actualizar tu contraseña. Intenta nuevamente.'
				);
				this.showFeedback(
					'security',
					this.normalizeSecurityMessage(
						this.readApiMessage(data, 'Tu contraseña se actualizó correctamente.'),
						'success'
					),
					'success'
				);
				this.resetSecurityForm();
			} catch (error) {
				this.showFeedback(
					'security',
					this.normalizeSecurityMessage(
						error instanceof Error
							? error.message
							: 'No pudimos actualizar tu contraseña. Intenta nuevamente.',
						'error'
					),
					'error'
				);
			}
		};

		private handleAppearanceSave = async (event: Event) => {
			event.preventDefault();
			this.clearFeedback();
			if (!this.els.preferencesForm) return;

			const { theme } = this.getPanelAppearanceValues();

			if (!this.isAdmin) {
				this.persistPanelAppearance(theme);
				this.showFeedback('preferences', 'Apariencia guardada correctamente.', 'success');
				return;
			}

			const payload = this.getAppearancePayload();
			payload.panel_theme = theme;
			if (!payload.theme_pref) {
				payload.theme_pref = theme;
			}

			if (this.els.brandingForm) {
				const logoFile = this.els.brandingForm.querySelector<HTMLInputElement>('[name="logo_file"]')?.files?.[0];
				if (logoFile) {
					payload.logo_base64 = await this.fileToBase64(logoFile);
					payload.logo_name = logoFile.name;
					payload.logo_mime = logoFile.type || 'application/octet-stream';
				}
			}

			try {
				const data = await this.requestApi(
					'/api/workspace',
					{
						method: 'PUT',
						headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
						body: JSON.stringify(payload),
					},
					'No fue posible guardar la apariencia.'
				);

				this.persistPanelAppearance(theme);
				this.showFeedback('preferences', this.readApiMessage(data, 'Apariencia guardada correctamente.'), 'success');
				this.reloadAfterWorkspaceSave();
			} catch (error) {
				this.showFeedback('preferences', error instanceof Error ? error.message : 'No fue posible guardar la apariencia.', 'error');
			}
		};

		private async saveWorkspaceSettings(
			panel: string,
			extraPayload: Record<string, string | number | null> = {}
		) {
			this.clearFeedback();
			try {
				const payload = { ...this.getWorkspacePayload(), ...extraPayload };
				const data = await this.requestApi('/api/workspace', {
					method: 'PUT',
					headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
					body: JSON.stringify(payload),
				}, 'No fue posible guardar la configuración.');

				let successMessage = 'Configuración guardada correctamente.';
				if (panel === 'workspace') successMessage = 'Negocio actualizado correctamente.';
				if (panel === 'branding') successMessage = 'Personalización guardada correctamente.';
				if (panel === 'system') successMessage = 'Sistema actualizado correctamente.';

				this.showFeedback(panel, this.readApiMessage(data, successMessage), 'success');
				this.reloadAfterWorkspaceSave();
			} catch (error) {
				let errorMessage = 'No fue posible guardar la configuración.';
				if (panel === 'workspace') errorMessage = 'No fue posible guardar negocio.';
				if (panel === 'branding') errorMessage = 'No fue posible guardar personalización.';
				if (panel === 'system') errorMessage = 'No fue posible guardar sistema.';

				this.showFeedback(panel, error instanceof Error ? error.message : errorMessage, 'error');
			}
		}

		private handleWorkspaceSubmit = async (event: SubmitEvent) => {
			event.preventDefault();
			await this.saveWorkspaceSettings('workspace');
		};

		private handleSystemSubmit = async (event: SubmitEvent) => {
			event.preventDefault();
			this.clearFeedback();

			const validation = this.validateSystemFormPayload();
			if (!validation.ok || !validation.payload) {
				this.showFeedback('system', validation.message || 'Revisa la configuración del sistema.', 'error');
				return;
			}

			await this.saveWorkspaceSettings('system', validation.payload);
		};
	}

	if (!customElements.get('settings-manager')) {
		customElements.define('settings-manager', SettingsManager);
	}
</script>

