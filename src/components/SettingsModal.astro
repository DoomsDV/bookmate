---
import { ROLES } from '../config/roles';

interface Props {
	roleId?: number;
}

const { roleId = 0 } = Astro.props;
const isAdmin = Number(roleId) === ROLES.ADMIN;
const rawPublicProfileDomain = String(
	import.meta.env.PUBLIC_BOOKMATE_PUBLIC_DOMAIN ?? Astro.url.origin
).trim();
const publicProfileDomain =
	rawPublicProfileDomain.replace(/^https?:\/\//i, '').replace(/\/+$/, '') || Astro.url.host;
---

<settings-manager data-role-id={String(roleId)} data-public-profile-domain={publicProfileDomain}>
<dialog
	data-settings-modal
		class="m-0 mt-auto mb-0 max-h-[92dvh] w-screen max-w-none sm:m-auto sm:w-[min(54rem,calc(100vw-2rem))] sm:max-w-[min(54rem,calc(100vw-2rem))] open:flex open:flex-col sm:max-h-[90vh] overflow-hidden rounded-t-[1.8rem] rounded-b-none sm:rounded-[1.8rem] border border-(--shell-border) bg-(--surface-bright) p-0 text-(--on-surface) shadow-[0_24px_80px_rgba(0,0,0,0.2)]"
>
	<div class="shrink-0 z-10 shadow-sm border-b border-(--shell-border) bg-(--surface-bright) px-4 py-3 sm:px-7 sm:py-6">
		<div class="flex items-start justify-between gap-4">
			<div class="flex items-center gap-4">
				<div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-(--primary-soft) text-(--primary)">
					<span class="material-symbols-rounded text-[1.4rem]">settings</span>
				</div>
				<div>
					<h2 class="text-[1.2rem] font-extrabold tracking-tight text-(--on-surface)">Ajustes</h2>
					<p class="text-[0.9rem] font-medium text-(--on-surface-variant) mt-0.5 hidden sm:block">Perfil y preferencias de la cuenta.</p>
				</div>
			</div>
			<button type="button" class="flex size-9 shrink-0 items-center justify-center rounded-full text-(--on-surface-variant) transition-colors hover:bg-(--surface-variant) hover:text-(--on-surface) focus:outline-none focus:ring-2 focus:ring-(--primary)" data-settings-close aria-label="Cerrar modal">
				<span class="material-symbols-rounded text-[1.3rem]">close</span>
			</button>
		</div>
	</div>

	<div class="settings-layout flex min-h-0 flex-1 flex-col overflow-hidden bg-(--surface)/30 shadow-[inset_0_4px_10px_rgba(0,0,0,0.015)]">
		<nav class="settings-nav shrink-0 border-b border-(--shell-border) bg-(--surface-bright)/50 px-0 py-3">
			<div class="settings-tabs-grid">
				<button type="button" data-settings-tab-trigger data-settings-tab="profile" class="settings-tab is-active">
					<span class="material-symbols-rounded">person</span>Mi perfil
				</button>
				<button type="button" data-settings-tab-trigger data-settings-tab="security" class="settings-tab">
					<span class="material-symbols-rounded">lock</span>Seguridad
				</button>
				<button type="button" data-settings-tab-trigger data-settings-tab="preferences" class="settings-tab">
					<span class="material-symbols-rounded">palette</span>Apariencia
				</button>
				{
					isAdmin ? (
						<>
							<button type="button" data-settings-tab-trigger data-settings-tab="workspace" class="settings-tab">
								<span class="material-symbols-rounded">storefront</span>Negocio
							</button>
							<button type="button" data-settings-tab-trigger data-settings-tab="system" class="settings-tab">
								<span class="material-symbols-rounded">settings_applications</span>Sistema
							</button>
						</>
					) : null
				}
			</div>
		</nav>

		<div class="settings-content flex-1 min-h-0 overflow-y-auto p-4 sm:p-6 overscroll-contain">
			<section data-settings-panel="profile" class="grid gap-6">
				<p data-settings-feedback="profile" class="hidden settings-feedback"></p>
				<form data-settings-profile-form class="grid gap-8">
					<div class="grid gap-5">
						<div class="grid gap-1">
							<h3 class="text-[1.05rem] font-bold text-(--on-surface)">Información personal</h3>
							<p class="text-[0.9rem] font-medium text-(--on-surface-variant)">Solo para tu cuenta y acceso interno.</p>
						</div>
						<div class="grid gap-5 sm:grid-cols-2">
							<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">Nombre<input name="first_name" required class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10" /></label>
							<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">Apellido<input name="last_name" required class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10" /></label>
						</div>
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">Correo electrónico<input name="email" readonly class="rounded-xl border border-(--shell-border) bg-(--control-surface) px-4 py-3 text-[0.95rem] outline-none text-(--on-surface-variant) cursor-not-allowed" /></label>
					</div>

					<div data-settings-prof-fields class="settings-prof-section hidden gap-5 border-t border-(--shell-border) border-dashed pt-6">
						<div class="grid gap-1">
							<h3 class="text-[1.05rem] font-bold text-(--on-surface)">Avatar público</h3>
							<p class="text-[0.9rem] font-medium text-(--on-surface-variant)">Se mostrará en tu perfil público.</p>
						</div>
						<div class="flex flex-col items-start gap-4 sm:flex-row sm:items-center">
							<img data-settings-profile-preview class="hidden h-24 w-24 rounded-[1.25rem] border border-(--shell-border) object-cover shadow-sm bg-(--surface-bright)" alt="Foto de perfil" />
							<div class="grid gap-2">
								<input id="settings-profile-image-input" type="file" name="profile_image" accept="image/*" class="sr-only" />
								<label for="settings-profile-image-input" class="inline-flex cursor-pointer items-center justify-center rounded-2xl border border-(--shell-border) bg-(--surface-bright) px-5 py-2.5 text-[0.95rem] font-extrabold text-(--on-surface) transition hover:bg-(--surface-variant) shadow-sm focus-within:ring-2 focus-within:ring-(--primary) focus-within:ring-offset-2">
									<span class="material-symbols-rounded mr-2 text-[1.2rem]">photo_camera</span>
									Cambiar foto
								</label>
								<p class="text-[0.85rem] font-medium text-(--on-surface-variant)">JPG o PNG. Se mostrará en tu perfil público.</p>
							</div>
						</div>
					</div>

					<div data-settings-prof-fields class="settings-prof-section hidden gap-5 border-t border-(--shell-border) border-dashed pt-6">
						<div class="grid gap-1">
							<h3 class="text-[1.05rem] font-bold text-(--on-surface)">Perfil público</h3>
							<p class="text-[0.9rem] font-medium text-(--on-surface-variant)">Estos datos se muestran a tus clientes en internet.</p>
						</div>
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
							Teléfono público
							<div class="flex rounded-2xl shadow-sm transition-shadow focus-within:ring-4 focus-within:ring-(--primary)/10">
								<span class="inline-flex items-center rounded-l-2xl border border-r-0 border-(--shell-border) bg-(--control-surface) px-4 text-[0.95rem] font-semibold text-(--on-surface-variant)">
									+595
								</span>
								<input
									type="tel"
									name="phone_number"
									inputmode="numeric"
									autocomplete="tel-national"
									maxlength="11"
									placeholder="981 123 456"
									class="min-w-0 flex-1 rounded-none rounded-r-2xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary)"
								/>
							</div>
							<span class="text-[0.85rem] font-medium text-(--on-surface-variant)">Se guardará como número paraguayo con prefijo internacional.</span>
							<span data-settings-profile-field-error="phone_number" class="hidden text-[0.85rem] font-semibold text-rose-600 dark:text-rose-400 mt-1"></span>
						</label>
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
							URL del perfil público <span class="text-(--on-surface-variant) font-medium">(Opcional)</span>
							<div class="flex shadow-sm rounded-2xl transition-shadow focus-within:ring-4 focus-within:ring-(--primary)/10">
								<span data-settings-profile-slug-prefix class="inline-flex items-center rounded-l-2xl border border-r-0 border-(--shell-border) bg-(--control-surface) px-4 text-[0.95rem] font-medium text-(--on-surface-variant)">
									{publicProfileDomain}/p/
								</span>
								<input
									type="text"
									name="profile_slug"
									class="min-w-0 flex-1 rounded-none rounded-r-2xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition focus:border-(--primary)"
									placeholder="maria-lopez"
								/>
							</div>
							<span class="text-[0.85rem] font-medium text-(--on-surface-variant) mt-0.5">
								Este será el enlace directo para que los clientes agenden contigo.
							</span>
							<span data-settings-profile-field-error="profile_slug" class="hidden text-[0.85rem] font-semibold text-rose-600 dark:text-rose-400 mt-1"></span>
						</label>
					</div>

					<div data-settings-profile-note class="hidden rounded-2xl border border-amber-500/20 bg-amber-500/10 px-4 py-3 text-[0.9rem] font-medium text-amber-700 dark:text-amber-400 shadow-sm"></div>
					
					<div class="flex justify-end pt-2">
						<button type="submit" class="btn-primary-soft w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-2xl px-6 py-3 text-[0.95rem] font-extrabold transition shadow-sm hover:shadow-md focus:outline-none focus:ring-2 focus:ring-(--primary) focus:ring-offset-2 focus:ring-offset-(--surface-bright)">
							<span class="material-symbols-rounded text-[1.2rem] hidden sm:inline">save</span>
							Guardar perfil
						</button>
					</div>
				</form>
			</section>

			<section data-settings-panel="security" class="settings-panel hidden gap-6">
				<p data-settings-feedback="security" class="hidden settings-feedback"></p>
				<form data-settings-security-form class="grid gap-8">
					<div class="grid gap-5">
						<div class="grid gap-1">
							<h3 class="text-[1.05rem] font-bold text-(--on-surface)">Cambio de contraseña</h3>
							<p class="text-[0.9rem] font-medium text-(--on-surface-variant)">Asegúrate de usar una contraseña fuerte y segura.</p>
						</div>
					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						Contraseña actual
						<input
							type="password"
							name="current_password"
							autocomplete="current-password"
							required
							class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
						/>
					</label>
					<div class="grid gap-5 sm:grid-cols-2">
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						Nueva contraseña
						<input
							type="password"
							name="new_password"
							autocomplete="new-password"
							required
							minlength="8"
							class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
						/>
					</label>
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						Confirmar nueva contraseña
						<input
							type="password"
							name="confirm_password"
							autocomplete="new-password"
							required
							minlength="8"
							class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
						/>
					</label>
					</div>
					<p class="text-[0.85rem] font-medium text-(--on-surface-variant) -mt-2">
						La nueva contraseña debe tener al menos 8 caracteres.
					</p>
					</div>
					<div class="flex justify-end pt-2 border-t border-(--shell-border) border-dashed">
						<button type="submit" class="btn-primary-soft w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-2xl px-6 py-3 text-[0.95rem] font-extrabold transition shadow-sm hover:shadow-md focus:outline-none focus:ring-2 focus:ring-(--primary) focus:ring-offset-2 focus:ring-offset-(--surface-bright)">
							<span class="material-symbols-rounded text-[1.2rem] hidden sm:inline">key</span>
							Actualizar contraseña
						</button>
					</div>
				</form>
			</section>

			<section data-settings-panel="preferences" class="settings-panel hidden gap-8">
				<p data-settings-feedback="preferences" class="hidden settings-feedback"></p>
				<form data-settings-preferences-form class="grid gap-6">
					<div class="grid gap-1">
						<h3 class="text-[1.05rem] font-bold text-(--on-surface)">Tu panel de control</h3>
						<p class="text-[0.9rem] font-medium text-(--on-surface-variant)">Personaliza la apariencia y el comportamiento de tu vista.</p>
					</div>
					<div class="grid gap-5">
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">Tema del panel
							<div class="relative">
								<select name="panel_theme" class="w-full cursor-pointer appearance-none rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] font-semibold outline-none transition hover:border-(--on-surface-variant) focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M7%2010l5%205%205-5%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-position-[calc(100%-12px)_center] bg-no-repeat pr-10">
							<option value="light">Claro</option>
							<option value="dark">Oscuro</option>
						</select>
							</div>
					</label>
					</div>
				</form>

				{
					isAdmin ? (
						<>
							<form data-settings-branding-form class="grid gap-6 border-t border-(--shell-border) border-dashed pt-8">
								<div class="grid gap-1">
									<h3 class="text-[1.05rem] font-bold text-(--on-surface)">Página pública de reservas</h3>
									<p class="text-[0.9rem] font-medium text-(--on-surface-variant)">Personaliza como te ven los clientes.</p>
								</div>
								
								<div class="grid gap-1.5 mt-2">
									<span class="text-[0.95rem] font-bold text-(--on-surface)">Logo negocio</span>
									<div class="flex flex-col items-start gap-4 sm:flex-row sm:items-center mt-1">
										<img data-settings-logo-preview class="hidden h-20 w-20 rounded-2xl border border-(--shell-border) object-contain shadow-sm bg-(--surface-bright) p-2" alt="Vista previa del logo" />
										<div class="grid gap-2">
											<input id="settings-branding-logo-input" type="file" name="logo_file" accept="image/*" class="sr-only" />
											<label for="settings-branding-logo-input" class="inline-flex cursor-pointer items-center justify-center rounded-2xl border border-(--shell-border) bg-(--surface-bright) px-5 py-2.5 text-[0.95rem] font-extrabold text-(--on-surface) transition hover:bg-(--surface-variant) shadow-sm focus-within:ring-2 focus-within:ring-(--primary) focus-within:ring-offset-2">
												<span class="material-symbols-rounded mr-2 text-[1.2rem]">image</span>
												Subir logo
											</label>
											<p class="text-[0.85rem] font-medium text-(--on-surface-variant)">Se mostrará una vista previa antes de guardar.</p>
										</div>
									</div>
								</div>
							</form>
						</>
					) : null
				}
				<div class="flex justify-end border-t border-(--shell-border) border-dashed pt-2">
					<button type="button" data-settings-appearance-save class="btn-primary-soft w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-2xl px-6 py-3 text-[0.95rem] font-extrabold transition shadow-sm hover:shadow-md focus:outline-none focus:ring-2 focus:ring-(--primary) focus:ring-offset-2 focus:ring-offset-(--surface-bright)">
						<span class="material-symbols-rounded text-[1.2rem] hidden sm:inline">save</span>
						Guardar apariencia
					</button>
				</div>
			</section>

			{
				isAdmin ? (
					<>
						<section data-settings-panel="workspace" class="settings-panel hidden gap-6">
							<p data-settings-feedback="workspace" class="hidden settings-feedback"></p>
							<form data-settings-workspace-form class="grid gap-6">
								<div class="grid gap-1">
									<h3 class="text-[1.05rem] font-bold text-(--on-surface)">Información del negocio</h3>
									<p class="text-[0.9rem] font-medium text-(--on-surface-variant)">Detalles principales de tu organización.</p>
								</div>
								<div class="grid gap-5">
									<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">Nombre del negocio<input name="name" required class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10" /></label>
								</div>
								<input type="hidden" name="profile_slug" />
								<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">Descripción<textarea name="description" rows="4" class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 resize-y"></textarea></label>
								<div class="flex justify-end pt-4 border-t border-(--shell-border) border-dashed">
									<button type="submit" class="btn-primary-soft w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-2xl px-6 py-3 text-[0.95rem] font-extrabold transition shadow-sm hover:shadow-md focus:outline-none focus:ring-2 focus:ring-(--primary) focus:ring-offset-2 focus:ring-offset-(--surface-bright)"><span class="material-symbols-rounded text-[1.2rem] hidden sm:inline">store</span>Guardar negocio</button>
								</div>
							</form>
						</section>

						<section data-settings-panel="system" class="settings-panel hidden gap-6">
							<p data-settings-feedback="system" class="hidden settings-feedback"></p>
							<form data-settings-system-form class="grid gap-6">
								<div class="grid gap-1">
									<h3 class="text-[1.05rem] font-bold text-(--on-surface)">Configuración del sistema</h3>
									<p class="text-[0.9rem] font-medium text-(--on-surface-variant)">Ajustes regionales y de tiempo.</p>
								</div>
								<div class="grid gap-5">
									<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">Formato de hora
										<div class="relative">
											<select name="time_format" class="w-full cursor-pointer appearance-none rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] font-semibold outline-none transition hover:border-(--on-surface-variant) focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M7%2010l5%205%205-5%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-position-[calc(100%-12px)_center] bg-no-repeat pr-10">
										<option value="24H">24 horas</option>
										<option value="12H">12 horas</option>
									</select>
										</div>
								</label>
								</div>
								
								<div class="grid gap-5">
									<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">Alertas de citas no respondidas
										<div class="relative">
											<select name="unanswered_alert_action" class="w-full cursor-pointer appearance-none rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] font-semibold outline-none transition hover:border-(--on-surface-variant) focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M7%2010l5%205%205-5%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-position-[calc(100%-12px)_center] bg-no-repeat pr-10">
												<option value="KEEP">Mantener la cita (Ignorar)</option>
												<option value="CANCEL">Cancelar la cita automáticamente</option>
											</select>
										</div>
										<span class="text-[0.85rem] font-medium text-(--on-surface-variant) mt-0.5">Acción a tomar cuando un cliente no responde al recordatorio.</span>
									</label>
								</div>

								<div class="flex justify-end pt-4 border-t border-(--shell-border) border-dashed">
									<button type="submit" class="btn-primary-soft w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-2xl px-6 py-3 text-[0.95rem] font-extrabold transition shadow-sm hover:shadow-md focus:outline-none focus:ring-2 focus:ring-(--primary) focus:ring-offset-2 focus:ring-offset-(--surface-bright)">
										<span class="material-symbols-rounded text-[1.2rem] hidden sm:inline">settings</span>
										Guardar sistema
									</button>
								</div>
							</form>
						</section>
					</>
				) : null
			}
		</div>
	</div>
</dialog>
</settings-manager>

<script>
	import {
		PARAGUAY_MOBILE_PHONE_ERROR,
		parseParaguayMobilePhone,
	} from '../lib/paraguay-phone';

	interface ApiErrorDetail {
		field?: string;
		message?: string;
	}

	interface ApiResponse<T = unknown> {
		status?: string;
		message?: string;
		data?: T;
		errors?: ApiErrorDetail[];
		details?: unknown;
		slug?: string;
	}

	class SettingsApiError extends Error {
		status: number;
		errors: ApiErrorDetail[];
		details: unknown;

		constructor(message: string, status = 400, errors: ApiErrorDetail[] = [], details: unknown = null) {
			super(message);
			this.name = 'SettingsApiError';
			this.status = status;
			this.errors = errors;
			this.details = details;
		}
	}

	class SettingsManager extends HTMLElement {
		private abortController: AbortController | null = null;
		private isAdmin = false;
		private publicProfileDomain = '';

		private els!: {
			modal: HTMLDialogElement | null;
			closeBtn: HTMLButtonElement | null;
			appearanceSaveBtn: HTMLButtonElement | null;
			tabButtons: NodeListOf<HTMLElement>;
			panels: NodeListOf<HTMLElement>;
			profileForm: HTMLFormElement | null;
			securityForm: HTMLFormElement | null;
			preferencesForm: HTMLFormElement | null;
			workspaceForm: HTMLFormElement | null;
			brandingForm: HTMLFormElement | null;
			systemForm: HTMLFormElement | null;
			profilePreview: HTMLImageElement | null;
			logoPreview: HTMLImageElement | null;
			profFields: NodeListOf<HTMLElement>;
			profileNote: HTMLElement | null;
		};

		private formEls!: {
			firstNameInput: HTMLInputElement | null;
			lastNameInput: HTMLInputElement | null;
			phoneInput: HTMLInputElement | null;
			profileSlugInput: HTMLInputElement | null;
			profileSlugPrefix: HTMLElement | null;
			phoneError: HTMLElement | null;
			profileSlugError: HTMLElement | null;
			profileImageInput: HTMLInputElement | null;
			brandingLogoInput: HTMLInputElement | null;
		};

		private profilePreviewObjectUrl = '';
		private logoPreviewObjectUrl = '';
		private slugSuggestTimer: number | null = null;
		private slugRequestSeq = 0;
		private slugManuallyEdited = false;
		private suppressSlugManualTracking = false;
		private closingTimer: number | null = null;
		private feedbackHideTimer: number | null = null;

		connectedCallback() {
			const roleId = Number(this.dataset.roleId || '0');
			this.isAdmin = roleId === 1;
			this.publicProfileDomain = String(this.dataset.publicProfileDomain || '');

			this.els = {
				modal: this.querySelector<HTMLDialogElement>('[data-settings-modal]'),
				closeBtn: this.querySelector<HTMLButtonElement>('[data-settings-close]'),
				appearanceSaveBtn: this.querySelector<HTMLButtonElement>('[data-settings-appearance-save]'),
				tabButtons: this.querySelectorAll<HTMLElement>('[data-settings-tab-trigger]'),
				panels: this.querySelectorAll<HTMLElement>('[data-settings-panel]'),
				profileForm: this.querySelector<HTMLFormElement>('[data-settings-profile-form]'),
				securityForm: this.querySelector<HTMLFormElement>('[data-settings-security-form]'),
				preferencesForm: this.querySelector<HTMLFormElement>('[data-settings-preferences-form]'),
				workspaceForm: this.querySelector<HTMLFormElement>('[data-settings-workspace-form]'),
				brandingForm: this.querySelector<HTMLFormElement>('[data-settings-branding-form]'),
				systemForm: this.querySelector<HTMLFormElement>('[data-settings-system-form]'),
				profilePreview: this.querySelector<HTMLImageElement>('[data-settings-profile-preview]'),
				logoPreview: this.querySelector<HTMLImageElement>('[data-settings-logo-preview]'),
				profFields: this.querySelectorAll<HTMLElement>('[data-settings-prof-fields]'),
				profileNote: this.querySelector<HTMLElement>('[data-settings-profile-note]'),
			};

			this.formEls = {
				firstNameInput: this.els.profileForm?.querySelector<HTMLInputElement>('[name="first_name"]') ?? null,
				lastNameInput: this.els.profileForm?.querySelector<HTMLInputElement>('[name="last_name"]') ?? null,
				phoneInput: this.els.profileForm?.querySelector<HTMLInputElement>('[name="phone_number"]') ?? null,
				profileSlugInput: this.els.profileForm?.querySelector<HTMLInputElement>('[name="profile_slug"]') ?? null,
				profileSlugPrefix: this.els.profileForm?.querySelector<HTMLElement>('[data-settings-profile-slug-prefix]') ?? null,
				phoneError: this.els.profileForm?.querySelector<HTMLElement>('[data-settings-profile-field-error="phone_number"]') ?? null,
				profileSlugError: this.els.profileForm?.querySelector<HTMLElement>('[data-settings-profile-field-error="profile_slug"]') ?? null,
				profileImageInput: this.els.profileForm?.querySelector<HTMLInputElement>('[name="profile_image"]') ?? null,
				brandingLogoInput: this.els.brandingForm?.querySelector<HTMLInputElement>('[name="logo_file"]') ?? null,
			};

			if (!this.abortController) {
				this.abortController = new AbortController();
			}
			const { signal } = this.abortController;

			document.addEventListener('click', this.handleDocumentClick, { signal });
			this.els.closeBtn?.addEventListener('click', this.closeModal, { signal });
			this.els.modal?.addEventListener('click', this.handleBackdropClick, { signal });
			
			this.els.tabButtons.forEach(btn => 
				btn.addEventListener('click', () => this.setActiveTab(btn.dataset.settingsTab || 'profile'), { signal })
			);

			this.formEls.profileSlugInput?.addEventListener('input', this.handleSlugInput, { signal });
			this.formEls.firstNameInput?.addEventListener('input', this.queueSlugSuggestion, { signal });
			this.formEls.lastNameInput?.addEventListener('input', this.queueSlugSuggestion, { signal });
			this.formEls.phoneInput?.addEventListener('input', this.handlePhoneInput, { signal });
			this.formEls.profileImageInput?.addEventListener('change', this.handleProfileImageChange, { signal });
			this.formEls.brandingLogoInput?.addEventListener('change', this.handleLogoImageChange, { signal });

			this.els.profileForm?.addEventListener('submit', this.handleProfileSubmit, { signal });
			this.els.securityForm?.addEventListener('submit', this.handleSecuritySubmit, { signal });
			this.els.appearanceSaveBtn?.addEventListener('click', this.handleAppearanceSave, { signal });
			this.els.workspaceForm?.addEventListener('submit', this.handleWorkspaceSubmit, { signal });
			this.els.systemForm?.addEventListener('submit', this.handleSystemSubmit, { signal });
		}

		disconnectedCallback() {
			this.abortController?.abort();
			this.abortController = null;
			this.clearSlugSuggestTimer();
			this.releaseProfilePreviewObjectUrl();
			this.releaseLogoPreviewObjectUrl();
			if (this.closingTimer) window.clearTimeout(this.closingTimer);
			if (this.feedbackHideTimer) window.clearTimeout(this.feedbackHideTimer);
		}

		private handleDocumentClick = (event: MouseEvent) => {
			const target = event.target;
			if (!(target instanceof Element)) return;

			const openBtn = target.closest('[data-open-settings-modal]');
			if (openBtn) {
				event.preventDefault();
				openBtn.closest('details')?.removeAttribute('open');
				this.openModal();
			}
		};

		private openModal = () => {
			this.setActiveTab('profile');
			this.clearFeedback();
			this.resetSecurityForm();
			this.els.modal?.classList.remove('is-closing');
			this.els.modal?.removeAttribute('data-bottom-sheet-swipe-dismiss');
			if (this.closingTimer) {
				window.clearTimeout(this.closingTimer);
				this.closingTimer = null;
			}
			if (this.els.modal && !this.els.modal.open) this.els.modal.showModal();
			void this.loadData();
		};

		private handleBackdropClick = (event: MouseEvent) => {
			if (event.target instanceof HTMLDialogElement) {
				this.closeModal();
			}
		};

		private closeModal = () => {
			if (!this.els.modal?.open) return;
			const swipeDismiss =
				this.els.modal.hasAttribute('data-bottom-sheet-swipe-dismiss');
			const closeDelay = swipeDismiss ? 0 : 160;
			this.els.modal.classList.add('is-closing');
			this.closingTimer = window.setTimeout(() => {
				this.els.modal?.close();
				this.els.modal?.classList.remove('is-closing');
				this.els.modal?.removeAttribute('data-bottom-sheet-swipe-dismiss');
				this.resetSecurityForm();
				this.releaseProfilePreviewObjectUrl();
				this.releaseLogoPreviewObjectUrl();
				this.clearSlugSuggestTimer();
				this.slugRequestSeq += 1;
				this.closingTimer = null;
			}, closeDelay);
		};

		private readApiMessage(data: ApiResponse | null, fallback: string): string {
			return typeof data?.message === 'string' && data.message.trim() ? data.message.trim() : fallback;
		}

		private normalizeSecurityMessage(message: string, kind: 'success' | 'error') {
			const raw = String(message || '').trim();
			if (!raw) {
				return kind === 'success'
					? 'Tu contraseña se actualizó correctamente.'
					: 'No pudimos actualizar tu contraseña. Intenta nuevamente.';
			}

			const normalized = raw
				.normalize('NFD')
				.replace(/[\u0300-\u036f]/g, '')
				.toLowerCase();

			if (kind === 'success') {
				if (normalized.includes('contrasena actualizada correctamente')) {
					return 'Tu contraseña se actualizó correctamente.';
				}
				return raw;
			}

			if (normalized.includes('debes completar') || normalized.includes('contrasena actual y la nueva')) {
				return 'Ingresa tu contraseña actual y la nueva contraseña.';
			}
			if (normalized.includes('no fue posible actualizar la contrasena')) {
				return 'No pudimos actualizar tu contraseña. Intenta nuevamente.';
			}

			return raw;
		}

		private async fileToBase64(file: File): Promise<string> {
			return new Promise((resolve, reject) => {
				const reader = new FileReader();
				reader.onload = () => {
					const result = String(reader.result || '');
					resolve(result.includes(',') ? result.split(',')[1] : result);
				};
				reader.onerror = () => reject(new Error('No fue posible leer el archivo.'));
				reader.readAsDataURL(file);
			});
		}

		private releaseProfilePreviewObjectUrl() {
			if (!this.profilePreviewObjectUrl) return;
			URL.revokeObjectURL(this.profilePreviewObjectUrl);
			this.profilePreviewObjectUrl = '';
		}

		private releaseLogoPreviewObjectUrl() {
			if (!this.logoPreviewObjectUrl) return;
			URL.revokeObjectURL(this.logoPreviewObjectUrl);
			this.logoPreviewObjectUrl = '';
		}

		private clearSlugSuggestTimer() {
			if (!this.slugSuggestTimer) return;
			window.clearTimeout(this.slugSuggestTimer);
			this.slugSuggestTimer = null;
		}

		private getPublicProfilePrefix() {
			const configuredDomain = String(this.publicProfileDomain || '')
				.replace(/^https?:\/\//i, '')
				.replace(/\/+$/, '')
				.trim();
			if (configuredDomain) return `${configuredDomain}/p/`;
			const origin = String(window.location?.origin || '').replace(/\/$/, '');
			return `${origin}/p/`;
		}

		private getSlugSourceName() {
			return `${String(this.formEls.firstNameInput?.value || '').trim()} ${String(this.formEls.lastNameInput?.value || '').trim()}`.trim();
		}

		private setSuggestedSlug(slug: string) {
			if (!this.formEls.profileSlugInput) return;
			this.suppressSlugManualTracking = true;
			this.formEls.profileSlugInput.value = slug;
			this.suppressSlugManualTracking = false;
		}

		private toParaguayPhoneLocalDigits(rawValue: string) {
			const parsedPhone = parseParaguayMobilePhone(rawValue);
			if (parsedPhone.isValid) return parsedPhone.e164.slice(4);

			let digits = String(rawValue || '').replace(/\D/g, '');
			if (digits.startsWith('00595')) digits = digits.slice(5);
			if (digits.startsWith('595')) digits = digits.slice(3);
			if (digits.startsWith('0')) digits = digits.slice(1);
			return digits.slice(0, 9);
		}

		private formatParaguayPhoneLocal(rawValue: string) {
			const digits = this.toParaguayPhoneLocalDigits(rawValue);
			if (!digits) return '';
			if (digits.length <= 3) return digits;
			if (digits.length <= 6) return `${digits.slice(0, 3)} ${digits.slice(3)}`;
			return `${digits.slice(0, 3)} ${digits.slice(3, 6)} ${digits.slice(6, 9)}`;
		}

		private setPhoneFieldError(message: string) {
			if (!this.formEls.phoneError) return;
			this.formEls.phoneError.textContent = message;
			this.formEls.phoneError.classList.remove('hidden');
		}

		private clearProfileFieldErrors() {
			if (this.formEls.profileSlugError) {
				this.formEls.profileSlugError.textContent = '';
				this.formEls.profileSlugError.classList.add('hidden');
			}
			if (this.formEls.phoneError) {
				this.formEls.phoneError.textContent = '';
				this.formEls.phoneError.classList.add('hidden');
			}
		}

		private isGenericValidationMessage(message: unknown): boolean {
			const normalized = String(message || '').trim().toLowerCase();
			return (
				normalized === 'errores de validacion.' ||
				normalized === 'errores de validacion' ||
				normalized === 'errores de validacion.' ||
				normalized === 'errores de validacion'
			);
		}

		private renderProfileFieldErrors(errors: unknown, fallbackMessage = ''): boolean {
			let rendered = false;
			const items = Array.isArray(errors) ? errors : [];
			for (const item of items) {
				if (!item || typeof item !== 'object') continue;
				const field = 'field' in item ? String((item as Record<string, unknown>).field || '').trim() : '';
				const message = 'message' in item ? String((item as Record<string, unknown>).message || '').trim() : '';
				if (!field || !message) continue;
				if (field === 'phone_number' && this.formEls.phoneError) {
					this.formEls.phoneError.textContent = message;
					this.formEls.phoneError.classList.remove('hidden');
					rendered = true;
				}
				if (field === 'profile_slug' && this.formEls.profileSlugError) {
					this.formEls.profileSlugError.textContent = message;
					this.formEls.profileSlugError.classList.remove('hidden');
					rendered = true;
				}
			}
			if (rendered) return true;
			if (typeof fallbackMessage === 'string' && /slug|perfil/i.test(fallbackMessage) && this.formEls.profileSlugError) {
				this.formEls.profileSlugError.textContent = fallbackMessage;
				this.formEls.profileSlugError.classList.remove('hidden');
				return true;
			}
			return false;
		}

		private showFeedback(key: string, message: string, kind: 'success' | 'error' = 'success') {
			const node = this.querySelector(`[data-settings-feedback="${key}"]`);
			if (!node) return;
			if (this.feedbackHideTimer) {
				window.clearTimeout(this.feedbackHideTimer);
				this.feedbackHideTimer = null;
			}
			node.textContent = message;
			node.classList.remove('hidden', 'is-success', 'is-error');
			node.classList.add(kind === 'success' ? 'is-success' : 'is-error');

			// Keep feedback visible even when the user is scrolled down in the panel.
			node.scrollIntoView({ block: 'nearest', behavior: 'smooth' });

			if (kind === 'success') {
				this.feedbackHideTimer = window.setTimeout(() => {
					node.classList.add('hidden');
					node.classList.remove('is-success', 'is-error');
					node.textContent = '';
					this.feedbackHideTimer = null;
				}, 3200);
			}
		}

		private clearFeedback() {
			if (this.feedbackHideTimer) {
				window.clearTimeout(this.feedbackHideTimer);
				this.feedbackHideTimer = null;
			}
			this.querySelectorAll('.settings-feedback').forEach((node) => {
				node.textContent = '';
				node.classList.add('hidden');
				node.classList.remove('is-success', 'is-error');
			});
			this.clearProfileFieldErrors();
		}

		private async requestApi<T = unknown>(url: string, options: RequestInit, fallbackMessage: string): Promise<ApiResponse<T>> {
			const response = await fetch(url, options);
			let data: ApiResponse<T> | null = null;
			try {
				data = await response.json();
			} catch {
				throw new SettingsApiError('No fue posible interpretar la respuesta.', response.status || 502);
			}
			if (!response.ok || !data || data.status !== 'success') {
				throw new SettingsApiError(
					this.readApiMessage(data, fallbackMessage),
					response.status || 400,
					data?.errors,
					data?.details
				);
			}
			return data;
		}

		private handleSlugInput = () => {
			if (this.suppressSlugManualTracking) return;
			const currentValue = String(this.formEls.profileSlugInput?.value || '').trim();
			this.slugManuallyEdited = currentValue !== '';
			this.clearProfileFieldErrors();
			if (!this.slugManuallyEdited) this.queueSlugSuggestion();
		};

		private queueSlugSuggestion = () => {
			if (!this.formEls.profileSlugInput) return;
			const profVisible = !this.els.profFields[0]?.classList.contains('hidden');
			if (!profVisible) return;
			const fullName = this.getSlugSourceName();
			if (!fullName) return;
			if (this.slugManuallyEdited && this.formEls.profileSlugInput.value.trim() !== '') return;
			
			this.clearSlugSuggestTimer();
			const currentRequest = ++this.slugRequestSeq;
			this.slugSuggestTimer = window.setTimeout(async () => {
				try {
					const response = await fetch(
						`/api/professionals/slug/suggest?name=${encodeURIComponent(fullName)}`,
						{ method: 'GET', headers: { Accept: 'application/json' } }
					);
					let data: ApiResponse | null = null;
					try {
						data = await response.json();
					} catch {
						return;
					}
					if (currentRequest !== this.slugRequestSeq) return;
					if (!response.ok || !data || data.status !== 'success' || typeof data.slug !== 'string') return;
					if (this.slugManuallyEdited && this.formEls.profileSlugInput!.value.trim() !== '') return;
					const suggestedSlug = String(data.slug || '').trim();
					if (!suggestedSlug) return;
					this.setSuggestedSlug(suggestedSlug);
				} catch {
					// Ignoramos errores de red
				}
			}, 350);
		};

		private handlePhoneInput = () => {
			if (!this.formEls.phoneInput) return;
			this.formEls.phoneInput.value = this.formatParaguayPhoneLocal(this.formEls.phoneInput.value);
			this.clearProfileFieldErrors();
		};

		private handleProfileImageChange = () => {
			const imageFile = this.formEls.profileImageInput?.files?.[0];
			if (!imageFile || !this.els.profilePreview) return;
			this.releaseProfilePreviewObjectUrl();
			this.profilePreviewObjectUrl = URL.createObjectURL(imageFile);
			this.els.profilePreview.src = this.profilePreviewObjectUrl;
			this.els.profilePreview.classList.remove('hidden');
		};

		private handleLogoImageChange = () => {
			const logoFile = this.formEls.brandingLogoInput?.files?.[0];
			if (!logoFile || !this.els.logoPreview) return;
			this.releaseLogoPreviewObjectUrl();
			this.logoPreviewObjectUrl = URL.createObjectURL(logoFile);
			this.els.logoPreview.src = this.logoPreviewObjectUrl;
			this.els.logoPreview.classList.remove('hidden');
		};

		private setActiveTab(tabId: string) {
			this.els.tabButtons.forEach((btn) => btn.classList.toggle('is-active', btn.dataset.settingsTab === tabId));
			this.els.panels.forEach((panel) => panel.classList.toggle('hidden', panel.dataset.settingsPanel !== tabId));
		}

		private resetSecurityForm() {
			if (!this.els.securityForm) return;
			const current = this.els.securityForm.querySelector<HTMLInputElement>('[name="current_password"]');
			const next = this.els.securityForm.querySelector<HTMLInputElement>('[name="new_password"]');
			const confirm = this.els.securityForm.querySelector<HTMLInputElement>('[name="confirm_password"]');
			if (current) current.value = '';
			if (next) next.value = '';
			if (confirm) confirm.value = '';
		}

		private fillProfile(profile: any) {
			if (!this.els.profileForm) return;
			const email = this.els.profileForm.querySelector<HTMLInputElement>('[name="email"]');
			const phone = this.els.profileForm.querySelector<HTMLInputElement>('[name="phone_number"]');

			if (this.formEls.firstNameInput) this.formEls.firstNameInput.value = profile?.first_name || '';
			if (this.formEls.lastNameInput) this.formEls.lastNameInput.value = profile?.last_name || '';
			if (email) email.value = profile?.email || '';
			if (this.formEls.profileImageInput) this.formEls.profileImageInput.value = '';
			if (this.formEls.profileSlugPrefix) this.formEls.profileSlugPrefix.textContent = this.getPublicProfilePrefix();
			
			this.clearSlugSuggestTimer();
			this.slugRequestSeq += 1;
			this.slugManuallyEdited = false;
			this.releaseProfilePreviewObjectUrl();

			const prof = profile?.professional_profile;
			if (prof) {
				this.els.profFields.forEach((el) => el.classList.remove('hidden'));
				if (phone) phone.value = this.formatParaguayPhoneLocal(prof.phone_number || '');
				if (this.formEls.profileSlugInput) {
					this.setSuggestedSlug(String(prof.profile_slug || '').trim());
					if (this.formEls.profileSlugInput.value.trim() === '') this.queueSlugSuggestion();
				}
				if (this.els.profilePreview && prof.image_url) {
					this.els.profilePreview.src = prof.image_url;
					this.els.profilePreview.classList.remove('hidden');
				} else {
					this.els.profilePreview?.classList.add('hidden');
				}
				if (this.els.profileNote) {
					this.els.profileNote.classList.add('hidden');
					this.els.profileNote.textContent = '';
				}
			} else {
				this.els.profFields.forEach((el) => el.classList.add('hidden'));
				if (phone) phone.value = '';
				if (this.formEls.profileSlugInput) this.setSuggestedSlug('');
				this.els.profilePreview?.classList.add('hidden');
				if (this.els.profileNote) {
					this.els.profileNote.textContent = 'Esta cuenta no tiene perfil profesional público. Solo se guarda nombre y apellido.';
					this.els.profileNote.classList.remove('hidden');
				}
			}
		}

		private fillWorkspace(workspace: any) {
			const setValue = (selector: string, value: string) => {
				const input = this.querySelector<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(selector);
				if (input) input.value = value || '';
			};
			
			setValue('[data-settings-workspace-form] [name="name"]', workspace?.name);
			setValue('[data-settings-workspace-form] [name="profile_slug"]', workspace?.profile_slug);
			setValue('[data-settings-workspace-form] [name="description"]', workspace?.description);
			const workspaceTimeFormat = String(workspace?.time_format || '').trim().toLowerCase();
			setValue('[data-settings-system-form] [name="time_format"]', workspaceTimeFormat === '12h' ? '12H' : '24H');
			
			// Aquí está la línea ya corregida apuntando al formulario correcto de sistema.
			setValue('[data-settings-system-form] [name="unanswered_alert_action"]', workspace?.unanswered_alert_action === 'CANCEL' ? 'CANCEL' : 'KEEP');
			
			this.releaseLogoPreviewObjectUrl();

			if (this.els.logoPreview && workspace?.logo_url) {
				this.els.logoPreview.src = workspace.logo_url;
				this.els.logoPreview.classList.remove('hidden');
			} else {
				this.els.logoPreview?.classList.add('hidden');
			}
			const logoFile = this.formEls.brandingLogoInput;
			if (logoFile) logoFile.value = '';
		}

		private getPanelAppearanceValues(): { theme: 'light' | 'dark' } {
			const theme: 'light' | 'dark' =
				this.els.preferencesForm?.querySelector<HTMLSelectElement>('[name="panel_theme"]')?.value === 'dark'
					? 'dark'
					: 'light';
			return { theme };
		}

		private persistPanelAppearance(theme: string) {
			const safeTheme = theme === 'dark' ? 'dark' : 'light';
			document.documentElement.dataset.theme = safeTheme;
			localStorage.setItem('bookmate-theme', safeTheme);
		}

		private getFormPayload(form: HTMLFormElement | null): Record<string, string> {
			const payload: Record<string, string> = {};
			if (!form) return payload;

			const formData = new FormData(form);
			for (const [key, value] of formData.entries()) {
				if (typeof value === 'string') {
					payload[key] = value.trim();
				}
			}

			return payload;
		}

		private getAppearancePayload(): Record<string, string> {
			const payload = this.getFormPayload(this.els.preferencesForm);
			if (this.els.brandingForm) {
				Object.assign(payload, this.getFormPayload(this.els.brandingForm));
			}
			return payload;
		}


		private getWorkspacePayload(): Record<string, string> {
			const payload: Record<string, string> = {};
			const forms = [this.els.workspaceForm, this.els.systemForm, this.els.brandingForm];

			for (const form of forms) {
				Object.assign(payload, this.getFormPayload(form));
			}
			return payload;
		}

		private async loadData() {
			try {
				const profileRes = await this.requestApi('/api/profile/me', { method: 'GET', headers: { Accept: 'application/json' } }, 'No fue posible cargar perfil.');
				this.fillProfile(profileRes.data || {});

				if (this.els.preferencesForm) {
					const panelTheme = this.els.preferencesForm.querySelector<HTMLSelectElement>('[name="panel_theme"]');
					if (panelTheme) {
						const storedTheme = localStorage.getItem('bookmate-theme');
						panelTheme.value = storedTheme === 'dark' || storedTheme === 'light' ? storedTheme : 'dark';
					}
				}

				if (this.isAdmin) {
					const workspaceRes = await this.requestApi('/api/workspace', { method: 'GET', headers: { Accept: 'application/json' } }, 'No fue posible cargar negocio.');
					this.fillWorkspace(workspaceRes.data || null);
				}
			} catch (error) {
				this.showFeedback('profile', error instanceof Error ? error.message : 'No fue posible cargar ajustes.', 'error');
			}
		}

		private handleProfileSubmit = async (event: SubmitEvent) => {
			event.preventDefault();
			this.clearFeedback();
			if (!this.els.profileForm) return;

			const first = String(this.els.profileForm.querySelector<HTMLInputElement>('[name="first_name"]')?.value || '').trim();
			const last = String(this.els.profileForm.querySelector<HTMLInputElement>('[name="last_name"]')?.value || '').trim();
			if (!first || !last) {
				this.showFeedback('profile', 'Nombre y apellido son obligatorios.', 'error');
				return;
			}

			const payload: Record<string, string | number> = { first_name: first, last_name: last };
			const profVisible = !this.els.profFields[0]?.classList.contains('hidden');
			
			if (profVisible) {
				const rawPhone = String(this.formEls.phoneInput?.value || '').trim();
				if (rawPhone !== '') {
					const parsedPhone = parseParaguayMobilePhone(rawPhone);
					if (!parsedPhone.isValid) {
						this.setPhoneFieldError(PARAGUAY_MOBILE_PHONE_ERROR);
						return;
					}
					payload.phone_number = parsedPhone.e164;
				} else {
					payload.phone_number = '';
				}
				const profileSlug = String(this.formEls.profileSlugInput?.value || '').trim();
				if (profileSlug) payload.profile_slug = profileSlug;

				const imageFile = this.els.profileForm.querySelector<HTMLInputElement>('[name="profile_image"]')?.files?.[0];
				if (imageFile) {
					payload.image_base64 = await this.fileToBase64(imageFile);
					payload.image_name = imageFile.name;
					payload.image_mime = imageFile.type || 'application/octet-stream';
				}
			}

			try {
				const data = await this.requestApi('/api/profile/me', {
					method: 'PUT',
					headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
					body: JSON.stringify(payload),
				}, 'No fue posible guardar perfil.');
				this.showFeedback('profile', this.readApiMessage(data, 'Perfil actualizado correctamente.'), 'success');
				await this.loadData();
			} catch (error) {
				const message = error instanceof Error ? error.message : 'No fue posible guardar perfil.';
				const hasFieldErrors = this.renderProfileFieldErrors(
					error instanceof SettingsApiError ? error.errors : [],
					message
				);
				if (!hasFieldErrors || !this.isGenericValidationMessage(message)) {
					this.showFeedback('profile', message, 'error');
				}
			}
		};

		private handleSecuritySubmit = async (event: SubmitEvent) => {
			event.preventDefault();
			this.clearFeedback();
			if (!this.els.securityForm) return;

			const currentPassword = String(this.els.securityForm.querySelector<HTMLInputElement>('[name="current_password"]')?.value || '').trim();
			const newPassword = String(this.els.securityForm.querySelector<HTMLInputElement>('[name="new_password"]')?.value || '').trim();
			const confirmPassword = String(this.els.securityForm.querySelector<HTMLInputElement>('[name="confirm_password"]')?.value || '').trim();

			if (!currentPassword || !newPassword || !confirmPassword) {
				this.showFeedback('security', 'Ingresa la contraseña actual, la nueva y su confirmación.', 'error');
				return;
			}

			if (newPassword.length < 8) {
				this.showFeedback('security', 'La nueva contraseña debe tener al menos 8 caracteres.', 'error');
				return;
			}

			if (newPassword !== confirmPassword) {
				this.showFeedback('security', 'La confirmación no coincide. Verifica ambos campos.', 'error');
				return;
			}

			if (newPassword === currentPassword) {
				this.showFeedback('security', 'La nueva contraseña no puede ser igual a la actual.', 'error');
				return;
			}

			try {
				const data = await this.requestApi(
					'/api/profile/change-password',
					{
						method: 'PUT',
						headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
						body: JSON.stringify({ current_password: currentPassword, new_password: newPassword }),
					},
					'No pudimos actualizar tu contraseña. Intenta nuevamente.'
				);
				this.showFeedback(
					'security',
					this.normalizeSecurityMessage(
						this.readApiMessage(data, 'Tu contraseña se actualizó correctamente.'),
						'success'
					),
					'success'
				);
				this.resetSecurityForm();
			} catch (error) {
				this.showFeedback(
					'security',
					this.normalizeSecurityMessage(
						error instanceof Error
							? error.message
							: 'No pudimos actualizar tu contraseña. Intenta nuevamente.',
						'error'
					),
					'error'
				);
			}
		};

		private handleAppearanceSave = async (event: Event) => {
			event.preventDefault();
			this.clearFeedback();
			if (!this.els.preferencesForm) return;

			const { theme } = this.getPanelAppearanceValues();

			if (!this.isAdmin) {
				this.persistPanelAppearance(theme);
				this.showFeedback('preferences', 'Apariencia guardada correctamente.', 'success');
				return;
			}

			const payload = this.getAppearancePayload();
			payload.panel_theme = theme;
			if (!payload.theme_pref) {
				payload.theme_pref = theme;
			}

			if (this.els.brandingForm) {
				const logoFile = this.els.brandingForm.querySelector<HTMLInputElement>('[name="logo_file"]')?.files?.[0];
				if (logoFile) {
					payload.logo_base64 = await this.fileToBase64(logoFile);
					payload.logo_name = logoFile.name;
					payload.logo_mime = logoFile.type || 'application/octet-stream';
				}
			}

			try {
				const data = await this.requestApi(
					'/api/workspace',
					{
						method: 'PUT',
						headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
						body: JSON.stringify(payload),
					},
					'No fue posible guardar la apariencia.'
				);

				this.persistPanelAppearance(theme);
				this.showFeedback('preferences', this.readApiMessage(data, 'Apariencia guardada correctamente.'), 'success');
				await this.loadData();
			} catch (error) {
				this.showFeedback('preferences', error instanceof Error ? error.message : 'No fue posible guardar la apariencia.', 'error');
			}
		};

		private async saveWorkspaceSettings(panel: string, extraPayload: Record<string, string> = {}) {
			this.clearFeedback();
			try {
				const payload = { ...this.getWorkspacePayload(), ...extraPayload };
				const data = await this.requestApi('/api/workspace', {
					method: 'PUT',
					headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
					body: JSON.stringify(payload),
				}, 'No fue posible guardar la configuración.');

				let successMessage = 'Configuración guardada correctamente.';
				if (panel === 'workspace') successMessage = 'Negocio actualizado correctamente.';
				if (panel === 'branding') successMessage = 'Personalización guardada correctamente.';
				if (panel === 'system') successMessage = 'Sistema actualizado correctamente.';

				this.showFeedback(panel, this.readApiMessage(data, successMessage), 'success');
				await this.loadData();
			} catch (error) {
				let errorMessage = 'No fue posible guardar la configuración.';
				if (panel === 'workspace') errorMessage = 'No fue posible guardar negocio.';
				if (panel === 'branding') errorMessage = 'No fue posible guardar personalización.';
				if (panel === 'system') errorMessage = 'No fue posible guardar sistema.';

				this.showFeedback(panel, error instanceof Error ? error.message : errorMessage, 'error');
			}
		}

		private handleWorkspaceSubmit = async (event: SubmitEvent) => {
			event.preventDefault();
			await this.saveWorkspaceSettings('workspace');
		};

		private handleSystemSubmit = async (event: SubmitEvent) => {
			event.preventDefault();
			
			const extraPayload: Record<string, string> = {};
			
			// Extraemos y aseguramos explícitamente el campo para el JSON.
			const actionSelect = this.els.systemForm?.querySelector<HTMLSelectElement>('[name="unanswered_alert_action"]');
			if (actionSelect) {
				extraPayload.unanswered_alert_action = actionSelect.value;
			}
			
			await this.saveWorkspaceSettings('system', extraPayload);
		};
	}

	if (!customElements.get('settings-manager')) {
		customElements.define('settings-manager', SettingsManager);
	}
</script>

