---
import { FEATURE_FLAGS } from '../config/feature-flags';
import { ROLES } from '../config/roles';

interface Props {
	roleId?: number;
}

const { roleId = 0 } = Astro.props;
const isAdmin = Number(roleId) === ROLES.ADMIN;
const canEditAppearance = isAdmin;
const showIntegrationsTab = isAdmin && FEATURE_FLAGS.INTEGRATIONS_SETTINGS;
const rawPublicProfileDomain = String(
	import.meta.env.PUBLIC_BOOKMATE_PUBLIC_DOMAIN ?? Astro.url.origin
).trim();
const publicProfileDomain =
	rawPublicProfileDomain.replace(/^https?:\/\//i, '').replace(/\/+$/, '') || Astro.url.host;
---

<settings-manager data-role-id={String(roleId)} data-public-profile-domain={publicProfileDomain}>
<dialog
	data-settings-modal
		class="m-0 mt-auto mb-0 h-[92dvh] w-screen max-w-none sm:m-auto sm:h-[min(46rem,90vh)] sm:w-[min(54rem,calc(100vw-2rem))] sm:max-w-[min(54rem,calc(100vw-2rem))] open:flex open:flex-col overflow-hidden rounded-t-[1.8rem] rounded-b-none sm:rounded-[1.8rem] border border-(--shell-border) bg-(--surface-bright) p-0 text-(--on-surface) shadow-[0_24px_80px_rgba(0,0,0,0.2)]"
>
	<div class="shrink-0 z-10 shadow-sm border-b border-(--shell-border) bg-(--surface-bright) px-4 py-3 sm:px-7 sm:py-6">
		<div class="flex items-start justify-between gap-4">
			<div class="flex items-center gap-4">
				<div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-(--primary-soft) text-(--primary)">
					<span class="material-symbols-rounded text-[1.4rem]">settings</span>
				</div>
				<div>
					<h2 class="text-[1.2rem] font-extrabold tracking-tight text-(--on-surface)">Ajustes</h2>
					<p class="text-[0.9rem] font-medium text-(--on-surface-variant) mt-0.5 hidden sm:block">Perfil y preferencias de la cuenta.</p>
				</div>
			</div>
			<div class="flex shrink-0 items-center gap-2">
				<button
					type="button"
					class="schedule-exceptions-help inline-flex shrink-0 items-center gap-1.5 rounded-full border border-(--shell-border) bg-(--surface-bright) px-3 py-2 text-[0.82rem] font-bold text-(--on-surface-variant) transition hover:border-(--primary)/35 hover:text-(--primary) focus:outline-none focus:ring-2 focus:ring-(--primary)/25"
					data-settings-modal-tour-help
					aria-label="Guía de URL del perfil público"
				>
					<span class="material-symbols-rounded text-[1.1rem]">help</span>
					<span class="hidden sm:inline">Guía</span>
				</button>
				<button type="button" class="flex size-9 shrink-0 items-center justify-center rounded-full text-(--on-surface-variant) transition-colors hover:bg-(--surface-variant) hover:text-(--on-surface) focus:outline-none focus:ring-2 focus:ring-(--primary)" data-settings-close aria-label="Cerrar modal">
					<span class="material-symbols-rounded text-[1.3rem]">close</span>
				</button>
			</div>
		</div>
	</div>

	<div class="settings-layout flex min-h-0 flex-1 flex-col overflow-hidden bg-(--surface)/30 shadow-[inset_0_4px_10px_rgba(0,0,0,0.015)]">
		<nav class="settings-nav shrink-0 border-b border-(--shell-border) bg-(--surface-bright)/50 px-0 py-3">
			<div class="settings-tabs-grid">
				<button type="button" data-settings-tab-trigger data-settings-tab="profile" class="settings-tab is-active">
					<span class="material-symbols-rounded">person</span>Mi perfil
				</button>
				<button type="button" data-settings-tab-trigger data-settings-tab="security" class="settings-tab">
					<span class="material-symbols-rounded">lock</span>Seguridad
				</button>
				{
					canEditAppearance ? (
						<button type="button" data-settings-tab-trigger data-settings-tab="preferences" class="settings-tab">
							<span class="material-symbols-rounded">palette</span>Apariencia
						</button>
					) : null
				}
				{
					isAdmin ? (
						<>
							<button type="button" data-settings-tab-trigger data-settings-tab="workspace" class="settings-tab">
								<span class="material-symbols-rounded">storefront</span>Negocio
							</button>
							{
								showIntegrationsTab ? (
									<button type="button" data-settings-tab-trigger data-settings-tab="integrations" class="settings-tab">
										<span class="material-symbols-rounded">credit_card</span>Integraciones
									</button>
								) : null
							}
							<button type="button" data-settings-tab-trigger data-settings-tab="system" class="settings-tab">
								<span class="material-symbols-rounded">settings_applications</span>Sistema
							</button>
						</>
					) : null
				}
			</div>
		</nav>

		<div class="settings-content relative flex-1 min-h-0 overflow-y-auto p-4 sm:p-6 overscroll-contain">
			<div class="settings-loading-overlay hidden" data-settings-loading aria-live="polite" aria-busy="true">
				<div class="settings-loading-card">
					<span class="material-symbols-rounded animate-spin">progress_activity</span>
					<span>Cargando ajustes...</span>
				</div>
			</div>
			<section data-settings-panel="profile" class="grid gap-6">
				<p data-settings-feedback="profile" class="hidden settings-feedback"></p>
				<form data-settings-profile-form class="grid gap-8">
					<div class="grid gap-5">
						<div class="grid gap-1">
							<h3 class="text-[1.05rem] font-bold text-(--on-surface)">Información personal</h3>
							<p class="text-[0.9rem] font-medium text-(--on-surface-variant)">Solo para tu cuenta y acceso interno.</p>
						</div>
						<div class="grid gap-5 sm:grid-cols-2">
							<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)"><span>Nombre <span class="text-rose-500">*</span></span><input name="first_name" maxlength="50" required class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10" /></label>
							<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)"><span>Apellido <span class="text-rose-500">*</span></span><input name="last_name" maxlength="50" required class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10" /></label>
						</div>
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">Correo electrónico<input name="email" readonly class="rounded-xl border border-(--shell-border) bg-(--control-surface) px-4 py-3 text-[0.95rem] outline-none text-(--on-surface-variant) cursor-not-allowed" /></label>
					</div>

					<div data-settings-prof-fields class="settings-prof-section hidden gap-5 border-t border-(--shell-border) border-dashed pt-6">
						<div class="settings-upload-card" data-settings-profile-dropzone>
							<div class="settings-upload-card__preview settings-upload-card__preview--avatar">
								<img data-settings-profile-preview class="hidden" alt="Foto de perfil" />
								<div data-settings-profile-placeholder class="settings-upload-card__placeholder">
									<span class="material-symbols-rounded">account_circle</span>
								</div>
							</div>
							<div class="settings-upload-card__content">
								<div class="settings-upload-card__copy">
									<h3>Avatar público <span class="text-rose-500">*</span></h3>
									<p>Arrastra una imagen o selecciona un archivo JPG o PNG.</p>
								</div>
								<div class="settings-upload-card__actions">
									<label for="settings-profile-image-input" class="settings-upload-card__button">
										<span class="material-symbols-rounded">add_photo_alternate</span>
										<span data-settings-profile-file-name>Cambiar foto</span>
										<input id="settings-profile-image-input" type="file" name="profile_image" accept=".jpg,.jpeg,.png" class="sr-only" />
									</label>
									<span class="settings-upload-card__meta">Se mostrará en tu perfil público.</span>
								</div>
							</div>
						</div>
					</div>

					<div data-settings-prof-fields class="settings-prof-section hidden gap-5 border-t border-(--shell-border) border-dashed pt-6">
						<div class="grid gap-1">
							<h3 class="text-[1.05rem] font-bold text-(--on-surface)">Perfil público</h3>
							<p class="text-[0.9rem] font-medium text-(--on-surface-variant)">Estos datos se muestran a tus clientes en internet.</p>
						</div>
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
							<span>Teléfono público <span class="text-rose-500">*</span></span>
							<div class="flex rounded-2xl shadow-sm transition-shadow focus-within:ring-4 focus-within:ring-(--primary)/10">
								<span class="inline-flex items-center rounded-l-2xl border border-r-0 border-(--shell-border) bg-(--control-surface) px-4 text-[0.95rem] font-semibold text-(--on-surface-variant)">
									+595
								</span>
								<input
									type="tel"
									name="phone_number"
									inputmode="numeric"
									autocomplete="tel-national"
									maxlength="20"
									placeholder="981 123 456"
									class="min-w-0 flex-1 rounded-none rounded-r-2xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary)"
								/>
							</div>
							<span class="text-[0.85rem] font-medium text-(--on-surface-variant)">Se guardará como número paraguayo con prefijo internacional.</span>
							<span data-settings-profile-field-error="phone_number" class="hidden text-[0.85rem] font-semibold text-rose-600 dark:text-rose-400 mt-1"></span>
						</label>
						<label class="settings-public-profile-field" data-settings-public-profile-field>
							<span class="inline-flex items-center gap-1 text-[0.95rem] font-bold text-(--on-surface)">URL del perfil público <span class="text-rose-500">*</span></span>
							<div class="flex">
								<span data-settings-profile-slug-prefix class="inline-flex max-w-[55%] items-center truncate rounded-l-2xl border border-r-0 border-(--shell-border) bg-(--control-surface) px-3 text-xs font-medium text-(--on-surface-variant) shadow-sm sm:max-w-[65%] sm:px-4 sm:text-sm">
									{publicProfileDomain}/p/
								</span>
								<input
									type="text"
									name="profile_slug"
									maxlength="100"
									class="block w-full min-w-0 flex-1 rounded-none border border-l-0 border-r-0 border-(--shell-border) bg-(--surface-bright) px-4 py-2.5 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
									placeholder="maria-lopez"
								/>
								<button
									type="button"
									class="inline-flex w-12 shrink-0 items-center justify-center rounded-r-2xl border border-l border-(--shell-border) bg-(--control-surface) text-(--on-surface-variant) transition hover:bg-(--surface-container-high) hover:text-(--primary) focus:outline-none focus:ring-4 focus:ring-(--primary)/10"
									data-copy-settings-profile-url
									aria-label="Copiar URL del perfil público"
									title="Copiar URL"
								>
									<span class="material-symbols-rounded text-[1.1rem]" data-copy-settings-profile-url-icon>content_copy</span>
								</button>
							</div>
							<span class="text-[0.84rem] font-semibold text-(--on-surface-variant)">
								Este será el enlace directo para que los clientes agenden contigo.
							</span>
							<span data-settings-profile-field-error="profile_slug" class="hidden text-[0.85rem] font-semibold text-rose-600 dark:text-rose-400 mt-1"></span>
						</label>
					</div>

					<div data-settings-profile-note class="hidden rounded-2xl border border-amber-500/20 bg-amber-500/10 px-4 py-3 text-[0.9rem] font-medium text-amber-700 dark:text-amber-400 shadow-sm"></div>
					
					<div class="pt-2">
						<div class="modal-footer">
							<div class="modal-footer-actions">
						<button type="button" class="modal-action-secondary" data-settings-close-action>
							Cancelar
						</button>
						<button type="submit" class="modal-action-primary">
							<span class="material-symbols-rounded text-[1.2rem] hidden sm:inline">save</span>
							Guardar perfil
						</button>
							</div>
						</div>
					</div>
				</form>
			</section>

			<section data-settings-panel="security" class="settings-panel hidden gap-6">
				<p data-settings-feedback="security" class="hidden settings-feedback"></p>
				<form data-settings-security-form class="grid gap-8">
					<div class="grid gap-5">
						<div class="grid gap-1">
							<h3 class="text-[1.05rem] font-bold text-(--on-surface)">Cambio de contraseña</h3>
							<p class="text-[0.9rem] font-medium text-(--on-surface-variant)">Asegúrate de usar una contraseña fuerte y segura.</p>
						</div>
					<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span>Contraseña actual <span class="text-rose-500">*</span></span>
						<input
							type="password"
							name="current_password"
							autocomplete="current-password"
							required
							class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
						/>
					</label>
					<div class="grid gap-5 sm:grid-cols-2">
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span>Nueva contraseña <span class="text-rose-500">*</span></span>
						<input
							type="password"
							name="new_password"
							autocomplete="new-password"
							required
							minlength="8"
							class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
						/>
					</label>
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
						<span>Confirmar nueva contraseña <span class="text-rose-500">*</span></span>
						<input
							type="password"
							name="confirm_password"
							autocomplete="new-password"
							required
							minlength="8"
							class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
						/>
					</label>
					</div>
					<p class="text-[0.85rem] font-medium text-(--on-surface-variant) -mt-2">
						La nueva contraseña debe tener al menos 8 caracteres.
					</p>
					</div>
					<div class="pt-2 border-t border-(--shell-border) border-dashed">
						<div class="modal-footer">
							<div class="modal-footer-actions">
						<button type="button" class="modal-action-secondary" data-settings-close-action>
							Cancelar
						</button>
						<button type="submit" class="modal-action-primary">
							<span class="material-symbols-rounded text-[1.2rem] hidden sm:inline">key</span>
							Actualizar contraseña
						</button>
							</div>
						</div>
					</div>
				</form>
			</section>

			<section data-settings-panel="preferences" class="settings-panel hidden gap-8">
				<p data-settings-feedback="preferences" class="hidden settings-feedback"></p>
				<form data-settings-preferences-form class="grid gap-6">
					<div class="grid gap-1">
						<h3 class="text-[1.05rem] font-bold text-(--on-surface)">Tu panel de control</h3>
						<p class="text-[0.9rem] font-medium text-(--on-surface-variant)">Personaliza la apariencia y el comportamiento de tu vista.</p>
					</div>
					<div class="grid gap-5">
						<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)"><span>Tema del panel <span class="text-rose-500">*</span></span>
							<div class="relative">
								<select name="panel_theme" class="w-full cursor-pointer appearance-none rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] font-semibold outline-none transition hover:border-(--on-surface-variant) focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M7%2010l5%205%205-5%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-position-[calc(100%-12px)_center] bg-no-repeat pr-10">
							<option value="light">Claro</option>
							<option value="dark">Oscuro</option>
						</select>
							</div>
					</label>
					</div>
				</form>

				{
					isAdmin ? (
						<>
							<form data-settings-branding-form class="grid gap-6 border-t border-(--shell-border) border-dashed pt-8">
								<div class="grid gap-1">
									<h3 class="text-[1.05rem] font-bold text-(--on-surface)">Página pública de reservas</h3>
									<p class="text-[0.9rem] font-medium text-(--on-surface-variant)">Personaliza como te ven los clientes.</p>
								</div>
								
								<div class="grid gap-1.5 mt-2">
									<div class="settings-upload-card" data-settings-logo-dropzone>
										<div class="settings-upload-card__preview settings-upload-card__preview--logo">
											<img data-settings-logo-preview class="hidden" alt="Vista previa del logo" />
											<div data-settings-logo-placeholder class="settings-upload-card__placeholder">
												<span class="material-symbols-rounded">image</span>
											</div>
										</div>
										<div class="settings-upload-card__content">
											<div class="settings-upload-card__copy">
												<h3>Logo negocio <span class="text-rose-500">*</span></h3>
												<p>Arrastra tu logo o selecciona un archivo JPG o PNG.</p>
											</div>
											<div class="settings-upload-card__actions">
												<label for="settings-branding-logo-input" class="settings-upload-card__button">
													<span class="material-symbols-rounded">add_photo_alternate</span>
													<span data-settings-logo-file-name>Subir logo</span>
													<input id="settings-branding-logo-input" type="file" name="logo_file" accept=".jpg,.jpeg,.png" class="sr-only" />
												</label>
												<span class="settings-upload-card__meta">Se mostrará una vista previa antes de guardar.</span>
											</div>
										</div>
									</div>
								</div>
							</form>
						</>
					) : null
				}
				<div class="border-t border-(--shell-border) border-dashed pt-2">
					<div class="modal-footer">
						<div class="modal-footer-actions">
					<button type="button" class="modal-action-secondary" data-settings-close-action>
						Cancelar
					</button>
					<button type="button" data-settings-appearance-save class="modal-action-primary">
						<span class="material-symbols-rounded text-[1.2rem] hidden sm:inline">save</span>
						Guardar apariencia
					</button>
						</div>
					</div>
				</div>
			</section>

			{
				isAdmin ? (
					<>
						<section data-settings-panel="workspace" class="settings-panel hidden gap-6">
							<p data-settings-feedback="workspace" class="hidden settings-feedback"></p>
							<form data-settings-workspace-form class="grid gap-6">
								<div class="grid gap-1">
									<h3 class="text-[1.05rem] font-bold text-(--on-surface)">Información del negocio</h3>
									<p class="text-[0.9rem] font-medium text-(--on-surface-variant)">Detalles principales de tu organización.</p>
								</div>
								<div class="grid gap-5">
									<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)"><span>Nombre del negocio <span class="text-rose-500">*</span></span><input name="name" maxlength="100" required class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10" /></label>
								</div>
								<input type="hidden" name="profile_slug" />
								<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">Descripción<textarea name="description" maxlength="1000" rows="4" class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10 resize-y"></textarea></label>
								<div class="pt-4 border-t border-(--shell-border) border-dashed">
									<div class="modal-footer">
										<div class="modal-footer-actions">
									<button type="button" class="modal-action-secondary" data-settings-close-action>
										Cancelar
									</button>
									<button type="submit" class="modal-action-primary"><span class="material-symbols-rounded text-[1.2rem] hidden sm:inline">store</span>Guardar negocio</button>
										</div>
									</div>
								</div>
							</form>
						</section>

						{
							showIntegrationsTab ? (
								<section data-settings-panel="integrations" class="settings-panel hidden gap-6">
									<p data-settings-feedback="integrations" class="hidden settings-feedback"></p>
									<form data-settings-integrations-form class="grid gap-6">
										<div class="grid gap-1">
											<h3 class="text-[1.05rem] font-bold text-(--on-surface)">Pagopar</h3>
											<p class="text-[0.9rem] font-medium text-(--on-surface-variant)">
												Configura las claves del negocio para cobrar señas en la reserva pública.
											</p>
										</div>

										<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
											<span>Clave pública <span class="text-rose-500">*</span></span>
											<input
												name="public_key"
												autocomplete="off"
												spellcheck="false"
												class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
												placeholder="Public key de Pagopar"
												required
											/>
										</label>

										<label class="grid gap-1.5 text-[0.95rem] font-bold text-(--on-surface)">
											<span>Clave privada <span class="text-rose-500">*</span></span>
											<input
												name="private_key"
												type="password"
												autocomplete="new-password"
												spellcheck="false"
												class="rounded-xl border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-[0.95rem] outline-none transition hover:border-(--on-surface-variant)/40 focus:border-(--primary) focus:ring-4 focus:ring-(--primary)/10"
												placeholder="Private key de Pagopar"
												required
