		private setSuggestedSlug(slug: string) {
			if (!this.formEls.profileSlugInput) return;
			this.suppressSlugManualTracking = true;
			this.formEls.profileSlugInput.value = slug;
			this.suppressSlugManualTracking = false;
		}

		private toParaguayPhoneLocalDigits(rawValue: string) {
			const parsedPhone = parseParaguayMobilePhone(rawValue);
			if (parsedPhone.isValid) return parsedPhone.e164.slice(4);

			let digits = String(rawValue || '').replace(/\D/g, '');
			if (digits.startsWith('00595')) digits = digits.slice(5);
			if (digits.startsWith('595')) digits = digits.slice(3);
			if (digits.startsWith('0')) digits = digits.slice(1);
			return digits.slice(0, 9);
		}

		private formatParaguayPhoneLocal(rawValue: string) {
			const digits = this.toParaguayPhoneLocalDigits(rawValue);
			if (!digits) return '';
			if (digits.length <= 3) return digits;
			if (digits.length <= 6) return `${digits.slice(0, 3)} ${digits.slice(3)}`;
			return `${digits.slice(0, 3)} ${digits.slice(3, 6)} ${digits.slice(6, 9)}`;
		}

		private setPhoneFieldError(message: string) {
			if (!this.formEls.phoneError) return;
			this.formEls.phoneError.textContent = message;
			this.formEls.phoneError.classList.remove('hidden');
		}

		private clearProfileFieldErrors() {
			if (this.formEls.profileSlugError) {
				this.formEls.profileSlugError.textContent = '';
				this.formEls.profileSlugError.classList.add('hidden');
			}
			if (this.formEls.phoneError) {
				this.formEls.phoneError.textContent = '';
				this.formEls.phoneError.classList.add('hidden');
			}
		}

		private isGenericValidationMessage(message: unknown): boolean {
			const normalized = String(message || '').trim().toLowerCase();
			return (
				normalized === 'errores de validacion.' ||
				normalized === 'errores de validacion' ||
				normalized === 'errores de validacion.' ||
				normalized === 'errores de validacion'
			);
		}

		private renderProfileFieldErrors(errors: unknown, fallbackMessage = ''): boolean {
			let rendered = false;
			const items = Array.isArray(errors) ? errors : [];
			for (const item of items) {
				if (!item || typeof item !== 'object') continue;
				const field = 'field' in item ? String((item as Record<string, unknown>).field || '').trim() : '';
				const message = 'message' in item ? String((item as Record<string, unknown>).message || '').trim() : '';
				if (!field || !message) continue;
				if (field === 'phone_number' && this.formEls.phoneError) {
					this.formEls.phoneError.textContent = message;
					this.formEls.phoneError.classList.remove('hidden');
					rendered = true;
				}
				if (field === 'profile_slug' && this.formEls.profileSlugError) {
					this.formEls.profileSlugError.textContent = message;
					this.formEls.profileSlugError.classList.remove('hidden');
					rendered = true;
				}
			}
			if (rendered) return true;
			if (typeof fallbackMessage === 'string' && /slug|perfil/i.test(fallbackMessage) && this.formEls.profileSlugError) {
				this.formEls.profileSlugError.textContent = fallbackMessage;
				this.formEls.profileSlugError.classList.remove('hidden');
				return true;
			}
			return false;
		}

		private showFeedback(key: string, message: string, kind: 'success' | 'error' = 'success') {
			const node = this.querySelector(`[data-settings-feedback="${key}"]`);
			if (!node) return;
			if (this.feedbackHideTimer) {
				window.clearTimeout(this.feedbackHideTimer);
				this.feedbackHideTimer = null;
			}
			node.textContent = message;
			node.classList.remove('hidden', 'is-success', 'is-error');
			node.classList.add(kind === 'success' ? 'is-success' : 'is-error');

			// Keep feedback visible even when the user is scrolled down in the panel.
			node.scrollIntoView({ block: 'nearest', behavior: 'smooth' });

			if (kind === 'success') {
				this.feedbackHideTimer = window.setTimeout(() => {
					node.classList.add('hidden');
					node.classList.remove('is-success', 'is-error');
					node.textContent = '';
					this.feedbackHideTimer = null;
				}, 3200);
			}
		}

		private clearFeedback() {
			if (this.feedbackHideTimer) {
				window.clearTimeout(this.feedbackHideTimer);
				this.feedbackHideTimer = null;
			}
			this.querySelectorAll('.settings-feedback').forEach((node) => {
				node.textContent = '';
				node.classList.add('hidden');
				node.classList.remove('is-success', 'is-error');
			});
			this.clearProfileFieldErrors();
		}

		private async requestApi<T = unknown>(url: string, options: RequestInit, fallbackMessage: string): Promise<ApiResponse<T>> {
			const response = await fetch(url, options);
			let data: ApiResponse<T> | null = null;
			try {
				data = await response.json();
			} catch {
				throw new SettingsApiError('No fue posible interpretar la respuesta.', response.status || 502);
			}
			if (!response.ok || !data || data.status !== 'success') {
				throw new SettingsApiError(
					this.readApiMessage(data, fallbackMessage),
					response.status || 400,
					data?.errors,
					data?.details
				);
			}
			return data;
		}

		private handleSlugInput = () => {
			if (this.suppressSlugManualTracking) return;
			const currentValue = String(this.formEls.profileSlugInput?.value || '').trim();
			this.slugManuallyEdited = currentValue !== '';
			this.clearProfileFieldErrors();
			if (!this.slugManuallyEdited) this.queueSlugSuggestion();
		};

		private queueSlugSuggestion = () => {
			if (!this.formEls.profileSlugInput) return;
			const profVisible = !this.els.profFields[0]?.classList.contains('hidden');
			if (!profVisible) return;
			const fullName = this.getSlugSourceName();
			if (!fullName) return;
			if (this.slugManuallyEdited && this.formEls.profileSlugInput.value.trim() !== '') return;
			
			this.clearSlugSuggestTimer();
			const currentRequest = ++this.slugRequestSeq;
			this.slugSuggestTimer = window.setTimeout(async () => {
				try {
					const response = await fetch(
						`/api/professionals/slug/suggest?name=${encodeURIComponent(fullName)}`,
						{ method: 'GET', headers: { Accept: 'application/json' } }
					);
					let data: ApiResponse | null = null;
					try {
						data = await response.json();
					} catch {
						return;
					}
					if (currentRequest !== this.slugRequestSeq) return;
					if (!response.ok || !data || data.status !== 'success' || typeof data.slug !== 'string') return;
					if (this.slugManuallyEdited && this.formEls.profileSlugInput!.value.trim() !== '') return;
					const suggestedSlug = String(data.slug || '').trim();
					if (!suggestedSlug) return;
					this.setSuggestedSlug(suggestedSlug);
				} catch {
					// Ignoramos errores de red
				}
			}, 350);
		};

		private handlePhoneInput = () => {
			if (!this.formEls.phoneInput) return;
			this.formEls.phoneInput.value = this.formatParaguayPhoneLocal(this.formEls.phoneInput.value);
			this.clearProfileFieldErrors();
		};

		private handleProfileImageChange = () => {
			const imageFile = this.formEls.profileImageInput?.files?.[0];
			if (!imageFile) return;
			if (!this.isAllowedImageFile(imageFile)) {
				if (this.formEls.profileImageInput) this.formEls.profileImageInput.value = '';
				this.showFeedback('profile', 'Selecciona una imagen JPG o PNG.', 'error');
				return;
			}
			this.releaseProfilePreviewObjectUrl();
			this.profilePreviewObjectUrl = URL.createObjectURL(imageFile);
			this.setProfilePreview(this.profilePreviewObjectUrl);
			if (this.els.profileFileName) this.els.profileFileName.textContent = imageFile.name;
		};

		private handleLogoImageChange = () => {
			const logoFile = this.formEls.brandingLogoInput?.files?.[0];
			if (!logoFile) return;
			if (!this.isAllowedImageFile(logoFile)) {
				if (this.formEls.brandingLogoInput) this.formEls.brandingLogoInput.value = '';
				this.showFeedback('preferences', 'Selecciona una imagen JPG o PNG.', 'error');
				return;
			}
			this.releaseLogoPreviewObjectUrl();
			this.logoPreviewObjectUrl = URL.createObjectURL(logoFile);
			this.setLogoPreview(this.logoPreviewObjectUrl);
			if (this.els.logoFileName) this.els.logoFileName.textContent = logoFile.name;
		};

		private setActiveTab(tabId: string) {
			this.els.tabButtons.forEach((btn) => btn.classList.toggle('is-active', btn.dataset.settingsTab === tabId));
			this.els.panels.forEach((panel) => panel.classList.toggle('hidden', panel.dataset.settingsPanel !== tabId));
		}

		private resetSecurityForm() {
			if (!this.els.securityForm) return;
			const current = this.els.securityForm.querySelector<HTMLInputElement>('[name="current_password"]');
			const next = this.els.securityForm.querySelector<HTMLInputElement>('[name="new_password"]');
			const confirm = this.els.securityForm.querySelector<HTMLInputElement>('[name="confirm_password"]');
			if (current) current.value = '';
			if (next) next.value = '';
			if (confirm) confirm.value = '';
		}

		private fillProfile(profile: any) {
			if (!this.els.profileForm) return;
			const email = this.els.profileForm.querySelector<HTMLInputElement>('[name="email"]');
			const phone = this.els.profileForm.querySelector<HTMLInputElement>('[name="phone_number"]');

			if (this.formEls.firstNameInput) this.formEls.firstNameInput.value = profile?.first_name || '';
			if (this.formEls.lastNameInput) this.formEls.lastNameInput.value = profile?.last_name || '';
			if (email) email.value = profile?.email || '';
			if (this.formEls.profileImageInput) this.formEls.profileImageInput.value = '';
			if (this.formEls.profileSlugPrefix) this.formEls.profileSlugPrefix.textContent = this.getPublicProfilePrefix();
			
			this.clearSlugSuggestTimer();
			this.slugRequestSeq += 1;
			this.slugManuallyEdited = false;
			this.releaseProfilePreviewObjectUrl();

			const prof = profile?.professional_profile;
			if (prof) {
				this.els.profFields.forEach((el) => el.classList.remove('hidden'));
				if (phone) phone.value = this.formatParaguayPhoneLocal(prof.phone_number || '');
				if (this.formEls.profileSlugInput) {
					this.setSuggestedSlug(String(prof.profile_slug || '').trim());
					if (this.formEls.profileSlugInput.value.trim() === '') this.queueSlugSuggestion();
				}
				this.setProfilePreview(prof.image_url || '');
				if (this.els.profileFileName) this.els.profileFileName.textContent = 'Cambiar foto';
				if (this.els.profileNote) {
					this.els.profileNote.classList.add('hidden');
					this.els.profileNote.textContent = '';
				}
			} else {
				this.els.profFields.forEach((el) => el.classList.add('hidden'));
				if (phone) phone.value = '';
				if (this.formEls.profileSlugInput) this.setSuggestedSlug('');
				this.setProfilePreview('');
				if (this.els.profileFileName) this.els.profileFileName.textContent = 'Cambiar foto';
				if (this.els.profileNote) {
					this.els.profileNote.textContent = 'Esta cuenta no tiene perfil profesional público. Solo se guarda nombre y apellido.';
					this.els.profileNote.classList.remove('hidden');
				}
			}
		}

		private populateSystemSelect(
			select: HTMLSelectElement | null,
			options: Array<{ id: number; label: string }>,
			selectedId: number | null
		) {
			if (!select) return;
			select.replaceChildren();
			for (const option of options) {
				const node = document.createElement('option');
				node.value = String(option.id);
				node.textContent = option.label;
				select.appendChild(node);
			}
			if (selectedId && options.some((item) => item.id === selectedId)) {
				select.value = String(selectedId);
			} else if (options[0]) {
				select.value = String(options[0].id);
			}
		}

		private getSystemSelectValue(selector: string) {
			const select = this.querySelector<HTMLSelectElement>(selector);
			const parsed = Number(select?.value || 0);
			return Number.isInteger(parsed) && parsed > 0 ? parsed : null;
		}

		private fillSystemSettings(workspace: WorkspaceSettingsData | null) {
			if (!this.els.systemForm || !workspace) return;

			this.systemCatalogs = workspace.catalogs ?? null;

			this.populateSystemSelect(
				this.querySelector<HTMLSelectElement>('[data-settings-system-slot-interval]'),
				this.systemCatalogs?.slot_intervals ?? [],
				workspace.rsi_id_slot_interval
			);
			this.renderSystemSlotPreview();
			this.populateSystemSelect(
				this.querySelector<HTMLSelectElement>('[data-settings-system-reminder-hours]'),
				this.systemCatalogs?.reminder_hours ?? [],
				workspace.rh_id_reminder_hours
			);

			const timeFormat = String(workspace.time_format || '24H').trim().toLowerCase();
			const timeFormatSelect = this.els.systemForm.querySelector<HTMLSelectElement>('[name="time_format"]');
			if (timeFormatSelect) timeFormatSelect.value = timeFormat === '12h' ? '12H' : '24H';

			const alertSelect = this.querySelector<HTMLSelectElement>('[data-settings-system-alert-action]');
			if (alertSelect) {
				alertSelect.value = workspace.unanswered_alert_action === 'CANCEL' ? 'CANCEL' : 'KEEP';
			}

			this.refreshSystemCancelWaitField(workspace.cwh_id_cancel_wait_hours);
		}

		private getSelectedSlotIntervalMinutes() {
			const slotId = this.getSystemSelectValue('[data-settings-system-slot-interval]');
			const match = this.systemCatalogs?.slot_intervals.find((item) => item.id === slotId);
			const minutes = Number(match?.minutes ?? 0);
			return Number.isInteger(minutes) && minutes > 0 ? minutes : 30;
		}

		private buildExampleSlotTimes(minutes: number, count = 5) {
			let totalMinutes = 9 * 60;
			const times: string[] = [];
			for (let index = 0; index < count; index += 1) {
				const hours = Math.floor(totalMinutes / 60) % 24;
				const mins = totalMinutes % 60;
				times.push(`${String(hours).padStart(2, '0')}:${String(mins).padStart(2, '0')}`);
				totalMinutes += minutes;
			}
			return times;
		}

		private renderSystemSlotPreview() {
			const chipsHost = this.querySelector<HTMLElement>(
				'[data-settings-system-slot-preview-chips]'
			);
			if (!chipsHost) return;

			const minutes = this.getSelectedSlotIntervalMinutes();
			const exampleTimes = this.buildExampleSlotTimes(minutes);
			chipsHost.replaceChildren();

			for (const time of exampleTimes) {
				const chip = document.createElement('span');
				chip.className = 'settings-slot-preview-chip';
				chip.textContent = time;
				chipsHost.appendChild(chip);
			}
		}

		private refreshSystemCancelWaitField(preferredCancelWaitId: number | null = null) {
			const alertAction =
				this.querySelector<HTMLSelectElement>('[data-settings-system-alert-action]')?.value || 'KEEP';
			const cancelField = this.querySelector<HTMLElement>('[data-settings-system-cancel-wait-field]');
			const cancelSelect = this.querySelector<HTMLSelectElement>('[data-settings-system-cancel-wait]');
			const reminderId = this.getSystemSelectValue('[data-settings-system-reminder-hours]');
			const showCancel = alertAction === 'CANCEL';

			cancelField?.classList.toggle('hidden', !showCancel);
			if (!showCancel) {
				if (cancelSelect) cancelSelect.value = '';
				return;
			}

			const options = getCancelWaitOptionsForReminder(this.systemCatalogs ?? undefined, reminderId);
			this.populateSystemSelect(cancelSelect, options, preferredCancelWaitId);
		}

		private validateSystemFormPayload() {
			if (!this.els.systemForm) return { ok: false, message: 'Formulario de sistema no disponible.' };

			const slotId = this.getSystemSelectValue('[data-settings-system-slot-interval]');
			const reminderId = this.getSystemSelectValue('[data-settings-system-reminder-hours]');
			const alertAction =
				this.querySelector<HTMLSelectElement>('[data-settings-system-alert-action]')?.value || 'KEEP';
			const cancelId =
				alertAction === 'CANCEL'
					? this.getSystemSelectValue('[data-settings-system-cancel-wait]')
					: null;

			if (!slotId) return { ok: false, message: 'Selecciona un intervalo de reserva.' };
			if (!reminderId) return { ok: false, message: 'Selecciona un tiempo de recordatorio.' };
			if (alertAction === 'CANCEL' && !cancelId) {
				return { ok: false, message: 'Selecciona el tiempo límite de espera para cancelar.' };
			}

			const reminderHours = getReminderHoursValue(this.systemCatalogs ?? undefined, reminderId);
			const cancelHours =
				cancelId && this.systemCatalogs
					? this.systemCatalogs.cancel_wait_hours.find((item) => item.id === cancelId)?.hours ?? 0
					: 0;

			if (alertAction === 'CANCEL' && cancelHours >= reminderHours) {
				return {
					ok: false,
					message: 'El tiempo de espera debe ser menor que el tiempo de recordatorio.',
				};
			}

			return {
				ok: true,
				payload: {
					rsi_id_slot_interval: slotId,
					rh_id_reminder_hours: reminderId,
					unanswered_alert_action: alertAction,
					cwh_id_cancel_wait_hours: alertAction === 'CANCEL' ? cancelId : null,
				},
			};
		}

		private handleSystemFormChange = (event: Event) => {
			const target = event.target;
			if (
				target instanceof HTMLSelectElement &&
				target.matches('[data-settings-system-slot-interval]')
			) {
				this.renderSystemSlotPreview();
				return;
			}

			if (
				target instanceof HTMLSelectElement &&
				target.matches('[data-settings-system-cancel-wait]')
			) {
				return;
			}

			const preserveCancelWaitId = this.getSystemSelectValue('[data-settings-system-cancel-wait]');
			this.refreshSystemCancelWaitField(preserveCancelWaitId);
		};

		private fillWorkspace(workspace: WorkspaceSettingsData | null) {
			const setValue = (selector: string, value: string) => {
				const input = this.querySelector<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(selector);
				if (input) input.value = value || '';
			};
			
			setValue('[data-settings-workspace-form] [name="name"]', String(workspace?.name ?? ''));
			setValue('[data-settings-workspace-form] [name="profile_slug"]', String(workspace?.profile_slug ?? ''));
			setValue('[data-settings-workspace-form] [name="description"]', String(workspace?.description ?? ''));
			this.fillSystemSettings(workspace);
			
			this.releaseLogoPreviewObjectUrl();

			this.setLogoPreview(workspace?.logo_url || '');
			if (this.els.logoFileName) this.els.logoFileName.textContent = 'Subir logo';
			const logoFile = this.formEls.brandingLogoInput;
			if (logoFile) logoFile.value = '';
		}

		private getPanelAppearanceValues(): { theme: 'light' | 'dark' } {
			const theme: 'light' | 'dark' =
				this.els.preferencesForm?.querySelector<HTMLSelectElement>('[name="panel_theme"]')?.value === 'dark'
					? 'dark'
					: 'light';
			return { theme };
		}

		private persistPanelAppearance(theme: string) {
			const safeTheme = theme === 'dark' ? 'dark' : 'light';
			document.documentElement.dataset.theme = safeTheme;
			localStorage.setItem('bookmate-theme', safeTheme);
		}

		private reloadAfterWorkspaceSave() {
			window.setTimeout(() => {
				window.location.reload();
			}, 650);
		}

		private getFormPayload(form: HTMLFormElement | null): Record<string, string> {
			const payload: Record<string, string> = {};
			if (!form) return payload;

			const formData = new FormData(form);
			for (const [key, value] of formData.entries()) {
				if (typeof value === 'string') {
					payload[key] = value.trim();
				}
			}

			return payload;
		}

		private getAppearancePayload(): Record<string, string> {
			const payload = this.getFormPayload(this.els.preferencesForm);
			if (this.els.brandingForm) {
				Object.assign(payload, this.getFormPayload(this.els.brandingForm));
			}
			return payload;
		}


		private getWorkspacePayload(): Record<string, string> {
			const payload: Record<string, string> = {};
			const forms = [this.els.workspaceForm, this.els.systemForm, this.els.brandingForm];

			for (const form of forms) {
				Object.assign(payload, this.getFormPayload(form));
			}
			return payload;
		}

		private async loadData() {
			this.setLoadingState(true);
			try {
				const profileRes = await this.requestApi('/api/profile/me', { method: 'GET', headers: { Accept: 'application/json' } }, 'No fue posible cargar perfil.');
				this.fillProfile(profileRes.data || {});

				if (this.els.preferencesForm) {
					const panelTheme = this.els.preferencesForm.querySelector<HTMLSelectElement>('[name="panel_theme"]');
					if (panelTheme) {
						const storedTheme = localStorage.getItem('bookmate-theme');
						panelTheme.value = storedTheme === 'dark' || storedTheme === 'light' ? storedTheme : 'dark';
					}
				}

				if (this.isAdmin) {
					const workspaceRes = await this.requestApi('/api/workspace', { method: 'GET', headers: { Accept: 'application/json' } }, 'No fue posible cargar negocio.');
					this.fillWorkspace((workspaceRes.data as unknown as WorkspaceSettingsData | null) ?? null);
					if (FEATURE_FLAGS.INTEGRATIONS_SETTINGS) {
						await this.loadIntegrations();
					}
				}
			} catch (error) {
				this.showFeedback('profile', error instanceof Error ? error.message : 'No fue posible cargar ajustes.', 'error');
			} finally {
				this.setLoadingState(false);
			}
		}

		private async loadIntegrations() {
			if (!this.isAdmin || !this.els.integrationsForm) return;

			try {
				const data = await this.requestApi(
					'/api/org-integrations/pagopar',
					{ method: 'GET', headers: { Accept: 'application/json' } },
					'No fue posible cargar Pagopar.'
				);

				const raw = (data as any)?.data ?? {};
				const publicKey = String(raw?.public_key || '').trim();
				const privateConfigured = Boolean(raw?.private_key_configured);

				const publicKeyInput = this.els.integrationsForm.querySelector<HTMLInputElement>('[name="public_key"]');
				const privateKeyInput = this.els.integrationsForm.querySelector<HTMLInputElement>('[name="private_key"]');

				if (publicKeyInput) publicKeyInput.value = publicKey;
				if (privateKeyInput) privateKeyInput.value = '';

				if (privateConfigured) {
					privateKeyInput?.setAttribute('placeholder', 'Clave privada configurada (reemplaza para actualizar)');
				}
			} catch (error) {
				// 404: integración no configurada aún → no es error para UI.
				const status = error instanceof SettingsApiError ? error.status : 0;
				if (status === 404) return;
				this.showFeedback('integrations', error instanceof Error ? error.message : 'No fue posible cargar Pagopar.', 'error');
			}
		}

		private handleIntegrationsSubmit = async (event: SubmitEvent) => {
			event.preventDefault();
			this.clearFeedback();
			if (!this.els.integrationsForm) return;

			const publicKey = String(
				this.els.integrationsForm.querySelector<HTMLInputElement>('[name="public_key"]')?.value || ''
			).trim();
			const privateKey = String(
				this.els.integrationsForm.querySelector<HTMLInputElement>('[name="private_key"]')?.value || ''
			).trim();

			if (!publicKey || !privateKey) {
				this.showFeedback('integrations', 'Clave pública y clave privada son obligatorias.', 'error');
				return;
			}

			try {
				const data = await this.requestApi(
					'/api/org-integrations/pagopar',
					{
						method: 'PUT',
						headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
						body: JSON.stringify({ provider: 'pagopar', public_key: publicKey, private_key: privateKey }),
					},
					'No fue posible guardar Pagopar.'
				);
				this.showFeedback('integrations', this.readApiMessage(data, 'Pagopar configurado correctamente.'), 'success');
				await this.loadIntegrations();
			} catch (error) {
				this.showFeedback('integrations', error instanceof Error ? error.message : 'No fue posible guardar Pagopar.', 'error');
			}
		};

		private handleProfileSubmit = async (event: SubmitEvent) => {
			event.preventDefault();
			this.clearFeedback();
			if (!this.els.profileForm) return;

			const first = String(this.els.profileForm.querySelector<HTMLInputElement>('[name="first_name"]')?.value || '').trim();
			const last = String(this.els.profileForm.querySelector<HTMLInputElement>('[name="last_name"]')?.value || '').trim();
			if (!first || !last) {
				this.showFeedback('profile', 'Nombre y apellido son obligatorios.', 'error');
				return;
			}

			const payload: Record<string, string | number> = { first_name: first, last_name: last };
			const profVisible = !this.els.profFields[0]?.classList.contains('hidden');
			
			if (profVisible) {
				const rawPhone = String(this.formEls.phoneInput?.value || '').trim();
				if (rawPhone !== '') {
					const parsedPhone = parseParaguayMobilePhone(rawPhone);
					if (!parsedPhone.isValid) {
						this.setPhoneFieldError(PARAGUAY_MOBILE_PHONE_ERROR);
						return;
					}
					payload.phone_number = parsedPhone.e164;
				} else {
					payload.phone_number = '';
				}
				const profileSlug = String(this.formEls.profileSlugInput?.value || '').trim();
				if (profileSlug) payload.profile_slug = profileSlug;

				const imageFile = this.els.profileForm.querySelector<HTMLInputElement>('[name="profile_image"]')?.files?.[0];
				if (imageFile) {
					payload.image_base64 = await this.fileToBase64(imageFile);
					payload.image_name = imageFile.name;
					payload.image_mime = imageFile.type || 'application/octet-stream';
				}
			}

			try {
				const data = await this.requestApi('/api/profile/me', {
					method: 'PUT',
					headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
					body: JSON.stringify(payload),
				}, 'No fue posible guardar perfil.');
				this.showFeedback('profile', this.readApiMessage(data, 'Perfil actualizado correctamente.'), 'success');
				await this.loadData();
			} catch (error) {
				const message = error instanceof Error ? error.message : 'No fue posible guardar perfil.';
				const hasFieldErrors = this.renderProfileFieldErrors(
					error instanceof SettingsApiError ? error.errors : [],
					message
				);
				if (!hasFieldErrors || !this.isGenericValidationMessage(message)) {
					this.showFeedback('profile', message, 'error');
				}
			}
		};

		private handleSecuritySubmit = async (event: SubmitEvent) => {
			event.preventDefault();
			this.clearFeedback();
			if (!this.els.securityForm) return;

			const currentPassword = String(this.els.securityForm.querySelector<HTMLInputElement>('[name="current_password"]')?.value || '').trim();
			const newPassword = String(this.els.securityForm.querySelector<HTMLInputElement>('[name="new_password"]')?.value || '').trim();
			const confirmPassword = String(this.els.securityForm.querySelector<HTMLInputElement>('[name="confirm_password"]')?.value || '').trim();

			if (!currentPassword || !newPassword || !confirmPassword) {
				this.showFeedback('security', 'Ingresa la contraseña actual, la nueva y su confirmación.', 'error');
				return;
			}

			if (newPassword.length < 8) {
				this.showFeedback('security', 'La nueva contraseña debe tener al menos 8 caracteres.', 'error');
				return;
			}

			if (newPassword !== confirmPassword) {
				this.showFeedback('security', 'La confirmación no coincide. Verifica ambos campos.', 'error');
				return;
			}

			if (newPassword === currentPassword) {
				this.showFeedback('security', 'La nueva contraseña no puede ser igual a la actual.', 'error');
				return;
			}

			try {
				const data = await this.requestApi(
					'/api/profile/change-password',
					{
						method: 'PUT',
						headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
						body: JSON.stringify({ current_password: currentPassword, new_password: newPassword }),
					},
					'No pudimos actualizar tu contraseña. Intenta nuevamente.'
				);
				this.showFeedback(
					'security',
					this.normalizeSecurityMessage(
						this.readApiMessage(data, 'Tu contraseña se actualizó correctamente.'),
						'success'
					),
					'success'
				);
				this.resetSecurityForm();
			} catch (error) {
				this.showFeedback(
					'security',
					this.normalizeSecurityMessage(
						error instanceof Error
							? error.message
							: 'No pudimos actualizar tu contraseña. Intenta nuevamente.',
						'error'
					),
					'error'
				);
			}
		};

		private handleAppearanceSave = async (event: Event) => {
			event.preventDefault();
			this.clearFeedback();
			if (!this.els.preferencesForm) return;

			const { theme } = this.getPanelAppearanceValues();

			if (!this.isAdmin) {
				this.persistPanelAppearance(theme);
				this.showFeedback('preferences', 'Apariencia guardada correctamente.', 'success');
				return;
			}

			const payload = this.getAppearancePayload();
			payload.panel_theme = theme;
			if (!payload.theme_pref) {
				payload.theme_pref = theme;
			}

			if (this.els.brandingForm) {
				const logoFile = this.els.brandingForm.querySelector<HTMLInputElement>('[name="logo_file"]')?.files?.[0];
				if (logoFile) {
					payload.logo_base64 = await this.fileToBase64(logoFile);
					payload.logo_name = logoFile.name;
					payload.logo_mime = logoFile.type || 'application/octet-stream';
				}
			}

			try {
				const data = await this.requestApi(
					'/api/workspace',
					{
						method: 'PUT',
						headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
						body: JSON.stringify(payload),
					},
					'No fue posible guardar la apariencia.'
				);

				this.persistPanelAppearance(theme);
				this.showFeedback('preferences', this.readApiMessage(data, 'Apariencia guardada correctamente.'), 'success');
				this.reloadAfterWorkspaceSave();
			} catch (error) {
				this.showFeedback('preferences', error instanceof Error ? error.message : 'No fue posible guardar la apariencia.', 'error');
			}
		};

		private async saveWorkspaceSettings(
			panel: string,
			extraPayload: Record<string, string | number | null> = {}
		) {
			this.clearFeedback();
			try {
				const payload = { ...this.getWorkspacePayload(), ...extraPayload };
				const data = await this.requestApi('/api/workspace', {
					method: 'PUT',
					headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
					body: JSON.stringify(payload),
				}, 'No fue posible guardar la configuración.');

				let successMessage = 'Configuración guardada correctamente.';
				if (panel === 'workspace') successMessage = 'Negocio actualizado correctamente.';
				if (panel === 'branding') successMessage = 'Personalización guardada correctamente.';
				if (panel === 'system') successMessage = 'Sistema actualizado correctamente.';

				this.showFeedback(panel, this.readApiMessage(data, successMessage), 'success');
				this.reloadAfterWorkspaceSave();
			} catch (error) {
				let errorMessage = 'No fue posible guardar la configuración.';
				if (panel === 'workspace') errorMessage = 'No fue posible guardar negocio.';
				if (panel === 'branding') errorMessage = 'No fue posible guardar personalización.';
				if (panel === 'system') errorMessage = 'No fue posible guardar sistema.';

				this.showFeedback(panel, error instanceof Error ? error.message : errorMessage, 'error');
			}
		}

		private handleWorkspaceSubmit = async (event: SubmitEvent) => {
			event.preventDefault();
			await this.saveWorkspaceSettings('workspace');
		};

		private handleSystemSubmit = async (event: SubmitEvent) => {
			event.preventDefault();
			this.clearFeedback();

			const validation = this.validateSystemFormPayload();
			if (!validation.ok || !validation.payload) {
				this.showFeedback('system', validation.message || 'Revisa la configuración del sistema.', 'error');
				return;
			}

			await this.saveWorkspaceSettings('system', validation.payload);
		};
	}

	if (!customElements.get('settings-manager')) {
		customElements.define('settings-manager', SettingsManager);
	}
</script>

