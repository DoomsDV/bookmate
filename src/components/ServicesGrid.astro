---
import type { Service } from '../lib/services';

interface Props {
	services: Service[];
	showCreateAction?: boolean;
}

const { services, showCreateAction = false } = Astro.props;

const currencyFormatter = new Intl.NumberFormat('es-PY', {
	style: 'currency',
	currency: 'PYG',
	maximumFractionDigits: 0,
});

const SERVICE_ICON = 'sell';

const toDurationLabel = (value: number) => {
	if (value <= 0) return 'Sin duracion';
	if (value === 60) return '1 hora';
	if (value > 60 && value % 60 === 0) return `${value / 60} horas`;
	return `${value} min`;
};

const cardItems = services.map((service) => ({ service }));

const activeServices = services.filter((item) => item.is_active === 1).length;
---

<section class="rounded-[1.7rem] border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.55)]">
	<div class="flex flex-wrap items-center justify-between gap-3">
		<div class="flex flex-wrap justify-start gap-2 text-xs font-semibold">
			<span class="status-chip-total">
				Total: {services.length}
			</span>
			<span class="status-chip-success">
				Activos: {activeServices}
			</span>
			<span class="status-chip-danger">
				Inactivos: {services.length - activeServices}
			</span>
		</div>

		{
			showCreateAction ? (
				<button
					type="button"
					class="btn-primary-soft inline-flex cursor-pointer items-center gap-2 rounded-xl px-4 py-2.5 text-sm font-semibold transition"
					data-open-service-modal
				>
					<span class="material-symbols-rounded text-[1.1rem]">add</span>
					Nuevo servicio
				</button>
			) : null
		}
	</div>

	{
		services.length === 0 ? (
			<div class="mt-6 rounded-[1.45rem] border border-dashed border-[color:var(--shell-border)] bg-[color:var(--control-surface)] px-5 py-7 text-sm text-[color:var(--on-surface-variant)]">
				No hay servicios registrados para esta organizacion.
			</div>
		) : (
			<div class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
				{
					cardItems.map((item) => (
						<article
							class="cursor-pointer rounded-[1.45rem] border border-[color:var(--shell-border)] bg-[color:var(--card-surface-strong)] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.6)] transition duration-200 hover:-translate-y-0.5 hover:shadow-[0_16px_30px_rgba(15,23,42,0.12)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--primary)]"
							data-service-card
							data-service-id={item.service.id_service}
							tabindex="0"
							role="button"
							aria-label={`Editar servicio ${item.service.name || item.service.id_service}`}
						>
							<div class="flex items-start justify-between gap-3">
								<div class="flex size-10 items-center justify-center rounded-xl bg-[color:var(--primary-soft)] text-[color:var(--primary)]">
									<span class="material-symbols-rounded text-[1rem]">{SERVICE_ICON}</span>
								</div>

								<span
									class:list={[
										'status-pill',
										item.service.is_active === 1
											? 'status-pill-success'
											: 'status-pill-danger',
									]}
								>
									{item.service.is_active === 1 ? 'Activo' : 'Inactivo'}
								</span>
							</div>

							<h3 class="mt-4 text-lg font-semibold leading-6 text-[color:var(--on-surface)]">
								{item.service.name || `Servicio #${item.service.id_service}`}
							</h3>

							<div class="mt-5 space-y-3 text-sm text-[color:var(--on-surface-variant)]">
								<div class="flex items-center justify-between">
									<span>Duracion</span>
									<span class="font-semibold text-[color:var(--on-surface)]">
										{toDurationLabel(item.service.duration_minutes)}
									</span>
								</div>
								<div class="flex items-center justify-between">
									<span>Precio</span>
									<span class="font-semibold text-[color:var(--on-surface)]">
										{currencyFormatter.format(item.service.price)}
									</span>
								</div>
							</div>
						</article>
					))
				}
			</div>
		)
	}
</section>
