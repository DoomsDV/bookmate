---
import type { Service } from '../lib/services';

interface Props {
	services: Service[];
	showCreateAction?: boolean;
}

const { services = [], showCreateAction = false } = Astro.props;

const currencyFormatter = new Intl.NumberFormat('es-PY', {
	style: 'currency',
	currency: 'PYG',
	maximumFractionDigits: 0,
});

const toDurationLabel = (value?: number | null) => {
	if (!value || value <= 0) return '--';
	if (value === 60) return '1 hora';
	if (value > 60 && value % 60 === 0) return `${value / 60} horas`;

	const hours = Math.floor(value / 60);
	const mins = value % 60;
	if (hours > 0) return `${hours} h ${mins} min`;
	return `${value} min`;
};

const activeCount = services.filter((s) => s.is_active === 1).length;
const inactiveCount = services.length - activeCount;
---

<section class="services-view">
	<header class="services-page-header">
		<div class="services-page-top-row">
			<h2 class="services-page-title">Servicios</h2>

			{showCreateAction && (
				<button
					type="button"
					class="services-create-btn flex items-center justify-center gap-2"
					data-open-service-modal
				>
					<svg
						class="services-create-btn-icon w-[18px] h-[18px]"
						viewBox="0 0 24 24"
						fill="none"
						aria-hidden="true"
					>
						<path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" />
					</svg>
					<span>Nuevo Servicio</span>
				</button>
			)}
		</div>

		<div class="services-summary-pills">
			<span class="services-summary-pill services-summary-pill--active">
				<span class="size-2 rounded-full services-summary-dot services-summary-dot--active"></span>
				Activos: {activeCount}
			</span>
			{inactiveCount > 0 && (
				<span class="services-summary-pill services-summary-pill--inactive">
					<span class="size-2 rounded-full services-summary-dot services-summary-dot--inactive"></span>
					Inactivos: {inactiveCount}
				</span>
			)}
		</div>
	</header>

	{services.length === 0 ? (
		<div class="services-empty-state">
			<div class="services-empty-icon">
				<span class="material-symbols-rounded text-[2rem]">inbox</span>
			</div>
			<h3 class="text-[1.1rem] font-bold text-(--on-surface)">No hay servicios registrados</h3>
			<p class="mt-1.5 max-w-sm text-[0.95rem] leading-relaxed text-(--on-surface-variant)">
				Aun no has agregado ningun servicio a esta organizacion. Comienza creando tu primera prestacion.
			</p>
		</div>
	) : (
		<div class="material-cards-grid gap-6 sm:grid-cols-2 sm:gap-8 lg:grid-cols-3">
			{services.map((service) => (
				<article
					class="services-card group cursor-pointer"
					data-service-card
					data-service-id={service.id_service}
					tabindex="0"
					role="button"
					aria-label={`Editar servicio ${service.name || service.id_service}`}
				>
					<div class="flex items-start justify-between gap-4">
						<div class="services-card-icon">
							<span class="material-symbols-rounded text-[1.25rem]">design_services</span>
						</div>

						<span
							class:list={[
								'services-card-status',
								service.is_active === 1
									? 'services-card-status--active'
									: 'services-card-status--inactive',
							]}
						>
							<span
								class:list={[
									'size-1.5 rounded-full',
									service.is_active === 1
										? 'services-summary-dot--active'
										: 'services-summary-dot--inactive',
								]}
							></span>
							{service.is_active === 1 ? 'Activo' : 'Inactivo'}
						</span>
					</div>

					<div class="services-card-body">
						<h3 class="services-card-title">
							{service.name || `Servicio #${service.id_service}`}
						</h3>

						<dl class="services-card-metrics">
							<div class="flex items-center justify-between text-[0.92rem]">
								<dt class="services-card-term">Duracion</dt>
								<dd class="services-card-value">{toDurationLabel(service.duration_minutes)}</dd>
							</div>
							<div class="flex items-center justify-between text-[0.92rem]">
								<dt class="services-card-term">Precio</dt>
								<dd class="services-card-value">
									{service.price ? currencyFormatter.format(service.price) : '--'}
								</dd>
							</div>
						</dl>
					</div>
				</article>
			))}
		</div>
	)}
</section>

<style>
	.services-view {
		display: grid;
		gap: 1.2rem;
	}

	.services-page-header {
		display: grid;
		gap: 0.45rem;
	}

	.services-page-top-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.8rem;
		flex-wrap: wrap;
	}

	.services-page-title {
		margin: 0;
		font-size: clamp(1.35rem, 1.95vw, 1.7rem);
		font-weight: 760;
		letter-spacing: -0.015em;
		color: var(--on-surface);
	}

	.services-summary-pills {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		margin-top: 0.5rem;
	}

	.services-summary-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		border-radius: 999px;
		border: 0;
		padding: 0.33rem 0.78rem;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.01em;
	}

	.services-summary-pill--active {
		background: rgba(16, 185, 129, 0.12);
		color: #0f6d4a;
	}

	.services-summary-pill--inactive {
		background: rgba(244, 63, 94, 0.11);
		color: #8d3e4a;
	}

	.services-summary-dot {
		display: inline-block;
	}

	.services-summary-dot--active {
		background: #22c55e;
	}

	.services-summary-dot--inactive {
		background: #fb7185;
	}

	.services-create-btn {
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--primary) 72%, #123e7a 28%);
		background: var(--primary);
		padding: 0.72rem 1.15rem;
		font-size: 0.92rem;
		font-weight: 780;
		color: #f8fbff;
		box-shadow: none;
		transition: filter 140ms ease, border-color 140ms ease;
	}

	.services-create-btn-icon {
		flex-shrink: 0;
	}

	.services-create-btn:hover {
		filter: brightness(1.04);
	}

	.services-create-btn:focus-visible {
		outline: 2px solid color-mix(in srgb, var(--primary) 42%, white 58%);
		outline-offset: 3px;
	}

	.services-empty-state {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		border-radius: 1.35rem;
		border: 1px solid rgba(148, 163, 184, 0.24);
		background: color-mix(in srgb, var(--surface-container-low) 72%, var(--surface-bright) 28%);
		padding: 2.5rem 1.25rem;
		text-align: center;
	}

	.services-empty-icon {
		margin-bottom: 1rem;
		display: flex;
		height: 4rem;
		width: 4rem;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		background: color-mix(in srgb, var(--surface-container) 88%, var(--surface-bright) 12%);
		color: var(--on-surface-variant);
	}

	.services-card {
		display: flex;
		flex-direction: column;
		gap: 0.95rem;
		border-radius: 1.2rem;
		border: 0;
		background: color-mix(in srgb, var(--surface-container-low) 76%, var(--surface-bright) 24%);
		padding: 1.45rem 1.5rem 1.55rem;
		box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.08);
		transition: transform 170ms ease, box-shadow 170ms ease, background-color 170ms ease;
	}

	.services-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 14px 44px -12px rgba(0, 0, 0, 0.1);
	}

	.services-card:focus-visible {
		outline: 2px solid color-mix(in srgb, var(--primary) 55%, #ffffff 45%);
		outline-offset: 2px;
	}

	.services-card-icon {
		display: inline-flex;
		height: 2.75rem;
		width: 2.75rem;
		flex-shrink: 0;
		align-items: center;
		justify-content: center;
		border-radius: 0.85rem;
		background: color-mix(in srgb, var(--primary) 15%, transparent);
		color: var(--primary);
	}

	.services-card-status {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		border-radius: 999px;
		border: 0;
		padding: 0.24rem 0.6rem;
		font-size: 0.66rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		white-space: nowrap;
	}

	.services-card-status--active {
		background: rgba(16, 185, 129, 0.12);
		color: #0f6d4a;
	}

	.services-card-status--inactive {
		background: rgba(244, 63, 94, 0.11);
		color: #8d3e4a;
	}

	.services-card-body {
		display: grid;
		gap: 0.85rem;
	}

	.services-card-title {
		margin: 0;
		font-size: 1.1rem;
		font-weight: 760;
		line-height: 1.3;
		letter-spacing: -0.01em;
		color: var(--on-surface);
	}

	.services-card-metrics {
		margin: 0;
		display: grid;
		gap: 0.5rem;
	}

	.services-card-term {
		color: var(--on-surface-variant);
		font-weight: 500;
	}

	.services-card-value {
		font-weight: 700;
		color: color-mix(in srgb, var(--on-surface-variant) 74%, var(--on-surface) 26%);
		text-align: right;
	}

	html[data-theme='dark'] .services-summary-pill--active {
		background: rgba(110, 231, 183, 0.16);
		color: #b8f5d5;
	}

	html[data-theme='dark'] .services-summary-pill--inactive {
		background: rgba(255, 182, 193, 0.12);
		color: #ffc8d2;
	}

	html[data-theme='dark'] .services-create-btn {
		border-color: color-mix(in srgb, var(--primary) 58%, #0f172a 42%);
		background: color-mix(in srgb, var(--primary) 78%, #0f172a 22%);
	}

	html[data-theme='dark'] .services-create-btn:hover {
		filter: brightness(1.08);
	}

	html[data-theme='dark'] .services-empty-state {
		border-color: rgba(255, 255, 255, 0.08);
		background: color-mix(
			in srgb,
			var(--surface-container-low, #171d28) 82%,
			var(--surface-container, #141923) 18%
		);
	}

	html[data-theme='dark'] .services-empty-icon {
		background: rgba(255, 255, 255, 0.05);
		color: var(--on-surface-variant);
	}

	html[data-theme='dark'] .services-card {
		border: 1px solid color-mix(in srgb, var(--shell-border) 86%, transparent);
		background: color-mix(in srgb, var(--surface-container-low, #171d28) 78%, var(--surface-container, #141923) 22%);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
	}

	html[data-theme='dark'] .services-card:hover {
		border-color: color-mix(in srgb, var(--shell-border) 96%, transparent);
		background: color-mix(in srgb, var(--surface-container-low, #171d28) 70%, var(--surface-container, #141923) 30%);
	}

	html[data-theme='dark'] .services-card-status--active {
		background: rgba(110, 231, 183, 0.16);
		color: #b8f5d5;
	}

	html[data-theme='dark'] .services-card-status--inactive {
		background: rgba(255, 182, 193, 0.12);
		color: #ffc8d2;
	}

	html[data-theme='dark'] .services-card-value {
		color: color-mix(in srgb, var(--on-surface-variant) 86%, #d1d5db 14%);
	}

	:global(div:has(> nav[aria-label='Paginacion servicios'])) {
		background: transparent !important;
		border: 0 !important;
		box-shadow: none !important;
		backdrop-filter: none !important;
		padding-inline: 0 !important;
		padding-top: 0.25rem !important;
		padding-bottom: 0 !important;
		margin-top: 2rem !important;
	}

	:global(div:has(> nav[aria-label='Paginacion servicios']) > p) {
		color: var(--on-surface-variant) !important;
		white-space: nowrap !important;
	}

	:global(nav[aria-label='Paginacion servicios']) {
		width: 100%;
		justify-content: center;
	}

	html[data-theme='dark'] :global(nav[aria-label='Paginacion servicios'] a) {
		color: #94a3b8 !important;
		background: rgba(255, 255, 255, 0.03) !important;
		border: 1px solid rgba(255, 255, 255, 0.08);
	}

	html[data-theme='dark'] :global(nav[aria-label='Paginacion servicios'] a:hover) {
		color: #e2e8f0 !important;
		background: rgba(255, 255, 255, 0.08) !important;
	}

	html[data-theme='dark'] :global(nav[aria-label='Paginacion servicios'] a:active) {
		color: #f8fafc !important;
		background: rgba(255, 255, 255, 0.12) !important;
	}

	html[data-theme='dark'] :global(nav[aria-label='Paginacion servicios'] span.cursor-not-allowed) {
		color: #94a3b8 !important;
		background: rgba(255, 255, 255, 0.04) !important;
		border: 1px solid rgba(255, 255, 255, 0.08);
	}

	@media (min-width: 640px) {
		:global(nav[aria-label='Paginacion servicios']) {
			justify-content: flex-end;
		}
	}
</style>
