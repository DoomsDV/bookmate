---
interface Props {
	error?: string;
	identifier?: string;
	identifierError?: string;
	passwordError?: string;
}

const { error = '', identifier = '', identifierError = '', passwordError = '' } = Astro.props;
---

<section class="grid min-h-screen bg-(--page-background) lg:grid-cols-2">
	<div class="relative hidden overflow-hidden border-b border-(--shell-border) bg-(--shell-surface) lg:block lg:border-b-0 lg:border-r">
		<div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(102,167,255,0.12),transparent_34%),radial-gradient(circle_at_bottom_right,rgba(47,111,221,0.08),transparent_30%)]"></div>

		<div class="relative flex h-full items-center px-5 py-10 sm:px-8 lg:px-12 xl:px-16">
			<div class="max-w-2xl">
				<p class="text-[0.72rem] font-bold uppercase tracking-[0.3em] text-(--on-surface-variant)/80">
					Plataforma Bookmate
				</p>
				<h1 class="mt-5 text-4xl font-extrabold tracking-[-0.05em] text-(--on-surface) sm:text-5xl xl:text-6xl">
					Acceso al Portal Empresarial
				</h1>
				<p class="mt-6 max-w-xl text-base leading-8 text-(--on-surface-variant) sm:text-lg">
					El acceso a la plataforma está restringido a usuarios autorizados. 
					Utilice sus credenciales corporativas para ingresar al sistema.
				</p>

				<div class="mt-10 max-w-xl rounded-[1.8rem] border border-(--shell-border) bg-(--card-surface) p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.55)]">
					<p class="text-xs font-bold uppercase tracking-[0.22em] text-(--on-surface-variant)/75">
						Uso Exclusivo
					</p>
					<p class="mt-4 text-xl font-semibold text-(--on-surface)">
						Entorno Corporativo Seguro
					</p>
					<p class="mt-3 text-sm leading-7 text-(--on-surface-variant)">
						Las credenciales de acceso son administradas de forma centralizada. 
						Contacte al administrador del sistema para gestionar su cuenta.
					</p>
				</div>
			</div>
		</div>
	</div>

	<div class="flex items-center justify-center px-5 py-8 sm:px-8 lg:px-10 xl:px-14">
		<div class="w-full rounded-4xl border border-(--shell-border) bg-(--card-surface-strong) p-6 shadow-[0_24px_60px_rgba(15,23,42,0.12)] sm:p-8 lg:max-w-none">
			<div class="mb-8">
				<a
					href="/"
					class="inline-flex items-center gap-2 text-sm font-semibold text-(--on-surface-variant) no-underline"
				>
					<span class="material-symbols-rounded text-[1rem]">west</span>
					Volver
				</a>

				<p class="mt-6 text-[0.72rem] font-bold uppercase tracking-[0.3em] text-(--on-surface-variant)/80">
					Bookmate
				</p>
				<h2 class="mt-3 text-3xl font-extrabold tracking-[-0.04em] text-(--on-surface) sm:text-4xl">
					Iniciar sesión
				</h2>
				<p class="mt-3 max-w-xl text-sm leading-7 text-(--on-surface-variant) sm:text-base">
					Ingrese sus credenciales de acceso proporcionadas por su administrador.
				</p>
			</div>

			<form class="grid gap-5" method="post" action="/api/auth/login" data-astro-reload>
				{
					error && (
						<div class="rounded-[1.25rem] border border-red-300/70 bg-red-50 px-4 py-3 text-sm text-red-700">
							{error}
						</div>
					)
				}

				<label class="grid gap-2">
					<span class="text-sm font-semibold text-(--on-surface)">Correo electrónico o usuario</span>
					<input
						type="text"
						name="identifier"
						value={identifier}
						placeholder="usuario@empresa.com"
						class:list={[
							'rounded-2xl border bg-(--control-surface) px-4 py-3 text-sm text-(--on-surface) outline-none transition placeholder:text-(--on-surface-variant)/70 focus:ring-2 focus:ring-(--primary)/15',
							identifierError
								? 'border-red-300 focus:border-red-400'
								: 'border-(--shell-border) focus:border-(--primary)',
						]}
					/>
					{
						identifierError && (
							<span class="text-sm text-red-600">
								{identifierError}
							</span>
						)
					}
				</label>

				<label class="grid gap-2">
					<span class="text-sm font-semibold text-(--on-surface)">Contraseña</span>
					<input
						type="password"
						name="password"
						placeholder="********"
						class:list={[
							'rounded-2xl border bg-(--control-surface) px-4 py-3 text-sm text-(--on-surface) outline-none transition placeholder:text-(--on-surface-variant)/70 focus:ring-2 focus:ring-(--primary)/15',
							passwordError
								? 'border-red-300 focus:border-red-400'
								: 'border-(--shell-border) focus:border-(--primary)',
						]}
					/>
					{
						passwordError && (
							<span class="text-sm text-red-600">
								{passwordError}
							</span>
						)
					}
				</label>

				<div class="flex items-center justify-between gap-3">
					<label class="inline-flex items-center gap-3 text-sm text-(--on-surface-variant)">
						<input
							type="checkbox"
							name="remember"
							class="size-4 rounded border border-(--shell-border) text-(--primary) focus:ring-(--primary)"
						/>
						Recordar credenciales
					</label>

					<a href="#" class="text-sm font-semibold text-(--primary) no-underline">
						Soporte técnico
					</a>
				</div>

				<button
					type="submit"
					class="btn-primary-soft mt-2 rounded-2xl px-4 py-3 text-sm font-bold transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-(--primary) focus-visible:ring-offset-2"
				>
					Acceder al sistema
				</button>
			</form>

			<div class="mt-6 rounded-[1.4rem] border border-(--shell-border) bg-(--control-surface) px-4 py-4">
				<p class="text-sm font-semibold text-(--on-surface)">
					¿No cuenta con credenciales?
				</p>
				<p class="mt-2 text-sm leading-6 text-(--on-surface-variant)">
					Póngase en contacto con el administrador del sistema de su organización 
					para solicitar acceso a la plataforma.
				</p>
			</div>
		</div>
	</div>
</section>
