---
const hasSession = Boolean(Astro.locals.token ?? '');
---

{
	hasSession ? (
		<script>
			import {
				FCM_DEVICE_TOKEN_STORAGE_KEY,
				FCM_PROMPT_SHOWN_SESSION_KEY,
				isInstalledPwaContext,
				refreshPushTokenSilently,
				runInitialFcmPromptIfNeeded,
			} from '../lib/fcm-client';

			const logoutAfterAppInstalled = async () => {
				if ((window as any).__bookmateInstallLogoutRunning) return;
				(window as any).__bookmateInstallLogoutRunning = true;

				const localToken = String(
					localStorage.getItem(FCM_DEVICE_TOKEN_STORAGE_KEY) || ''
				).trim();

				try {
					await fetch('/api/auth/logout', {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json',
							Accept: 'application/json',
						},
						body: JSON.stringify({
							fcm_token: localToken,
						}),
					});
				} catch {
					// Even if API logout fails, force local cleanup and redirect.
				} finally {
					localStorage.removeItem(FCM_DEVICE_TOKEN_STORAGE_KEY);
					sessionStorage.removeItem(FCM_PROMPT_SHOWN_SESSION_KEY);
					window.location.assign('/auth/login');
				}
			};

			const initializeFcmManager = async () => {
				if ((window as any).__bookmateFcmManagerRunning) return;
				(window as any).__bookmateFcmManagerRunning = true;

				try {
					if (!isInstalledPwaContext()) return;

					const handledPrompt = await runInitialFcmPromptIfNeeded();
					if (!handledPrompt) {
						await refreshPushTokenSilently();
					}
				} finally {
					(window as any).__bookmateFcmManagerRunning = false;
				}
			};

			void initializeFcmManager();

			if (!(window as any).__bookmateAppInstalledLogoutBound) {
				window.addEventListener('appinstalled', () => {
					void logoutAfterAppInstalled();
				});
				(window as any).__bookmateAppInstalledLogoutBound = true;
			}

			if (!(window as any).__bookmateFcmManagerBound) {
				document.addEventListener('astro:page-load', () => {
					void initializeFcmManager();
				});
				(window as any).__bookmateFcmManagerBound = true;
			}

			document.addEventListener('bookmate:fcm-state-changed', () => {
				void refreshPushTokenSilently();
			});
		</script>
	) : null
}
