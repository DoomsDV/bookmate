---
const hasSession = Boolean(Astro.locals.token ?? '');
---

{
	hasSession ? (
		<script>
			import { getFcmTokenFromFirebase } from '../scripts/firebase-messaging';

			const FCM_PROMPT_COOKIE_KEY = 'fcm_prompt_pending';
			const FCM_DEVICE_TOKEN_STORAGE_KEY = 'hasel:fcm:device-token';
			const FCM_PROMPT_SHOWN_SESSION_KEY = 'hasel:fcm:prompt-shown';

			const isInstalledPwaContext = () => {
				const isStandaloneDisplayMode = window.matchMedia(
					'(display-mode: standalone)'
				).matches;
				const isIosStandalone = Boolean(
					(
						window.navigator as Navigator & {
							standalone?: boolean;
						}
					).standalone
				);
				const isAndroidTwa = document.referrer.startsWith('android-app://');

				return isStandaloneDisplayMode || isIosStandalone || isAndroidTwa;
			};

			const readCookie = (name: string) => {
				const pattern = new RegExp(
					`(?:^|; )${name.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}=([^;]*)`
				);
				const match = document.cookie.match(pattern);
				return match ? decodeURIComponent(match[1]) : '';
			};

			const clearCookie = (name: string) => {
				document.cookie = `${name}=; Max-Age=0; path=/; SameSite=Lax`;
			};

			const showNotificationAlert = async (title: string, message: string) => {
				if (window.BookmateAlert?.alert) {
					await window.BookmateAlert.alert({
						type: 'info',
						title,
						message,
						confirmText: 'Entendido',
					});
					return;
				}

				window.alert(message);
			};

			const askNotificationConsent = async () => {
				const message =
					'¿Querés activar notificaciones para recibir avisos de nuevas citas y recordatorios en este dispositivo?';
				if (window.BookmateAlert?.confirm) {
					return window.BookmateAlert.confirm({
						type: 'info',
						title: 'Activar notificaciones',
						message,
						confirmText: 'Activar',
						cancelText: 'Ahora no',
					});
				}
				return window.confirm(message);
			};

			const inferPlatform = () => {
				const userAgent = window.navigator.userAgent.toLowerCase();
				if (userAgent.includes('android')) return 'android';
				if (
					userAgent.includes('iphone') ||
					userAgent.includes('ipad') ||
					userAgent.includes('ios')
				) {
					return 'ios';
				}
				return 'web';
			};

			const subscribeCurrentDevice = async (fcmToken: string) => {
				const response = await fetch('/api/fcm/subscribe', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
						Accept: 'application/json',
					},
					body: JSON.stringify({
						fcm_token: fcmToken,
						platform: inferPlatform(),
					}),
				});

				const payload = await response.json().catch(() => ({}));
				if (!response.ok || payload?.status !== 'success') {
					throw new Error(payload?.message || 'No fue posible activar las notificaciones.');
				}
			};

			const requestNotificationPermission = async () => {
				if (!('Notification' in window)) {
					await showNotificationAlert(
						'Notificaciones no disponibles',
						'Este navegador no soporta notificaciones push.'
					);
					return 'unsupported';
				}

				if (Notification.permission === 'granted') return 'granted';

				const accepted = await askNotificationConsent();
				if (!accepted) return 'rejected';

				return Notification.requestPermission();
			};

			const resolveAndSyncDeviceToken = async (options?: { forceSubscribe?: boolean; silent?: boolean }) => {
				const forceSubscribe = Boolean(options?.forceSubscribe);
				const silent = Boolean(options?.silent);
				const storedToken = String(localStorage.getItem(FCM_DEVICE_TOKEN_STORAGE_KEY) || '').trim();

				let firebaseToken = '';
				try {
					firebaseToken = await getFcmTokenFromFirebase();
				} catch (error) {
					if (storedToken) return storedToken;
					if (silent) return '';
					throw error;
				}

				const resolvedToken = String(firebaseToken || storedToken).trim();
				if (!resolvedToken) return '';

				const tokenChanged = resolvedToken !== storedToken;
				if (tokenChanged) {
					localStorage.setItem(FCM_DEVICE_TOKEN_STORAGE_KEY, resolvedToken);
				}

				if (forceSubscribe || tokenChanged) {
					await subscribeCurrentDevice(resolvedToken);
				}

				return resolvedToken;
			};

			const initializeNotificationSubscription = async () => {
				const promptPending = readCookie(FCM_PROMPT_COOKIE_KEY) === '1';
				if (!promptPending) return false;

				if (sessionStorage.getItem(FCM_PROMPT_SHOWN_SESSION_KEY) === '1') return true;
				sessionStorage.setItem(FCM_PROMPT_SHOWN_SESSION_KEY, '1');

				try {
					const permission = await requestNotificationPermission();
					if (permission !== 'granted') return true;

					const deviceToken = await resolveAndSyncDeviceToken({
						forceSubscribe: true,
					});
					if (!deviceToken) {
						await showNotificationAlert(
							'No se pudo suscribir',
							'No se obtuvo el token FCM de Firebase para este dispositivo.'
						);
					}
				} catch (error) {
					const message =
						error instanceof Error ? error.message : 'No fue posible activar las notificaciones.';
					await showNotificationAlert('Notificaciones', message);
				} finally {
					clearCookie(FCM_PROMPT_COOKIE_KEY);
				}

				return true;
			};

			const refreshRotatedTokenSilently = async () => {
				if (!('Notification' in window)) return;
				if (Notification.permission !== 'granted') return;

				try {
					await resolveAndSyncDeviceToken({
						forceSubscribe: false,
						silent: true,
					});
				} catch {
					// Keep silent refresh non-blocking.
				}
			};

			const logoutAfterAppInstalled = async () => {
				if ((window as any).__bookmateInstallLogoutRunning) return;
				(window as any).__bookmateInstallLogoutRunning = true;

				const localToken = String(
					localStorage.getItem(FCM_DEVICE_TOKEN_STORAGE_KEY) || ''
				).trim();

				try {
					await fetch('/api/auth/logout', {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json',
							Accept: 'application/json',
						},
						body: JSON.stringify({
							fcm_token: localToken,
						}),
					});
				} catch {
					// Even if API logout fails, force local cleanup and redirect.
				} finally {
					localStorage.removeItem(FCM_DEVICE_TOKEN_STORAGE_KEY);
					sessionStorage.removeItem(FCM_PROMPT_SHOWN_SESSION_KEY);
					window.location.assign('/auth/login');
				}
			};

			const initializeFcmManager = async () => {
				if ((window as any).__bookmateFcmManagerRunning) return;
				(window as any).__bookmateFcmManagerRunning = true;

				try {
					if (!isInstalledPwaContext()) return;

					const handledPrompt = await initializeNotificationSubscription();
					if (!handledPrompt) {
						await refreshRotatedTokenSilently();
					}
				} finally {
					(window as any).__bookmateFcmManagerRunning = false;
				}
			};

			void initializeFcmManager();

			if (!(window as any).__bookmateAppInstalledLogoutBound) {
				window.addEventListener('appinstalled', () => {
					void logoutAfterAppInstalled();
				});
				(window as any).__bookmateAppInstalledLogoutBound = true;
			}

			if (!(window as any).__bookmateFcmManagerBound) {
				document.addEventListener('astro:page-load', () => {
					void initializeFcmManager();
				});
				(window as any).__bookmateFcmManagerBound = true;
			}
		</script>
	) : null
}
