---
import type { OrgSpecialtyOption } from '../lib/auth';

interface Props {
	error?: string;
	step?: string;
	firstName?: string;
	lastName?: string;
	email?: string;
	businessName?: string;
	phone?: string;
	companyEmail?: string;
	orgSpecialtyId?: string;
	orgSpecialties?: OrgSpecialtyOption[];
	specialtiesLoadError?: string;
	firstNameError?: string;
	lastNameError?: string;
	emailError?: string;
	passwordError?: string;
	businessNameError?: string;
	phoneError?: string;
	companyEmailError?: string;
	orgSpecialtyIdError?: string;
}

const {
	error = '',
	step = 'admin',
	firstName = '',
	lastName = '',
	email = '',
	businessName = '',
	phone = '',
	companyEmail = '',
	orgSpecialtyId = '',
	orgSpecialties = [],
	specialtiesLoadError = '',
	firstNameError = '',
	lastNameError = '',
	emailError = '',
	passwordError = '',
	businessNameError = '',
	phoneError = '',
	companyEmailError = '',
	orgSpecialtyIdError = '',
} = Astro.props;

const normalizeStep = (value: string) =>
	String(value || '').trim().toLowerCase() === 'organization' ? 'organization' : 'admin';

const currentStep = normalizeStep(step);
---

<section class="m3-container auth-dark">
	<aside class="m3-sidebar">
		<div class="m3-sidebar-inner">
			<div class="m3-brand">
				<a href="/" class="m3-brand-link" aria-label="Ir al inicio">
					<img src="/icon-512x512.png" alt="Hasel Logo" class="m3-logo" />
				</a>
			</div>

			<div class="m3-stepper-header">
				<h2 class="m3-step-maintitle" data-sidebar-title>Paso 1</h2>
				<p class="m3-step-maindesc" data-sidebar-desc>
					Ingresa tu información personal para comenzar con la configuración de tu espacio.
				</p>
			</div>

			<div class="m3-vertical-stepper">
				<div class="m3-step" data-step-indicator="admin" class:list={[{ 'is-active': currentStep === 'admin' }]}>
					<div class="m3-step-node">1</div>
					<div class="m3-step-content">
						<span class="m3-step-label">Datos del Administrador</span>
					</div>
					<div class="m3-step-line"></div>
				</div>

				<div class="m3-step" data-step-indicator="organization" class:list={[{ 'is-active': currentStep === 'organization' }]}>
					<div class="m3-step-node">2</div>
					<div class="m3-step-content">
						<span class="m3-step-label">Datos de Organización</span>
					</div>
				</div>
			</div>
		</div>
	</aside>

	<main class="m3-content">
		<div class="m3-form-wrapper">
			<div class="m3-form-header">
				<div class="m3-panel-icon" data-panel-icon>
					<span class="material-symbols-rounded">person</span>
				</div>
				<div class="m3-panel-titles">
					<h3 class="m3-panel-title" data-panel-title>Tus datos personales</h3>
					<p class="m3-panel-subtitle" data-panel-desc>Al crear el espacio, se te asignará el rol de administrador de la organización</p>
				</div>
			</div>

			<div
				class:list={['m3-error-banner', !error && 'is-hidden']}
				data-error-banner
				role="alert"
				aria-live="polite"
			>
				<span class="material-symbols-rounded">error</span>
				<span data-error-text>{error}</span>
			</div>

			<form method="post" action="/api/auth/register" data-register-form data-initial-step={currentStep}>
				<input type="hidden" name="step" value={currentStep} data-step-input />

				<!-- PANEL: ADMIN -->
				<div data-step-panel="admin" class:list={['m3-panel', currentStep !== 'admin' && 'is-hidden']}>
					<div class="m3-grid-2">
						<div class="m3-field">
							<label class="m3-label" for="first_name">Nombres <span class="m3-label-required">*</span></label>
							<input type="text" id="first_name" name="first_name" class:list={['m3-input', firstNameError && 'is-invalid']} placeholder="Ej: Juan" value={firstName} autocomplete="given-name" required />
							{firstNameError && <span class="m3-field-error">{firstNameError}</span>}
						</div>
						<div class="m3-field">
							<label class="m3-label" for="last_name">Apellidos <span class="m3-label-required">*</span></label>
							<input type="text" id="last_name" name="last_name" class:list={['m3-input', lastNameError && 'is-invalid']} placeholder="Ej: Pérez" value={lastName} autocomplete="family-name" required />
							{lastNameError && <span class="m3-field-error">{lastNameError}</span>}
						</div>
					</div>

					<div class="m3-grid-2">
						<div class="m3-field">
							<label class="m3-label" for="email">Correo electrónico <span class="m3-label-required">*</span></label>
							<input type="email" id="email" name="email" class:list={['m3-input', emailError && 'is-invalid']} placeholder="Ej: juan@empresa.com" value={email} autocomplete="email" autocapitalize="none" spellcheck="false" required />
							{emailError && <span class="m3-field-error">{emailError}</span>}
						</div>
						<div class="m3-field">
							<label class="m3-label" for="password">Contraseña <span class="m3-label-required">*</span></label>
							<div class="m3-input-affix">
								<input type="password" id="password" name="password" class:list={['m3-input', passwordError && 'is-invalid']} placeholder="Tu contraseña" autocomplete="new-password" required />
								<button type="button" class="m3-icon-btn" data-password-toggle aria-label="Mostrar contraseña">
									<span class="material-symbols-rounded" data-password-icon>visibility_off</span>
								</button>
							</div>
							<div class="m3-password-strength is-hidden" data-password-strength aria-live="polite">
								<div class="m3-password-strength-bars">
									<span class="m3-password-strength-segment" data-password-segment></span>
									<span class="m3-password-strength-segment" data-password-segment></span>
									<span class="m3-password-strength-segment" data-password-segment></span>
									<span class="m3-password-strength-segment" data-password-segment></span>
								</div>
								<p class="m3-password-strength-text" data-password-strength-text>Poco segura</p>
							</div>
							{passwordError && <span class="m3-field-error">{passwordError}</span>}
						</div>
					</div>

					<div class="m3-actions m3-actions--between">
						<a
							href="/auth/login?redirectTo=%2Fauth%2Fcreate-organization"
							class="m3-link-accent m3-link-accent--inline"
						>
							¿Ya tienes una cuenta? <strong>Crea tu organización</strong>
						</a>
						<button type="button" data-next-step class="m3-btn-primary">
							Siguiente Paso
						</button>
					</div>
				</div>

				<!-- PANEL: ORGANIZATION -->
				<div data-step-panel="organization" class:list={['m3-panel', currentStep !== 'organization' && 'is-hidden']}>
					<div class="m3-grid-2">
						<div class="m3-field">
							<label class="m3-label" for="business_name">Nombre de la Organización <span class="m3-label-required">*</span></label>
							<input type="text" id="business_name" name="business_name" class:list={['m3-input', businessNameError && 'is-invalid']} placeholder="Ej: Clínica Dental San José" value={businessName} autocomplete="organization" required />
							<p class="m3-field-help">Este será el nombre de tu organización o como te verán las personas.</p>
							{businessNameError && <span class="m3-field-error">{businessNameError}</span>}
						</div>
						<div class="m3-field">
							<label class="m3-label" for="company_email">Correo de la compañía <span class="m3-label-required">*</span></label>
							<input type="email" id="company_email" name="company_email" class:list={['m3-input', companyEmailError && 'is-invalid']} placeholder="Ej: contacto@tuempresa.com" value={companyEmail} autocomplete="email" autocapitalize="none" spellcheck="false" required />
							<p class="m3-field-help">Este correo será el contacto principal de tu organización para notificaciones y comunicación institucional.</p>
							{companyEmailError && <span class="m3-field-error">{companyEmailError}</span>}
						</div>
					</div>

					<div class="m3-grid-2">
						<div class="m3-field">
							<label class="m3-label" for="phone">Teléfono de corporativo <span class="m3-label-required">*</span></label>
							<div class:list={['m3-phone-group', phoneError && 'is-invalid']}>
								<span class="m3-phone-prefix">+595</span>
								<input
									type="tel"
									id="phone"
									name="phone"
									inputmode="numeric"
									autocomplete="tel-national"
									maxlength="11"
									class:list={['m3-input', 'm3-phone-input', phoneError && 'is-invalid']}
									placeholder="981 123 456"
									value={phone}
									autocapitalize="none"
									spellcheck="false"
									required
								/>
							</div>
							{phoneError && <span class="m3-field-error">{phoneError}</span>}
						</div>
						<div class="m3-field">
							<label class="m3-label" for="id_org_specialty">Especialidad de la organización <span class="m3-label-required">*</span></label>
							<select
								id="id_org_specialty"
								name="id_org_specialty"
								class:list={['m3-input', 'm3-select', orgSpecialtyIdError && 'is-invalid']}
								required
								disabled={orgSpecialties.length === 0}
							>
								<option value="">Selecciona una especialidad</option>
								{orgSpecialties.map((specialty) => (
									<option value={String(specialty.id_org_specialty)} selected={String(specialty.id_org_specialty) === orgSpecialtyId}>
										{specialty.name}
									</option>
								))}
							</select>

							{specialtiesLoadError && <span class="m3-field-error">{specialtiesLoadError}</span>}
							{orgSpecialtyIdError && <span class="m3-field-error">{orgSpecialtyIdError}</span>}
						</div>
					</div>

					<div class="m3-actions m3-actions--between">
						<button type="button" data-prev-step class="m3-btn-tonal">
							Atrás
						</button>
						<button type="submit" class="m3-btn-primary" disabled={orgSpecialties.length === 0}>
							Finalizar Registro
						</button>
					</div>
				</div>
			</form>

			<div class="m3-card-footer">
				<div class="m3-footer-divider"></div>
				<a href="/auth/login" class="m3-link-accent">
					¿Solo quieres entrar? <strong>Iniciar sesión</strong>
				</a>
			</div>
		</div>
	</main>
</section>

<script is:inline>
	function setupRegisterForm() {
		const form = document.querySelector('[data-register-form]');
		if (!form || form.dataset.enhanced) return;
		form.dataset.enhanced = 'true';

		const formWrapper = form.closest('.m3-form-wrapper');
		const errorBanner = formWrapper?.querySelector('[data-error-banner]');
		const errorText = formWrapper?.querySelector('[data-error-text]');
		const stepInput = form.querySelector('[data-step-input]');
		const orgPhoneInput = form.querySelector('[name="phone"]');
		const passwordInput = form.querySelector('input[name="password"]');
		const passwordStrength = form.querySelector('[data-password-strength]');
		const passwordStrengthText = form.querySelector('[data-password-strength-text]');
		const passwordSegments = form.querySelectorAll('[data-password-segment]');
		const submitButton = form.querySelector('button[type="submit"]');
		const panels = {
			admin: form.querySelector('[data-step-panel="admin"]'),
			organization: form.querySelector('[data-step-panel="organization"]')
		};
		const indicators = form.closest('.m3-container').querySelectorAll('[data-step-indicator]');
		
		// DOM Texts to update
		const sidebarTitle = document.querySelector('[data-sidebar-title]');
		const sidebarDesc = document.querySelector('[data-sidebar-desc]');
		const panelIcon = document.querySelector('[data-panel-icon] span');
		const panelTitle = document.querySelector('[data-panel-title]');
		const panelDesc = document.querySelector('[data-panel-desc]');

		let currentStep = stepInput?.value || 'admin';

		const textMap = {
			admin: {
				sbt: 'Paso 1',
				sbd: 'Ingresa tu información personal para comenzar con la configuración de tu espacio.',
				pi: 'person',
				pt: 'Tus datos personales',
				pd: 'Al crear el espacio, se te asignará el rol de administrador de la organización'
			},
			organization: {
				sbt: 'Paso 2',
				sbd: 'Configuremos los detalles de tu organización y tu espacio de trabajo principal.',
				pi: 'domain',
				pt: 'Datos de Organización',
				pd: 'Completa el contacto corporativo y la especialidad principal de tu organización'
			}
		};

		const toParaguayLocalPhoneDigits = (rawValue) => {
			let digits = String(rawValue || '').replace(/\D/g, '');
			if (digits.startsWith('00595')) digits = digits.slice(5);
			if (digits.startsWith('595')) digits = digits.slice(3);
			if (digits.startsWith('0')) digits = digits.slice(1);
			return digits.slice(0, 9);
		};

		const formatParaguayLocalPhone = (rawValue) => {
			const digits = toParaguayLocalPhoneDigits(rawValue);
			if (!digits) return '';
			if (digits.length <= 3) return digits;
			if (digits.length <= 6) return `${digits.slice(0, 3)} ${digits.slice(3)}`;
			return `${digits.slice(0, 3)} ${digits.slice(3, 6)} ${digits.slice(6, 9)}`;
		};

		const toParaguayE164Phone = (rawValue) => {
			const digits = toParaguayLocalPhoneDigits(rawValue);
			return digits ? `+595${digits}` : '';
		};

		const setErrorMessage = (message) => {
			const cleanMessage = String(message || '').trim() || 'No fue posible completar el registro.';
			if (errorText) errorText.textContent = cleanMessage;
			errorBanner?.classList.remove('is-hidden');
		};

		const clearErrorMessage = () => {
			if (errorText) errorText.textContent = '';
			errorBanner?.classList.add('is-hidden');
		};

		const normalizeErrorText = (value) => {
			if (typeof value === 'string' && value.trim()) return value.trim();
			if (!value || typeof value !== 'object') return '';
			if (typeof value.message === 'string' && value.message.trim()) return value.message.trim();
			if (typeof value.error === 'string' && value.error.trim()) return value.error.trim();
			try {
				return JSON.stringify(value);
			} catch {
				return '';
			}
		};

		const getServerErrorMessage = (data) => {
			const fieldErrors = Array.isArray(data?.fieldErrors)
				? data.fieldErrors
				: (Array.isArray(data?.errors) ? data.errors : []);
			return (
				normalizeErrorText(data?.error) ||
				normalizeErrorText(data?.message) ||
				normalizeErrorText(fieldErrors[0]?.message) ||
				normalizeErrorText(data?.details) ||
				'No fue posible completar el registro.'
			);
		};

		const readJsonResponse = async (response) => {
			const responseText = await response.text();
			if (!responseText.trim()) return {};
			try {
				return JSON.parse(responseText);
			} catch {
				return { error: responseText };
			}
		};

		const getPasswordValidationMessage = (rawPassword) => {
			const password = String(rawPassword || '');
			if (password.trim().length < 8) {
				return 'La contraseña debe tener al menos 8 caracteres.';
			}
			if (!/[A-Z]/.test(password)) {
				return 'La contraseña debe contener al menos una letra mayúscula.';
			}
			if (!/[0-9]/.test(password)) {
				return 'La contraseña debe contener al menos un número.';
			}
			return '';
		};

		const getPasswordStrengthState = (rawPassword) => {
			const password = String(rawPassword || '');
			const trimmedLength = password.trim().length;
			const hasUppercase = /[A-Z]/.test(password);
			const hasNumber = /[0-9]/.test(password);
			const hasSpecial = /[^A-Za-z0-9]/.test(password);

			if (!password) return { level: 0, tone: 'weak', label: '' };
			if (trimmedLength < 8) return { level: 1, tone: 'weak', label: 'Muy débil' };
			if (!hasUppercase) return { level: 2, tone: 'warning', label: 'Poco segura' };
			if (!hasNumber) return { level: 3, tone: 'warning', label: 'Media' };
			if (trimmedLength >= 12 && hasSpecial) return { level: 4, tone: 'strong', label: 'Fuerte' };
			return { level: 4, tone: 'good', label: 'Segura' };
		};

		const renderPasswordStrength = (rawPassword) => {
			if (!passwordStrength || !passwordStrengthText || passwordSegments.length === 0) return;

			const state = getPasswordStrengthState(rawPassword);
			passwordStrength.classList.toggle('is-hidden', state.level === 0);
			passwordStrength.dataset.tone = state.tone;
			passwordStrengthText.textContent = state.label;

			passwordSegments.forEach((segment, index) => {
				segment.classList.toggle('is-active', index < state.level);
			});
		};

		const validatePasswordField = () => {
			if (!(passwordInput instanceof HTMLInputElement)) return true;
			const message = getPasswordValidationMessage(passwordInput.value);
			passwordInput.setCustomValidity(message);
			renderPasswordStrength(passwordInput.value);
			return message === '';
		};

		const updateUI = () => {
			Object.entries(panels).forEach(([key, panel]) => {
				panel?.classList.toggle('is-hidden', key !== currentStep);
			});

			indicators.forEach(ind => {
				ind.classList.toggle('is-active', ind.dataset.stepIndicator === currentStep);
			});

			if (stepInput) stepInput.value = currentStep;

			const txt = textMap[currentStep];
			if (sidebarTitle) sidebarTitle.textContent = txt.sbt;
			if (sidebarDesc) sidebarDesc.textContent = txt.sbd;
			if (panelIcon) panelIcon.textContent = txt.pi;
			if (panelTitle) panelTitle.textContent = txt.pt;
			if (panelDesc) panelDesc.textContent = txt.pd;
		};

		form.querySelector('[data-next-step]')?.addEventListener('click', () => {
			const fn = form.querySelector('[name="first_name"]')?.value.trim();
			const ln = form.querySelector('[name="last_name"]')?.value.trim();
			const em = form.querySelector('[name="email"]')?.value.trim();
			const pw = form.querySelector('[name="password"]')?.value;
			const isPasswordValid = validatePasswordField();

			if (!fn || !ln || !em || !pw || !isPasswordValid) {
				form.reportValidity();
				return;
			}
			currentStep = 'organization';
			updateUI();
		});

		form.querySelector('[data-prev-step]')?.addEventListener('click', () => {
			currentStep = 'admin';
			updateUI();
		});

		const pwToggle = form.querySelector('[data-password-toggle]');
		const pwIcon = form.querySelector('[data-password-icon]');
		pwToggle?.addEventListener('click', () => {
			const input = form.querySelector('[name="password"]');
			const isPw = input?.type === 'password';
			if (input) input.type = isPw ? 'text' : 'password';
			if (pwIcon) pwIcon.textContent = isPw ? 'visibility' : 'visibility_off';
		});

		if (passwordInput instanceof HTMLInputElement) {
			passwordInput.addEventListener('input', validatePasswordField);
			passwordInput.addEventListener('blur', validatePasswordField);
			validatePasswordField();
		}

		if (orgPhoneInput instanceof HTMLInputElement) {
			orgPhoneInput.value = formatParaguayLocalPhone(orgPhoneInput.value);
			orgPhoneInput.addEventListener('input', () => {
				orgPhoneInput.value = formatParaguayLocalPhone(orgPhoneInput.value);
			});
		}

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			clearErrorMessage();
			validatePasswordField();

			if (!form.reportValidity()) return;

			const formData = new FormData(form);
			const payload = {
				first_name: String(formData.get('first_name') || '').trim(),
				last_name: String(formData.get('last_name') || '').trim(),
				email: String(formData.get('email') || '').trim(),
				password: String(formData.get('password') || ''),
				business_name: String(formData.get('business_name') || '').trim(),
				phone: orgPhoneInput instanceof HTMLInputElement
					? toParaguayE164Phone(orgPhoneInput.value)
					: String(formData.get('phone') || '').trim(),
				company_email: String(formData.get('company_email') || '').trim(),
				id_org_specialty: Number(String(formData.get('id_org_specialty') || '').trim()),
				step: currentStep,
			};

			const previousSubmitText = submitButton?.textContent || '';
			const wasSubmitDisabled = Boolean(submitButton?.disabled);

			if (submitButton) {
				submitButton.disabled = true;
				submitButton.textContent = 'Registrando...';
			}

			try {
				const response = await fetch(form.action, {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
						Accept: 'application/json',
					},
					body: JSON.stringify(payload),
				});
				const data = await readJsonResponse(response);

				if (!response.ok) {
					if (data?.step === 'admin' || data?.step === 'organization') {
						currentStep = data.step;
						updateUI();
					}
					setErrorMessage(getServerErrorMessage(data));
					return;
				}

				if (typeof data?.redirect === 'string' && data.redirect.trim()) {
					window.location.assign(data.redirect);
					return;
				}

				setErrorMessage('El registro se completó, pero no recibimos la ruta de inicio de sesión.');
			} catch (error) {
				console.error('[RegisterForm] Registration request failed', error);
				setErrorMessage('No pudimos comunicarnos con el servidor. Inténtalo de nuevo.');
			} finally {
				if (submitButton) {
					submitButton.disabled = wasSubmitDisabled;
					submitButton.textContent = previousSubmitText;
				}
			}
		});

		updateUI();
	}

	if (typeof window !== 'undefined') {
		setupRegisterForm();
		document.addEventListener('astro:page-load', setupRegisterForm);
	}
</script>

<style>
/* Material 3 Design System - Split Screen Layout */
.m3-container {
	display: flex;
	flex-direction: column;
	min-height: 100vh;
	min-height: 100svh;
	font-family: var(--font-body);
	background-color: #050505;
}

@media (min-width: 1024px) {
	.m3-container {
		flex-direction: row;
		height: 100vh;
		height: 100svh;
		overflow: hidden;
	}
}

/* Left Sidebar - Dark/Premium Theme */
.m3-sidebar {
	background-color: #050505; /* Deep elegant slate */
	color: #f8fafc;
	padding: 2.5rem 1.5rem;
	position: relative;
	overflow: hidden;
}

.m3-sidebar::before {
	content: '';
	position: absolute;
	top: 0; left: 0; right: 0; bottom: 0;
	background: radial-gradient(circle at top right, rgba(37, 99, 235, 0.15), transparent 60%);
	pointer-events: none;
}

@media (min-width: 1024px) {
	.m3-sidebar {
		width: 40%;
		max-width: 28rem;
		padding: 3.5rem 4rem;
		display: flex;
		flex-direction: column;
	}
}

.m3-sidebar-inner {
	position: relative;
	z-index: 1;
	display: flex;
	flex-direction: column;
	height: 100%;
}

.m3-brand {
	display: flex;
	align-items: center;
	gap: 0.75rem;
	margin-bottom: 3.25rem;
}

.m3-logo {
	height: 3rem;
	width: auto;
	object-fit: contain;
}

.m3-brand-link {
