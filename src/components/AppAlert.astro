---
---

<dialog
	class="w-[min(24rem,calc(100vw-2rem))] overflow-hidden rounded-[1.8rem] border border-(--shell-border) bg-(--surface-bright) p-0 text-(--on-surface) shadow-[0_24px_80px_rgba(0,0,0,0.3)] backdrop:bg-slate-950/40 backdrop:backdrop-blur-md"
	data-app-alert-dialog
>
	<div class="px-7 pb-6 pt-9 text-center flex flex-col items-center">
		<div
			class="mb-5 flex size-14 shrink-0 items-center justify-center rounded-full transition-colors duration-300 ring-[6px]"
			data-app-alert-icon-shell
		>
			<span class="material-symbols-rounded text-[2rem]" data-app-alert-icon>info</span>
		</div>

		<h3 class="text-[1.35rem] font-extrabold tracking-tight text-(--on-surface) leading-snug" data-app-alert-title>
			Confirmar acción
		</h3>
		<p class="mt-3 leading-relaxed text-(--on-surface-variant) text-[0.95rem]" data-app-alert-message>
			¿Estás seguro de continuar?
		</p>
	</div>

	<div class="flex items-center justify-center gap-3 bg-(--surface)/50 px-7 py-5 border-t border-(--shell-border)">
		<button
			type="button"
			class="flex-1 rounded-2xl border border-(--shell-border) bg-transparent px-4 py-3 text-sm font-bold text-(--on-surface) shadow-sm transition hover:bg-(--control-surface-strong) hover:text-(--primary) focus:outline-none focus:ring-2 focus:ring-(--primary) focus:ring-offset-2 focus:ring-offset-(--surface-bright)"
			data-app-alert-cancel
		>
			Cancelar
		</button>
		<button
			type="button"
			class="flex-1 rounded-2xl px-4 py-3 text-sm font-bold text-white shadow-md transition focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-(--surface-bright)"
			data-app-alert-confirm
		>
			Aceptar
		</button>
	</div>
</dialog>


<script>
	type AlertDialogMode = 'alert' | 'confirm';
	type AlertDialogType = 'info' | 'success' | 'warning' | 'error';
	type AlertDialogOptions = BookmateAlertOptions & { mode?: AlertDialogMode };

	const initializeAppAlert = () => {
		const dialog = document.querySelector<HTMLDialogElement>('[data-app-alert-dialog]');
		if (!dialog || dialog.dataset.bound === '1') return;
		dialog.dataset.bound = '1';

		const titleNode = dialog.querySelector<HTMLElement>('[data-app-alert-title]');
		const messageNode = dialog.querySelector<HTMLElement>('[data-app-alert-message]');
		const iconNode = dialog.querySelector<HTMLElement>('[data-app-alert-icon]');
		const iconShellNode = dialog.querySelector<HTMLElement>('[data-app-alert-icon-shell]');
		const confirmButton = dialog.querySelector<HTMLButtonElement>('[data-app-alert-confirm]');
		const cancelButton = dialog.querySelector<HTMLButtonElement>('[data-app-alert-cancel]');

		let resolver: ((value: boolean) => void) | null = null;
		let closingTimer: number | null = null;

		const toneClasses: Record<AlertDialogType, { icon: string; iconClasses: string[]; btnClasses: string[] }> = {
			info: {
				icon: 'info',
				iconClasses: ['bg-sky-100', 'text-sky-600', 'ring-sky-50', 'dark:bg-sky-500/10', 'dark:text-sky-400', 'dark:ring-sky-500/10'],
				btnClasses: ['bg-sky-600', 'hover:bg-sky-700', 'focus:ring-sky-600', 'shadow-[0_8px_20px_rgba(2,132,199,0.25)]']
			},
			success: {
				icon: 'check_circle',
				iconClasses: ['bg-teal-100', 'text-teal-600', 'ring-teal-50', 'dark:bg-teal-500/10', 'dark:text-teal-400', 'dark:ring-teal-500/10'],
				btnClasses: ['bg-teal-600', 'hover:bg-teal-700', 'focus:ring-teal-600', 'shadow-[0_8px_20px_rgba(13,148,136,0.25)]']
			},
			warning: {
				icon: 'warning',
				iconClasses: ['bg-amber-100', 'text-amber-600', 'ring-amber-50', 'dark:bg-amber-500/10', 'dark:text-amber-400', 'dark:ring-amber-500/10'],
				btnClasses: ['bg-amber-500', 'hover:bg-amber-600', 'focus:ring-amber-500', 'text-white', 'shadow-[0_8px_20px_rgba(245,158,11,0.25)]']
			},
			error: {
				icon: 'delete',
				iconClasses: ['bg-red-100', 'text-red-600', 'ring-red-50', 'dark:bg-red-500/10', 'dark:text-red-400', 'dark:ring-red-500/10'],
				btnClasses: ['bg-red-600', 'hover:bg-red-700', 'focus:ring-red-600', 'shadow-[0_8px_20px_rgba(220,38,38,0.25)]']
			},
		};

		const clearToneClasses = () => {
			for (const tone of Object.values(toneClasses)) {
				if (iconShellNode) iconShellNode.classList.remove(...tone.iconClasses);
				if (confirmButton) confirmButton.classList.remove(...tone.btnClasses);
			}
		};

		const resolveAndClose = (value: boolean) => {
			if (!resolver) return;
			if (dialog.dataset.isClosing === '1') return;
			dialog.dataset.isClosing = '1';
			dialog.classList.add('is-closing');

			closingTimer = window.setTimeout(() => {
				dialog.close();
				dialog.classList.remove('is-closing');
				dialog.dataset.isClosing = '0';
				const resolve = resolver;
				resolver = null;
				if (!resolve) return;
				resolve(value);
			}, 160);
		};

		const showDialog = (options: AlertDialogOptions = {}): Promise<boolean> => {
			const mode: AlertDialogMode = options.mode === 'alert' ? 'alert' : 'confirm';
			const toneKey: AlertDialogType = options.type ?? 'info';
			const tone = toneClasses[toneKey];

			if (titleNode) {
				titleNode.textContent =
					typeof options.title === 'string' && options.title.trim()
						? options.title
						: mode === 'alert'
							? 'Aviso'
							: 'Confirmar acción';
			}
			if (messageNode) {
				messageNode.textContent =
					typeof options.message === 'string' && options.message.trim()
						? options.message
						: '¿Deseas continuar?';
			}
			
			if (iconNode) iconNode.textContent = tone.icon;
			
			clearToneClasses();
			
			if (iconShellNode) {
				iconShellNode.classList.add(...tone.iconClasses);
			}

			if (confirmButton) {
				confirmButton.classList.add(...tone.btnClasses);
				confirmButton.textContent =
					typeof options.confirmText === 'string' && options.confirmText.trim()
						? options.confirmText
						: mode === 'alert'
							? 'Entendido'
							: 'Aceptar';
			}

			if (cancelButton) {
				cancelButton.textContent =
					typeof options.cancelText === 'string' && options.cancelText.trim()
						? options.cancelText
						: 'Cancelar';
				if (mode === 'alert') cancelButton.classList.add('hidden');
				else cancelButton.classList.remove('hidden');
			}

			if (closingTimer) {
				window.clearTimeout(closingTimer);
				closingTimer = null;
			}

			dialog.dataset.isClosing = '0';
			dialog.classList.remove('is-closing');
			if (!dialog.open) dialog.showModal();

			return new Promise<boolean>((resolve) => {
				resolver = resolve;
			});
		};

		confirmButton?.addEventListener('click', () => resolveAndClose(true));
		cancelButton?.addEventListener('click', () => resolveAndClose(false));
		dialog.addEventListener('cancel', (event: Event) => {
			event.preventDefault();
			resolveAndClose(false);
		});
		dialog.addEventListener('click', (event: MouseEvent) => {
			if (event.target instanceof HTMLDialogElement) resolveAndClose(false);
		});

		window.BookmateAlert = {
			alert: (options: BookmateAlertOptions = {}) => showDialog({ ...options, mode: 'alert' }),
			confirm: (options: BookmateAlertOptions = {}) => showDialog({ ...options, mode: 'confirm' }),
		};
	};

	initializeAppAlert();
	document.addEventListener('astro:page-load', initializeAppAlert);
</script>

<style is:global>
	dialog[data-app-alert-dialog] {
		position: fixed;
		inset: 0;
		margin: auto;
		animation: app-alert-in 180ms ease-out;
	}

	dialog[data-app-alert-dialog]::backdrop {
		animation: app-alert-backdrop-in 180ms ease-out;
	}

	dialog[data-app-alert-dialog].is-closing {
		animation: app-alert-out 160ms ease-in forwards;
	}

	dialog[data-app-alert-dialog].is-closing::backdrop {
		animation: app-alert-backdrop-out 160ms ease-in forwards;
	}

	@keyframes app-alert-in {
		from {
			opacity: 0;
			transform: translateY(10px) scale(0.98);
		}

		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	@keyframes app-alert-out {
		from {
			opacity: 1;
			transform: translateY(0) scale(1);
		}

		to {
			opacity: 0;
			transform: translateY(8px) scale(0.98);
		}
	}

	@keyframes app-alert-backdrop-in {
		from {
			opacity: 0;
		}

		to {
			opacity: 1;
		}
	}

	@keyframes app-alert-backdrop-out {
		from {
			opacity: 1;
		}

		to {
			opacity: 0;
		}
	}
</style>
