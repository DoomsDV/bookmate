---
type MessageType = 'success' | 'error' | 'info' | 'warning';

interface Props {
	message: string;
	type?: MessageType;
	autoHideMs?: number;
	expand?: boolean;
	dismissible?: boolean;
}

const {
	message,
	type = 'info',
	autoHideMs = 0,
	expand = false,
	dismissible = true,
} = Astro.props;

const toneMap: Record<MessageType, { icon: string; iconColor: string }> = {
	success: {
		icon: 'check_circle',
		iconColor: 'text-(--flash-success-text)',
	},
	error: {
		icon: 'error',
		iconColor: 'text-(--flash-danger-text)',
	},
	info: {
		icon: 'info',
		iconColor: 'text-(--primary)',
	},
	warning: {
		icon: 'warning',
		iconColor: 'text-(--status-pending-text)',
	},
};

const tone = toneMap[type];
---

{
	message ? (
		<div
			role="alert"
			aria-live="polite"
			class:list={[
				'pointer-events-auto group relative flex items-center gap-3 rounded-full border border-(--shell-border) bg-(--surface-bright) px-4 py-3 text-(--on-surface) shadow-lg',
				expand ? 'w-full max-w-full rounded-2xl' : 'w-max max-w-[calc(100vw-2rem)]',
			]}
			style="transform: translateY(20px); opacity: 0; animation: flash-slide-in 260ms cubic-bezier(0.16, 1, 0.3, 1) forwards;"
			data-flash-message
			data-auto-hide-ms={autoHideMs > 0 ? String(autoHideMs) : undefined}
		>
			<span class:list={['material-symbols-rounded shrink-0 text-[1.22rem] tracking-normal', tone.iconColor]}>{tone.icon}</span>
			<p class="min-w-0 flex-1 truncate text-sm font-medium leading-5">{message}</p>

			{
				dismissible ? (
					<button
						type="button"
						class="shrink-0 -mr-1 rounded-full p-1.5 text-(--on-surface-variant) transition hover:bg-(--primary-soft) hover:text-(--on-surface) focus:outline-none focus:ring-2 focus:ring-(--primary)/30"
						aria-label="Cerrar mensaje"
						data-flash-close
					>
						<span class="material-symbols-rounded text-[1.1rem]">close</span>
					</button>
				) : null
			}
		</div>
	) : null
}

<style is:global>
	@keyframes flash-slide-in {
		0% {
			transform: translateY(20px);
			opacity: 0;
		}
		100% {
			transform: translateY(0);
			opacity: 1;
		}
	}
</style>

<script>
	const hideMessage = (node: any) => {
		if (!node || node.dataset.isClosing === '1') return;
		node.dataset.isClosing = '1';
		node.classList.add('pointer-events-none');
		node.animate(
			[
				{ transform: 'translateY(0)', opacity: 1 },
				{ transform: 'translateY(16px)', opacity: 0 },
			],
			{
				duration: 220,
				easing: 'cubic-bezier(0.4, 0, 1, 1)',
				fill: 'forwards',
			}
		).onfinish = () => node.remove();
	};

	const initMessage = (node: any) => {
		if (!node || node.dataset.flashBound === '1') return;
		node.dataset.flashBound = '1';

		const closeButton = node.querySelector('[data-flash-close]');
		closeButton?.addEventListener('click', () => hideMessage(node));

		const delay = Number(node.dataset.autoHideMs || '0');
		if (Number.isFinite(delay) && delay > 0) {
			window.setTimeout(() => hideMessage(node), delay);
		}
	};

	for (const node of document.querySelectorAll('[data-flash-message]')) {
		initMessage(node);
	}

	// Integración con View Transitions
	document.addEventListener('astro:page-load', () => {
		for (const node of document.querySelectorAll('[data-flash-message]')) {
			initMessage(node);
		}
	});
</script>
