---
type MessageType = 'success' | 'error' | 'info' | 'warning';

interface Props {
	message: string;
	type?: MessageType;
	autoHideMs?: number;
	expand?: boolean;
	dismissible?: boolean;
}

const {
	message,
	type = 'info',
	autoHideMs = 0,
	expand = false,
	dismissible = true,
} = Astro.props;

const toneMap: Record<MessageType, { icon: string; iconClass: string }> = {
	success: {
		icon: 'check_circle',
		iconClass: 'flash-message__icon--success',
	},
	error: {
		icon: 'error',
		iconClass: 'flash-message__icon--error',
	},
	info: {
		icon: 'info',
		iconClass: 'flash-message__icon--info',
	},
	warning: {
		icon: 'warning',
		iconClass: 'flash-message__icon--warning',
	},
};

const tone = toneMap[type];
const flashBaseClass =
	'flash-message pointer-events-auto group relative flex items-center gap-3 rounded-full px-4 py-3 text-sm font-medium leading-5';
---

{
	message ? (
		<div
			role="alert"
			aria-live="polite"
			class:list={[
				flashBaseClass,
				expand ? 'w-full max-w-full rounded-2xl' : 'w-auto max-w-[calc(100vw-2rem)]',
			]}
			style="transform: translateY(20px); opacity: 0; animation: flash-slide-in 260ms cubic-bezier(0.16, 1, 0.3, 1) forwards;"
			data-flash-message
			data-auto-hide-ms={autoHideMs > 0 ? String(autoHideMs) : undefined}
		>
			<span class:list={['material-symbols-rounded shrink-0 text-[1.22rem] tracking-normal', tone.iconClass]}>
				{tone.icon}
			</span>
			<p class="min-w-0 flex-1">{message}</p>

			{
				dismissible ? (
					<button
						type="button"
						class="flash-message__close shrink-0 -mr-1 rounded-full p-1.5 transition focus:outline-none focus:ring-2 focus:ring-[color-mix(in_srgb,var(--flash-fg)_35%,transparent)]"
						aria-label="Cerrar mensaje"
						data-flash-close
					>
						<span class="material-symbols-rounded text-[1.1rem]">close</span>
					</button>
				) : null
			}
		</div>
	) : null
}

<style is:global>
	@keyframes flash-slide-in {
		0% {
			transform: translateY(20px);
			opacity: 0;
		}
		100% {
			transform: translateY(0);
			opacity: 1;
		}
	}
</style>

<script>
	import {
		consumeStashedFlash,
		drainPendingFlashMessages,
		stripFlashParamsFromUrl,
	} from '../lib/flash';

	const flashToneMap = {
		success: {
			icon: 'check_circle',
			iconClass: 'flash-message__icon--success',
		},
		error: {
			icon: 'error',
			iconClass: 'flash-message__icon--error',
		},
		info: {
			icon: 'info',
			iconClass: 'flash-message__icon--info',
		},
		warning: {
			icon: 'warning',
			iconClass: 'flash-message__icon--warning',
		},
	};

	const hideMessage = (node: HTMLElement) => {
		if (!node || node.dataset.isClosing === '1') return;
		node.dataset.isClosing = '1';
		node.classList.add('pointer-events-none');
		node.animate(
			[
				{ transform: 'translateY(0)', opacity: 1 },
				{ transform: 'translateY(16px)', opacity: 0 },
			],
			{
				duration: 220,
				easing: 'cubic-bezier(0.4, 0, 1, 1)',
				fill: 'forwards',
			}
		).onfinish = () => node.remove();
	};

	const initMessage = (node: HTMLElement) => {
		if (!node || node.dataset.flashBound === '1') return;
		node.dataset.flashBound = '1';

		const closeButton = node.querySelector('[data-flash-close]');
		closeButton?.addEventListener('click', () => hideMessage(node));

		const delay = Number(node.dataset.autoHideMs || '0');
		if (Number.isFinite(delay) && delay > 0) {
			window.setTimeout(() => hideMessage(node), delay);
		}
	};

	const ensureFlashStack = () => {
		let stack = document.querySelector('[data-flash-stack]');
		if (stack) return stack;

		stack = document.createElement('div');
		stack.setAttribute('data-flash-stack', 'true');
		stack.className =
			'pointer-events-none fixed inset-x-0 bottom-5 z-[10000] flex flex-col items-center gap-3 px-4';
		document.body.appendChild(stack);
		return stack;
	};

	const createDynamicMessage = ({
		message,
		type = 'info',
		autoHideMs = 5000,
	}: {
		message?: string;
		type?: keyof typeof flashToneMap;
		autoHideMs?: number;
	}) => {
		const cleanMessage = String(message || '').trim();
		if (!cleanMessage) return null;

		const tone = flashToneMap[type] || flashToneMap.info;
		const node = document.createElement('div');
		node.setAttribute('role', 'alert');
		node.setAttribute('aria-live', 'polite');
		node.setAttribute('data-flash-message', 'true');
		node.dataset.autoHideMs = String(autoHideMs);
		node.className =
			'flash-message pointer-events-auto group relative flex w-auto max-w-[calc(100vw-2rem)] items-center gap-3 rounded-full px-4 py-3 text-sm font-medium leading-5';
		node.style.transform = 'translateY(20px)';
		node.style.opacity = '0';
		node.style.animation = 'flash-slide-in 260ms cubic-bezier(0.16, 1, 0.3, 1) forwards';
		node.innerHTML = `
			<span class="material-symbols-rounded shrink-0 text-[1.22rem] tracking-normal ${tone.iconClass}">${tone.icon}</span>
			<p class="min-w-0 flex-1"></p>
			<button
				type="button"
				class="flash-message__close shrink-0 -mr-1 rounded-full p-1.5 transition focus:outline-none focus:ring-2 focus:ring-[color-mix(in_srgb,var(--flash-fg)_35%,transparent)]"
				aria-label="Cerrar mensaje"
				data-flash-close
			>
				<span class="material-symbols-rounded text-[1.1rem]">close</span>
			</button>
		`;
		const textNode = node.querySelector('p');
		if (textNode) textNode.textContent = cleanMessage;
		return node;
	};

	const showFlashMessage = (detail: {
		message?: string;
		type?: keyof typeof flashToneMap;
		autoHideMs?: number;
	}) => {
		const node = createDynamicMessage(detail);
		if (!node) return;
		const stack = ensureFlashStack();
		stack.appendChild(node);
		initMessage(node);
	};

	const bootstrapFlashHost = () => {
		stripFlashParamsFromUrl();
		ensureFlashStack();

		for (const node of document.querySelectorAll<HTMLElement>('[data-flash-message]')) {
			initMessage(node);
		}

		const stashed = consumeStashedFlash();
		if (stashed) showFlashMessage(stashed);

		drainPendingFlashMessages();
	};

	window.BookmateFlash = {
		show: showFlashMessage,
	};

	document.addEventListener('bookmate:flash', ((event: CustomEvent) => {
		showFlashMessage(event.detail || {});
	}) as EventListener);

	bootstrapFlashHost();

	document.addEventListener('astro:page-load', bootstrapFlashHost);
</script>
