---
type MessageType = 'success' | 'error' | 'info' | 'warning';

interface Props {
	message: string;
	type?: MessageType;
	autoHideMs?: number;
	expand?: boolean;
	dismissible?: boolean;
}

const {
	message,
	type = 'info',
	autoHideMs = 0,
	expand = false,
	dismissible = true,
} = Astro.props;

const toneMap: Record<MessageType, { icon: string; title: string; border: string; progressBg: string; iconColor: string }> = {
	success: {
		icon: 'check_circle',
		title: 'Éxito',
		border: 'border-l-emerald-500',
		progressBg: 'bg-emerald-500',
		iconColor: 'text-emerald-500',
	},
	error: {
		icon: 'error',
		title: 'Error',
		border: 'border-l-rose-500',
		progressBg: 'bg-rose-500',
		iconColor: 'text-rose-500',
	},
	info: {
		icon: 'info',
		title: 'Información',
		border: 'border-l-sky-500',
		progressBg: 'bg-sky-500',
		iconColor: 'text-sky-500',
	},
	warning: {
		icon: 'warning',
		title: 'Atención',
		border: 'border-l-amber-500',
		progressBg: 'bg-amber-500',
		iconColor: 'text-amber-500',
	},
};

const tone = toneMap[type];
---

{
	message ? (
		<div
			role="alert"
			aria-live="polite"
			class:list={[
				'group relative overflow-hidden rounded-[1.2rem] border border-(--shell-border) border-l-[6px] bg-(--surface-bright) shadow-[0_12px_40px_rgba(0,0,0,0.12)] transition-all duration-300 ease-out',
				tone.border,
				expand ? 'w-full' : 'w-[min(100%,26rem)]',
			]}
			style="transform: translateY(12px) scale(0.95); opacity: 0; animation: flash-slide-in 400ms cubic-bezier(0.16, 1, 0.3, 1) forwards;"
			data-flash-message
			data-auto-hide-ms={autoHideMs > 0 ? String(autoHideMs) : undefined}
		>
			<div class="flex items-start gap-4 py-4 pl-5 pr-4">
				<span class:list={['material-symbols-rounded shrink-0 text-[1.4rem] tracking-normal', tone.iconColor]}>{tone.icon}</span>

				<div class="min-w-0 flex-1 pt-[1.5px]">
					<p class="text-[0.95rem] font-extrabold tracking-tight text-(--on-surface)">{tone.title}</p>
					<p class="mt-1 text-[0.9rem] font-medium leading-relaxed text-(--on-surface)/80 dark:text-(--on-surface)/90">{message}</p>
				</div>

				{
					dismissible ? (
						<button
							type="button"
							class="shrink-0 -mr-1 rounded-full p-1.5 text-(--on-surface-variant)/70 transition hover:bg-(--shell-border) hover:text-(--on-surface) focus:outline-none focus:ring-2 focus:ring-(--primary)/30"
							aria-label="Cerrar mensaje"
							data-flash-close
						>
							<span class="material-symbols-rounded text-[1.2rem]">close</span>
						</button>
					) : null
				}
			</div>

			{
				autoHideMs > 0 ? (
					<div class="absolute bottom-0 left-0 right-0 h-1 overflow-hidden rounded-b-[1.2rem] bg-black/5 dark:bg-white/5">
						<div
							class:list={['h-full w-full origin-left opacity-90', tone.progressBg]}
							style={`animation: flash-progress-bar ${autoHideMs}ms linear forwards;`}
						></div>
					</div>
				) : null
			}
		</div>
	) : null
}

<style is:global>
	@keyframes flash-slide-in {
		0% {
			transform: translateY(12px) scale(0.95);
			opacity: 0;
		}
		100% {
			transform: translateY(0) scale(1);
			opacity: 1;
		}
	}

	@keyframes flash-progress-bar {
		0% {
			transform: scaleX(1);
		}
		100% {
			transform: scaleX(0);
		}
	}
</style>

<script>
	const hideMessage = (node: any) => {
		if (!node || node.dataset.isClosing === '1') return;
		node.dataset.isClosing = '1';
		node.classList.add('pointer-events-none');
		node.style.animation = 'none';
		node.style.transform = 'translateY(10px) scale(0.95)';
		node.style.opacity = '0';
		window.setTimeout(() => node.remove(), 250);
	};

	const initMessage = (node: any) => {
		if (!node || node.dataset.flashBound === '1') return;
		node.dataset.flashBound = '1';

		const closeButton = node.querySelector('[data-flash-close]');
		closeButton?.addEventListener('click', () => hideMessage(node));

		const delay = Number(node.dataset.autoHideMs || '0');
		if (Number.isFinite(delay) && delay > 0) {
			window.setTimeout(() => hideMessage(node), delay);
		}
	};

	for (const node of document.querySelectorAll('[data-flash-message]')) {
		initMessage(node);
	}

	// Integración con View Transitions
	document.addEventListener('astro:page-load', () => {
		for (const node of document.querySelectorAll('[data-flash-message]')) {
			initMessage(node);
		}
	});
</script>
