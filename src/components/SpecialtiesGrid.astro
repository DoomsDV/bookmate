---
import type { Specialty } from '../lib/specialties';

interface Props {
	specialties: Specialty[];
	showCreateAction?: boolean;
}

const { specialties, showCreateAction = false } = Astro.props;

const SPECIALTY_ICON = 'workspace_premium';

const toDescriptionLabel = (value: string) => {
	const text = String(value || '').trim();
	return text || 'Sin descripción';
};

const cardItems = specialties.map((specialty) => ({ specialty }));

const activeSpecialties = specialties.filter((item) => item.is_active === 1).length;
---

<section class="rounded-[1.7rem] border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.55)]">
	<div class="flex flex-wrap items-center justify-between gap-3">
		<div class="flex flex-wrap justify-start gap-2 text-xs font-semibold">
			<span class="status-chip-total">
				Total: {specialties.length}
			</span>
			<span class="status-chip-success">
				Activas: {activeSpecialties}
			</span>
			<span class="status-chip-danger">
				Inactivas: {specialties.length - activeSpecialties}
			</span>
		</div>

		{
			showCreateAction ? (
				<button
					type="button"
					class="btn-primary-soft inline-flex cursor-pointer items-center gap-2 rounded-xl px-4 py-2.5 text-sm font-semibold transition"
					data-open-specialty-modal
				>
					<span class="material-symbols-rounded text-[1.1rem]">add</span>
					Nueva especialidad
				</button>
			) : null
		}
	</div>

	{
		specialties.length === 0 ? (
			<div class="mt-6 rounded-[1.45rem] border border-dashed border-[color:var(--shell-border)] bg-[color:var(--control-surface)] px-5 py-7 text-sm text-[color:var(--on-surface-variant)]">
			No hay especialidades registradas para esta organización.
			</div>
		) : (
			<div class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
				{
					cardItems.map((item) => (
						<article
							class="cursor-pointer rounded-[1.45rem] border border-[color:var(--shell-border)] bg-[color:var(--card-surface-strong)] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.6)] transition duration-200 hover:-translate-y-0.5 hover:shadow-[0_16px_30px_rgba(15,23,42,0.12)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--primary)]"
							data-specialty-card
							data-specialty-id={item.specialty.id_specialty}
							tabindex="0"
							role="button"
							aria-label={`Editar especialidad ${item.specialty.name || item.specialty.id_specialty}`}
						>
							<div class="flex items-start justify-between gap-3">
								<div class="flex size-10 items-center justify-center rounded-xl bg-[color:var(--primary-soft)] text-[color:var(--primary)]">
									<span class="material-symbols-rounded text-[1rem]">{SPECIALTY_ICON}</span>
								</div>

								<span
									class:list={[
										'status-pill',
										item.specialty.is_active === 1
											? 'status-pill-success'
											: 'status-pill-danger',
									]}
								>
									{item.specialty.is_active === 1 ? 'Activa' : 'Inactiva'}
								</span>
							</div>

							<h3 class="mt-4 text-lg font-semibold leading-6 text-[color:var(--on-surface)]">
								{item.specialty.name || `Especialidad #${item.specialty.id_specialty}`}
							</h3>

							<p class="mt-2 text-sm text-[color:var(--on-surface-variant)]">
								{toDescriptionLabel(item.specialty.description)}
							</p>

						</article>
					))
				}
			</div>
		)
	}
</section>
