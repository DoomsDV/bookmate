---
import type { Specialty } from '../lib/specialties';

interface Props {
	specialties: Specialty[];
	showCreateAction?: boolean;
}

const { specialties = [], showCreateAction = false } = Astro.props;

const SPECIALTY_ICON = 'workspace_premium';

const toDescriptionLabel = (value?: string | null) => {
	const text = String(value || '').trim();
	return text || 'Sin descripción';
};

const activeCount = specialties.filter((item) => item.is_active === 1).length;
const inactiveCount = specialties.length - activeCount;

---

<section class="specialties-view">
	<header class="mb-8 flex flex-col sm:flex-row sm:items-start justify-between gap-4">
		<div class="flex flex-col gap-2.5">
			<h2 class="text-[1.5rem] sm:text-[1.75rem] font-bold tracking-tight text-(--on-surface) leading-none m-0">Especialidades</h2>
			<div class="flex flex-wrap items-center gap-2">
				<span class="specialties-summary-pill specialties-summary-pill--active">
					<span class="size-2 rounded-full specialties-summary-dot specialties-summary-dot--active"></span>
					Activas: {activeCount}
				</span>
				{inactiveCount > 0 && (
					<span class="specialties-summary-pill specialties-summary-pill--inactive">
						<span class="size-2 rounded-full specialties-summary-dot specialties-summary-dot--inactive"></span>
						Inactivas: {inactiveCount}
					</span>
				)}
			</div>
		</div>

		<div class="w-full shrink-0 sm:mt-0 sm:w-auto">
			{showCreateAction && (
				<button
					type="button"
					class="specialties-create-btn w-full sm:w-auto flex items-center justify-center gap-2"
					data-open-specialty-modal
				>
					<svg class="specialties-create-btn-icon w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" />
					</svg>
					<span>Nueva Especialidad</span>
				</button>
			)}
		</div>
	</header>

	{specialties.length === 0 ? (
		<div class="specialties-empty-state">
			<div class="specialties-empty-icon">
				<span class="material-symbols-rounded text-[2rem]">inbox</span>
			</div>
			<h3 class="text-[1.1rem] font-bold text-(--on-surface)">No hay especialidades registradas</h3>
			<p class="mt-1.5 max-w-sm text-[0.95rem] leading-relaxed text-(--on-surface-variant)">
				Aún no has agregado ninguna especialidad a esta organización. Comienza creando tu primera especialidad.
			</p>
		</div>
	) : (
		<div class="material-cards-grid gap-6 sm:grid-cols-2 sm:gap-8 lg:grid-cols-3">
			{specialties.map((specialty) => (
				<article
					class="specialties-card group cursor-pointer relative overflow-hidden"
					data-specialty-card
					data-specialty-id={specialty.id_specialty}
					tabindex="0"
					role="button"
					aria-label={`Editar especialidad ${specialty.name || specialty.id_specialty}`}
				>
					<div class="relative flex items-start justify-between gap-4">
						<div class="relative flex size-[2.75rem] shrink-0 items-center justify-center rounded-[0.85rem] bg-(--primary-soft) text-(--primary)">
							<span class="material-symbols-rounded text-[1.25rem]">{SPECIALTY_ICON}</span>
						</div>

						<span
							class:list={[
								'specialties-card-status',
								specialty.is_active === 1
									? 'specialties-card-status--active'
									: 'specialties-card-status--inactive',
							]}
						>
							<span
								class:list={[
									'size-1.5 rounded-full',
									specialty.is_active === 1
										? 'specialties-summary-dot--active'
										: 'specialties-summary-dot--inactive',
								]}
							></span>
							{specialty.is_active === 1 ? 'Activa' : 'Inactiva'}
						</span>
					</div>

					<div class="relative flex flex-1 flex-col gap-[0.85rem]">
						<div>
							<h3 class="specialties-card-title line-clamp-1">
								{specialty.name || `Especialidad #${specialty.id_specialty}`}
							</h3>
							<p class="mt-1 text-[0.9rem] text-(--on-surface-variant) line-clamp-2 leading-relaxed">
								{toDescriptionLabel(specialty.description)}
							</p>
						</div>
					</div>
				</article>
			))}
		</div>
	)}
</section>

<style>
	.specialties-view {
		display: grid;
		gap: 1.2rem;
	}

	.specialties-summary-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		border-radius: 999px;
		border: 0;
		padding: 0.33rem 0.78rem;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.01em;
	}

	.specialties-summary-pill--active {
		background: rgba(16, 185, 129, 0.12);
		color: #0f6d4a;
	}

	.specialties-summary-pill--inactive {
		background: rgba(244, 63, 94, 0.11);
		color: #8d3e4a;
	}

	.specialties-summary-dot {
		display: inline-block;
	}

	.specialties-summary-dot--active {
		background: #22c55e;
	}

	.specialties-summary-dot--inactive {
		background: #fb7185;
	}

	.specialties-create-btn {
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--primary) 72%, #123e7a 28%);
		background: var(--primary);
		padding: 0.72rem 1.15rem;
		font-size: 0.92rem;
		font-weight: 780;
		color: #f8fbff;
		box-shadow: none;
		transition: filter 140ms ease, border-color 140ms ease;
	}

	.specialties-create-btn-icon {
		flex-shrink: 0;
	}

	.specialties-create-btn:hover {
		filter: brightness(1.04);
	}

	.specialties-empty-state {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		border-radius: 1.35rem;
		border: 1px solid rgba(148, 163, 184, 0.24);
		background: color-mix(in srgb, var(--surface-container-low) 72%, var(--surface-bright) 28%);
		padding: 2.5rem 1.25rem;
		text-align: center;
	}

	.specialties-empty-icon {
		margin-bottom: 1rem;
		display: flex;
		height: 4rem;
		width: 4rem;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		background: color-mix(in srgb, var(--surface-container) 88%, var(--surface-bright) 12%);
		color: var(--on-surface-variant);
	}

	.specialties-card {
		display: flex;
		flex-direction: column;
		gap: 0.95rem;
		border-radius: 1.2rem;
		border: 0;
		background: color-mix(in srgb, var(--surface-container-low) 76%, var(--surface-bright) 24%);
		padding: 1.45rem 1.5rem 1.55rem;
		box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.08);
		transition: transform 170ms ease, box-shadow 170ms ease, background-color 170ms ease;
	}

	.specialties-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 14px 44px -12px rgba(0, 0, 0, 0.1);
	}

	.specialties-card-status {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		border-radius: 999px;
		border: 0;
		padding: 0.24rem 0.6rem;
		font-size: 0.66rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		white-space: nowrap;
	}

	.specialties-card-status--active {
		background: rgba(16, 185, 129, 0.12);
		color: #0f6d4a;
	}

	.specialties-card-status--inactive {
		background: rgba(244, 63, 94, 0.11);
		color: #8d3e4a;
	}

	.specialties-card-title {
		margin: 0;
		font-size: 1.1rem;
		font-weight: 760;
		line-height: 1.3;
		letter-spacing: -0.01em;
		color: var(--on-surface);
	}

	.specialties-card-term {
		color: var(--on-surface-variant);
		font-weight: 500;
	}

	.specialties-card-value {
		font-weight: 700;
		color: color-mix(in srgb, var(--on-surface-variant) 74%, var(--on-surface) 26%);
		text-align: right;
	}

	html[data-theme='dark'] .specialties-summary-pill--active {
		background: rgba(110, 231, 183, 0.16);
		color: #b8f5d5;
	}

	html[data-theme='dark'] .specialties-summary-pill--inactive {
		background: rgba(255, 182, 193, 0.12);
		color: #ffc8d2;
	}

	html[data-theme='dark'] .specialties-create-btn {
		border-color: color-mix(in srgb, var(--primary) 58%, #131314 42%);
		background: color-mix(in srgb, var(--primary) 78%, #131314 22%);
	}

	html[data-theme='dark'] .specialties-create-btn:hover {
		filter: brightness(1.08);
	}

	html[data-theme='dark'] .specialties-empty-state {
		border-color: rgba(255, 255, 255, 0.08);
		background: color-mix(
			in srgb,
			var(--surface-container-low, #1e1f22) 82%,
			var(--surface-container, #131314) 18%
		);
	}

	html[data-theme='dark'] .specialties-card {
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: var(--surface-container, #1e1f22);
		box-shadow: none;
	}

	html[data-theme='dark'] .specialties-card:hover {
		border-color: rgba(255, 255, 255, 0.15);
		background: var(--surface-container-high, #282a2c);
	}

	html[data-theme='dark'] .specialties-card-status--active {
		background: rgba(110, 231, 183, 0.16);
		color: #b8f5d5;
	}

	html[data-theme='dark'] .specialties-card-status--inactive {
		background: rgba(255, 182, 193, 0.12);
		color: #ffc8d2;
	}

	html[data-theme='dark'] .specialties-card-value {
		color: color-mix(in srgb, var(--on-surface-variant) 86%, #d1d5db 14%);
	}
</style>
