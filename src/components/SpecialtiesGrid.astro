---
import type { Specialty } from '../lib/specialties';

interface Props {
	specialties: Specialty[];
	showCreateAction?: boolean;
}

const { specialties = [], showCreateAction = false } = Astro.props;

const SPECIALTY_ICON = 'workspace_premium';

const toDescriptionLabel = (value?: string | null) => {
	const text = String(value || '').trim();
	return text || 'Sin descripción';
};

const activeCount = specialties.filter((item) => item.is_active === 1).length;
const inactiveCount = specialties.length - activeCount;
---

<section class="material-region dark:shadow-none">
	<header class="mb-4 flex flex-col justify-between gap-3 sm:mb-5 sm:flex-row sm:items-center">
		<div class="flex flex-wrap items-center gap-2.5 text-[0.82rem] font-bold">
			<span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-500/10 px-3 py-1.5 text-emerald-700 dark:bg-emerald-500/20 dark:text-emerald-400 transition border border-emerald-500/10">
				<span class="size-2 rounded-full bg-emerald-500"></span> Activas: {activeCount}
			</span>
			{inactiveCount > 0 && (
				<span class="inline-flex items-center gap-1.5 rounded-full bg-rose-500/10 px-3 py-1.5 text-rose-700 dark:bg-rose-500/20 dark:text-rose-300 transition border border-rose-500/10">
					<span class="size-2 rounded-full bg-rose-500"></span> Inactivas: {inactiveCount}
				</span>
			)}
		</div>

		{showCreateAction && (
			<button
				type="button"
				class="btn-primary-soft inline-flex items-center justify-center gap-2 rounded-2xl px-5 py-3 text-[0.95rem] font-extrabold shadow-sm transition hover:shadow-md focus:outline-none focus:ring-2 focus:ring-(--primary) focus:ring-offset-2 focus:ring-offset-(--surface-bright) sm:w-auto w-full"
				data-open-specialty-modal
			>
				<span class="material-symbols-rounded text-[1.2rem]">add</span>
				Nueva Especialidad
			</button>
		)}
	</header>

	{specialties.length === 0 ? (
		<div class="flex flex-col items-center justify-center rounded-[1.35rem] border-2 border-dashed border-(--shell-border) bg-(--surface)/40 px-5 py-10 text-center transition">
			<div class="mb-4 flex size-16 items-center justify-center rounded-full bg-(--surface-variant) text-(--on-surface-variant) ring-8 ring-(--surface-bright)">
				<span class="material-symbols-rounded text-[2rem]">inbox</span>
			</div>
			<h3 class="text-[1.1rem] font-bold text-(--on-surface)">No hay especialidades registradas</h3>
			<p class="mt-1.5 text-[0.95rem] text-(--on-surface-variant) max-w-sm leading-relaxed">
				Aún no has agregado ninguna especialidad a esta organización. Comienza creando tu primera especialidad.
			</p>
		</div>
	) : (
		<div class="material-cards-grid sm:grid-cols-2 lg:grid-cols-3">
			{specialties.map((specialty) => (
				<article
					class="material-data-card group cursor-pointer relative overflow-hidden hover:-translate-y-0.5 hover:border-(--primary)/40 hover:shadow-[0_14px_30px_-18px_rgba(0,0,0,0.16)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-(--primary) focus-visible:ring-offset-2"
					data-specialty-card
					data-specialty-id={specialty.id_specialty}
					tabindex="0"
					role="button"
					aria-label={`Editar especialidad ${specialty.name || specialty.id_specialty}`}
				>
					<div class="absolute right-0 top-0 h-32 w-32 -translate-y-16 translate-x-16 rounded-full bg-(--primary)/5 opacity-0 blur-2xl transition-opacity duration-300 group-hover:opacity-100"></div>

					<div class="relative flex items-start justify-between gap-4">
						<div class="flex size-11 shrink-0 items-center justify-center rounded-xl bg-(--primary-soft) text-(--primary) transition-transform duration-300 group-hover:scale-105 shadow-[inset_0_1px_0_rgba(255,255,255,0.4)]">
							<span class="material-symbols-rounded text-[1.25rem]">{SPECIALTY_ICON}</span>
						</div>

						<span
							class:list={[
								'inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[0.7rem] font-extrabold uppercase tracking-widest border',
								specialty.is_active === 1
									? 'bg-emerald-500/10 text-emerald-700 border-emerald-500/10 dark:bg-emerald-500/20 dark:text-emerald-400 dark:border-emerald-500/20'
									: 'bg-(--surface-variant) text-(--on-surface-variant) border-(--shell-border)',
							]}
						>
							<span class:list={["size-1.5 rounded-full", specialty.is_active === 1 ? "bg-emerald-500" : "bg-(--on-surface-variant)"]}></span>
							{specialty.is_active === 1 ? 'Activa' : 'Inactiva'}
						</span>
					</div>

					<div class="relative flex flex-1 flex-col gap-3">
						<h3 class="text-[1.1rem] font-extrabold tracking-tight text-(--on-surface) line-clamp-1 group-hover:text-(--primary) transition-colors">
							{specialty.name || `Especialidad #${specialty.id_specialty}`}
						</h3>

						<p class="text-sm text-(--on-surface-variant) line-clamp-2 leading-relaxed">
							{toDescriptionLabel(specialty.description)}
						</p>
					</div>
				</article>
			))}
		</div>
	)}
</section>
