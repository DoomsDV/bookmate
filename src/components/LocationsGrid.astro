---
import type { Location } from '../lib/locations';

interface Props {
	locations: Location[];
	showCreateAction?: boolean;
}

const { locations = [], showCreateAction = false } = Astro.props;

const activeCount = locations.filter((item) => item.is_active === 1).length;
const inactiveCount = locations.length - activeCount;
---

<section class="rounded-[1.7rem] border border-(--shell-border) bg-(--surface-bright) p-6 md:p-8 shadow-[0_6px_30px_rgba(0,0,0,0.03)] dark:shadow-none transition-all">
	<header class="flex flex-col sm:flex-row sm:items-center justify-between gap-5 mb-8">
		<div class="flex flex-wrap items-center gap-2.5 text-[0.82rem] font-bold">
			<span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-500/10 px-3 py-1.5 text-emerald-700 dark:bg-emerald-500/20 dark:text-emerald-400 transition border border-emerald-500/10">
				<span class="size-2 rounded-full bg-emerald-500"></span> Activas: {activeCount}
			</span>
			{inactiveCount > 0 && (
				<span class="inline-flex items-center gap-1.5 rounded-full bg-rose-500/10 px-3 py-1.5 text-rose-700 dark:bg-rose-500/20 dark:text-rose-300 transition border border-rose-500/10">
					<span class="size-2 rounded-full bg-rose-500"></span> Inactivas: {inactiveCount}
				</span>
			)}
		</div>

		{showCreateAction && (
			<button
				type="button"
				class="btn-primary-soft inline-flex items-center justify-center gap-2 rounded-2xl px-5 py-3 text-[0.95rem] font-extrabold shadow-sm transition hover:shadow-md focus:outline-none focus:ring-2 focus:ring-(--primary) focus:ring-offset-2 focus:ring-offset-(--surface-bright) sm:w-auto w-full"
				data-open-location-modal
			>
				<span class="material-symbols-rounded text-[1.2rem]">add</span>
				Nueva Sucursal
			</button>
		)}
	</header>

	{locations.length === 0 ? (
		<div class="flex flex-col items-center justify-center rounded-[1.6rem] border-2 border-dashed border-(--shell-border) bg-(--surface)/40 px-6 py-14 text-center transition">
			<div class="mb-4 flex size-16 items-center justify-center rounded-full bg-(--surface-variant) text-(--on-surface-variant) ring-8 ring-(--surface-bright)">
				<span class="material-symbols-rounded text-[2rem]">domain</span>
			</div>
			<h3 class="text-[1.1rem] font-bold text-(--on-surface)">No hay sucursales registradas</h3>
			<p class="mt-1.5 text-[0.95rem] text-(--on-surface-variant) max-w-sm leading-relaxed">
				Aún no has agregado ninguna sucursal a esta organización. Comienza registrando tu primer local.
			</p>
		</div>
	) : (
		<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
			{locations.map((location) => (
				<article
					class="group cursor-pointer relative overflow-hidden rounded-3xl border border-(--shell-border) bg-(--card-surface-strong) p-5.5 transition-all duration-300 hover:-translate-y-1 hover:border-(--primary)/40 hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.1)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-(--primary) focus-visible:ring-offset-2"
					data-location-card
					data-location-id={location.id_location}
					tabindex="0"
					role="button"
					aria-label={`Editar sucursal ${location.name || location.id_location}`}
				>
					<div class="absolute right-0 top-0 h-32 w-32 -translate-y-16 translate-x-16 rounded-full bg-(--primary)/5 opacity-0 blur-2xl transition-opacity duration-300 group-hover:opacity-100"></div>

					<div class="relative flex items-start justify-between gap-4">
						<div class="flex size-11 shrink-0 items-center justify-center rounded-xl bg-(--primary-soft) text-(--primary) transition-transform duration-300 group-hover:scale-105 shadow-[inset_0_1px_0_rgba(255,255,255,0.4)]">
							<span class="material-symbols-rounded text-[1.25rem]">storefront</span>
						</div>

						<span
							class:list={[
								'inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[0.7rem] font-extrabold uppercase tracking-widest border',
								location.is_active === 1
									? 'bg-emerald-500/10 text-emerald-700 border-emerald-500/10 dark:bg-emerald-500/20 dark:text-emerald-400 dark:border-emerald-500/20'
									: 'bg-(--surface-variant) text-(--on-surface-variant) border-(--shell-border)',
							]}
						>
							<span class:list={["size-1.5 rounded-full", location.is_active === 1 ? "bg-emerald-500" : "bg-(--on-surface-variant)"]}></span>
							{location.is_active === 1 ? 'Activa' : 'Inactiva'}
						</span>
					</div>

					<div class="relative mt-5">
						<h3 class="text-[1.1rem] font-extrabold tracking-tight text-(--on-surface) line-clamp-1 group-hover:text-(--primary) transition-colors">
							{location.name || `Sucursal #${location.id_location}`}
						</h3>
						
						<p class="mt-1 text-[0.9rem] text-(--on-surface-variant) line-clamp-1">
							{location.address || 'Dirección no disponible'}
						</p>

						<dl class="mt-4 shrink-0 grid gap-2.5">
							<div class="flex items-center justify-between border-b border-(--shell-border) border-dashed pb-2.5 text-[0.9rem]">
								<dt class="flex items-center gap-1.5 text-(--on-surface-variant) font-semibold">
									<span class="material-symbols-rounded text-[1.1rem] opacity-70">location_city</span>
									Ciudad
								</dt>
								<dd class="font-bold text-(--on-surface) text-right">
									{location.city?.name || '-'}
								</dd>
							</div>
							<div class="flex items-center justify-between pt-0.5 text-[0.9rem]">
								<dt class="flex items-center gap-1.5 text-(--on-surface-variant) font-semibold">
									<span class="material-symbols-rounded text-[1.1rem] opacity-70">map</span>
									Depto.
								</dt>
								<dd class="font-extrabold text-(--on-surface) text-right">
									{location.department?.name || '-'}
								</dd>
							</div>
						</dl>
					</div>
				</article>
			))}
		</div>
	)}
</section>
