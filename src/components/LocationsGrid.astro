---
import type { Location } from '../lib/locations';

interface Props {
	locations: Location[];
	showCreateAction?: boolean;
}

const { locations, showCreateAction = false } = Astro.props;

const LOCATION_ICON = 'storefront';

const cardItems = locations.map((location) => ({ location }));

const activeLocations = locations.filter((item) => item.is_active === 1).length;
---

<section class="rounded-[1.7rem] border border-[color:var(--shell-border)] bg-[color:var(--card-surface)] p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.55)]">
	<div class="flex flex-wrap items-center justify-between gap-3">
		<div class="flex flex-wrap justify-start gap-2 text-xs font-semibold">
			<span class="status-chip-total">
				Total: {locations.length}
			</span>
			<span class="status-chip-success">
				Activas: {activeLocations}
			</span>
			<span class="status-chip-danger">
				Inactivas: {locations.length - activeLocations}
			</span>
		</div>

		{
			showCreateAction ? (
				<button
					type="button"
					class="btn-primary-soft inline-flex cursor-pointer items-center gap-2 rounded-xl px-4 py-2.5 text-sm font-semibold transition"
					data-open-location-modal
				>
					<span class="material-symbols-rounded text-[1.1rem]">add</span>
					Nueva sucursal
				</button>
			) : null
		}
	</div>

	{
		locations.length === 0 ? (
			<div class="mt-6 rounded-[1.45rem] border border-dashed border-[color:var(--shell-border)] bg-[color:var(--control-surface)] px-5 py-7 text-sm text-[color:var(--on-surface-variant)]">
				No hay sucursales registradas para esta organizacion.
			</div>
		) : (
			<div class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
				{
					cardItems.map((item) => (
						<article
							class="cursor-pointer rounded-[1.45rem] border border-[color:var(--shell-border)] bg-[color:var(--card-surface-strong)] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.6)] transition duration-200 hover:-translate-y-0.5 hover:shadow-[0_16px_30px_rgba(15,23,42,0.12)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--primary)]"
							data-location-card
							data-location-id={item.location.id_location}
							tabindex="0"
							role="button"
							aria-label={`Editar sucursal ${item.location.name || item.location.id_location}`}
						>
							<div class="flex items-start justify-between gap-3">
								<div class="flex size-10 items-center justify-center rounded-xl bg-[color:var(--primary-soft)] text-[color:var(--primary)]">
									<span class="material-symbols-rounded text-[1rem]">{LOCATION_ICON}</span>
								</div>

								<span
									class:list={[
										'status-pill',
										item.location.is_active === 1
											? 'status-pill-success'
											: 'status-pill-danger',
									]}
								>
									{item.location.is_active === 1 ? 'Activa' : 'Inactiva'}
								</span>
							</div>

							<h3 class="mt-4 text-lg font-semibold leading-6 text-[color:var(--on-surface)]">
								{item.location.name || `Sucursal #${item.location.id_location}`}
							</h3>

							<p class="mt-2 text-sm text-[color:var(--on-surface-variant)]">
								{item.location.address || 'Direccion no disponible'}
							</p>

							<div class="mt-5 space-y-3 text-sm text-[color:var(--on-surface-variant)]">
								<div class="flex items-center justify-between gap-3">
									<span>Ciudad</span>
									<span class="text-right font-semibold text-[color:var(--on-surface)]">
										{item.location.city.name || '-'}
									</span>
								</div>
								<div class="flex items-center justify-between gap-3">
									<span>Departamento</span>
									<span class="text-right font-semibold text-[color:var(--on-surface)]">
										{item.location.department.name || '-'}
									</span>
								</div>
							</div>
						</article>
					))
				}
			</div>
		)
	}
</section>
