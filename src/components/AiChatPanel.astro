<ai-chat-panel>
	<div class="ai-chat-shell" data-ai-chat-shell aria-hidden="true">
		<button type="button" class="ai-chat-backdrop" data-ai-chat-close aria-label="Cerrar asistente IA"></button>

		<aside class="ai-chat-drawer" role="dialog" aria-modal="true" aria-label="Asistente IA Hasel">
			<header class="ai-chat-header">
				<div class="ai-chat-title-wrap">
					<div class="ai-chat-mark">
						<span class="material-symbols-rounded">auto_awesome</span>
					</div>
					<div class="min-w-0">
						<h2 class="ai-chat-title">Asistente IA</h2>
						<p class="ai-chat-subtitle">Hasel</p>
					</div>
				</div>

				<div class="ai-chat-header-actions">
					<button
						type="button"
						class="ai-chat-history-toggle"
						data-ai-chat-history-toggle
						aria-controls="ai-chat-history-panel"
						aria-expanded="false"
						aria-label="Abrir historial"
					>
						<span class="material-symbols-rounded" aria-hidden="true">history</span>
					</button>

					<button type="button" class="ai-chat-new-btn" data-ai-chat-new aria-label="Nuevo chat">
						<span class="material-symbols-rounded" aria-hidden="true">add</span>
					</button>

					<button type="button" class="ai-chat-icon-btn" data-ai-chat-close aria-label="Cerrar asistente IA">
						<span class="material-symbols-rounded">close</span>
					</button>
				</div>
			</header>

			<div class="ai-chat-layout">
				<button
					type="button"
					class="ai-chat-history-backdrop"
					data-ai-chat-history-close
					aria-label="Cerrar historial"
				></button>

				<section class="ai-chat-history" id="ai-chat-history-panel" aria-label="Historial de conversaciones">
					<div class="ai-chat-history-head">
						<h3>Historial</h3>
						<button type="button" class="ai-chat-icon-btn" data-ai-chat-history-close aria-label="Cerrar historial">
							<span class="material-symbols-rounded">close</span>
						</button>
					</div>

					<div class="ai-chat-history-state" data-ai-chat-sessions-state>Cargando historial...</div>
					<div class="ai-chat-sessions" data-ai-chat-sessions></div>
				</section>

				<section class="ai-chat-main">
					<div class="ai-chat-messages" data-ai-chat-messages>
						<div class="ai-chat-empty">
							<div class="ai-chat-empty-icon">
								<span class="material-symbols-rounded">auto_awesome</span>
							</div>
							<h3>Consulta tu agenda</h3>
							<p>Haz preguntas sobre clientes, turnos, disponibilidad o el estado del negocio.</p>
							<div class="ai-chat-suggestions" data-ai-chat-suggestions aria-label="Preguntas sugeridas"></div>
						</div>
					</div>

					<div class="ai-chat-tools" data-ai-chat-tools>
						<div class="ai-chat-tools-row">
							<button
								type="button"
								class="ai-chat-tools-btn"
								data-ai-chat-tools-toggle
								aria-controls="ai-chat-tools-popover"
								aria-expanded="false"
							>
								<span class="material-symbols-rounded" aria-hidden="true">tune</span>
								Herramientas
							</button>
						</div>

						<div
							class="ai-chat-tools-popover"
							id="ai-chat-tools-popover"
							aria-label="Acciones rápidas del asistente"
							aria-hidden="true"
						>
							<h3>Herramientas</h3>
							<div class="ai-chat-quick-actions" data-ai-chat-quick-actions></div>
						</div>
					</div>

					<div class="ai-chat-error hidden" data-ai-chat-error></div>

					<form class="ai-chat-form" data-ai-chat-form>
						<textarea
							name="message"
							rows="1"
							maxlength="2000"
							placeholder="Escribe tu mensaje..."
							data-ai-chat-input
						></textarea>
						<button type="submit" class="ai-chat-send-btn" data-ai-chat-send aria-label="Enviar mensaje">
							<span class="material-symbols-rounded">send</span>
						</button>
					</form>
				</section>
			</div>
		</aside>
	</div>
</ai-chat-panel>

<script>
	import '../scripts/ai-chat-panel';
</script>

