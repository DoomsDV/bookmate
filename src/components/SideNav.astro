---
const primaryItems = [
	{ label: 'Dashboard', icon: 'space_dashboard', href: '#dashboard' },
	{ label: 'Calendario', icon: 'calendar_month', href: '#calendario' },
	{ label: 'Servicios', icon: 'inventory_2', href: '#servicios' },
];

const teamItems = [
	{ label: 'Personal', href: '#personal' },
	{ label: 'Horarios', href: '#horarios' },
	{ label: 'Cuentas', href: '#cuentas' },
];
---

<div
	class="pointer-events-none fixed inset-0 z-40 px-4 pb-4 pt-[5.35rem] sm:px-6 sm:pt-[5.75rem] lg:px-8"
	data-side-nav-shell
>
	<div class="absolute inset-0 bg-slate-950/12 opacity-0 transition duration-200" data-side-nav-backdrop></div>

	<aside
		id="app-side-nav"
		class="relative h-full w-[min(20rem,calc(100vw-2rem))] -translate-x-[calc(100%+2rem)] overflow-y-auto rounded-[2rem] border border-white/70 bg-[color:var(--surface-bright)] px-5 py-6 shadow-[0_18px_48px_rgba(15,23,42,0.16)] transition duration-300"
		data-side-nav
	>
		<div class="mb-8 flex items-center justify-between">
			<div
				class="flex size-11 items-center justify-center rounded-2xl bg-[color:var(--primary-container)] text-[color:var(--primary)] shadow-[inset_0_1px_0_rgba(255,255,255,0.7)]"
			>
				<span class="material-symbols-rounded text-[1.35rem]">dashboard_customize</span>
			</div>

			<button
				type="button"
				class="flex size-10 items-center justify-center rounded-full text-[color:var(--on-surface-variant)] transition hover:bg-black/5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--primary)]"
				aria-label="Cerrar menu lateral"
				data-side-nav-close
			>
				<span class="material-symbols-rounded text-[1.2rem]">close</span>
			</button>
		</div>

		<nav aria-label="Side navigation">
			<ul class="space-y-2">
				{
					primaryItems.map((item) => (
						<li>
							<a
								href={item.href}
								class="flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-semibold text-[color:var(--on-surface)] no-underline transition hover:bg-[color:var(--secondary-container)]/55"
								data-side-nav-close
							>
								<span class="material-symbols-rounded text-[1.1rem] text-[color:var(--on-surface-variant)]">
									{item.icon}
								</span>
								<span>{item.label}</span>
							</a>
						</li>
					))
				}

				<li>
					<details open class="group">
						<summary
							class="flex cursor-pointer list-none items-center justify-between rounded-2xl px-4 py-3 text-sm font-semibold text-[color:var(--primary)] transition hover:bg-[color:var(--secondary-container)]/55"
						>
							<span class="flex items-center gap-3">
								<span class="material-symbols-rounded text-[1.1rem]">groups</span>
								<span>Equipo</span>
							</span>

							<span
								class="material-symbols-rounded text-[1rem] transition group-open:rotate-180"
							>
								expand_more
							</span>
						</summary>

						<div class="ml-5 mt-1 border-l border-[color:var(--bar-outline)] pl-4">
							<ul class="space-y-1">
								{
									teamItems.map((item, index) => (
										<li>
											<a
												href={item.href}
												class:list={[
													'flex rounded-2xl px-4 py-3 text-sm font-medium no-underline transition',
													index === 0
														? 'bg-[color:var(--primary-container)] text-[color:var(--primary)] shadow-[inset_0_1px_0_rgba(255,255,255,0.65)]'
														: 'text-[color:var(--on-surface)] hover:bg-[color:var(--secondary-container)]/45',
												]}
												data-side-nav-close
											>
												{item.label}
											</a>
										</li>
									))
								}
							</ul>
						</div>
					</details>
				</li>
			</ul>
		</nav>
	</aside>
</div>
