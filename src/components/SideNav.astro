---
import { canAccessPath } from "../config/roles";
import OrgSwitcherModal from "./OrgSwitcherModal.astro";

interface NavItem {
	label: string;
	href: string;
	icon?: string;
	active?: boolean;
}

interface Props {
	currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const normalizePath = (path: string) => {
	if (!path || path === "/") return "/";
	return path.endsWith("/") ? path.slice(0, -1) : path;
};

const cachedOrganizationName = String(
	Astro.locals.organizationName || Astro.cookies.get("org_name")?.value || "",
).trim();
const cachedOrganizationLogoUrl = String(
	Astro.locals.organizationLogoUrl || Astro.cookies.get("org_logo_url")?.value || "",
).trim();
const workspaceName = cachedOrganizationName || "Workspace";
const workspaceInitial = workspaceName.charAt(0).toUpperCase();
const workspaceLogoUrl = cachedOrganizationLogoUrl;
const currentOrgMemberId = Number(Astro.locals.userId ?? 0);

const activePath = normalizePath(currentPath);
const currentRoleId = Number(Astro.locals.roleId ?? 0);

const isItemActive = (item: NavItem) => {
	if (typeof item.active === "boolean") return item.active;
	if (!item.href.startsWith("/")) return false;
	return normalizePath(item.href) === activePath;
};

/** Rutas con shell SSR liviano (datos en cliente). Prefetch solo al hover, no en viewport. */
const prefetchHoverPaths = new Set(["/panel/dashboard", "/panel/customers"]);

const getPrefetchMode = (item: NavItem) =>
	prefetchHoverPaths.has(normalizePath(item.href)) ? "hover" : undefined;

const primaryItems: NavItem[] = [
	{ label: "Dashboard", icon: "space_dashboard", href: "/panel/dashboard" },
	{ label: "Calendario", icon: "calendar_month", href: "/panel/calendar" },
	{ label: "Clientes", icon: "contacts", href: "/panel/customers" },
	{ label: "Servicios", icon: "inventory_2", href: "/panel/services" },
	{ label: "Sucursales", icon: "storefront", href: "/panel/locations" },
];

const teamItems: NavItem[] = [
	{ label: "Especialidades", href: "/panel/specialties" },
	{ label: "Personal", href: "/panel/professionals" },
	{ label: "Horarios", href: "/panel/schedules" },
];

const visiblePrimaryItems = primaryItems.filter((item) =>
	canAccessPath(item.href, currentRoleId),
);
const visibleTeamItems = teamItems.filter((item) =>
	canAccessPath(item.href, currentRoleId),
);
---

<div
	class="pointer-events-none fixed inset-0 z-50 lg:hidden"
	data-side-nav-shell
>
	<div
		class="absolute inset-0 bg-slate-950/18 opacity-0"
		data-side-nav-backdrop
	>
	</div>

	<aside
		id="app-side-nav"
		class="relative flex h-full w-[min(20rem,100vw)] -translate-x-full flex-col overflow-y-auto border-r border-(--shell-border) bg-(--sidebar-surface)"
		data-side-nav
	>
		<div class="shell-header-zone sidebar-account-header shrink-0 px-6 pt-6 pb-4">
			<div class="flex w-full items-center justify-between gap-3">
				<button
					type="button"
					class="sidebar-account-row sidebar-account-trigger min-w-0 flex-1"
					data-org-switcher-trigger
					aria-haspopup="dialog"
					aria-label={`Organización actual: ${workspaceName}. Cambiar organización`}
				>
					<div
						class:list={[
							"workspace-avatar flex size-16 shrink-0 items-center justify-center overflow-hidden rounded-full text-xl font-bold",
							workspaceLogoUrl ? "workspace-avatar--has-logo" : "workspace-avatar--empty",
						]}
						data-workspace-avatar
					>
						<span class="workspace-logo-placeholder" aria-hidden="true">
							<span class="material-symbols-rounded">storefront</span>
						</span>
						{
							workspaceLogoUrl ? (
								<img
									src={workspaceLogoUrl}
									alt=""
									class="workspace-logo-image size-full object-cover"
									loading="eager"
									onerror="this.classList.add('is-hidden'); this.removeAttribute('src');"
								/>
							) : null
						}
					</div>
					<div class="sidebar-account-meta" data-sidebar-brand-text>
						<div class="sidebar-account-title-row">
							<p class="workspace-account-name text-[1.1rem] leading-snug font-bold">
								{workspaceName}
							</p>
						</div>
						<p class="workspace-account-subtitle truncate">
							Plan Pro
						</p>
					</div>
					<span class="material-symbols-rounded sidebar-account-chevron" aria-hidden="true">
						unfold_more
					</span>
				</button>

				<button
					type="button"
					class="flex size-12 shrink-0 items-center justify-center rounded-2xl border border-(--shell-border) bg-(--control-surface) text-(--on-surface-variant) transition hover:bg-(--control-surface-strong)"
					aria-label="Cerrar menú lateral"
					data-side-nav-close
				>
					<span class="material-symbols-rounded text-[1.35rem]">close</span
					>
				</button>
			</div>
		</div>

		<div class="sidebar-divider shrink-0" role="presentation" aria-hidden="true"></div>

		<div class="flex-1 px-6 pb-6">
		<nav aria-label="Side navigation móvil">
			<ul class="space-y-2.5">
				{
					visiblePrimaryItems.map((item) => (
						<li>
							<a
								href={item.href}
								data-astro-prefetch={getPrefetchMode(item)}
								class:list={[
									"mx-1 flex min-h-12 items-center gap-3.5 rounded-full px-4 py-3.5 text-[1.02rem] font-semibold no-underline transition lg:gap-3 lg:py-2.5 lg:text-[0.9rem]",
									isItemActive(item)
										? "bg-(--primary-container) text-(--primary) font-extrabold shadow-[0_2px_8px_rgba(15,23,42,0.08)]"
										: "text-(--on-surface) font-semibold hover:bg-(--sidebar-hover)",
								]}
								data-side-nav-close
							>
								<span class="material-symbols-rounded text-[1.55rem] leading-none lg:text-[1.25rem]">
									{item.icon}
								</span>
								<span>{item.label}</span>
							</a>
						</li>
					))
				}

				{
					visibleTeamItems.length > 0 && (
						<li class="pt-2">
							<details open class="group">
								<summary class="flex min-h-12 cursor-pointer list-none items-center justify-between rounded-2xl px-4 py-3.5 text-[1.02rem] font-bold text-(--primary) transition hover:bg-(--sidebar-hover) lg:py-2.5 lg:text-[0.9rem]">
									<span class="flex items-center gap-3.5 lg:gap-3">
										<span class="material-symbols-rounded text-[1.55rem] leading-none lg:text-[1.25rem]">
											groups
										</span>
										<span>Equipo</span>
									</span>
									<span class="material-symbols-rounded text-[1.25rem] leading-none transition group-open:rotate-180 lg:text-[1rem]">
										expand_more
									</span>
								</summary>

								<div class="ml-5 mt-1 border-l border-(--shell-border) pl-4">
									<ul class="space-y-1">
										{visibleTeamItems.map((item) => (
											<li>
												<a
													href={item.href}
													class:list={[
														"mx-1 flex min-h-12 rounded-full px-4 py-3.5 text-[0.98rem] font-semibold no-underline transition lg:py-2.5 lg:text-[0.88rem]",
														isItemActive(item)
															? "bg-(--primary-container) text-(--primary) font-bold shadow-[0_2px_8px_rgba(15,23,42,0.08)]"
															: "text-(--on-surface) font-semibold hover:bg-(--sidebar-hover)",
													]}
													data-side-nav-close
												>
													{item.label}
												</a>
											</li>
										))}
									</ul>
								</div>
							</details>
						</li>
					)
				}
			</ul>
		</nav>
		</div>
	</aside>
</div>

<aside
	class="hidden h-full min-h-0 flex-col overflow-hidden border-r border-(--shell-border) bg-(--sidebar-surface) transition-[width] duration-200 lg:flex lg:w-[17.5rem]"
	data-desktop-sidebar
>
	<div
		class="shell-header-zone sidebar-account-header shrink-0 px-6 pb-4 pt-5"
		data-sidebar-brand-block
	>
		<button
			type="button"
			class="sidebar-account-row sidebar-account-trigger w-full"
			data-org-switcher-trigger
			data-sidebar-brand
			aria-haspopup="dialog"
			aria-label={`Organización actual: ${workspaceName}. Cambiar organización`}
		>
			<div
				class:list={[
					"workspace-avatar flex size-14 shrink-0 items-center justify-center overflow-hidden rounded-full text-lg font-bold",
					workspaceLogoUrl ? "workspace-avatar--has-logo" : "workspace-avatar--empty",
				]}
				data-workspace-avatar
			>
				<span class="workspace-logo-placeholder" aria-hidden="true">
					<span class="material-symbols-rounded">storefront</span>
				</span>
				{
					workspaceLogoUrl ? (
						<img
							src={workspaceLogoUrl}
							alt=""
							class="workspace-logo-image size-full object-cover"
							loading="eager"
							onerror="this.classList.add('is-hidden'); this.removeAttribute('src');"
						/>
					) : null
				}
			</div>
			<div class="sidebar-account-meta" data-sidebar-brand-text>
				<div class="sidebar-account-title-row">
					<p
						class="workspace-account-name text-[1.02rem] font-bold leading-snug lg:text-[0.95rem]"
						data-sidebar-title
					>
						{workspaceName}
					</p>
				</div>
				<p class="workspace-account-subtitle truncate">
					Plan Pro
				</p>
			</div>
			<span class="material-symbols-rounded sidebar-account-chevron" aria-hidden="true">
				unfold_more
			</span>
		</button>
	</div>

	<div class="sidebar-divider shrink-0" role="presentation" aria-hidden="true"></div>

	<div
		class="flex min-h-0 flex-1 flex-col overflow-y-auto overscroll-contain px-6 pb-7 transition-[padding] duration-200"
		data-sidebar-desktop-inner
	>
		<nav aria-label="Side navigation desktop">
			<ul class="space-y-2">
				{
					visiblePrimaryItems.map((item) => (
						<li>
							<a
								href={item.href}
								data-astro-prefetch={getPrefetchMode(item)}
								data-sidebar-item
								class:list={[
									"sidebar-nav-link flex items-center gap-3 rounded-full px-4 py-2.5 text-[0.9rem] font-semibold no-underline transition",
									isItemActive(item)
										? "is-active bg-(--primary-container) text-(--primary) font-bold"
										: "text-(--on-surface) font-semibold hover:bg-(--sidebar-hover)",
								]}
							>
								<span class="sidebar-nav-icon material-symbols-rounded shrink-0 text-[1.25rem] leading-none">
									{item.icon}
								</span>
								<span class="sidebar-nav-label" data-sidebar-label>{item.label}</span>
							</a>
						</li>
					))
				}

				{
					visibleTeamItems.length > 0 && (
						<li class="pt-2">
							<details open class="group">
								<summary
									class="sidebar-nav-link sidebar-nav-summary flex cursor-pointer list-none items-center justify-between rounded-full px-4 py-2.5 text-[0.9rem] font-semibold text-(--primary) transition hover:bg-(--sidebar-hover)"
									data-sidebar-summary
								>
									<span class="sidebar-nav-summary-main flex min-w-0 items-center gap-3">
										<span class="sidebar-nav-icon material-symbols-rounded shrink-0 text-[1.25rem] leading-none">
											groups
										</span>
										<span class="sidebar-nav-label" data-sidebar-label>Equipo</span>
									</span>
									<span
										class="sidebar-nav-trailing material-symbols-rounded shrink-0 text-[1.05rem] leading-none transition group-open:rotate-180"
										data-sidebar-trailing
									>
										expand_more
									</span>
								</summary>

								<div
									class="ml-5 mt-1 border-l border-(--shell-border) pl-4"
									data-team-submenu
								>
									<ul class="space-y-1">
										{visibleTeamItems.map((item) => (
											<li>
												<a
													href={item.href}
													data-sidebar-item
													class:list={[
														"sidebar-nav-link sidebar-nav-link--sub flex rounded-full px-4 py-2.5 text-[0.88rem] font-medium no-underline transition",
														isItemActive(item)
															? "is-active bg-(--control-surface-strong) text-(--primary) font-semibold shadow-[0_2px_8px_rgba(15,23,42,0.08)]"
															: "text-(--on-surface) hover:bg-(--sidebar-hover)",
													]}
												>
													<span class="sidebar-nav-label" data-sidebar-label>
														{item.label}
													</span>
												</a>
											</li>
										))}
									</ul>
								</div>
							</details>
						</li>
					)
				}
			</ul>
		</nav>

		
	</div>
</aside>

<OrgSwitcherModal currentOrgMemberId={currentOrgMemberId} />

<style>
	.sidebar-divider {
		margin: 0 1.5rem 1rem;
		height: 0;
		border: 0;
		border-top: 1px solid var(--shell-border);
	}

	.sidebar-account-trigger {
		border: 0;
		background: transparent;
		cursor: pointer;
		text-align: left;
		transition: background-color 0.15s ease;
	}

	.sidebar-account-trigger:hover {
		background: var(--sidebar-hover);
	}

	.sidebar-account-chevron {
		margin-left: auto;
		flex-shrink: 0;
		font-size: 1.35rem;
		line-height: 1;
		color: var(--on-surface-variant);
	}

	.workspace-avatar {
		position: relative;
		color: var(--primary);
		border: 1px solid color-mix(in srgb, var(--primary) 24%, var(--shell-border) 76%);
		background: var(--surface-container);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08), 0 10px 26px rgba(15, 23, 42, 0.12);
	}

	.workspace-avatar--empty {
		background: var(--surface-container-high);
		box-shadow: none;
	}

	:global(html[data-theme='dark']) .workspace-avatar--empty {
		border-color: var(--shell-border);
		background: var(--surface-container-highest);
		box-shadow: none;
	}

	.workspace-logo-placeholder {
		position: absolute;
		inset: 0;
		display: grid;
		place-items: center;
	}

	.workspace-logo-placeholder .material-symbols-rounded {
		font-size: 1.7rem;
		line-height: 1;
	}

	.workspace-logo-image {
		position: absolute;
		inset: 0;
		z-index: 1;
		background: var(--surface-bright);
	}

	.workspace-logo-image.is-hidden {
		display: none;
	}

	.sidebar-nav-icon {
		display: inline-flex;
		width: 1.25rem;
		height: 1.25rem;
		align-items: center;
		justify-content: center;
	}

	.sidebar-nav-label {
		min-width: 0;
		line-height: 1.25;
	}
</style>

