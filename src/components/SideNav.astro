---
import { canAccessPath } from "../config/roles";

interface NavItem {
	label: string;
	href: string;
	icon?: string;
	active?: boolean;
}

interface Props {
	currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const normalizePath = (path: string) => {
	if (!path || path === "/") return "/";
	return path.endsWith("/") ? path.slice(0, -1) : path;
};

const activePath = normalizePath(currentPath);
const currentRoleId = Number(Astro.locals.roleId ?? 0);

const isItemActive = (item: NavItem) => {
	if (typeof item.active === "boolean") return item.active;
	if (!item.href.startsWith("/")) return false;
	return normalizePath(item.href) === activePath;
};

const primaryItems: NavItem[] = [
	{ label: "Dashboard", icon: "space_dashboard", href: "/" },
	{ label: "Calendario", icon: "calendar_month", href: "/calendar" },
	{ label: "Servicios", icon: "inventory_2", href: "/services" },
	{ label: "Sucursales", icon: "storefront", href: "/locations" },
];

const teamItems: NavItem[] = [
	{ label: "Especialidades", href: "/specialties" },
	{ label: "Personal", href: "/professionals" },
	{ label: "Horarios", href: "/schedules" },
];

const visiblePrimaryItems = primaryItems.filter((item) =>
	canAccessPath(item.href, currentRoleId),
);
const visibleTeamItems = teamItems.filter((item) =>
	canAccessPath(item.href, currentRoleId),
);
---

<div
	class="pointer-events-none fixed inset-0 z-50 lg:hidden"
	data-side-nav-shell
>
	<div
		class="absolute inset-0 bg-slate-950/18 opacity-0 transition duration-200"
		data-side-nav-backdrop
	>
	</div>

	<aside
		id="app-side-nav"
		class="relative h-full w-[min(20rem,100vw)] -translate-x-full overflow-y-auto border-r border-[color:var(--shell-border)] bg-[color:var(--surface-bright)] px-5 py-6 transition duration-300"
		data-side-nav
	>
		<div class="mb-8 flex items-center justify-between">
			<div>
				<p
					class="text-[0.68rem] font-bold uppercase tracking-[0.28em] text-[color:var(--on-surface-variant)]/75"
				>
					Navegacion
				</p>
				<p
					class="mt-2 [font-family:var(--font-logo)] text-[1.35rem] font-extrabold uppercase tracking-[0.08em] leading-none text-[color:var(--primary)]"
				>
					Bookmate
				</p>
			</div>

			<button
				type="button"
				class="flex size-10 items-center justify-center rounded-2xl border border-[color:var(--shell-border)] bg-[color:var(--control-surface)] text-[color:var(--on-surface-variant)] shadow-[inset_0_1px_0_rgba(255,255,255,0.55)] transition hover:bg-[color:var(--control-surface-strong)]"
				aria-label="Cerrar menú lateral"
				data-side-nav-close
			>
				<span class="material-symbols-rounded text-[1.2rem]">close</span
				>
			</button>
		</div>

		<nav aria-label="Side navigation móvil">
			<ul class="space-y-2">
				{
					visiblePrimaryItems.map((item) => (
						<li>
							<a
								href={item.href}
								class:list={[
									"flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-semibold no-underline transition",
									isItemActive(item)
										? "bg-[color:var(--primary-container)] text-[color:var(--primary)]"
										: "text-[color:var(--on-surface)] hover:bg-[color:var(--sidebar-hover)]",
								]}
								data-side-nav-close
							>
								<span class="material-symbols-rounded text-[1.1rem]">
									{item.icon}
								</span>
								<span>{item.label}</span>
							</a>
						</li>
					))
				}

				{
					visibleTeamItems.length > 0 && (
						<li class="pt-2">
							<details open class="group">
								<summary class="flex cursor-pointer list-none items-center justify-between rounded-2xl px-4 py-3 text-sm font-semibold text-[color:var(--primary)] transition hover:bg-[color:var(--sidebar-hover)]">
									<span class="flex items-center gap-3">
										<span class="material-symbols-rounded text-[1.1rem]">
											groups
										</span>
										<span>Equipo</span>
									</span>
									<span class="material-symbols-rounded text-[1rem] transition group-open:rotate-180">
										expand_more
									</span>
								</summary>

								<div class="ml-5 mt-1 border-l border-[color:var(--shell-border)] pl-4">
									<ul class="space-y-1">
										{visibleTeamItems.map((item) => (
											<li>
												<a
													href={item.href}
													class:list={[
														"flex rounded-2xl px-4 py-3 text-sm font-medium no-underline transition",
														isItemActive(item)
															? "bg-[color:var(--primary-container)] text-[color:var(--primary)]"
															: "text-[color:var(--on-surface)] hover:bg-[color:var(--sidebar-hover)]",
													]}
													data-side-nav-close
												>
													{item.label}
												</a>
											</li>
										))}
									</ul>
								</div>
							</details>
						</li>
					)
				}
			</ul>
		</nav>
	</aside>
</div>

<aside
	class="hidden h-full border-r border-[color:var(--shell-border)]/85 bg-[color:var(--sidebar-surface)] transition-[width] duration-300 lg:block"
	data-desktop-sidebar
>
	<div
		class="flex h-full flex-col px-6 py-7 transition-all duration-300"
		data-sidebar-desktop-inner
	>
		<div class="flex items-center gap-3" data-sidebar-brand>
			<div data-sidebar-brand-text>
				<p
					class="text-[0.68rem] font-bold uppercase tracking-[0.28em] text-[color:var(--on-surface-variant)]/75"
					data-sidebar-caption
				>
					Navegación
				</p>
				<p
					class="mt-3 [font-family:var(--font-logo)] text-[1.45rem] font-extrabold uppercase tracking-[0.08em] leading-none text-[color:var(--primary)]"
					data-sidebar-title
				>
					Bookmate
				</p>
			</div>
		</div>

		<nav class="mt-10" aria-label="Side navigation desktop">
			<ul class="space-y-2">
				{
					visiblePrimaryItems.map((item) => (
						<li>
							<a
								href={item.href}
								data-sidebar-item
								class:list={[
									"flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-semibold no-underline transition",
									isItemActive(item)
										? "bg-[color:var(--primary-container)] text-[color:var(--primary)]"
										: "text-[color:var(--on-surface)] hover:bg-[color:var(--sidebar-hover)]",
								]}
							>
								<span class="material-symbols-rounded shrink-0 text-[1.1rem]">
									{item.icon}
								</span>
								<span data-sidebar-label>{item.label}</span>
							</a>
						</li>
					))
				}

				{
					visibleTeamItems.length > 0 && (
						<li class="pt-2">
							<details open class="group">
								<summary
									class="flex cursor-pointer list-none items-center justify-between rounded-2xl px-4 py-3 text-sm font-semibold text-[color:var(--primary)] transition hover:bg-[color:var(--sidebar-hover)]"
									data-sidebar-summary
								>
									<span class="flex items-center gap-3">
										<span class="material-symbols-rounded shrink-0 text-[1.1rem]">
											groups
										</span>
										<span data-sidebar-label>Equipo</span>
									</span>
									<span
										class="material-symbols-rounded text-[1rem] transition group-open:rotate-180"
										data-sidebar-trailing
									>
										expand_more
									</span>
								</summary>

								<div
									class="ml-5 mt-1 border-l border-[color:var(--shell-border)] pl-4"
									data-team-submenu
								>
									<ul class="space-y-1">
										{visibleTeamItems.map((item) => (
											<li>
												<a
													href={item.href}
													data-sidebar-item
													class:list={[
														"flex rounded-2xl px-4 py-3 text-sm font-medium no-underline transition",
														isItemActive(item)
															? "bg-[color:var(--control-surface-strong)] text-[color:var(--primary)]"
															: "text-[color:var(--on-surface)] hover:bg-[color:var(--sidebar-hover)]",
													]}
												>
													<span data-sidebar-label>
														{item.label}
													</span>
												</a>
											</li>
										))}
									</ul>
								</div>
							</details>
						</li>
					)
				}
			</ul>
		</nav>

		<div
			class="mt-auto rounded-[1.45rem] border border-[color:var(--shell-border)] bg-[color:var(--sidebar-card-surface)] p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.55)]"
			data-sidebar-footer
		>
			<p
				class="text-xs font-bold uppercase tracking-[0.22em] text-[color:var(--on-surface-variant)]/75"
			>
				Estado
			</p>
			<p
				class="mt-3 text-sm font-semibold text-[color:var(--on-surface)]"
				data-time-greeting
			>
				Buenos días
			</p>
		</div>
	</div>
</aside>

<script>
	const greetingNodes = document.querySelectorAll("[data-time-greeting]");
	const hour = new Date().getHours();
	const greeting =
		hour < 12
			? "Buenos días"
			: hour < 19
				? "Buenas tardes"
				: "Buenas noches";

	for (const node of greetingNodes) {
		node.textContent = greeting;
	}
</script>
