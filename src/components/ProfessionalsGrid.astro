---
import type { Professional } from '../lib/professionals';

interface Props {
	professionals: Professional[];
	showCreateAction?: boolean;
}

const { professionals = [], showCreateAction = false } = Astro.props;

const PROFESSIONAL_ICON = 'badge';

const toDisplayName = (professional: Professional) => {
	const first = String(professional.user.first_name || '').trim();
	const last = String(professional.user.last_name || '').trim();
	const fullName = `${first} ${last}`.trim();
	if (fullName) return fullName;
	return professional.user.apex_user_name || `Personal #${professional.id_professional}`;
};

const toSpecialtyName = (professional: Professional) => {
	return professional.specialty?.name || 'Sin especialidad';
};

const toProfileImageUrl = (professional: Professional) => {
	return String(professional.profile_image_url || '').trim();
};

const cardItems = professionals.map((professional) => ({
	professional,
	profileImageUrl: toProfileImageUrl(professional),
}));

const activeCount = professionals.filter((item) => item.is_active === 1).length;
const inactiveCount = professionals.length - activeCount;

const formatStrictDate = (dateString?: string) => {
	if (!dateString) return '--';
	const d = new Date(dateString);
	if (isNaN(d.getTime())) return '--';
	const day = String(d.getDate()).padStart(2, '0');
	const month = String(d.getMonth() + 1).padStart(2, '0');
	const year = String(d.getFullYear()).slice(-2);
	return `${day}-${month}-${year}`;
};
---

<section class="professionals-view">
	<header class="mb-4 flex flex-col sm:flex-row sm:items-start justify-between gap-4">
		<div class="flex flex-col gap-2.5">
			<h2 class="text-[1.5rem] sm:text-[1.75rem] font-bold tracking-tight text-(--on-surface) leading-none m-0">Personal</h2>
			<div class="flex flex-wrap items-center gap-2">
				<span class="professionals-summary-pill professionals-summary-pill--active">
					<span class="size-2 rounded-full professionals-summary-dot professionals-summary-dot--active"></span>
					Activos: {activeCount}
				</span>
				{inactiveCount > 0 && (
					<span class="professionals-summary-pill professionals-summary-pill--inactive">
						<span class="size-2 rounded-full professionals-summary-dot professionals-summary-dot--inactive"></span>
						Inactivos: {inactiveCount}
					</span>
				)}
			</div>
		</div>

		<div class="shrink-0 sm:mt-0">
			{showCreateAction && (
				<button
					type="button"
					class="professionals-create-btn flex items-center justify-center gap-2"
					data-open-professional-modal
				>
					<svg class="professionals-create-btn-icon w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" />
					</svg>
					<span>Nuevo Personal</span>
				</button>
			)}
		</div>
	</header>

	{professionals.length === 0 ? (
		<div class="professionals-empty-state">
			<div class="professionals-empty-icon">
				<span class="material-symbols-rounded text-[2rem]">badge</span>
			</div>
			<h3 class="text-[1.1rem] font-bold text-(--on-surface)">No hay profesionales registrados</h3>
			<p class="mt-1.5 max-w-sm text-[0.95rem] leading-relaxed text-(--on-surface-variant)">
				Aún no has agregado a ningún profesional a esta organización. Comienza creando tu primer registro de personal.
			</p>
		</div>
	) : (
		<div class="material-cards-grid gap-6 sm:grid-cols-2 sm:gap-8 lg:grid-cols-3">
			{cardItems.map((item) => (
				<article
					class="professionals-card group cursor-pointer relative overflow-hidden"
					data-professional-card
					data-professional-id={item.professional.id_professional}
					tabindex="0"
					role="button"
					aria-label={`Editar personal ${toDisplayName(item.professional)}`}
				>
					<div class="relative flex items-start justify-between gap-4">
						<div class="relative flex size-[2.75rem] shrink-0 items-center justify-center rounded-[0.85rem] bg-(--primary-soft) text-(--primary) overflow-hidden">
							{item.profileImageUrl ? (
								<img
									src={item.profileImageUrl}
									alt={`Foto de perfil de ${toDisplayName(item.professional)}`}
									class="h-full w-full object-cover"
									loading="lazy"
									decoding="async"
								/>
							) : (
								<span class="material-symbols-rounded text-[1.25rem]">{PROFESSIONAL_ICON}</span>
							)}
						</div>

						<span
							class:list={[
								'professionals-card-status',
								item.professional.is_active === 1
									? 'professionals-card-status--active'
									: 'professionals-card-status--inactive',
							]}
						>
							<span
								class:list={[
									'size-1.5 rounded-full',
									item.professional.is_active === 1
										? 'professionals-summary-dot--active'
										: 'professionals-summary-dot--inactive',
								]}
							></span>
							{item.professional.is_active === 1 ? 'Activo' : 'Inactivo'}
						</span>
					</div>

					<div class="relative flex flex-1 flex-col gap-[0.85rem]">
						<div>
							<h3 class="professionals-card-title line-clamp-1">
								{toDisplayName(item.professional)}
							</h3>
							<p class="mt-1 text-[0.9rem] text-(--on-surface-variant) line-clamp-1">
								@{item.professional.user.apex_user_name || '-'}
							</p>
						</div>

						<dl class="mt-auto shrink-0 grid gap-0.5">
							<div class="flex items-center justify-between text-[0.92rem]">
								<dt class="professionals-card-term">Especialidad</dt>
								<dd class="professionals-card-value">{toSpecialtyName(item.professional)}</dd>
							</div>
							<div class="flex items-center justify-between text-[0.92rem]">
								<dt class="professionals-card-term">Teléfono</dt>
								<dd class="professionals-card-value">{item.professional.phone_number || '-'}</dd>
							</div>
							<div class="flex items-center justify-between text-[0.92rem] mt-1">
								<dt class="professionals-card-term text-[0.82rem]">Registro</dt>
								<dd class="professionals-card-value text-[0.82rem] font-bold">{formatStrictDate(item.professional.created_at)}</dd>
							</div>
						</dl>
					</div>
				</article>
			))}
		</div>
	)}
</section>

<style>
	.professionals-view {
		display: grid;
		gap: 1.2rem;
	}

	.professionals-summary-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		border-radius: 999px;
		border: 0;
		padding: 0.33rem 0.78rem;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.01em;
	}

	.professionals-summary-pill--active {
		background: rgba(16, 185, 129, 0.12);
		color: #0f6d4a;
	}

	.professionals-summary-pill--inactive {
		background: rgba(244, 63, 94, 0.11);
		color: #8d3e4a;
	}

	.professionals-summary-dot {
		display: inline-block;
	}

	.professionals-summary-dot--active {
		background: #22c55e;
	}

	.professionals-summary-dot--inactive {
		background: #fb7185;
	}

	.professionals-create-btn {
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--primary) 72%, #123e7a 28%);
		background: var(--primary);
		padding: 0.72rem 1.15rem;
		font-size: 0.92rem;
		font-weight: 780;
		color: #f8fbff;
		box-shadow: none;
		transition: filter 140ms ease, border-color 140ms ease;
	}

	.professionals-create-btn-icon {
		flex-shrink: 0;
	}

	.professionals-create-btn:hover {
		filter: brightness(1.04);
	}

	.professionals-empty-state {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		border-radius: 1.35rem;
		border: 1px solid rgba(148, 163, 184, 0.24);
		background: color-mix(in srgb, var(--surface-container-low) 72%, var(--surface-bright) 28%);
		padding: 2.5rem 1.25rem;
		text-align: center;
	}

	.professionals-empty-icon {
		margin-bottom: 1rem;
		display: flex;
		height: 4rem;
		width: 4rem;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		background: color-mix(in srgb, var(--surface-container) 88%, var(--surface-bright) 12%);
		color: var(--on-surface-variant);
	}

	.professionals-card {
		display: flex;
		flex-direction: column;
		gap: 0.95rem;
		border-radius: 1.2rem;
		border: 0;
		background: color-mix(in srgb, var(--surface-container-low) 76%, var(--surface-bright) 24%);
		padding: 1.45rem 1.5rem 1.55rem;
		box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.08);
		transition: transform 170ms ease, box-shadow 170ms ease, background-color 170ms ease;
	}

	.professionals-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 14px 44px -12px rgba(0, 0, 0, 0.1);
	}

	.professionals-card-status {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		border-radius: 999px;
		border: 0;
		padding: 0.24rem 0.6rem;
		font-size: 0.66rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		white-space: nowrap;
	}

	.professionals-card-status--active {
		background: rgba(16, 185, 129, 0.12);
		color: #0f6d4a;
	}

	.professionals-card-status--inactive {
		background: rgba(244, 63, 94, 0.11);
		color: #8d3e4a;
	}

	.professionals-card-title {
		margin: 0;
		font-size: 1.1rem;
		font-weight: 760;
		line-height: 1.3;
		letter-spacing: -0.01em;
		color: var(--on-surface);
	}

	.professionals-card-term {
		color: var(--on-surface-variant);
		font-weight: 500;
	}

	.professionals-card-value {
		font-weight: 700;
		color: color-mix(in srgb, var(--on-surface-variant) 74%, var(--on-surface) 26%);
		text-align: right;
	}

	html[data-theme='dark'] .professionals-summary-pill--active {
		background: rgba(110, 231, 183, 0.16);
		color: #b8f5d5;
	}

	html[data-theme='dark'] .professionals-summary-pill--inactive {
		background: rgba(255, 182, 193, 0.12);
		color: #ffc8d2;
	}

	html[data-theme='dark'] .professionals-create-btn {
		border-color: color-mix(in srgb, var(--primary) 58%, #131314 42%);
		background: color-mix(in srgb, var(--primary) 78%, #131314 22%);
	}

	html[data-theme='dark'] .professionals-create-btn:hover {
		filter: brightness(1.08);
	}

	html[data-theme='dark'] .professionals-empty-state {
		border-color: rgba(255, 255, 255, 0.08);
		background: color-mix(
			in srgb,
			var(--surface-container-low, #1e1f22) 82%,
			var(--surface-container, #131314) 18%
		);
	}

	html[data-theme='dark'] .professionals-card {
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: var(--surface-container, #1e1f22);
		box-shadow: none;
	}

	html[data-theme='dark'] .professionals-card:hover {
		border-color: rgba(255, 255, 255, 0.15);
		background: var(--surface-container-high, #282a2c);
	}

	html[data-theme='dark'] .professionals-card-status--active {
		background: rgba(110, 231, 183, 0.16);
		color: #b8f5d5;
	}

	html[data-theme='dark'] .professionals-card-status--inactive {
		background: rgba(255, 182, 193, 0.12);
		color: #ffc8d2;
	}

	html[data-theme='dark'] .professionals-card-value {
		color: color-mix(in srgb, var(--on-surface-variant) 86%, #d1d5db 14%);
	}
</style>
