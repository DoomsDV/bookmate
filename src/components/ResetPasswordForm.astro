---
interface Props {
	error?: string;
	token?: string;
	newPasswordError?: string;
	confirmPasswordError?: string;
}

const {
	error = '',
	token = '',
	newPasswordError = '',
	confirmPasswordError = '',
} = Astro.props;

const safeToken = String(token || '').trim();
const hasToken = safeToken.length > 0;
---

<section class="m3-container auth-dark">
	<aside class="m3-sidebar">
		<div class="m3-sidebar-inner">
			<div class="m3-brand">
				<a href="/" class="m3-brand-link" aria-label="Ir al inicio">
					<img src="/icon-512x512.png" alt="Hasel Logo" class="m3-logo" />
				</a>
			</div>

			<div class="m3-stepper-header">
				<h2 class="m3-step-maintitle">Crea tu nueva contraseña</h2>
				<p class="m3-step-maindesc">
					Usa el enlace seguro de recuperación para actualizar tu acceso y cerrar sesiones anteriores.
				</p>
			</div>

		</div>
	</aside>

	<main class="m3-content">
		<div class="m3-form-wrapper">
			<div class="m3-form-header">
				<div class="m3-panel-icon">
					<span class="material-symbols-rounded">lock_reset</span>
				</div>
				<div class="m3-panel-titles">
					<h1 class="m3-panel-title">Restablecer contraseña</h1>
					<p class="m3-panel-subtitle">Crea una nueva contraseña segura para tu cuenta.</p>
				</div>
			</div>

			{!hasToken && (
				<div class="m3-warning-banner" role="alert">
					<span class="material-symbols-rounded">warning</span>
					<span>No encontramos un token válido. Solicita un nuevo enlace de recuperación.</span>
				</div>
			)}

			{error && (
				<div class="m3-error-banner" role="alert">
					<span class="material-symbols-rounded">error</span>
					<span>{error}</span>
				</div>
			)}

			<form method="post" action="/api/auth/reset-password" data-astro-reload data-reset-password-form>
				<input type="hidden" name="token" value={safeToken} />

				<div class="m3-panel">
					<div class="m3-field">
						<label class="m3-label" for="new_password">Nueva contraseña <span class="m3-label-required">*</span></label>
						<div class="m3-input-affix">
							<input
								type="password"
								id="new_password"
								name="new_password"
								placeholder="Tu nueva contraseña"
								class:list={['m3-input', newPasswordError && 'is-invalid']}
								required
								disabled={!hasToken}
							/>
							<button type="button" class="m3-password-toggle" data-password-toggle="new_password" aria-label="Mostrar contraseña" disabled={!hasToken}>
								<span class="material-symbols-rounded" data-password-icon>visibility_off</span>
							</button>
						</div>
						<div class="reset-password-strength is-hidden" data-password-strength aria-live="polite">
							<div class="reset-password-strength-bars">
								<span class="reset-password-strength-segment" data-password-segment></span>
								<span class="reset-password-strength-segment" data-password-segment></span>
								<span class="reset-password-strength-segment" data-password-segment></span>
								<span class="reset-password-strength-segment" data-password-segment></span>
							</div>
							<p class="reset-password-strength-text" data-password-strength-text>Poco segura</p>
						</div>
						{newPasswordError && <span class="m3-field-error">{newPasswordError}</span>}
					</div>

					<div class="m3-field">
						<label class="m3-label" for="confirm_password">Confirmar contraseña <span class="m3-label-required">*</span></label>
						<div class="m3-input-affix">
							<input
								type="password"
								id="confirm_password"
								name="confirm_password"
								placeholder="Confirma tu contraseña"
								class:list={['m3-input', confirmPasswordError && 'is-invalid']}
								required
								disabled={!hasToken}
							/>
							<button type="button" class="m3-password-toggle" data-password-toggle="confirm_password" aria-label="Mostrar contraseña" disabled={!hasToken}>
								<span class="material-symbols-rounded" data-password-icon>visibility_off</span>
							</button>
						</div>
						{confirmPasswordError && <span class="m3-field-error">{confirmPasswordError}</span>}
					</div>

					<div class="m3-actions">
						<button type="submit" class="m3-btn-primary" disabled={!hasToken}>
							Actualizar contraseña
							<span class="material-symbols-rounded">check_circle</span>
						</button>
					</div>
				</div>
			</form>

			<div class="m3-card-footer">
				<div class="m3-footer-divider"></div>
				<div class="m3-footer-links">
					<a href="/auth/forgot-password" class="m3-link-accent"><strong>Solicitar nuevo enlace</strong></a>
					<span>•</span>
					<a href="/auth/login" class="m3-link-accent"><strong>Volver al login</strong></a>
				</div>
			</div>
		</div>
	</main>
</section>

<script is:inline>
	function setupResetPasswordForm() {
		const form = document.querySelector('[data-reset-password-form]');
		if (!form || form.dataset.enhanced) return;
		form.dataset.enhanced = 'true';

		const newPasswordInput = form.querySelector('input[name="new_password"]');
		const confirmPasswordInput = form.querySelector('input[name="confirm_password"]');
		const passwordStrength = form.querySelector('[data-password-strength]');
		const passwordStrengthText = form.querySelector('[data-password-strength-text]');
		const passwordSegments = form.querySelectorAll('[data-password-segment]');
		const toggleButtons = form.querySelectorAll('[data-password-toggle]');

		const getPasswordValidationMessage = (rawPassword) => {
			const password = String(rawPassword || '');
			if (password.trim().length < 8) {
				return 'La contraseña debe tener al menos 8 caracteres.';
			}
			if (!/[A-Z]/.test(password)) {
				return 'La contraseña debe contener al menos una letra mayúscula.';
			}
			if (!/[0-9]/.test(password)) {
				return 'La contraseña debe contener al menos un número.';
			}
			return '';
		};

		const getPasswordStrengthState = (rawPassword) => {
			const password = String(rawPassword || '');
			const trimmedLength = password.trim().length;
			const hasUppercase = /[A-Z]/.test(password);
			const hasNumber = /[0-9]/.test(password);
			const hasSpecial = /[^A-Za-z0-9]/.test(password);

			if (!password) return { level: 0, tone: 'weak', label: '' };
			if (trimmedLength < 8) return { level: 1, tone: 'weak', label: 'Muy débil' };
			if (!hasUppercase) return { level: 2, tone: 'warning', label: 'Poco segura' };
			if (!hasNumber) return { level: 3, tone: 'warning', label: 'Media' };
			if (trimmedLength >= 12 && hasSpecial) return { level: 4, tone: 'strong', label: 'Fuerte' };
			return { level: 4, tone: 'good', label: 'Segura' };
		};

		const renderPasswordStrength = (rawPassword) => {
			if (!passwordStrength || !passwordStrengthText || passwordSegments.length === 0) return;

			const state = getPasswordStrengthState(rawPassword);
			passwordStrength.classList.toggle('is-hidden', state.level === 0);
			passwordStrength.dataset.tone = state.tone;
			passwordStrengthText.textContent = state.label;

			passwordSegments.forEach((segment, index) => {
				segment.classList.toggle('is-active', index < state.level);
			});
		};

		const validateNewPassword = () => {
			if (!(newPasswordInput instanceof HTMLInputElement)) return true;
			const message = getPasswordValidationMessage(newPasswordInput.value);
			newPasswordInput.setCustomValidity(message);
			renderPasswordStrength(newPasswordInput.value);
			return message === '';
		};

		const validateConfirmPassword = () => {
			if (!(newPasswordInput instanceof HTMLInputElement) || !(confirmPasswordInput instanceof HTMLInputElement)) {
				return true;
			}

			if (!confirmPasswordInput.value) {
				confirmPasswordInput.setCustomValidity('Debes confirmar tu contraseña.');
				return false;
			}

			if (confirmPasswordInput.value !== newPasswordInput.value) {
				confirmPasswordInput.setCustomValidity('Las contraseñas no coinciden.');
				return false;
			}

			confirmPasswordInput.setCustomValidity('');
			return true;
		};

		toggleButtons.forEach((button) => {
			button.addEventListener('click', () => {
				const targetName = button.getAttribute('data-password-toggle');
				if (!targetName) return;
				const targetInput = form.querySelector(`input[name="${targetName}"]`);
				if (!(targetInput instanceof HTMLInputElement)) return;
				const isPassword = targetInput.type === 'password';
				targetInput.type = isPassword ? 'text' : 'password';
				button.setAttribute('aria-label', isPassword ? 'Ocultar contraseña' : 'Mostrar contraseña');
				const icon = button.querySelector('[data-password-icon]');
				if (icon) icon.textContent = isPassword ? 'visibility' : 'visibility_off';
			});
		});

		if (newPasswordInput instanceof HTMLInputElement) {
			newPasswordInput.addEventListener('input', () => {
				validateNewPassword();
				validateConfirmPassword();
			});
			newPasswordInput.addEventListener('blur', validateNewPassword);
			validateNewPassword();
		}

		if (confirmPasswordInput instanceof HTMLInputElement) {
			confirmPasswordInput.addEventListener('input', validateConfirmPassword);
			confirmPasswordInput.addEventListener('blur', validateConfirmPassword);
		}

		form.addEventListener('submit', (event) => {
			const okPassword = validateNewPassword();
			const okConfirm = validateConfirmPassword();
			if (!okPassword || !okConfirm) {
				event.preventDefault();
				form.reportValidity();
			}
		});
	}

	if (typeof window !== 'undefined') {
		setupResetPasswordForm();
		document.addEventListener('astro:page-load', setupResetPasswordForm);
	}
</script>

<style>
.reset-shell {
	min-height: 100svh;
	display: grid;
	place-items: center;
	padding: 1.2rem;
}

.reset-card {
	width: min(100%, 30rem);
	border: 1px solid #d7e0ea;
	border-radius: 1.5rem;
	background: #ffffff;
	box-shadow: 0 18px 38px rgba(15, 23, 42, 0.08);
	padding: 1.4rem;
	display: grid;
	gap: 1rem;
}

.reset-brand {
	display: inline-flex;
	line-height: 0;
	justify-self: center;
}

.reset-logo {
	height: 2.8rem;
	width: auto;
	object-fit: contain;
	filter: drop-shadow(0 6px 16px rgba(59, 130, 246, 0.25));
}

.reset-header h1 {
	margin: 0;
	font-size: 1.55rem;
	color: #0f172a;
}

.reset-header p {
	margin: 0.4rem 0 0;
	color: #64748b;
	line-height: 1.45;
}

.reset-warning,
.reset-error {
	display: flex;
	align-items: center;
	gap: 0.55rem;
	padding: 0.75rem 0.9rem;
	border-radius: 0.7rem;
	font-weight: 600;
}

.reset-warning {
	border: 1px solid #fcd34d;
	background: #fffbeb;
	color: #b45309;
}

.reset-error {
	border: 1px solid #fecdd3;
	background: #fff1f2;
	color: #be123c;
}

.reset-form {
	display: grid;
	gap: 0.6rem;
}

.reset-form label {
	font-weight: 700;
	color: #334155;
	font-size: 0.92rem;
}

.reset-input-affix {
	display: flex;
	align-items: center;
	gap: 0.55rem;
}

.reset-input {
	width: 100%;
	border: 1px solid #cbd5e1;
	border-radius: 0.8rem;
	padding: 0.85rem 0.9rem;
	font-size: 1rem;
	outline: none;
	background: #f8fafc;
	color: #0f172a;
	box-sizing: border-box;
}

.reset-input:focus {
	border-color: #2563eb;
	box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
	background: #ffffff;
}

.reset-input.is-invalid {
	border-color: #e11d48;
	background: #fff1f2;
}

.reset-toggle {
	border: 0;
	background: transparent;
	color: #475569;
	font-weight: 700;
	text-decoration: underline;
	cursor: pointer;
	padding: 0.25rem;
}

.reset-toggle:disabled {
	opacity: 0.5;
	cursor: not-allowed;
}

.reset-field-error {
	font-size: 0.84rem;
	font-weight: 600;
	color: #be123c;
}

.reset-password-strength {
	display: grid;
	gap: 0.35rem;
	margin-top: 0.2rem;
}

.reset-password-strength.is-hidden {
	display: none;
}

.reset-password-strength-bars {
	display: grid;
	grid-template-columns: repeat(4, minmax(0, 1fr));
	gap: 0.35rem;
}

.reset-password-strength-segment {
	height: 0.28rem;
	border-radius: 9999px;
	background-color: #e2e8f0;
	transition: background-color 0.2s ease;
}

.reset-password-strength-segment.is-active {
	background-color: #f59e0b;
}

.reset-password-strength[data-tone='weak'] .reset-password-strength-segment.is-active {
	background-color: #dc2626;
}

.reset-password-strength[data-tone='warning'] .reset-password-strength-segment.is-active {
	background-color: #f59e0b;
}

.reset-password-strength[data-tone='good'] .reset-password-strength-segment.is-active {
	background-color: #0ea5e9;
}

.reset-password-strength[data-tone='strong'] .reset-password-strength-segment.is-active {
	background-color: #059669;
}

.reset-password-strength-text {
	margin: 0;
	font-size: 0.82rem;
	font-weight: 600;
	color: #64748b;
	text-align: right;
}

.reset-button {
	margin-top: 0.4rem;
	border: none;
	border-radius: 9999px;
	padding: 0.82rem 1rem;
	background: #2563eb;
	color: #ffffff;
	font-size: 1rem;
	font-weight: 700;
	cursor: pointer;
}

.reset-button:hover {
	background: #1d4ed8;
}

.reset-button:disabled {
	opacity: 0.6;
	cursor: not-allowed;
}

.reset-footer {
	margin: 0;
	text-align: center;
	font-size: 0.93rem;
	color: #64748b;
	display: inline-flex;
	gap: 0.45rem;
	justify-content: center;
}

.reset-footer a {
	color: #2563eb;
	text-decoration: none;
	font-weight: 700;
}

.reset-footer a:hover {
	text-decoration: underline;
}

