	color: #fb7185;
}

.m3-input-affix {
	position: relative;
	display: flex;
	align-items: center;
}

.m3-input {
	box-sizing: border-box;
	width: 100%;
	border: 1px solid #262626;
	border-radius: 0.75rem;
