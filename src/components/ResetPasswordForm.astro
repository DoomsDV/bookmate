@media (min-width: 1024px) {
	.m3-container {
		flex-direction: row;
		height: 100svh;
		overflow: hidden;
	}

	.m3-sidebar {
		display: flex;
		width: 40%;
		max-width: 28rem;
		flex-direction: column;
	}

	.m3-content {
		padding: 3rem 4rem;
	}

	.m3-mobile-brand {
		display: none;
	}
}

