---
interface Props {
	error?: string;
	email?: string;
	emailError?: string;
}

const { error = '', email = '', emailError = '' } = Astro.props;
---

<section class="m3-container auth-dark">
	<aside class="m3-sidebar">
		<div class="m3-sidebar-inner">
			<div class="m3-brand">
				<a href="/" class="m3-brand-link" aria-label="Ir al inicio">
					<img src="/icon-512x512.png" alt="Hasel Logo" class="m3-logo" />
				</a>
			</div>

			<div class="m3-stepper-header">
				<h2 class="m3-step-maintitle">Recupera tu acceso</h2>
				<p class="m3-step-maindesc">
					Te enviaremos un enlace seguro para que puedas cambiar tu contraseña y volver a ingresar al portal.
				</p>
			</div>
		</div>
	</aside>

	<main class="m3-content">
		<div class="m3-form-wrapper">
			<div class="m3-form-header">
				<div class="m3-panel-icon">
					<span class="material-symbols-rounded">lock_reset</span>
				</div>
				<div class="m3-panel-titles">
					<h1 class="m3-panel-title">Recuperar contraseña</h1>
					<p class="m3-panel-subtitle">Ingresa tu correo para enviarte un enlace de recuperación.</p>
				</div>
			</div>

			{error && (
				<div class="m3-error-banner" role="alert">
					<span class="material-symbols-rounded">error</span>
					<span>{error}</span>
				</div>
			)}

			<form method="post" action="/api/auth/forgot-password" data-astro-reload>
				<div class="m3-panel">
					<div class="m3-field">
						<label class="m3-label" for="email">Correo electrónico <span class="m3-label-required">*</span></label>
						<input
							type="email"
							id="email"
							name="email"
							placeholder="Ej: usuario@empresa.com"
							value={email}
							class:list={['m3-input', emailError && 'is-invalid']}
							required
						/>
						{emailError && <span class="m3-field-error">{emailError}</span>}
					</div>

					<div class="m3-actions">
						<button type="submit" class="m3-btn-primary">
							Enviar enlace
							<span class="material-symbols-rounded">send</span>
						</button>
					</div>
				</div>
			</form>

			<div class="m3-card-footer">
				<div class="m3-footer-divider"></div>
				<a href="/auth/login" class="m3-link-accent">¿Recordaste tu contraseña? <strong>Volver al login</strong></a>
			</div>
		</div>
	</main>
</section>

<style>
.m3-container {
	display: flex;
	flex-direction: column;
	min-height: 100svh;
	background-color: #050505;
	font-family: var(--font-body);
}

.m3-sidebar {
	position: relative;
	display: none;
	overflow: hidden;
	background-color: #050505;
	color: #f8fafc;
	padding: 3.5rem 4rem;
}

.m3-sidebar::before {
	content: '';
	position: absolute;
	inset: 0;
	background: radial-gradient(circle at top right, rgba(37, 99, 235, 0.15), transparent 60%);
	pointer-events: none;
	opacity: 1;
}

.m3-sidebar-inner {
	position: relative;
	z-index: 1;
	display: flex;
	height: 100%;
	flex-direction: column;
}

.m3-brand {
	margin-bottom: 3.25rem;
}

.m3-brand-link {
	display: inline-flex;
	align-items: center;
	line-height: 0;
}

.m3-logo {
	height: 3.5rem;
	width: auto;
	object-fit: contain;
	filter: drop-shadow(0 8px 20px rgba(59, 130, 246, 0.25));
}

.m3-stepper-header {
	margin-bottom: 3rem;
	max-width: 18rem;
}

.m3-step-maintitle {
	margin: 0 0 1rem;
	color: #ffffff;
	font-size: clamp(2rem, 5vw, 2.5rem);
	font-weight: 700;
	line-height: 1.1;
}

.m3-step-maindesc {
	margin: 0;
	color: #94a3b8;
	font-size: 1.05rem;
	line-height: 1.6;
}

.m3-content {
	display: flex;
	flex: 1;
	align-items: center;
	justify-content: center;
	padding: 2rem 1.5rem;
}

.m3-form-wrapper {
	width: 100%;
	max-width: 28rem;
}

.m3-form-header {
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 1rem;
	margin-bottom: 2.5rem;
	text-align: center;
}

.m3-panel-icon {
	display: flex;
	width: 3.5rem;
	height: 3.5rem;
	align-items: center;
	justify-content: center;
	border-radius: 50%;
}

.m3-panel-icon .material-symbols-rounded {
	font-size: 1.75rem;
}

.m3-panel-title {
	margin: 0 0 0.25rem;
	font-size: 1.75rem;
	font-weight: 700;
}

.m3-panel-subtitle {
	margin: 0;
	font-size: 1rem;
	line-height: 1.5;
}

.m3-error-banner {
	display: flex;
	align-items: center;
	gap: 0.75rem;
	margin-bottom: 2rem;
	border: 1px solid #fecdd3;
	border-radius: 0.75rem;
	background-color: #fff1f2;
	color: #be123c;
	padding: 1rem 1.25rem;
	font-weight: 600;
}

.m3-panel {
	animation: m3fade 0.3s cubic-bezier(0.2, 0, 0, 1);
}

@keyframes m3fade {
	from {
		opacity: 0;
		transform: translateY(10px);
	}

	to {
		opacity: 1;
		transform: translateY(0);
	}
}

.m3-field {
	display: flex;
	flex-direction: column;
	gap: 0.5rem;
}

.m3-label {
	margin-left: 0.25rem;
	font-size: 0.9rem;
	font-weight: 600;
}

.m3-label-required {
	color: #fb7185;
}

.m3-input {
	box-sizing: border-box;
	width: 100%;
	border: 1px solid #cbd5e1;
	border-radius: 0.75rem;
	background-color: #f8fafc;
	color: #0f172a;
	font: inherit;
	font-size: 1rem;
	outline: none;
	padding: 0.875rem 1rem;
	transition: all 0.2s cubic-bezier(0.2, 0, 0, 1);
}

.m3-input:focus {
	border-color: #2563eb;
	background-color: #ffffff;
	box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
}

.m3-input.is-invalid {
	border-color: #e11d48;
	background-color: #fff1f2;
}

.m3-field-error {
	margin-left: 0.25rem;
	color: #e11d48;
	font-size: 0.85rem;
	font-weight: 500;
}

.m3-actions {
	display: flex;
	align-items: center;
	margin-top: 2rem;
}

.m3-btn-primary {
	display: inline-flex;
	width: 100%;
	align-items: center;
	justify-content: center;
	gap: 0.5rem;
	border: none;
	border-radius: 9999px;
	background-color: #2563eb;
	color: #ffffff;
	cursor: pointer;
	font: inherit;
	font-size: 1rem;
	font-weight: 600;
	padding: 0.875rem 2rem;
	transition: all 0.2s cubic-bezier(0.2, 0, 0, 1);
}

.m3-btn-primary:hover {
	background-color: #1d4ed8;
	box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
	transform: translateY(-1px);
}

.m3-card-footer {
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 1.5rem;
	margin-top: 2.5rem;
	padding-top: 1.5rem;
}

.m3-footer-divider {
	width: 40px;
	height: 2px;
	border-radius: 1px;
	background: #e2e8f0;
}

.m3-link-accent {
	color: #475569;
	text-align: center;
	text-decoration: none;
	font-size: 0.95rem;
}

.m3-link-accent strong {
	color: #2563eb;
	transition: color 0.2s;
}

.m3-link-accent:hover strong {
	color: #1d4ed8;
	text-decoration: underline;
}

@media (min-width: 1024px) {
	.m3-container {
		flex-direction: row;
		height: 100svh;
		overflow: hidden;
	}

	.m3-sidebar {
		display: flex;
		width: 40%;
		max-width: 28rem;
		flex-direction: column;
	}

	.m3-content {
		padding: 3rem 4rem;
	}

	.m3-mobile-brand {
		display: none;
	}
}
</style>
