---
interface Props {
	error?: string;
	email?: string;
	emailError?: string;
}

const { error = '', email = '', emailError = '' } = Astro.props;
---

<section class="auth-shell">
	<div class="auth-card">
		<a href="/" class="auth-brand" aria-label="Ir al inicio">
			<img src="/icon-512x512.png" alt="Hasel Logo" class="auth-logo" />
		</a>

		<header class="auth-header">
			<h1>Recuperar contraseña</h1>
			<p>Ingresa tu correo para enviarte un enlace de recuperación.</p>
		</header>

		{error && (
			<div class="auth-error" role="alert">
				<span class="material-symbols-rounded">error</span>
				{error}
			</div>
		)}

		<form method="post" action="/api/auth/forgot-password" data-astro-reload class="auth-form">
			<label for="email">Correo electrónico</label>
			<input
				type="email"
				id="email"
				name="email"
				placeholder="Ej: usuario@empresa.com"
				value={email}
				class:list={['auth-input', emailError && 'is-invalid']}
				required
			/>
			{emailError && <span class="auth-field-error">{emailError}</span>}

			<button type="submit" class="auth-button">Enviar enlace</button>
		</form>

		<p class="auth-footer">
			¿Recordaste tu contraseña?
			<a href="/auth/login">Volver al login</a>
		</p>
	</div>
</section>

<style>
.auth-shell {
	min-height: 100svh;
	display: grid;
	place-items: center;
	padding: 1.2rem;
}

.auth-card {
	width: min(100%, 28rem);
	border: 1px solid #d7e0ea;
	border-radius: 1.5rem;
	background: #ffffff;
	box-shadow: 0 18px 38px rgba(15, 23, 42, 0.08);
	padding: 1.4rem;
	display: grid;
	gap: 1rem;
}

.auth-brand {
	display: inline-flex;
	line-height: 0;
	justify-self: center;
}

.auth-logo {
	height: 2.8rem;
	width: auto;
	object-fit: contain;
	filter: drop-shadow(0 6px 16px rgba(59, 130, 246, 0.25));
}

.auth-header h1 {
	margin: 0;
	font-size: 1.55rem;
	color: #0f172a;
}

.auth-header p {
	margin: 0.4rem 0 0;
	color: #64748b;
	line-height: 1.45;
}

.auth-error {
	display: flex;
	align-items: center;
	gap: 0.55rem;
	padding: 0.75rem 0.9rem;
	border-radius: 0.7rem;
	border: 1px solid #fecdd3;
	background: #fff1f2;
	color: #be123c;
	font-weight: 600;
}

.auth-form {
	display: grid;
	gap: 0.6rem;
}

.auth-form label {
	font-weight: 700;
	color: #334155;
	font-size: 0.92rem;
}

.auth-input {
	width: 100%;
	border: 1px solid #cbd5e1;
	border-radius: 0.8rem;
	padding: 0.85rem 0.9rem;
	font-size: 1rem;
	outline: none;
	background: #f8fafc;
	color: #0f172a;
	box-sizing: border-box;
}

.auth-input:focus {
	border-color: #2563eb;
	box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
	background: #ffffff;
}

.auth-input.is-invalid {
	border-color: #e11d48;
	background: #fff1f2;
}

.auth-field-error {
	font-size: 0.84rem;
	font-weight: 600;
	color: #be123c;
}

.auth-button {
	margin-top: 0.4rem;
	border: none;
	border-radius: 9999px;
	padding: 0.82rem 1rem;
	background: #2563eb;
	color: #ffffff;
	font-size: 1rem;
	font-weight: 700;
	cursor: pointer;
}

.auth-button:hover {
	background: #1d4ed8;
}

.auth-footer {
	margin: 0;
	text-align: center;
	font-size: 0.93rem;
	color: #64748b;
}

.auth-footer a {
	color: #2563eb;
	text-decoration: none;
	font-weight: 700;
	margin-left: 0.25rem;
}

.auth-footer a:hover {
	text-decoration: underline;
}
</style>
