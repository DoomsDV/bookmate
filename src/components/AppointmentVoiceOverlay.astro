---
import { FEATURE_FLAGS } from '../config/feature-flags';

const VOICE_BAR_COUNT = 28;
---

{FEATURE_FLAGS.APPOINTMENT_AI_VOICE && (
	<appointment-voice-overlay>
		<dialog
			class="appointment-voice-shell"
			data-voice-overlay-shell
			aria-label="Cita rápida por voz"
		>
			<div class="appointment-voice-dialog">
				<div class="appointment-voice-header">
					<div class="appointment-voice-title-wrap">
						<div class="appointment-voice-mark">
							<span class="material-symbols-rounded">auto_awesome</span>
						</div>
						<div>
							<h2 class="appointment-voice-title">Cita rápida</h2>
							<p class="appointment-voice-subtitle">Describe la cita con tu voz</p>
						</div>
					</div>
					<button
						type="button"
						class="appointment-voice-close"
						data-voice-overlay-close
						aria-label="Cerrar"
					>
						<span class="material-symbols-rounded">close</span>
					</button>
				</div>

				<div class="appointment-voice-body">
					<p class="appointment-voice-status" data-voice-overlay-status>
						Toca el micrófono y describe la cita.
					</p>
					<div class="appointment-voice-transcript-wrap hidden" data-voice-overlay-transcript-wrap>
						<p class="appointment-voice-transcript-label">Escuché</p>
						<p class="appointment-voice-transcript" data-voice-overlay-transcript></p>
					</div>
					<p class="appointment-voice-error hidden" data-voice-overlay-error role="alert"></p>

					<div class="appointment-voice-processing hidden" data-voice-overlay-processing>
						<div class="appointment-voice-processing__visual" aria-hidden="true">
							<span class="appointment-voice-processing__glow"></span>
							<span class="appointment-voice-processing__sparkle material-symbols-rounded">auto_awesome</span>
							<span class="appointment-voice-processing__spinner"></span>
						</div>
						<span class="appointment-voice-processing__shimmer">
							Transcribiendo y completando datos…
						</span>
					</div>

					<div class="appointment-voice-stage" data-voice-overlay-stage>
						<div class="appointment-voice-visual" data-voice-overlay-visualizer data-visualizer-mode="idle">
							<div class="appointment-voice-visual__aura" aria-hidden="true">
								<span class="appointment-voice-visual__blob appointment-voice-visual__blob--cyan"></span>
								<span class="appointment-voice-visual__blob appointment-voice-visual__blob--lavender"></span>
							</div>
							<div
								class="appointment-voice-visual__baseline"
								data-voice-overlay-baseline
								aria-hidden="true"
							></div>
							<div class="appointment-voice-visual__bars" data-voice-overlay-bars aria-hidden="true">
								{Array.from({ length: VOICE_BAR_COUNT }, () => (
									<span class="appointment-voice-visual__bar" data-voice-bar></span>
								))}
							</div>
						</div>
						<div class="appointment-voice-record-wrap">
							<button
								type="button"
								class="appointment-voice-record"
								data-voice-overlay-record
								aria-label="Empezar a grabar"
							>
								<span class="appointment-voice-record__pulse" aria-hidden="true"></span>
								<span class="appointment-voice-record__halo" aria-hidden="true"></span>
								<span
									class="appointment-voice-record__icon appointment-voice-record__icon--mic material-symbols-rounded"
									data-voice-overlay-record-icon-mic
									aria-hidden="true"
								>mic</span>
								<span
									class="appointment-voice-record__icon appointment-voice-record__icon--stop"
									data-voice-overlay-record-icon-stop
									aria-hidden="true"
								></span>
							</button>
						</div>
					</div>

					<p
						class="appointment-voice-timer hidden"
						data-voice-overlay-timer
						aria-live="polite"
						aria-atomic="true"
					>
						00:00 / 01:00
					</p>

					<button
						type="button"
						class="appointment-voice-discard hidden"
						data-voice-overlay-discard
						aria-label="Descartar grabación"
					>
						<span class="material-symbols-rounded" aria-hidden="true">delete</span>
						Descartar
					</button>

					<div class="appointment-voice-actions hidden" data-voice-overlay-actions>
						<button type="button" class="appointment-voice-continue" data-voice-overlay-continue>
							Ir al calendario
						</button>
					</div>
				</div>
			</div>
		</dialog>
	</appointment-voice-overlay>
)}

<style>
	.appointment-voice-shell {
		margin: 0;
		padding: 1rem;
		border: 0;
		background: transparent;
		max-width: none;
		max-height: none;
		width: 100%;
		height: 100%;
		overflow: visible;
	}

	.appointment-voice-shell[open] {
		display: grid;
		place-items: center;
	}

	.appointment-voice-shell::backdrop {
		background: rgba(15, 23, 42, 0.38);
		backdrop-filter: blur(5px);
		-webkit-backdrop-filter: blur(5px);
	}

	.appointment-voice-dialog {
		position: relative;
		z-index: 1;
		width: min(26rem, calc(100vw - 2rem));
		border-radius: 1.6rem;
		border: 1px solid color-mix(in srgb, var(--shell-border) 80%, #e2e8f0 20%);
		background: #ffffff;
		box-shadow: 0 24px 80px rgba(15, 23, 42, 0.14);
		overflow: hidden;
	}

	appointment-voice-overlay[data-voice-state='recording'] .appointment-voice-dialog,
	appointment-voice-overlay[data-voice-state='collapsing'] .appointment-voice-dialog,
	appointment-voice-overlay[data-voice-state='processing'] .appointment-voice-dialog {
		border-color: color-mix(in srgb, var(--primary) 34%, var(--shell-border));
		box-shadow:
			0 24px 80px rgba(0, 0, 0, 0.24),
			0 0 42px color-mix(in srgb, var(--primary) 16%, transparent);
	}

	.appointment-voice-header {
		position: relative;
		z-index: 1;
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		padding: 1.1rem 1.2rem 0.8rem;
		border-bottom: 1px solid var(--shell-border);
	}

	.appointment-voice-title-wrap {
		display: flex;
		align-items: center;
		gap: 0.85rem;
	}

	.appointment-voice-mark {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		border-radius: 1rem;
		background: var(--primary-soft);
		color: var(--primary);
	}

	.appointment-voice-title {
		margin: 0;
		font-size: 1.05rem;
		font-weight: 800;
		color: var(--on-surface);
	}

	.appointment-voice-subtitle {
		margin: 0.15rem 0 0;
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--on-surface-variant);
	}

	.appointment-voice-close {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		border: 0;
		border-radius: 999px;
		background: transparent;
		color: var(--on-surface-variant);
		cursor: pointer;
	}

	.appointment-voice-close:hover {
		background: var(--surface-variant);
		color: var(--on-surface);
	}

	.appointment-voice-body {
		position: relative;
		z-index: 1;
		display: grid;
		justify-items: center;
		gap: 0.85rem;
		padding: 1.4rem 1.2rem 1.6rem;
		text-align: center;
	}

	.appointment-voice-status {
		margin: 0;
		min-height: 1.35em;
		font-size: 0.94rem;
		font-weight: 750;
		color: color-mix(in srgb, var(--on-surface) 82%, var(--on-surface-variant) 18%);
		opacity: 1;
		transform: translateY(0);
		transition:
			opacity 180ms ease,
			transform 180ms ease,
			color 180ms ease;
	}

	appointment-voice-overlay[data-voice-state='recording'] .appointment-voice-status {
		color: color-mix(in srgb, var(--on-surface) 90%, var(--primary) 10%);
		margin-bottom: 0.65rem;
	}

	.appointment-voice-timer {
		margin: -0.55rem 0 0;
		font-size: 0.88rem;
		font-weight: 600;
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.05em;
		color: #3b82f6;
		transition: opacity 180ms ease, color 180ms ease;
	}

	.appointment-voice-timer.is-near-limit {
		color: #e11d48;
	}

	.appointment-voice-timer.hidden {
		display: none;
	}

	.appointment-voice-status.is-leaving {
		opacity: 0;
		transform: translateY(-4px);
	}

	.appointment-voice-status.is-entering {
		opacity: 0;
		transform: translateY(4px);
	}

	.appointment-voice-transcript-wrap {
		width: 100%;
		padding: 0.85rem 1rem;
		border-radius: 1rem;
		border: 1px solid var(--shell-border);
		background: var(--surface-variant);
		text-align: left;
	}

	.appointment-voice-transcript-wrap.hidden {
		display: none;
	}

	.appointment-voice-transcript-label {
		margin: 0 0 0.35rem;
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--on-surface-variant);
	}

	.appointment-voice-transcript {
		margin: 0;
		max-width: 100%;
		font-size: 0.95rem;
		font-weight: 600;
		line-height: 1.45;
		color: var(--on-surface);
	}

	.appointment-voice-error {
		margin: 0;
		font-size: 0.88rem;
		font-weight: 700;
		color: #e11d48;
	}

	.appointment-voice-status.hidden {
		display: none;
	}

	.appointment-voice-processing {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.85rem;
		width: 100%;
		min-height: 6.5rem;
	}

	.appointment-voice-processing__visual {
		position: relative;
		display: grid;
		place-items: center;
		width: 3.25rem;
		height: 3.25rem;
	}

	.appointment-voice-processing__glow {
		position: absolute;
		inset: 0;
		border-radius: 999px;
		background: radial-gradient(
			circle,
			color-mix(in srgb, #67e8f9 28%, transparent) 0%,
			color-mix(in srgb, #a78bfa 18%, transparent) 45%,
			transparent 72%
		);
		filter: blur(10px);
		animation: appointment-voice-breathe 2.8s ease-in-out infinite;
	}

	.appointment-voice-processing__sparkle {
		position: absolute;
		z-index: 1;
		font-size: 1.15rem;
		color: color-mix(in srgb, #67e8f9 70%, #c4b5fd 30%);
		opacity: 0.85;
		animation: appointment-voice-breathe 2.8s ease-in-out infinite;
	}

	.appointment-voice-processing__spinner {
		position: relative;
		z-index: 2;
		width: 2.35rem;
		height: 2.35rem;
		border-radius: 999px;
		background: conic-gradient(
			from 0deg,
			transparent 0deg 40deg,
			#67e8f9 80deg,
			#818cf8 160deg,
			#a78bfa 220deg,
			#22d3ee 300deg,
			transparent 340deg 360deg
		);
		animation: appointment-voice-spin 0.95s linear infinite;
		mask: radial-gradient(farthest-side, transparent calc(100% - 3px), #000 calc(100% - 2.5px));
		-webkit-mask: radial-gradient(farthest-side, transparent calc(100% - 3px), #000 calc(100% - 2.5px));
	}

	.appointment-voice-processing__shimmer {
		font-size: 0.92rem;
		font-weight: 700;
		line-height: 1.4;
		text-align: center;
		background: linear-gradient(
			110deg,
			color-mix(in srgb, var(--on-surface-variant) 92%, transparent) 0%,
			color-mix(in srgb, var(--on-surface-variant) 92%, transparent) 36%,
			#bae6fd 46%,
			#c4b5fd 50%,
			#bae6fd 54%,
			color-mix(in srgb, var(--on-surface-variant) 92%, transparent) 64%,
			color-mix(in srgb, var(--on-surface-variant) 92%, transparent) 100%
		);
		background-size: 220% 100%;
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		animation: appointment-voice-shimmer 2.4s ease-in-out infinite;
	}

	.appointment-voice-processing.hidden,
	.appointment-voice-transcript-wrap.hidden,
	.appointment-voice-error.hidden,
	.appointment-voice-actions.hidden,
	.appointment-voice-discard.hidden {
		display: none;
	}

	.appointment-voice-record[hidden] {
		display: none;
	}

	.appointment-voice-actions {
		width: 100%;
	}

	.appointment-voice-continue {
		width: 100%;
		border: 0;
		border-radius: 999px;
		padding: 0.85rem 1.2rem;
		font-size: 0.92rem;
		font-weight: 800;
		color: #f8fbff;
		background: var(--primary);
		box-shadow: 0 4px 14px rgba(15, 23, 42, 0.12);
		cursor: pointer;
		transition: background-color 140ms ease, transform 140ms ease, box-shadow 140ms ease;
	}

	.appointment-voice-continue:hover {
		transform: translateY(-1px);
		background: color-mix(in srgb, var(--primary) 92%, #000 8%);
	}

	.appointment-voice-discard {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		margin-top: -0.15rem;
		padding: 0.55rem 0.95rem;
		border: 1px solid color-mix(in srgb, var(--on-surface-variant) 28%, var(--shell-border) 72%);
		border-radius: 999px;
		background: transparent;
		color: color-mix(in srgb, var(--on-surface) 72%, var(--on-surface-variant) 28%);
		font-size: 0.84rem;
		font-weight: 600;
		cursor: pointer;
		transition:
			color 140ms ease,
			border-color 140ms ease,
			background-color 140ms ease,
			opacity 180ms ease,
			transform 180ms ease;
	}

	.appointment-voice-discard .material-symbols-rounded {
		font-size: 1.05rem;
		color: color-mix(in srgb, var(--on-surface-variant) 80%, #64748b 20%);
		transition: color 140ms ease;
	}

	.appointment-voice-discard:hover {
		color: #be123c;
		border-color: color-mix(in srgb, #e11d48 35%, var(--shell-border) 65%);
		background: color-mix(in srgb, #e11d48 6%, transparent);
	}

	.appointment-voice-discard:hover .material-symbols-rounded {
		color: #e11d48;
	}

	.appointment-voice-discard:focus-visible {
		outline: 2px solid color-mix(in srgb, var(--primary) 42%, white 58%);
		outline-offset: 3px;
	}

	.appointment-voice-stage {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		width: calc(100% + 2.4rem);
		margin-inline: -1.2rem;
		min-height: 13.5rem;
		margin-top: 0.35rem;
		padding-inline: 0;
		--voice-level: 0.16;
		--bar-max-height: 8.25rem;
	}

	.appointment-voice-visual {
		position: relative;
		z-index: 1;
		display: grid;
		place-items: center;
		width: 100%;
		height: var(--bar-max-height);
		pointer-events: none;
		overflow: visible;
	}

	.appointment-voice-visual__aura {
		position: absolute;
		inset: 0 -0.5rem;
		z-index: 0;
	}

	.appointment-voice-visual__blob {
		position: absolute;
		border-radius: 42% 58% 62% 38% / 38% 42% 58% 62%;
		filter: blur(40px);
		opacity: 0.72;
		animation: appointment-voice-blob-drift 9s ease-in-out infinite;
	}

	.appointment-voice-visual__blob--cyan {
		inset: 8% 6% 18% 8%;
		background: radial-gradient(circle at 35% 35%, rgba(103, 232, 249, 0.72), rgba(59, 130, 246, 0.28) 58%, transparent 78%);
		animation-duration: 8.5s;
	}

	.appointment-voice-visual__blob--lavender {
		inset: 20% 8% 10% 6%;
		background: radial-gradient(circle at 60% 40%, rgba(196, 181, 253, 0.62), rgba(56, 189, 248, 0.22) 55%, transparent 76%);
		animation-duration: 11s;
		animation-direction: reverse;
	}

	.appointment-voice-visual[data-visualizer-mode='idle'] .appointment-voice-visual__aura {
		opacity: 0;
	}

	appointment-voice-overlay[data-voice-state='recording'] .appointment-voice-visual__blob,
	.appointment-voice-visual[data-visualizer-mode='live'] .appointment-voice-visual__blob {
		opacity: calc(0.68 + var(--voice-level, 0.2) * 0.32);
		animation-duration: calc(7.5s - var(--voice-level, 0.2) * 2.2s);
	}

	.appointment-voice-visual__baseline {
		position: absolute;
		z-index: 1;
		left: 0.65rem;
		right: 0.65rem;
		top: 50%;
		height: 2px;
		border-radius: 999px;
		background: linear-gradient(
			90deg,
			color-mix(in srgb, #bfdbfe 55%, transparent) 0%,
			#93c5fd 50%,
			color-mix(in srgb, #bfdbfe 55%, transparent) 100%
		);
		transform: translateY(-50%);
		opacity: 1;
		transition: opacity 360ms ease, transform 360ms ease;
		animation: appointment-voice-baseline-idle 5s ease-in-out infinite;
	}

	.appointment-voice-visual[data-visualizer-mode='live'] .appointment-voice-visual__baseline,
	.appointment-voice-visual[data-visualizer-mode='collapsing'] .appointment-voice-visual__baseline,
	.appointment-voice-visual[data-visualizer-mode='off'] .appointment-voice-visual__baseline {
		opacity: 0;
		transform: translateY(-50%) scaleX(0.98);
		animation: none;
	}

	.appointment-voice-visual__bars {
		position: relative;
		z-index: 2;
		display: flex;
		align-items: center;
		justify-content: stretch;
		gap: 0.1rem;
		width: 100%;
		height: 100%;
		padding-inline: 0.65rem;
	}

	.appointment-voice-visual__bar {
		flex: 1 1 0;
		min-width: 0.18rem;
		height: var(--bar-max-height);
		border-radius: 999px;
		background: linear-gradient(180deg, #bfdbfe 0%, #93c5fd 42%, #60a5fa 100%);
		box-shadow: 0 0 8px color-mix(in srgb, #93c5fd 32%, transparent);
		transform: scaleY(var(--bar-scale, 0.06));
		transform-origin: center center;
		opacity: 0;
		transition:
			transform 160ms cubic-bezier(0.4, 0, 0.2, 1),
			opacity 280ms ease,
			background 220ms ease;
		will-change: transform;
	}

	appointment-voice-overlay[data-voice-state='idle'] .appointment-voice-visual__bar,
	.appointment-voice-visual[data-visualizer-mode='idle'] .appointment-voice-visual__bar {
		opacity: 0;
		transform: scaleY(0.06);
	}

	appointment-voice-overlay[data-voice-state='recording'] .appointment-voice-visual__bar,
	.appointment-voice-visual[data-visualizer-mode='live'] .appointment-voice-visual__bar {
		opacity: calc(0.94 + var(--voice-level, 0.2) * 0.06);
		transition:
			transform 110ms cubic-bezier(0.33, 1, 0.45, 1),
			opacity 180ms ease,
			background 180ms ease;
	}

	.appointment-voice-visual[data-visualizer-mode='collapsing'] .appointment-voice-visual__bar {
		opacity: calc(1 - var(--collapse, 0));
	}

	.appointment-voice-visual[data-visualizer-mode='off'] .appointment-voice-visual__aura {
		opacity: 0;
	}

	appointment-voice-overlay[data-voice-state='processing'] .appointment-voice-stage {
		display: none;
	}

	.appointment-voice-stage.is-collapsing {
		min-height: 13.5rem;
	}

	@keyframes appointment-voice-blob-drift {
		0%,
		100% {
			transform: translate3d(0, 0, 0) rotate(0deg) scale(1);
			border-radius: 42% 58% 62% 38% / 38% 42% 58% 62%;
		}
		33% {
			transform: translate3d(6%, -4%, 0) rotate(18deg) scale(1.08);
			border-radius: 58% 42% 38% 62% / 52% 38% 62% 48%;
		}
		66% {
			transform: translate3d(-5%, 5%, 0) rotate(-14deg) scale(0.94);
			border-radius: 48% 52% 58% 42% / 42% 58% 42% 58%;
		}
	}

	.appointment-voice-record-wrap {
		position: relative;
		z-index: 3;
		display: grid;
		place-items: center;
		flex-shrink: 0;
	}

	.appointment-voice-record {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 4.25rem;
		height: 4.25rem;
		border: 0;
		border-radius: 999px;
		background: linear-gradient(
			145deg,
			color-mix(in srgb, var(--primary) 88%, #fff 12%),
			color-mix(in srgb, var(--primary) 72%, #0f172a 28%)
		);
		color: #f8fbff;
		box-shadow: 0 4px 14px rgba(15, 23, 42, 0.12);
		cursor: pointer;
		transition:
			transform 220ms ease,
			opacity 420ms ease,
			box-shadow 220ms ease;
	}

	.appointment-voice-record__icon {
		position: absolute;
		z-index: 1;
		line-height: 1;
		transition:
			opacity 220ms ease,
			transform 280ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	.appointment-voice-record__icon--mic {
		font-size: 1.85rem;
		opacity: 1;
		transform: scale(1) rotate(0deg);
	}

	.appointment-voice-record__icon--stop {
		width: 1rem;
		height: 1rem;
		border-radius: 0.16rem;
		background: currentColor;
		opacity: 0;
		transform: scale(0.72) rotate(-12deg);
	}

	appointment-voice-overlay[data-voice-state='recording'] .appointment-voice-record__icon--mic {
		opacity: 0;
		transform: scale(0.72) rotate(12deg);
	}

	appointment-voice-overlay[data-voice-state='recording'] .appointment-voice-record__icon--stop {
		opacity: 1;
		transform: scale(1) rotate(0deg);
	}

	.appointment-voice-record__halo {
		position: absolute;
		inset: -0.35rem;
		z-index: 0;
		border-radius: 999px;
		border: 2px solid color-mix(in srgb, var(--primary) 42%, transparent);
		pointer-events: none;
		opacity: 0;
