---
import { FEATURE_FLAGS } from '../config/feature-flags';
---

{FEATURE_FLAGS.APPOINTMENT_AI_VOICE && (
	<appointment-voice-overlay>
		<dialog
			class="appointment-voice-shell"
			data-voice-overlay-shell
			aria-label="Cita rápida por voz"
		>
			<div class="appointment-voice-dialog">
				<div class="appointment-voice-header">
					<div class="appointment-voice-title-wrap">
						<div class="appointment-voice-mark">
							<span class="material-symbols-rounded">auto_awesome</span>
						</div>
						<div>
							<h2 class="appointment-voice-title">Cita rápida</h2>
							<p class="appointment-voice-subtitle">Describe la cita con tu voz</p>
						</div>
					</div>
					<button
						type="button"
						class="appointment-voice-close"
						data-voice-overlay-close
						aria-label="Cerrar"
					>
						<span class="material-symbols-rounded">close</span>
					</button>
				</div>

				<div class="appointment-voice-body">
					<p class="appointment-voice-status" data-voice-overlay-status>
						Toca el micrófono y describe la cita.
					</p>
					<div class="appointment-voice-transcript-wrap hidden" data-voice-overlay-transcript-wrap>
						<p class="appointment-voice-transcript-label">Escuché</p>
						<p class="appointment-voice-transcript" data-voice-overlay-transcript></p>
					</div>
					<p class="appointment-voice-error hidden" data-voice-overlay-error role="alert"></p>

					<div class="appointment-voice-processing hidden" data-voice-overlay-processing>
						<div class="appointment-voice-processing__visual" aria-hidden="true">
							<span class="appointment-voice-processing__glow"></span>
							<span class="appointment-voice-processing__sparkle material-symbols-rounded">auto_awesome</span>
							<span class="appointment-voice-processing__spinner"></span>
						</div>
						<span class="appointment-voice-processing__shimmer">
							Transcribiendo y completando datos…
						</span>
					</div>

					<div class="appointment-voice-stage" data-voice-overlay-stage>
						<div class="appointment-voice-stage__ambient" aria-hidden="true"></div>
						<canvas
							class="appointment-voice-waveform"
							data-voice-overlay-waveform
							aria-hidden="true"
						></canvas>
						<div class="appointment-voice-rings" aria-hidden="true">
							<span class="appointment-voice-rings__ring"></span>
							<span class="appointment-voice-rings__ring"></span>
							<span class="appointment-voice-rings__ring"></span>
						</div>
						<button
							type="button"
							class="appointment-voice-record"
							data-voice-overlay-record
							aria-label="Empezar a grabar"
						>
							<span class="appointment-voice-record__pulse" aria-hidden="true"></span>
							<span class="appointment-voice-record__halo" aria-hidden="true"></span>
							<span class="material-symbols-rounded" data-voice-overlay-record-icon>mic</span>
						</button>
					</div>

					<button
						type="button"
						class="appointment-voice-discard hidden"
						data-voice-overlay-discard
						aria-label="Descartar grabación"
					>
						<span class="material-symbols-rounded">delete</span>
						Descartar
					</button>

					<div class="appointment-voice-actions hidden" data-voice-overlay-actions>
						<button type="button" class="appointment-voice-continue" data-voice-overlay-continue>
							Ir al calendario
						</button>
					</div>
				</div>
			</div>
		</dialog>
	</appointment-voice-overlay>
)}

<style>
	.appointment-voice-shell {
		margin: 0;
		padding: 1rem;
		border: 0;
		background: transparent;
		max-width: none;
		max-height: none;
		width: 100%;
		height: 100%;
		overflow: visible;
	}

	.appointment-voice-shell[open] {
		display: grid;
		place-items: center;
	}

	.appointment-voice-shell::backdrop {
		background: rgba(15, 23, 42, 0.38);
		backdrop-filter: blur(5px);
		-webkit-backdrop-filter: blur(5px);
	}

	.appointment-voice-dialog {
		position: relative;
		z-index: 1;
		width: min(26rem, calc(100vw - 2rem));
		border-radius: 1.6rem;
		border: 1px solid var(--shell-border);
		background:
			radial-gradient(circle at 50% 0%, color-mix(in srgb, var(--primary) 12%, transparent), transparent 55%),
			var(--surface-bright);
		box-shadow:
			0 24px 80px rgba(0, 0, 0, 0.22),
			0 0 0 1px color-mix(in srgb, var(--primary) 8%, transparent);
		overflow: hidden;
	}

	appointment-voice-overlay[data-voice-state='recording'] .appointment-voice-dialog,
	appointment-voice-overlay[data-voice-state='collapsing'] .appointment-voice-dialog,
	appointment-voice-overlay[data-voice-state='processing'] .appointment-voice-dialog {
		border-color: color-mix(in srgb, var(--primary) 34%, var(--shell-border));
		box-shadow:
			0 24px 80px rgba(0, 0, 0, 0.24),
			0 0 42px color-mix(in srgb, var(--primary) 16%, transparent);
	}

	.appointment-voice-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		padding: 1.1rem 1.2rem 0.8rem;
		border-bottom: 1px solid var(--shell-border);
	}

	.appointment-voice-title-wrap {
		display: flex;
		align-items: center;
		gap: 0.85rem;
	}

	.appointment-voice-mark {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		border-radius: 1rem;
		background: var(--primary-soft);
		color: var(--primary);
	}

	.appointment-voice-title {
		margin: 0;
		font-size: 1.05rem;
		font-weight: 800;
		color: var(--on-surface);
	}

	.appointment-voice-subtitle {
		margin: 0.15rem 0 0;
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--on-surface-variant);
	}

	.appointment-voice-close {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		border: 0;
		border-radius: 999px;
		background: transparent;
		color: var(--on-surface-variant);
		cursor: pointer;
	}

	.appointment-voice-close:hover {
		background: var(--surface-variant);
		color: var(--on-surface);
	}

	.appointment-voice-body {
		display: grid;
		justify-items: center;
		gap: 0.85rem;
		padding: 1.4rem 1.2rem 1.6rem;
		text-align: center;
	}

	.appointment-voice-status {
		margin: 0;
		min-height: 1.35em;
		font-size: 0.92rem;
		font-weight: 700;
		color: var(--on-surface-variant);
		opacity: 1;
		transform: translateY(0);
		transition:
			opacity 180ms ease,
			transform 180ms ease;
	}

	.appointment-voice-status.is-leaving {
		opacity: 0;
		transform: translateY(-4px);
	}

	.appointment-voice-status.is-entering {
		opacity: 0;
		transform: translateY(4px);
	}

	.appointment-voice-transcript-wrap {
		width: 100%;
		padding: 0.85rem 1rem;
		border-radius: 1rem;
		border: 1px solid var(--shell-border);
		background: var(--surface-variant);
		text-align: left;
	}

	.appointment-voice-transcript-wrap.hidden {
		display: none;
	}

	.appointment-voice-transcript-label {
		margin: 0 0 0.35rem;
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--on-surface-variant);
	}

	.appointment-voice-transcript {
		margin: 0;
		max-width: 100%;
		font-size: 0.95rem;
		font-weight: 600;
		line-height: 1.45;
		color: var(--on-surface);
	}

	.appointment-voice-error {
		margin: 0;
		font-size: 0.88rem;
		font-weight: 700;
		color: #e11d48;
	}

	.appointment-voice-status.hidden {
		display: none;
	}

	.appointment-voice-processing {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.85rem;
		width: 100%;
		min-height: 6.5rem;
	}

	.appointment-voice-processing__visual {
		position: relative;
		display: grid;
		place-items: center;
		width: 3.25rem;
		height: 3.25rem;
	}

	.appointment-voice-processing__glow {
		position: absolute;
		inset: 0;
		border-radius: 999px;
		background: radial-gradient(
			circle,
			color-mix(in srgb, #67e8f9 28%, transparent) 0%,
			color-mix(in srgb, #a78bfa 18%, transparent) 45%,
			transparent 72%
		);
		filter: blur(10px);
		animation: appointment-voice-breathe 2.8s ease-in-out infinite;
	}

	.appointment-voice-processing__sparkle {
		position: absolute;
		z-index: 1;
		font-size: 1.15rem;
		color: color-mix(in srgb, #67e8f9 70%, #c4b5fd 30%);
		opacity: 0.85;
		animation: appointment-voice-breathe 2.8s ease-in-out infinite;
	}

	.appointment-voice-processing__spinner {
		position: relative;
		z-index: 2;
		width: 2.35rem;
		height: 2.35rem;
		border-radius: 999px;
		background: conic-gradient(
			from 0deg,
			transparent 0deg 40deg,
			#67e8f9 80deg,
			#818cf8 160deg,
			#a78bfa 220deg,
			#22d3ee 300deg,
			transparent 340deg 360deg
		);
		animation: appointment-voice-spin 0.95s linear infinite;
		mask: radial-gradient(farthest-side, transparent calc(100% - 3px), #000 calc(100% - 2.5px));
		-webkit-mask: radial-gradient(farthest-side, transparent calc(100% - 3px), #000 calc(100% - 2.5px));
	}

	.appointment-voice-processing__shimmer {
		font-size: 0.92rem;
		font-weight: 700;
		line-height: 1.4;
		text-align: center;
		background: linear-gradient(
			110deg,
			color-mix(in srgb, var(--on-surface-variant) 92%, transparent) 0%,
			color-mix(in srgb, var(--on-surface-variant) 92%, transparent) 36%,
			#bae6fd 46%,
			#c4b5fd 50%,
			#bae6fd 54%,
			color-mix(in srgb, var(--on-surface-variant) 92%, transparent) 64%,
			color-mix(in srgb, var(--on-surface-variant) 92%, transparent) 100%
		);
		background-size: 220% 100%;
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		animation: appointment-voice-shimmer 2.4s ease-in-out infinite;
	}

	.appointment-voice-processing.hidden,
	.appointment-voice-transcript-wrap.hidden,
	.appointment-voice-error.hidden,
	.appointment-voice-actions.hidden,
	.appointment-voice-discard.hidden {
		display: none;
	}

	.appointment-voice-record[hidden] {
		display: none;
	}

	.appointment-voice-actions {
		width: 100%;
	}

	.appointment-voice-continue {
		width: 100%;
		border: 0;
		border-radius: 999px;
		padding: 0.85rem 1.2rem;
		font-size: 0.92rem;
		font-weight: 800;
		color: #f8fbff;
		background: var(--primary);
		box-shadow: 0 4px 14px rgba(15, 23, 42, 0.12);
		cursor: pointer;
		transition: background-color 140ms ease, transform 140ms ease, box-shadow 140ms ease;
	}

	.appointment-voice-continue:hover {
		transform: translateY(-1px);
		background: color-mix(in srgb, var(--primary) 92%, #000 8%);
	}

	.appointment-voice-discard {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.35rem;
		margin-top: -0.15rem;
		padding: 0.45rem 0.75rem;
		border: 0;
		border-radius: 999px;
		background: transparent;
		color: var(--on-surface-variant);
		font-size: 0.82rem;
		font-weight: 700;
		cursor: pointer;
		transition:
			color 140ms ease,
			background-color 140ms ease,
			opacity 180ms ease,
			transform 180ms ease;
	}

	.appointment-voice-discard .material-symbols-rounded {
		font-size: 1.05rem;
	}

	.appointment-voice-discard:hover {
		color: #e11d48;
		background: color-mix(in srgb, #e11d48 10%, transparent);
	}

	.appointment-voice-discard:focus-visible {
		outline: 2px solid color-mix(in srgb, var(--primary) 42%, white 58%);
		outline-offset: 3px;
	}

	.appointment-voice-stage {
		position: relative;
		display: grid;
		place-items: center;
		width: min(100%, 18rem);
		height: 8.5rem;
		margin-top: 0.15rem;
	}

	.appointment-voice-stage__ambient {
		position: absolute;
		inset: 8% 0;
		border-radius: 999px;
		background: radial-gradient(
			ellipse at center,
			color-mix(in srgb, var(--primary) 24%, transparent) 0%,
			color-mix(in srgb, #22d3ee 10%, transparent) 42%,
			transparent 72%
		);
		opacity: 0.55;
		filter: blur(10px);
		transition: opacity 220ms ease, transform 220ms ease;
	}

	appointment-voice-overlay[data-voice-state='recording'] .appointment-voice-stage__ambient,
	appointment-voice-overlay[data-voice-state='collapsing'] .appointment-voice-stage__ambient {
		opacity: 0.95;
		transform: scale(1.04);
	}

	appointment-voice-overlay[data-voice-state='processing'] .appointment-voice-stage {
		display: none;
	}

	.appointment-voice-stage.is-collapsing {
		height: 9rem;
	}

	.appointment-voice-waveform {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		--voice-level: 0.16;
	}

	.appointment-voice-rings {
		position: absolute;
		inset: 0;
		display: grid;
		place-items: center;
		pointer-events: none;
	}

	.appointment-voice-rings__ring {
		position: absolute;
		width: 5rem;
		height: 5rem;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--primary) 42%, #22d3ee 58%);
		opacity: 0;
		transform: scale(0.82);
	}

	appointment-voice-overlay[data-voice-state='idle'] .appointment-voice-rings__ring,
	appointment-voice-overlay[data-voice-state='recording'] .appointment-voice-rings__ring {
		animation: appointment-voice-ring 3.2s ease-out infinite;
	}

	appointment-voice-overlay[data-voice-state='recording'] .appointment-voice-rings__ring {
		border-color: color-mix(in srgb, var(--primary) 48%, #67e8f9 52%);
		animation-duration: calc(2.6s - (var(--voice-level, 0.2) * 0.9s));
	}

	appointment-voice-overlay[data-voice-state='collapsing'] .appointment-voice-rings__ring,
	appointment-voice-overlay[data-voice-state='processing'] .appointment-voice-rings__ring {
		animation: none;
		opacity: 0;
	}

	.appointment-voice-rings__ring:nth-child(2) {
		animation-delay: 0.75s;
	}

	.appointment-voice-rings__ring:nth-child(3) {
		animation-delay: 1.5s;
	}

	.appointment-voice-record {
		position: relative;
		z-index: 2;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 5rem;
		height: 5rem;
		border: 0;
		border-radius: 999px;
		background: linear-gradient(
			145deg,
			color-mix(in srgb, var(--primary) 88%, #fff 12%),
			color-mix(in srgb, var(--primary) 72%, #0f172a 28%)
		);
		color: #f8fbff;
		box-shadow:
			0 4px 14px rgba(15, 23, 42, 0.12),
			0 0 28px color-mix(in srgb, var(--primary) 28%, transparent);
		cursor: pointer;
		transition:
			transform 220ms ease,
			opacity 420ms ease,
			box-shadow 220ms ease;
	}

	.appointment-voice-record__halo {
		position: absolute;
		inset: -0.55rem;
		border-radius: inherit;
		background: radial-gradient(circle, color-mix(in srgb, var(--primary) 38%, #67e8f9 62%) 0%, transparent 72%);
		opacity: 0.55;
		filter: blur(6px);
		transition: opacity 220ms ease, transform 220ms ease;
	}

	.appointment-voice-record__pulse {
		position: absolute;
		inset: -0.35rem;
		border-radius: inherit;
		border: 2px solid color-mix(in srgb, var(--primary) 40%, #67e8f9 60%);
		opacity: 0;
		pointer-events: none;
	}

	appointment-voice-overlay[data-voice-state='recording'] .appointment-voice-record {
		box-shadow:
			0 4px 18px rgba(15, 23, 42, 0.14),
			0 0 calc(22px + var(--voice-level, 0.2) * 32px) color-mix(in srgb, var(--primary) 42%, #38bdf8 58%);
	}

	appointment-voice-overlay[data-voice-state='recording'] .appointment-voice-record__halo {
		animation: appointment-voice-halo-pulse 1.5s ease-in-out infinite;
	}

	appointment-voice-overlay[data-voice-state='recording'] .appointment-voice-record__pulse {
		animation: appointment-voice-record-ring-pulse 1.5s ease-out infinite;
	}

	.appointment-voice-stage.is-collapsing .appointment-voice-record {
		opacity: 0;
		transform: scale(0.72);
		pointer-events: none;
	}

	.appointment-voice-record:hover:not(:disabled) {
		transform: translateY(-1px);
		box-shadow:
			0 8px 22px rgba(15, 23, 42, 0.16),
			0 0 36px color-mix(in srgb, var(--primary) 34%, transparent);
	}

	.appointment-voice-record:disabled {
		opacity: 0.65;
		cursor: not-allowed;
	}

	.appointment-voice-record .material-symbols-rounded {
		position: relative;
		z-index: 1;
		font-size: 2rem;
	}

	appointment-voice-overlay[data-voice-state='success'] .appointment-voice-stage {
		display: none;
	}

	@keyframes appointment-voice-halo-pulse {
		0%,
		100% {
			opacity: 0.45;
			transform: scale(1);
		}
		50% {
			opacity: 0.9;
			transform: scale(1.28);
		}
	}

	@keyframes appointment-voice-record-ring-pulse {
		0% {
			opacity: 0.55;
			transform: scale(0.92);
		}
		100% {
			opacity: 0;
			transform: scale(1.55);
		}
	}

	@keyframes appointment-voice-glow-pulse {
		0%,
		100% {
			transform: scale(1);
		}
		50% {
			transform: scale(1.035);
		}
	}

	@keyframes appointment-voice-shimmer {
		0% {
			background-position: 120% 0;
		}
		100% {
			background-position: -120% 0;
		}
	}

	@keyframes appointment-voice-spin {
		to {
			transform: rotate(360deg);
		}
	}

	@keyframes appointment-voice-breathe {
		0%,
		100% {
			opacity: 0.45;
			transform: scale(0.88);
		}
		50% {
			opacity: 0.9;
			transform: scale(1.08);
		}
	}

	@keyframes appointment-voice-ring {
		0% {
			opacity: 0.55;
			transform: scale(0.82);
		}
		70% {
			opacity: 0;
		}
		100% {
			opacity: 0;
			transform: scale(calc(1.55 + var(--voice-level, 0.2) * 0.35));
		}
	}

	@keyframes appointment-voice-pulse {
		0%,
		100% {
			transform: scale(1);
		}
		50% {
			transform: scale(1.04);
		}
	}

	html[data-theme='dark'] .appointment-voice-stage__ambient {
		opacity: 0.72;
	}

	html[data-theme='dark'] .appointment-voice-shell::backdrop {
		background: rgba(0, 0, 0, 0.58);
	}
</style>
