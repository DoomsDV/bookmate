---
import SettingsModal from './SettingsModal.astro';

interface Props {
	userName?: string;
}

const { userName = 'Perfil' } = Astro.props;
const roleId = Number(Astro.locals.roleId ?? 0);
---

<header class="relative z-40 border-b border-(--shell-border)/80 px-4 py-4 sm:px-6 sm:py-5">
	<div class="flex items-center justify-between gap-3 sm:gap-4">
		<div class="flex min-w-0 items-center gap-3">
			<button
				type="button"
				class="flex size-10 shrink-0 items-center justify-center rounded-2xl border border-(--shell-border) bg-(--control-surface) text-(--on-surface-variant) transition hover:bg-(--control-surface-strong) sm:size-11"
					aria-label="Alternar menú lateral"
				aria-controls="app-side-nav"
				aria-expanded="false"
				data-nav-toggle
			>
				<span class="material-symbols-rounded text-[1.2rem]">menu</span>
			</button>

			<div class="min-w-0">
				<a href="/panel/dashboard" class="topbar-brand-link no-underline" aria-label="Ir al dashboard">
					<img
						src="/icon-512x512.png"
						alt="Hasel"
						class="topbar-brand-logo"
						loading="eager"
						decoding="async"
					/>
				</a>
			</div>
		</div>

		<div class="flex shrink-0 items-center gap-2 sm:gap-3">
			<button
				id="pwa-install-btn"
				type="button"
				class="hidden items-center gap-2 rounded-full border border-(--primary) bg-(--primary-container) px-4 py-2 text-sm font-semibold text-(--on-primary-container) transition hover:bg-(--primary) hover:text-(--on-primary)"
				aria-label="Instalar App"
			>
				<span class="material-symbols-rounded text-[1rem]">download</span>
				<span class="hidden sm:inline">Instalar App</span>
			</button>

			<script is:inline>
				window.addEventListener('beforeinstallprompt', (e) => {
					// Prevenir automáticamente el prompt nativo
					e.preventDefault();
					// Guardarlo para que pueda ser invocado por el botón
					window.deferredPrompt = e;
					// Mostrar el botón en el DOM
					const installBtn = document.getElementById('pwa-install-btn');
					if (installBtn) {
						installBtn.classList.remove('hidden');
						installBtn.classList.add('flex');
					}
				});
			</script>

			<button
				type="button"
				class="flex size-11 items-center justify-center rounded-2xl border border-(--shell-border) bg-(--control-surface) text-(--on-surface-variant) transition hover:bg-(--control-surface-strong) sm:hidden"
				aria-label="Cambiar tema"
				aria-pressed="false"
				data-theme-toggle-mobile
			>
				<span class="material-symbols-rounded text-[1rem]" data-theme-icon-mobile>dark_mode</span>
			</button>

			<button
				type="button"
				class="hidden size-11 items-center justify-center rounded-2xl border border-(--shell-border) bg-(--control-surface) text-(--on-surface-variant) transition hover:bg-(--control-surface-strong) sm:flex"
				aria-label="Cambiar tema"
				title="Cambiar tema"
				aria-pressed="false"
				data-theme-toggle
			>
				<span class="material-symbols-rounded text-[1rem]" data-theme-icon>dark_mode</span>
				<span class="sr-only" data-theme-label>Modo Oscuro</span>
			</button>

			<details class="group relative" data-profile-menu>
				<summary
					class="flex size-11 cursor-pointer list-none items-center justify-center rounded-2xl border border-(--primary-container) bg-(--primary-soft) text-(--primary) outline-none transition duration-200 hover:bg-(--primary-soft-hover) focus-visible:ring-2 focus-visible:ring-(--primary) focus-visible:ring-offset-2 focus-visible:ring-offset-transparent"
					aria-label={`Abrir menu de ${userName}`}
				>
					<span class="material-symbols-rounded text-[1.2rem]">settings</span>
				</summary>

				<div
					class="absolute right-0 top-[calc(100%+0.75rem)] z-50 w-[min(15rem,calc(100vw-3rem))] overflow-hidden rounded-[1.35rem] border border-(--shell-border) bg-(--menu-surface) py-2 shadow-[0_22px_60px_rgba(15,23,42,0.16)] backdrop-blur sm:min-w-52 sm:w-auto"
				>
					<div class="border-b border-black/5 px-4 py-3">
						<p class="text-sm font-semibold text-(--on-surface)">{userName}</p>
						<p class="text-xs text-(--on-surface-variant)">Menú de cuenta</p>
					</div>

					<button
						type="button"
						class="flex w-full items-center gap-3 px-4 py-3 text-left text-sm font-medium text-(--on-surface) transition hover:bg-(--primary-container)/45"
						data-open-settings-modal
					>
						<span class="material-symbols-rounded text-[1.15rem] text-(--on-surface-variant)">
							settings
						</span>
						Ajustes
					</button>

					<form method="post" action="/api/auth/logout" class="border-t border-black/5">
						<button
							type="submit"
							class="flex w-full items-center gap-3 px-4 py-3 text-left text-sm font-medium text-red-600 transition hover:bg-red-50/80 dark:hover:bg-red-950/20"
						>
							<span class="material-symbols-rounded text-[1.15rem] text-red-500">logout</span>
							Cerrar sesión
						</button>
					</form>
				</div>
			</details>
		</div>
	</div>
</header>

<SettingsModal roleId={roleId} />

<script>
	const initializeTopBar = () => {
		// PWA Install Button Handler for SPA transitions (Astro View Transitions)
		const installBtn = document.getElementById('pwa-install-btn');
		const deferredPrompt = (window as any).deferredPrompt;
		if (installBtn && deferredPrompt) {
			installBtn.classList.remove('hidden');
			installBtn.classList.add('flex');
		}
		
		if (installBtn) {
			installBtn.addEventListener('click', async () => {
				const currentPrompt = (window as any).deferredPrompt;
				if (currentPrompt) {
					currentPrompt.prompt();
					const { outcome } = await currentPrompt.userChoice;
					(window as any).deferredPrompt = null;
					installBtn.classList.remove('flex');
					installBtn.classList.add('hidden');
				}
			});
		}

		// Cleanup previous initialization using AbortController for better performance and memory management
		if ((window as any).__bookmateTopBarAbort) {
			(window as any).__bookmateTopBarAbort.abort();
		}
		const abortController = new AbortController();
		(window as any).__bookmateTopBarAbort = abortController;
		const { signal } = abortController;

		const on = (target: EventTarget | null, eventName: string, handler: EventListener) => {
			target?.addEventListener(eventName, handler, { signal });
		};

		// DOM Element References
		const profileMenus = document.querySelectorAll<HTMLDetailsElement>('[data-profile-menu]');
		const navToggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
		const appShell = document.querySelector<HTMLElement>('[data-app-shell]');
		const sideNavShell = document.querySelector<HTMLElement>('[data-side-nav-shell]');
		const sideNav = document.querySelector<HTMLElement>('[data-side-nav]');
		const sideNavBackdrop = document.querySelector<HTMLElement>('[data-side-nav-backdrop]');
		const sideNavCloseButtons = document.querySelectorAll<HTMLButtonElement>('[data-side-nav-close]');
		
		const themeToggle = document.querySelector<HTMLElement>('[data-theme-toggle]');
		const themeIcon = document.querySelector<HTMLElement>('[data-theme-icon]');
		const themeLabel = document.querySelector<HTMLElement>('[data-theme-label]');
		const themeToggleMobile = document.querySelector<HTMLElement>('[data-theme-toggle-mobile]');
		const themeIconMobile = document.querySelector<HTMLElement>('[data-theme-icon-mobile]');
		
		const desktopBreakpoint = window.matchMedia('(min-width: 1024px)');

		// Profile Menu Actions
		const closeProfileMenus = () => {
			profileMenus.forEach(menu => menu.removeAttribute('open'));
		};

		// Sidebar Actions
		const openSideNav = () => {
			if (!sideNavShell || !sideNav || !navToggle) return;
			sideNavShell.classList.replace('pointer-events-none', 'pointer-events-auto');
			sideNavBackdrop?.classList.replace('opacity-0', 'opacity-100');
			sideNav.classList.replace('-translate-x-full', 'translate-x-0');
			navToggle.setAttribute('aria-expanded', 'true');
			document.body.classList.add('overflow-hidden');
		};

		const closeSideNav = () => {
			if (!sideNavShell || !sideNav || !navToggle) return;
			sideNavShell.classList.replace('pointer-events-auto', 'pointer-events-none');
			sideNavBackdrop?.classList.replace('opacity-100', 'opacity-0');
			sideNav.classList.replace('translate-x-0', '-translate-x-full');
			navToggle.setAttribute('aria-expanded', 'false');
			document.body.classList.remove('overflow-hidden');
		};

		const isSideNavOpen = () => Boolean(sideNav?.classList.contains('translate-x-0'));

		let swipeStartX: number | null = null;
		let swipeStartY: number | null = null;

		const resetSwipeTracking = () => {
			swipeStartX = null;
			swipeStartY = null;
		};

		const handleSideNavTouchStart = (event: TouchEvent) => {
			if (desktopBreakpoint.matches || !isSideNavOpen() || event.touches.length !== 1) {
				resetSwipeTracking();
				return;
			}
			const touch = event.touches[0];
			swipeStartX = touch.clientX;
			swipeStartY = touch.clientY;
		};

		const handleSideNavTouchEnd = (event: TouchEvent) => {
			if (swipeStartX === null || swipeStartY === null || desktopBreakpoint.matches || !isSideNavOpen()) {
				resetSwipeTracking();
				return;
			}

			const touch = event.changedTouches[0];
			const deltaX = touch.clientX - swipeStartX;
			const deltaY = touch.clientY - swipeStartY;
			const absDeltaX = Math.abs(deltaX);
			const absDeltaY = Math.abs(deltaY);

			const swipedLeft = deltaX <= -52;
			const mostlyHorizontal = absDeltaX > absDeltaY * 1.2;
			if (swipedLeft && mostlyHorizontal) {
				closeSideNav();
			}

			resetSwipeTracking();
		};

		const syncDesktopToggle = () => {
			if (!appShell || !navToggle || !desktopBreakpoint.matches) return;
			const isExpanded = appShell.getAttribute('data-sidebar-state') !== 'collapsed';
			navToggle.setAttribute('aria-expanded', String(isExpanded));
		};

		const toggleDesktopSidebar = () => {
			if (!appShell) return;
			const isCollapsed = appShell.getAttribute('data-sidebar-state') === 'collapsed';
			appShell.setAttribute('data-sidebar-state', isCollapsed ? 'expanded' : 'collapsed');
			syncDesktopToggle();
		};

		const toggleSideNav = () => {
			if (desktopBreakpoint.matches) return toggleDesktopSidebar();
			if (!sideNav) return;
			
			if (sideNav.classList.contains('translate-x-0')) {
				closeSideNav();
			} else {
				closeProfileMenus();
				openSideNav();
			}
		};

		// Theme Actions
		const applyTheme = (theme: 'light' | 'dark') => {
			const isDark = theme === 'dark';
			document.documentElement.dataset.theme = theme;
			localStorage.setItem('bookmate-theme', theme);
			const nextThemeLabel = isDark ? 'Cambiar a modo claro' : 'Cambiar a modo oscuro';
			
			[themeToggle, themeToggleMobile].forEach(t => {
				t?.setAttribute('aria-pressed', String(isDark));
				t?.setAttribute('aria-label', nextThemeLabel);
				t?.setAttribute('title', nextThemeLabel);
			});
			[themeIcon, themeIconMobile].forEach(i => { if (i) i.textContent = isDark ? 'light_mode' : 'dark_mode'; });
			if (themeLabel) themeLabel.textContent = isDark ? 'Modo Claro' : 'Modo Oscuro';
		};

		const resolveInitialTheme = (): 'light' | 'dark' => {
			const storedTheme = localStorage.getItem('bookmate-theme');
			if (storedTheme === 'dark' || storedTheme === 'light') return storedTheme;
			return 'dark';
		};

		const toggleTheme = () => {
			const isDark = document.documentElement.dataset.theme === 'dark';
			applyTheme(isDark ? 'light' : 'dark');
		};

		// Global Event Handlers
		const closeOnOutsideClick = (event: Event) => {
			profileMenus.forEach(menu => {
				if (!menu.contains(event.target as Node)) menu.removeAttribute('open');
			});
		};

		const closeOnEscape = (event: KeyboardEvent) => {
			if (event.key !== 'Escape') return;
			closeProfileMenus();
			if (!desktopBreakpoint.matches) closeSideNav();
		};

		const syncOnResize = () => {
			if (desktopBreakpoint.matches) {
				closeSideNav();
				syncDesktopToggle();
			} else {
				navToggle?.setAttribute('aria-expanded', 'false');
			}
		};

		// Attach Listeners
		on(navToggle, 'click', toggleSideNav);
		on(themeToggle, 'click', toggleTheme);
		on(themeToggleMobile, 'click', toggleTheme);
		on(sideNavBackdrop, 'click', closeSideNav);
		sideNavCloseButtons.forEach(btn => on(btn, 'click', closeSideNav));
		sideNav?.addEventListener('touchstart', handleSideNavTouchStart, { signal, passive: true });
		sideNav?.addEventListener('touchend', handleSideNavTouchEnd, { signal, passive: true });
		sideNav?.addEventListener('touchcancel', resetSwipeTracking, { signal });

		on(document, 'click', closeOnOutsideClick);
		on(document, 'keydown', closeOnEscape as EventListener);
		on(desktopBreakpoint, 'change', syncOnResize);

		// Initialization logic wrapper
		applyTheme(resolveInitialTheme());
		syncOnResize();
	};

	initializeTopBar();

	// Support for Astro View Transitions (page-load event)
	if (!(window as any).__bookmateTopBarBound) {
		document.addEventListener('astro:page-load', initializeTopBar);
		(window as any).__bookmateTopBarBound = true;
	}
</script>
