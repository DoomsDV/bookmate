---
import SettingsModal from './SettingsModal.astro';

interface Props {
	userName?: string;
}

const { userName = 'Perfil' } = Astro.props;
const cachedOrganizationName = String(
	Astro.locals.organizationName || Astro.cookies.get('org_name')?.value || ''
).trim();
const workspaceName = cachedOrganizationName || 'Bookmate';
const roleId = Number(Astro.locals.roleId ?? 0);
---

<header class="relative z-40 border-b border-[color:var(--shell-border)]/80 px-5 py-5 sm:px-7">
	<div class="flex items-center justify-between gap-4">
		<div class="flex items-center gap-3">
			<button
				type="button"
				class="flex size-11 items-center justify-center rounded-2xl border border-[color:var(--shell-border)] bg-[color:var(--control-surface)] text-[color:var(--on-surface-variant)] shadow-[inset_0_1px_0_rgba(255,255,255,0.55)] transition hover:bg-[color:var(--control-surface-strong)]"
					aria-label="Alternar menú lateral"
				aria-controls="app-side-nav"
				aria-expanded="false"
				data-nav-toggle
			>
				<span class="material-symbols-rounded text-[1.2rem]">menu</span>
			</button>

			<div>
				<p class="text-[0.68rem] font-bold uppercase tracking-[0.28em] text-[color:var(--on-surface-variant)]/80">
					{workspaceName} workspace
				</p>
				<a href="/" class="mt-1 block no-underline">
					<span
						class="[font-family:var(--font-logo)] text-[1.55rem] font-extrabold uppercase leading-none tracking-[0.08em] text-[color:var(--primary)]"
					>
						{workspaceName}
					</span>
				</a>
			</div>
		</div>

		<div class="flex items-center gap-3">
			<button
				type="button"
				class="flex size-11 items-center justify-center rounded-2xl border border-[color:var(--shell-border)] bg-[color:var(--control-surface)] text-[color:var(--on-surface-variant)] shadow-[inset_0_1px_0_rgba(255,255,255,0.55)] transition hover:bg-[color:var(--control-surface-strong)] sm:hidden"
				aria-label="Cambiar tema"
				aria-pressed="false"
				data-theme-toggle-mobile
			>
				<span class="material-symbols-rounded text-[1rem]" data-theme-icon-mobile>dark_mode</span>
			</button>

			<button
				type="button"
				class="hidden items-center gap-2 rounded-full border border-[color:var(--shell-border)] bg-[color:var(--control-surface)] px-4 py-2 text-sm text-[color:var(--on-surface-variant)] shadow-[inset_0_1px_0_rgba(255,255,255,0.55)] transition hover:bg-[color:var(--control-surface-strong)] sm:flex"
				aria-label="Cambiar tema"
				aria-pressed="false"
				data-theme-toggle
			>
				<span class="material-symbols-rounded text-[1rem]" data-theme-icon>dark_mode</span>
				<span data-theme-label>Modo Oscuro</span>
			</button>

			<details class="group relative" data-profile-menu>
				<summary
					class="flex size-11 cursor-pointer list-none items-center justify-center rounded-2xl border border-[color:var(--primary-container)] bg-[color:var(--primary-soft)] text-sm font-bold tracking-[0.08em] text-[color:var(--primary)] outline-none transition duration-200 hover:bg-[color:var(--primary-soft-hover)] focus-visible:ring-2 focus-visible:ring-[color:var(--primary)] focus-visible:ring-offset-2 focus-visible:ring-offset-transparent"
					aria-label={`Abrir menu de ${userName}`}
				>
					BM
				</summary>

				<div
					class="absolute right-0 top-[calc(100%+0.75rem)] z-50 w-[min(15rem,calc(100vw-3rem))] overflow-hidden rounded-[1.35rem] border border-[color:var(--shell-border)] bg-[color:var(--menu-surface)] py-2 shadow-[0_22px_60px_rgba(15,23,42,0.16)] backdrop-blur sm:min-w-52 sm:w-auto"
				>
					<div class="border-b border-black/5 px-4 py-3">
						<p class="text-sm font-semibold text-[color:var(--on-surface)]">{userName}</p>
						<p class="text-xs text-[color:var(--on-surface-variant)]">Menú de cuenta</p>
					</div>

					<button
						type="button"
						class="flex w-full items-center gap-3 px-4 py-3 text-left text-sm font-medium text-[color:var(--on-surface)] transition hover:bg-[color:var(--primary-container)]/45"
						data-open-settings-modal
					>
						<span class="material-symbols-rounded text-[1.15rem] text-[color:var(--on-surface-variant)]">
							settings
						</span>
						Ajustes
					</button>

					<form method="post" action="/api/auth/logout" class="border-t border-black/5">
						<button
							type="submit"
							class="flex w-full items-center gap-3 px-4 py-3 text-left text-sm font-medium text-red-600 transition hover:bg-red-50/80 dark:hover:bg-red-950/20"
						>
							<span class="material-symbols-rounded text-[1.15rem] text-red-500">logout</span>
							Cerrar sesión
						</button>
					</form>
				</div>
			</details>
		</div>
	</div>
</header>

<SettingsModal roleId={roleId} />

<script>
	const initializeTopBar = () => {
		const currentCleanup = (window as any).__bookmateTopBarCleanup;
		if (typeof currentCleanup === 'function') currentCleanup();

		const profileMenus = document.querySelectorAll('[data-profile-menu]');
		const navToggle = document.querySelector('[data-nav-toggle]');
		const appShell = document.querySelector('[data-app-shell]');
		const sideNavShell = document.querySelector('[data-side-nav-shell]');
		const sideNav = document.querySelector('[data-side-nav]');
		const sideNavBackdrop = document.querySelector('[data-side-nav-backdrop]');
		const sideNavCloseButtons = document.querySelectorAll('[data-side-nav-close]');
		const desktopBreakpoint = window.matchMedia('(min-width: 1024px)');
		const themeToggle = document.querySelector('[data-theme-toggle]');
		const themeIcon = document.querySelector('[data-theme-icon]');
		const themeLabel = document.querySelector('[data-theme-label]');
		const themeToggleMobile = document.querySelector('[data-theme-toggle-mobile]');
		const themeIconMobile = document.querySelector('[data-theme-icon-mobile]');
		const removeListeners: Array<() => void> = [];

		const on = (target: any, eventName: string, handler: EventListener) => {
			if (!target?.addEventListener) return;
			target.addEventListener(eventName, handler);
			removeListeners.push(() => target.removeEventListener(eventName, handler));
		};

		const closeProfileMenus = () => {
			for (const menu of profileMenus) menu.removeAttribute('open');
		};

		const openSideNav = () => {
			if (!sideNavShell || !sideNav || !navToggle) return;
			sideNavShell.classList.remove('pointer-events-none');
			sideNavShell.classList.add('pointer-events-auto');
			sideNavBackdrop?.classList.remove('opacity-0');
			sideNavBackdrop?.classList.add('opacity-100');
			sideNav.classList.remove('-translate-x-[calc(100%+2rem)]');
			sideNav.classList.add('translate-x-0');
			navToggle.setAttribute('aria-expanded', 'true');
			document.body.classList.add('overflow-hidden');
		};

		const syncDesktopToggle = () => {
			if (!appShell || !navToggle || !desktopBreakpoint.matches) return;
			const expanded = appShell.getAttribute('data-sidebar-state') !== 'collapsed';
			navToggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
		};

		const toggleDesktopSidebar = () => {
			if (!appShell) return;
			const nextState =
				appShell.getAttribute('data-sidebar-state') === 'collapsed' ? 'expanded' : 'collapsed';
			appShell.setAttribute('data-sidebar-state', nextState);
			syncDesktopToggle();
		};

		const applyTheme = (theme: string) => {
			document.documentElement.dataset.theme = theme;
			localStorage.setItem('bookmate-theme', theme);
			const isDark = theme === 'dark';
			themeToggle?.setAttribute('aria-pressed', String(isDark));
			themeToggleMobile?.setAttribute('aria-pressed', String(isDark));
			if (themeIcon) themeIcon.textContent = isDark ? 'light_mode' : 'dark_mode';
			if (themeIconMobile) themeIconMobile.textContent = isDark ? 'light_mode' : 'dark_mode';
			if (themeLabel) themeLabel.textContent = isDark ? 'Modo Claro' : 'Modo Oscuro';
		};

		const resolveInitialTheme = () => {
			const storedTheme = localStorage.getItem('bookmate-theme');
			if (storedTheme === 'dark' || storedTheme === 'light') return storedTheme;
			return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
		};

		const toggleTheme = () => {
			const currentTheme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
			applyTheme(currentTheme === 'dark' ? 'light' : 'dark');
		};

		const closeSideNav = () => {
			if (!sideNavShell || !sideNav || !navToggle) return;
			sideNavShell.classList.remove('pointer-events-auto');
			sideNavShell.classList.add('pointer-events-none');
			sideNavBackdrop?.classList.remove('opacity-100');
			sideNavBackdrop?.classList.add('opacity-0');
			sideNav.classList.remove('translate-x-0');
			sideNav.classList.add('-translate-x-[calc(100%+2rem)]');
			navToggle.setAttribute('aria-expanded', 'false');
			document.body.classList.remove('overflow-hidden');
		};

		const toggleSideNav = () => {
			if (desktopBreakpoint.matches) {
				toggleDesktopSidebar();
				return;
			}

			if (!sideNav) return;
			if (sideNav.classList.contains('translate-x-0')) {
				closeSideNav();
				return;
			}
			closeProfileMenus();
			openSideNav();
		};

		const closeOnOutsideClick = (event: any) => {
			for (const menu of profileMenus) {
				if (!menu.contains(event.target)) menu.removeAttribute('open');
			}
		};

		const closeOnEscape = (event: any) => {
			if (event.key !== 'Escape') return;
			closeProfileMenus();
			if (desktopBreakpoint.matches) return;
			closeSideNav();
		};

		const syncOnResize = () => {
			if (desktopBreakpoint.matches) {
				closeSideNav();
				syncDesktopToggle();
				return;
			}
			navToggle?.setAttribute('aria-expanded', 'false');
		};

		on(navToggle, 'click', toggleSideNav);
		on(themeToggle, 'click', toggleTheme);
		on(themeToggleMobile, 'click', toggleTheme);
		on(sideNavBackdrop, 'click', closeSideNav);
		for (const button of sideNavCloseButtons) {
			on(button, 'click', closeSideNav);
		}

		on(document, 'click', closeOnOutsideClick as EventListener);
		on(document, 'keydown', closeOnEscape as EventListener);
		on(desktopBreakpoint, 'change', syncOnResize as EventListener);
		applyTheme(resolveInitialTheme());
		syncOnResize();

		(window as any).__bookmateTopBarCleanup = () => {
			for (const removeListener of removeListeners) removeListener();
		};
	};

	initializeTopBar();

	if (!(window as any).__bookmateTopBarPageLoadBound) {
		document.addEventListener('astro:page-load', initializeTopBar);
		(window as any).__bookmateTopBarPageLoadBound = true;
	}
</script>
