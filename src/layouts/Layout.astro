---
import { ClientRouter } from 'astro:transitions';
import FlashMessage from '../components/FlashMessage.astro';
// 1. Importamos la información de la PWA
import { pwaInfo } from 'virtual:pwa-info';

const flashMessage = Astro.url.searchParams.get('flash_message') ?? '';
const flashTypeRaw = Astro.url.searchParams.get('flash_type') ?? 'success';
const validFlashTypes = ['success', 'error', 'info', 'warning'] as const;
type FlashType = (typeof validFlashTypes)[number];
const flashType: FlashType = validFlashTypes.includes(flashTypeRaw as FlashType)
    ? (flashTypeRaw as FlashType)
    : 'info';
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/x-icon" href="/hasel.ico" />
        <link rel="shortcut icon" href="/hasel.ico" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Lobster&family=Nunito+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,500,0,0"
            rel="stylesheet"
        />
        <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@800&display=swap" rel="stylesheet">
        
        <meta name="theme-color" content="#ffffff" />
        
        { pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} /> }

        <script>
            import { registerSW } from 'virtual:pwa-register';
            
            if ('serviceWorker' in navigator) {
                registerSW({ immediate: true });
            }
        </script>

        <script is:inline>
            // Agrupamos la lógica en una función
            const setBookmateTheme = () => {
                const storedTheme = localStorage.getItem('bookmate-theme');
                const theme = storedTheme === 'dark' || storedTheme === 'light' ? storedTheme : 'dark';
                document.documentElement.dataset.theme = theme;
            };

            // 1. Se ejecuta inmediatamente en la carga inicial (evita el FOUC)
            setBookmateTheme();

            // 2. Se ejecuta cada vez que ClientRouter intercambia el contenido de la página
            document.addEventListener('astro:after-swap', setBookmateTheme);
        </script>
        
        <meta name="generator" content={Astro.generator} />
        <title>Hasel</title>
    </head>
    <body>
        <ClientRouter />
        <slot />
        {flashMessage && (
            <div class="pointer-events-none fixed bottom-8 left-1/2 z-100 flex w-full -translate-x-1/2 justify-center px-4 sm:bottom-10">
                <FlashMessage
                    message={flashMessage}
                    type={flashType}
                    autoHideMs={4000}
                />
            </div>
        )}
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        min-height: 100%;
    }
</style>