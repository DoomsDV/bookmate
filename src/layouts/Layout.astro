---
import { ClientRouter } from 'astro:transitions';
import FlashMessage from '../components/FlashMessage.astro';
import FcmManager from '../components/FcmManager.astro';
import OrgNotificationDeepLink from '../components/OrgNotificationDeepLink.astro';
import SessionGuard from '../components/SessionGuard.astro';
import {
    FLASH_MESSAGE_COOKIE,
    FLASH_TYPE_COOKIE,
} from '../lib/flash-server';
// 1. Importamos la información de la PWA
import { pwaInfo } from 'virtual:pwa-info';

const decodeCookieValue = (value: string) => {
    try {
        return decodeURIComponent(value);
    } catch {
        return value;
    }
};

const flashMessageFromCookie = Astro.cookies.get(FLASH_MESSAGE_COOKIE)?.value ?? '';
const flashTypeFromCookie = Astro.cookies.get(FLASH_TYPE_COOKIE)?.value ?? '';
const flashMessage = decodeCookieValue(flashMessageFromCookie);
const flashTypeRaw = decodeCookieValue(flashTypeFromCookie) || 'success';
const validFlashTypes = ['success', 'error', 'info', 'warning'] as const;
type FlashType = (typeof validFlashTypes)[number];
const flashType: FlashType = validFlashTypes.includes(flashTypeRaw as FlashType)
    ? (flashTypeRaw as FlashType)
    : 'info';
const hasSession = Boolean(Astro.locals.token ?? '');

interface Props {
    pageTitle?: string;
    metaDescription?: string;
    canonicalPath?: string;
    siteOrigin?: string;
    ogImage?: string;
    ogImageAlt?: string;
    ogType?: string;
    robots?: string;
    jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
    pageTitle = 'Hasel',
    metaDescription,
    canonicalPath,
    siteOrigin: siteOriginProp,
    ogImage = '/icon-512x512.png',
    ogImageAlt,
    ogType = 'website',
    robots = 'index, follow',
    jsonLd,
} = Astro.props as Props;

const siteOrigin = siteOriginProp || Astro.site || Astro.url;
const canonicalUrl = new URL(canonicalPath ?? Astro.url.pathname, siteOrigin).href;
const ogImageUrl = /^https?:\/\//i.test(String(ogImage || '').trim())
    ? String(ogImage).trim()
    : new URL(ogImage, siteOrigin).href;
if (flashMessageFromCookie) {
    Astro.cookies.delete(FLASH_MESSAGE_COOKIE, { path: '/' });
}

if (flashTypeFromCookie) {
    Astro.cookies.delete(FLASH_TYPE_COOKIE, { path: '/' });
}
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/x-icon" href="/hasel.ico" />
        <link rel="shortcut icon" href="/hasel.ico" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,500,0,0&display=block"
            rel="stylesheet"
        />

        <meta name="theme-color" content="#ffffff" />
        
        { pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} /> }

        <script>
            import { registerSW } from 'virtual:pwa-register';
            
            if ('serviceWorker' in navigator) {
                registerSW({ immediate: true });
            }
        </script>

        <script is:inline>
            // Agrupamos la lógica en una función
            const setBookmateTheme = () => {
                const storedTheme = localStorage.getItem('bookmate-theme');
                const theme = storedTheme === 'dark' || storedTheme === 'light' ? storedTheme : 'dark';
                document.documentElement.dataset.theme = theme;
            };

            // 1. Se ejecuta inmediatamente en la carga inicial (evita el FOUC)
            setBookmateTheme();

            // 2. Se ejecuta cada vez que ClientRouter intercambia el contenido de la página
            document.addEventListener('astro:after-swap', setBookmateTheme);
        </script>
        
        <meta name="generator" content={Astro.generator} />
        <title>{pageTitle}</title>
        {metaDescription && (
            <>
                <meta name="description" content={metaDescription} />
                <meta name="robots" content={robots} />
                <link rel="canonical" href={canonicalUrl} />
                <meta property="og:locale" content="es_ES" />
                <meta property="og:site_name" content="Hasel" />
                <meta property="og:type" content={ogType} />
                <meta property="og:title" content={pageTitle} />
                <meta property="og:description" content={metaDescription} />
                <meta property="og:url" content={canonicalUrl} />
                <meta property="og:image" content={ogImageUrl} />
                {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
                <meta name="twitter:card" content="summary_large_image" />
                <meta name="twitter:title" content={pageTitle} />
                <meta name="twitter:description" content={metaDescription} />
                <meta name="twitter:image" content={ogImageUrl} />
            </>
        )}
        {jsonLd && (
            <script
                type="application/ld+json"
                set:html={JSON.stringify(jsonLd)}
            />
        )}
    </head>
    <body>
        <ClientRouter />
        <slot />
        {hasSession && (
            <>
                <SessionGuard />
                <FcmManager />
                <OrgNotificationDeepLink />
            </>
        )}
        {
            flashMessage ? (
                <div class="pointer-events-none fixed bottom-8 left-1/2 z-[10000] flex w-full -translate-x-1/2 justify-center px-4 sm:bottom-10">
                    <FlashMessage
                        message={flashMessage}
                        type={flashType}
                        autoHideMs={4000}
                    />
                </div>
            ) : (
                <FlashMessage message="" />
            )
        }
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        min-height: 100%;
    }
</style>
