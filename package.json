{
  "name": "bookmate",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "dev:force": "npm run clean:caches && astro dev --force",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "clean:caches": "node -e \"const fs=require('fs');for (const p of ['node_modules/.vite','.astro']){try{fs.rmSync(p,{recursive:true,force:true});console.log('removed',p);}catch{}}\""
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/preact": "^4.1.3",
    "@astrojs/vercel": "^9.0.5",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^5.17.1",
    "fullcalendar": "^6.1.20",
    "preact": "^10.28.4",
    "tailwindcss": "^4.2.1",
    "tom-select": "^2.5.2",
    "typescript": "^5.9.3",
    "zod": "^3.25.76"
  }
}
