{
  "name": "bookmate",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "dev:force": "npm run clean:caches && astro dev --force",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "clean:caches": "node -e \"const fs=require('fs');for (const p of ['node_modules/.vite','.astro']){try{fs.rmSync(p,{recursive:true,force:true});console.log('removed',p);}catch{}}\""
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/preact": "^4.1.3",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^9.0.5",
    "@google/genai": "^1.49.0",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^5.17.1",
    "croppie": "^2.6.5",
    "firebase": "^12.12.0",
    "fullcalendar": "^6.1.20",
    "googleapis": "^171.4.0",
    "marked": "^18.0.3",
    "preact": "^10.28.4",
    "tailwindcss": "^4.2.1",
    "tom-select": "^2.5.2",
    "typescript": "^5.9.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vite-pwa/astro": "^1.2.0"
  }
}
